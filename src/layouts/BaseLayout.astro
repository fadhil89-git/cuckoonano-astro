          <p class="font-bold text-white">Pautan Penting</p>
          <div class="mt-4 grid gap-2 text-sm font-bold">
            <a href="/#promo" class="rounded-xl px-3 py-2 text-white/64 transition-colors hover:bg-white/5 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-gold/70 focus-visible:ring-offset-2 focus-visible:ring-offset-ink">Promo Terkini</a>
            <a href="/goood-deal/" class="rounded-xl px-3 py-2 text-white/64 transition-colors hover:bg-white/5 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-gold/70 focus-visible:ring-offset-2 focus-visible:ring-offset-ink">Trade-In Plan</a>
            <a href="/service/" class="rounded-xl px-3 py-2 text-white/64 transition-colors hover:bg-white/5 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-gold/70 focus-visible:ring-offset-2 focus-visible:ring-offset-ink">Sambung Servis</a>
            <a href="/blog/" class="rounded-xl px-3 py-2 text-white/64 transition-colors hover:bg-white/5 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-gold/70 focus-visible:ring-offset-2 focus-visible:ring-offset-ink">Blog</a>
            <a href="/locations/" class="rounded-xl px-3 py-2 text-white/64 transition-colors hover:bg-white/5 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-gold/70 focus-visible:ring-offset-2 focus-visible:ring-offset-ink">Locations</a>
            <a href="/kerjaya-cuckoo/" class="rounded-xl px-3 py-2 text-white/64 transition-colors hover:bg-white/5 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-gold/70 focus-visible:ring-offset-2 focus-visible:ring-offset-ink">Daftar Ejen</a>
            <a href="/#contact" class="rounded-xl px-3 py-2 text-white/64 transition-colors hover:bg-white/5 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-gold/70 focus-visible:ring-offset-2 focus-visible:ring-offset-ink">Hubungi Kami</a>
          </div>
        </div>
      </div>
      <div class="mx-auto mt-10 max-w-7xl border-t border-white/10 pt-6">
        <div class="flex flex-col gap-4 text-xs font-semibold leading-6 text-white/50 lg:flex-row lg:items-center lg:justify-between">
          <p>© 2026 CUCKOONANO. All rights reserved.</p>
          <div class="flex flex-wrap gap-x-4 gap-y-2">
            <span>Privacy Policy</span>
            <span>Terms & Conditions</span>
            <span>Disclaimer</span>
          </div>
        </div>
        <p class="mt-4 max-w-4xl text-xs leading-6 text-white/45">
          Harga, promo, kelulusan dan pemasangan tertakluk kepada terma & syarat CUCKOO.
        </p>
      </div>
    </footer>
    )}
{showFloatingWhatsapp && (
<a data-floating-whatsapp href="#" onclick="this.href=rotatingWhatsapp()" class="fixed bottom-5 right-5 z-50 inline-flex items-center gap-2 rounded-full bg-[#25D366] px-5 py-3.5 text-sm font-black text-white shadow-xl transition-all duration-300 hover:-translate-y-1 hover:scale-105 sm:px-6 sm:py-4 sm:text-base">
  <img src="/assets/images/misc/whatsapp-png.webp" alt="" aria-hidden="true" width="256" height="256" class="h-5 w-5 sm:h-6 sm:w-6" />
  <span>Semak Promo</span>
</a>
)}
    <script is:inline defer src="/assets/js/site-data.js"></script>
    <script is:inline defer src="/assets/js/blog-items.js"></script>
    <script is:inline defer src="/assets/js/main.js"></script>
    <script is:inline>
      (() => {
        const hero = document.querySelector('[data-home-hero], #hero');
        const floatingWhatsapp = document.querySelector('[data-floating-whatsapp]');
        if (!hero || !floatingWhatsapp) return;

        const mobileQuery = window.matchMedia('(max-width: 767px)');
        const setHidden = (hidden) => {
          floatingWhatsapp.classList.toggle('pointer-events-none', hidden);
          floatingWhatsapp.classList.toggle('translate-y-4', hidden);
          floatingWhatsapp.classList.toggle('opacity-0', hidden);
        };

        const update = () => {
          if (!mobileQuery.matches) {
            setHidden(false);
            return;
          }
          const heroBottom = hero.getBoundingClientRect().bottom;
          setHidden(heroBottom > 80);
        };

        update();
        window.addEventListener('scroll', update, { passive: true });
        window.addEventListener('resize', update);
        mobileQuery.addEventListener?.('change', update);
      })();
    </script>
    <script is:inline>
      // Global WhatsApp-click conversion tracking. Works with rotatingWhatsapp():
      // the inline onclick runs in the target phase and rewrites href before this
      // document-level (bubble phase) listener reads it.
      document.addEventListener('click', function (e) {
        const link = e.target.closest && e.target.closest('a[href]');
        if (!link) return;
        const href = link.href;
        if (!/wa\.me|api\.whatsapp\.com|whatsapp\.com\/send/.test(href)) return;
        if (typeof gtag !== 'function') return; // no tracker: let normal navigation proceed
        e.preventDefault();
        gtagSendEvent(href);
      });
    </script>
    <script type="text/javascript" is:inline>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "xavyudimnn");
    </script>
    <Analytics />
    {cloudflareToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token":"${cloudflareToken}"}`}
      ></script>
    )}
  </body>
</html>
