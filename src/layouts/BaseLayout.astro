                ))}
              </div>
            </div>
          </details>
          <a class="nav-link hover:text-brand" href="/#promo">Promo</a>
          <a class="nav-link hover:text-brand" href="/goood-deal/">Trade-In</a>
          <a class="nav-link hover:text-brand" href="/service/">Servis</a>
          <a class="nav-link hover:text-brand" href="/kerjaya-cuckoo/">Daftar Ejen</a>
        </nav>
        <details class="group relative lg:hidden">
          <summary class="flex h-11 cursor-pointer list-none items-center gap-2 rounded-full border border-brand/15 bg-white px-4 text-sm font-black text-brand shadow-sm transition-all duration-300 hover:bg-cream [&::-webkit-details-marker]:hidden">
            <span>Menu</span>
            <span class="text-base leading-none transition-transform duration-300 group-open:rotate-45">+</span>
          </summary>
          <div class="absolute right-0 top-[calc(100%+0.75rem)] z-50 w-[min(22rem,calc(100vw-2rem))] overflow-hidden rounded-[1.5rem] border border-brand/10 bg-white shadow-soft">
