---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

const {
  title = 'CUCKOO Malaysia',
  description = 'Order produk CUCKOO dengan ejen berpengalaman sejak 2017.',
  canonical = 'https://www.cuckoonano.com/',
  ogImage = 'https://www.cuckoonano.com/assets/images/uploads/cuckoonano-og.webp',
  ogType = 'website',
  showWaterHalal = false,
  showHeader = true,
  showFooter = true,
  showFloatingWhatsapp = true,
  preloadImages = []
