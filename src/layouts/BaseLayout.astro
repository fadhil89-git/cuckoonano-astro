const logoSrc = '/assets/images/brand/logo_cmyk_maroon02-e1546229046344.png.webp';
const faviconSrc = '/assets/images/brand/cropped-favicon-cuckoo-fadhil-x.webp';
const cloudflareToken = import.meta.env.PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN ?? 'c48d4cf42b3a40119644169397c1e95e';

