                          <span class="block text-sm font-black text-ink">{category.title}</span>
                          <span class="block text-[11px] font-bold text-muted">{category.products.length} produk</span>
                        </span>
                        <span class="text-brand transition-transform duration-300 group-open/category:rotate-45">+</span>
                      </summary>
                      <div class="grid gap-1 border-t border-brand/10 px-2 py-2">
                        <a href={category.href} class="rounded-lg bg-cream px-3 py-2 text-xs font-black text-brand">
                          Lihat semua {category.title}
                        </a>
                        {category.products.map(([name, href]) => (
                          <a href={href} class="rounded-lg px-3 py-2 text-xs font-bold text-muted hover:bg-cream hover:text-brand">
                            {name}
                          </a>
                        ))}
                      </div>
                    </details>
                  ))}
                </div>
              </details>
              <a href="/#promo" class="rounded-2xl px-4 py-3 hover:bg-cream">Promo</a>
              <a href="/goood-deal/" class="rounded-2xl px-4 py-3 hover:bg-cream">Trade-In</a>
              <a href="/service/" class="rounded-2xl px-4 py-3 hover:bg-cream">Servis</a>
              <a href="/kerjaya-cuckoo/" class="rounded-2xl px-4 py-3 hover:bg-cream">Daftar Ejen</a>
            </div>
          </div>
        </details>
      </div>
    </header>
    )}

<main>
  <slot />
</main>

    {showFooter && (
    <footer class="bg-ink px-4 py-12 text-white sm:px-6 lg:px-8">
      <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[1fr_1.45fr_.85fr]">
        <div>
          <p class="text-xl font-black tracking-tight">CUCKOONANO</p>
          <p class="mt-4 max-w-sm text-sm leading-7 text-white/64">
            Website ejen CUCKOO oleh Fadhil & Izzah. Membantu pelanggan semak produk, promo dan pilihan bayaran bulanan CUCKOO.
          </p>
          <p class="mt-4 inline-flex rounded-full border border-brand-gold/25 bg-white/5 px-4 py-2 text-xs font-black uppercase tracking-[.14em] text-brand-gold">
            Ejen CUCKOO sejak 2017
          </p>
          <div class="mt-5 grid gap-3 text-sm leading-6 text-white/60">
            <div>
              <p class="font-black text-white">Fadhil <span class="text-brand-gold">SR1000138</span></p>
              <p>Cuckoo Branch Sales Manager (BSM)</p>
            </div>
            <div>
              <p class="font-black text-white">Nurul 'Izzah <span class="text-brand-gold">SR1003594</span></p>
              <p>Cuckoo Sales Representative</p>
