---
const {
  eyebrow = 'Proof & Consultation',
  title = 'Konsultasi Daripada Ejen CUCKOO Sejak 2017',
  description = 'Kami bantu semak promo, plan bulanan, kesesuaian model, bayaran permulaan dan urusan pemasangan.',
  items = ['Installation sebenar', 'Screenshot WhatsApp', 'Customer proof', 'Dapur customer'],
  images = []
} = Astro.props;
---

<section id="customer-proof" class="px-4 py-14 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="max-w-3xl">
      <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">{eyebrow}</p>
      <h2 class="mt-3 text-3xl font-black text-brand-ink sm:text-4xl">{title}</h2>
      <p class="mt-4 leading-8 text-brand-muted">{description}</p>
    </div>

    <div class="mt-8 flex snap-x gap-5 overflow-x-auto pb-5 [-ms-overflow-style:none] [scrollbar-width:none] md:grid md:grid-cols-4 md:overflow-visible md:pb-0 [&::-webkit-scrollbar]:hidden">
      {items.map((item, index) => {
        const image = images[index];

        return (
          <article class="w-[78vw] shrink-0 snap-start overflow-hidden rounded-3xl bg-white shadow-soft ring-1 ring-brand/10 md:w-auto">
            <div class="flex h-44 items-center justify-center bg-brand-cream sm:h-52">
              {image ? (
                <img src={image} alt={item} loading="lazy" class="h-full w-full object-cover" />
              ) : (
                <div class="flex h-full w-full flex-col items-center justify-center bg-[radial-gradient(circle_at_70%_20%,rgba(216,166,74,.22),transparent_34%),linear-gradient(135deg,#fff8f2,#ffffff)] p-5 text-center">
                  <span class="flex h-14 w-14 items-center justify-center rounded-full bg-white text-2xl font-black text-brand shadow-soft">
                    ✓
                  </span>
                  <p class="mt-4 text-sm font-black text-brand">{item}</p>
                </div>
              )}
            </div>
            <div class="p-5">
              <h3 class="font-black text-brand-ink">{item}</h3>
              <p class="mt-2 text-sm leading-6 text-brand-muted">
                Bukti dan rujukan pelanggan boleh dimasukkan di sini apabila gambar sebenar tersedia.
              </p>
            </div>
          </article>
        );
      })}
    </div>

    <p class="mt-1 text-center text-xs font-bold text-brand-muted md:hidden">
      Swipe kiri / kanan untuk lihat bukti lain
    </p>
  </div>
</section>
