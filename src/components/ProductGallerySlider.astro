---
interface GalleryItem {
  image: string;
  title: string;
  copy?: string;
  alt?: string;
}

interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
  description?: string;
  items: GalleryItem[];
  aspectClass?: string;
}

const {
  id = 'gallery',
  eyebrow = 'Product Gallery',
  title,
  description,
  items,
  aspectClass = 'aspect-[5/4]'
} = Astro.props;
---

<section id={id} class="px-4 py-14 sm:px-6 lg:px-8" data-product-gallery>
  <div class="mx-auto max-w-7xl">
    <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-3xl">
        <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">{eyebrow}</p>
        <h2 class="mt-3 text-3xl font-black text-brand-ink sm:text-4xl">{title}</h2>
        {description && <p class="mt-4 leading-8 text-brand-muted">{description}</p>}
      </div>

      <div class="flex gap-2">
        <button
          type="button"
          class="gallery-prev flex h-12 w-12 items-center justify-center rounded-full border border-brand/10 bg-white text-xl font-black text-brand shadow-soft transition hover:border-brand/25 hover:bg-brand-cream"
          aria-label="Gambar sebelum"
          data-gallery-prev
        >
          ‹
        </button>
        <button
          type="button"
          class="gallery-next flex h-12 w-12 items-center justify-center rounded-full border border-brand/10 bg-white text-xl font-black text-brand shadow-soft transition hover:border-brand/25 hover:bg-brand-cream"
          aria-label="Gambar selepas"
          data-gallery-next
        >
          ›
        </button>
      </div>
    </div>

    <div
      class="mt-8 flex snap-x gap-5 overflow-x-auto scroll-smooth pb-5 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
      data-gallery-track
    >
      {items.map((item) => (
        <article
          class="min-w-[82vw] snap-center overflow-hidden rounded-[2rem] bg-white shadow-soft ring-1 ring-brand/10 sm:min-w-[420px] lg:min-w-[31.5%]"
          data-gallery-card
        >
          <button
            type="button"
            class="block w-full text-left"
            data-gallery-open={item.image}
            data-gallery-alt={item.alt ?? item.title}
            data-gallery-title={item.title}
          >
            <div class={`${aspectClass} overflow-hidden bg-brand-cream`}>
              <img
                src={item.image}
                alt={item.alt ?? item.title}
                loading="lazy"
                class="h-full w-full object-contain transition duration-500 hover:scale-[1.03]"
              />
            </div>
          </button>

          <div class="p-5">
            <h3 class="text-lg font-black text-brand-ink">{item.title}</h3>
            {item.copy && <p class="mt-2 text-sm leading-7 text-brand-muted">{item.copy}</p>}
          </div>
        </article>
      ))}
    </div>

    <div class="mt-1 flex justify-center gap-2" aria-label="Pagination gambar">
      {items.map((_, index) => (
        <button
          type="button"
          class="h-2.5 w-2.5 rounded-full bg-brand/20 transition data-[active=true]:w-7 data-[active=true]:bg-brand"
          aria-label={`Pergi ke gambar ${index + 1}`}
          data-gallery-dot
          data-index={index}
          data-active={index === 0 ? 'true' : 'false'}
        ></button>
      ))}
    </div>

    <p class="mt-3 text-center text-xs font-bold text-brand-muted md:hidden">
      Swipe kiri / kanan untuk lihat gambar lain
    </p>
  </div>

  <div
    class="fixed inset-0 z-[80] hidden items-center justify-center bg-black/75 p-4 backdrop-blur-sm"
    role="dialog"
    aria-modal="true"
    aria-label="Paparan gambar produk"
    data-gallery-lightbox
  >
    <button
      type="button"
      class="absolute inset-0 cursor-zoom-out"
      aria-label="Tutup gambar"
      data-lightbox-backdrop
    ></button>

    <div class="relative z-10 w-full max-w-5xl overflow-hidden rounded-[2rem] bg-white shadow-premium">
      <button
        type="button"
        class="absolute right-3 top-3 z-20 flex h-11 w-11 items-center justify-center rounded-full bg-white/95 text-2xl font-black text-brand shadow-soft"
        aria-label="Tutup gambar"
        data-lightbox-close
      >
        ×
      </button>

      <button
        type="button"
        class="absolute left-3 top-1/2 z-20 hidden h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-white/95 text-3xl font-black text-brand shadow-soft transition hover:bg-brand-cream sm:flex"
        aria-label="Gambar sebelum"
        data-lightbox-prev
      >
        ‹
      </button>

      <button
        type="button"
        class="absolute right-3 top-1/2 z-20 hidden h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-white/95 text-3xl font-black text-brand shadow-soft transition hover:bg-brand-cream sm:flex"
        aria-label="Gambar selepas"
        data-lightbox-next
      >
        ›
      </button>

      <div class="max-h-[82vh] bg-brand-cream">
        <img src="" alt="" class="mx-auto max-h-[82vh] w-full object-contain" data-lightbox-image />
      </div>
      <div class="flex items-center justify-between gap-3 px-5 py-4">
        <p class="text-sm font-black text-brand-ink" data-lightbox-caption></p>
        <p class="shrink-0 text-xs font-black text-brand-muted" data-lightbox-count></p>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    document.querySelectorAll('[data-product-gallery]').forEach((gallery) => {
      const track = gallery.querySelector('[data-gallery-track]');
      const cards = Array.from(gallery.querySelectorAll('[data-gallery-card]'));
      const dots = Array.from(gallery.querySelectorAll('[data-gallery-dot]'));
      const prev = gallery.querySelector('[data-gallery-prev]');
      const next = gallery.querySelector('[data-gallery-next]');
      const lightbox = gallery.querySelector('[data-gallery-lightbox]');
      const lightboxImage = gallery.querySelector('[data-lightbox-image]');
      const lightboxCaption = gallery.querySelector('[data-lightbox-caption]');
      const lightboxCount = gallery.querySelector('[data-lightbox-count]');
      const lightboxPrev = gallery.querySelector('[data-lightbox-prev]');
      const lightboxNext = gallery.querySelector('[data-lightbox-next]');
      const closeButtons = gallery.querySelectorAll('[data-lightbox-close], [data-lightbox-backdrop]');
      const openButtons = Array.from(gallery.querySelectorAll('[data-gallery-open]'));
      let currentLightboxIndex = 0;
      let touchStartX = 0;
      let touchStartY = 0;

      if (!track || cards.length === 0) return;

      const getStep = () => {
        const first = cards[0];
        const style = window.getComputedStyle(track);
        const gap = Number.parseFloat(style.columnGap || style.gap || '20') || 20;
        return first.getBoundingClientRect().width + gap;
      };

      const updateDots = () => {
        const index = Math.max(0, Math.min(cards.length - 1, Math.round(track.scrollLeft / getStep())));
        dots.forEach((dot, dotIndex) => {
          dot.dataset.active = dotIndex === index ? 'true' : 'false';
        });
      };

      prev?.addEventListener('click', () => track.scrollBy({ left: -getStep(), behavior: 'smooth' }));
      next?.addEventListener('click', () => track.scrollBy({ left: getStep(), behavior: 'smooth' }));

      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          const index = Number(dot.dataset.index || 0);
          track.scrollTo({ left: index * getStep(), behavior: 'smooth' });
        });
      });

      track.addEventListener('scroll', () => window.requestAnimationFrame(updateDots), { passive: true });

      const showLightboxImage = (index) => {
        if (!lightbox || !lightboxImage || !lightboxCaption || openButtons.length === 0) return;
        currentLightboxIndex = (index + openButtons.length) % openButtons.length;
        const button = openButtons[currentLightboxIndex];
        lightboxImage.src = button.dataset.galleryOpen || '';
        lightboxImage.alt = button.dataset.galleryAlt || button.dataset.galleryTitle || 'Gambar produk';
        lightboxCaption.textContent = button.dataset.galleryTitle || '';
        if (lightboxCount) lightboxCount.textContent = `${currentLightboxIndex + 1} / ${openButtons.length}`;
      };

      const openLightbox = (index) => {
        if (!lightbox) return;
        showLightboxImage(index);
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden';
      };

      const closeLightbox = () => {
        lightbox?.classList.add('hidden');
        lightbox?.classList.remove('flex');
        document.body.style.overflow = '';
      };

      openButtons.forEach((button, index) => {
        button.addEventListener('click', () => openLightbox(index));
      });

      lightboxPrev?.addEventListener('click', () => showLightboxImage(currentLightboxIndex - 1));
      lightboxNext?.addEventListener('click', () => showLightboxImage(currentLightboxIndex + 1));

      lightbox?.addEventListener('touchstart', (event) => {
        touchStartX = event.touches[0]?.clientX || 0;
        touchStartY = event.touches[0]?.clientY || 0;
      }, { passive: true });

      lightbox?.addEventListener('touchend', (event) => {
        const touch = event.changedTouches[0];
        if (!touch) return;
        const deltaX = touch.clientX - touchStartX;
        const deltaY = touch.clientY - touchStartY;
        if (Math.abs(deltaX) < 45 || Math.abs(deltaX) < Math.abs(deltaY)) return;
        showLightboxImage(currentLightboxIndex + (deltaX < 0 ? 1 : -1));
      }, { passive: true });

      closeButtons.forEach((button) => button.addEventListener('click', closeLightbox));
      document.addEventListener('keydown', (event) => {
        if (lightbox?.classList.contains('hidden')) return;
        if (event.key === 'Escape') closeLightbox();
        if (event.key === 'ArrowLeft') showLightboxImage(currentLightboxIndex - 1);
        if (event.key === 'ArrowRight') showLightboxImage(currentLightboxIndex + 1);
      });

      updateDots();
    });
  })();
</script>
