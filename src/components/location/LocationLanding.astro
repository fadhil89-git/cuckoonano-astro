---
import { stateFlagUrls } from '../../data/locationFlags.js';

const { location, state } = Astro.props;
const flagUrl = stateFlagUrls[state.slug];

const productBenefits = [
  {
    title: `Penapis Air CUCKOO ${location.name}`,
    image: '/assets/images/Gambar%20Produk%20png/king-top-2.webp',
    description: 'Penapis air CUCKOO menggunakan teknologi Nano Positive Filtration untuk membantu menapis air sambil mengekalkan mineral bermanfaat.',
    tags: ['Nano Positive Filtration', 'Air Bermineral', 'Mild Alkaline Water', 'Hot / Cold / Room', 'Stainless Steel Tank*'],
  },
  {
    title: `Penapis Udara CUCKOO ${location.name}`,
    image: '/assets/images/Gambar%20Produk%20png/l-model-main.webp',
    description: 'Penapis udara CUCKOO membantu menjaga kualiti udara dalam rumah dengan sistem penapisan, sensor dan indikator udara mengikut model.',
    tags: ['HEPA H13 Filter', 'Cuckoo Plasma Ioniser', 'PM2.5 Sensor', 'Tapisan Habuk Halus', '±1100 sqft Coverage*', '8 Colour LED Indicator'],
  },
  {
    title: `Aircond CUCKOO ${location.name}`,
    image: '/assets/images/Gambar%20Produk%20png/aircond%20cuckoo%20vita%205tar%201%20png%20(1)-Photoroom.webp',
    description: 'Aircond CUCKOO menggabungkan penyejukan inverter dengan ciri penapisan tambahan untuk keselesaan rumah.',
    tags: ['Inverter 5-Star Energy Saving', 'Vitamin C Filter', 'Silver Ion Filter', 'UVC LED Sterilisation', 'Golden Hydrophilic Fin'],
  },
  {
    title: `Washer Dryer CUCKOO ${location.name}`,
    image: '/assets/images/Gambar%20Produk%20png/Samsung-bespoke-ai-img-03.webp',
    description: 'Samsung Bespoke AI Washer Dryer membantu memudahkan urusan basuh dan kering pakaian dalam satu mesin.',
    tags: ['AI Ecobubble™', 'AI Wash', 'Auto Dispense', 'Super Speed Wash', 'Basuh & Kering', 'SmartThings & AI Control'],
  },
  {
    title: `Kerusi Urut CUCKOO ${location.name}`,
    image: '/assets/images/Gambar%20Produk%20png/cuckoo%20bespoke%202%20massage%20chair%20kerusi%20urut%201.webp',
    description: 'Kerusi urut CUCKOO dibangunkan melalui kerjasama bersama OGAWA untuk pengalaman urutan premium di rumah.',
    tags: ['Co-created bersama OGAWA', '34 Air Massage Bags', 'Smart SL Track Massage', 'Auto Massage Programmes', 'Thermotherapy ±45°C*'],
  },
  {
    title: `Tilam CUCKOO ${location.name}`,
    image: '/assets/images/Gambar%20Produk%20png/tilam%20cuckoo%20a%20luxe%20mattress%20napure%201.webp',
    description: 'Tilam CUCKOO dihasilkan oleh Napure dengan keselesaan bertaraf hotel untuk pengalaman rehat yang lebih premium.',
    tags: ['Dihasilkan oleh Napure', 'Hotel Mattress Feel', '100% Natural Latex', 'Ketebalan 14 inci', 'Queen & King Size'],
  },
  {
    title: `Treadmill CUCKOO ${location.name}`,
    image: '/assets/images/Gambar%20Produk%20png/b-fit.webp',
    description: 'Treadmill CUCKOO membantu pengguna bina rutin gaya hidup aktif dari rumah dengan lebih mudah.',
    tags: ['Senaman dari rumah', 'Walking & Light Jogging', 'Rekaan sesuai untuk rumah', 'Mudah digunakan'],
  },
];
---

<section class="hero-pattern px-4 py-14 sm:px-6 lg:px-8 lg:py-20">
  <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[1.05fr_.95fr] lg:items-center">
    <div>
      <div class="mb-6 inline-flex items-center gap-3 rounded-full border border-brand/15 bg-white px-5 py-3 shadow-sm">
        <div class="flex h-10 w-14 items-center justify-center overflow-hidden rounded-xl bg-white">
          <img src={flagUrl} alt={`Bendera ${state.name}`} class="h-full w-full object-contain" />
        </div>
        <div>
          <p class="text-xs font-bold text-brand">{location.name.toUpperCase()}, {state.name.toUpperCase()}</p>
          <p class="text-xs text-muted">Order & pemasangan ikut coverage</p>
        </div>
      </div>
      <h1 class="max-w-4xl text-4xl font-black leading-tight tracking-tight sm:text-5xl lg:text-6xl">Nak pasang produk CUCKOO di {location.name}?</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-muted">
        Nak pasang <strong>penapis air CUCKOO</strong>, <strong>penapis udara</strong>, <strong>aircond</strong>, <strong>washer dryer</strong>, <strong>kerusi urut</strong> atau produk CUCKOO lain di {location.name}? Saya bantu terangkan pilihan produk, harga cash atau rental bulanan, promo terkini dan proses pemasangan untuk kawasan {location.name} dan sekitarnya.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href="https://wasap.my/60139916967" class="rounded-full bg-brand px-7 py-4 text-center text-base font-bold text-white shadow-glow transition-all duration-300 hover:-translate-y-1 hover:bg-brand-dark hover:shadow-xl">WhatsApp Ejen</a>
        <a href="#kategori-produk" class="rounded-full border border-brand/20 bg-white px-7 py-4 text-center text-base font-bold text-brand transition-all duration-300 hover:-translate-y-1 hover:bg-brand-soft hover:shadow-soft">Lihat Produk</a>
      </div>
    </div>
    <div class="rounded-[2rem] bg-white p-4 shadow-soft sm:p-5">
      <div class="relative overflow-hidden rounded-[1.75rem] bg-gradient-to-br from-brand via-brand-dark to-[#2B0710] p-6 text-white">
        <div class="relative">
          <div class="flex flex-col items-start">
            <div class="inline-flex items-center justify-center overflow-hidden rounded-3xl border border-white/20 bg-white p-4 shadow-xl">
              <img src={flagUrl} alt={`Bendera ${state.name}`} class="h-24 w-40 object-contain" />
            </div>
          </div>
          <div class="mt-5">
            <p class="text-sm font-bold text-white/70">{location.name}, {state.name}</p>
            <h2 class="mt-1 text-3xl font-black leading-tight">Tanya kami dahulu sebelum order</h2>
            <p class="mt-3 text-sm leading-6 text-white/75">Bagitahu kami produk apa yang anda berminat, bajet dan keperluan rumah atau pejabat. Saya bantu explain produk mana yang sesuai untuk anda.</p>
          </div>
        </div>
        <div class="relative mt-7 grid grid-cols-2 gap-3">
          <div class="rounded-2xl bg-white/10 p-4 text-center ring-1 ring-white/10">
            <p class="text-xs font-bold uppercase text-white/65">Ejen Full-Time Sejak</p>
            <p class="mt-2 text-3xl font-black text-white">2017</p>
          </div>
          <div class="rounded-2xl bg-white/10 p-4 text-center ring-1 ring-white/10">
            <p class="text-xs font-bold uppercase text-white/65">Pemasangan Diurus</p>
            <p class="mt-2 text-3xl font-black text-white">2000+</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="coverage" class="bg-white px-4 py-16 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-10 lg:grid-cols-[.78fr_1.22fr] lg:items-start">
      <div>
        <p class="font-bold text-brand">Kawasan sekitar {location.name}</p>
        <h2 class="mt-3 text-3xl font-black tracking-tight sm:text-4xl">Pasang CUCKOO di {location.name} dan kawasan sekitarnya</h2>
        <p class="mt-4 text-muted leading-7">Jika anda tinggal di {location.name} atau kawasan berdekatan, boleh WhatsApp lokasi rumah dahulu. Kami bantu semak pilihan produk, promo semasa dan sama ada urusan order serta pemasangan boleh dibuat mengikut coverage servis CUCKOO.</p>
      </div>
      <div class="rounded-[2rem] bg-cream p-5 shadow-sm">
        <div class="mb-4 flex items-center justify-between gap-3">
          <p class="text-sm font-bold text-brand">Kawasan yang biasa pelanggan tanya</p>
          <span class="rounded-full bg-white px-3 py-1 text-xs font-bold text-muted">dan lain-lain</span>
        </div>
        <div class="flex flex-wrap gap-3">
          {location.areas.map((area) => (
            <span class="area-chip rounded-full bg-white px-4 py-2 text-sm font-bold text-brand shadow-sm">{area}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<section class="px-4 py-16 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="rounded-[2rem] bg-white p-6 shadow-soft lg:p-10">
      <div class="grid gap-10 lg:grid-cols-[.95fr_1.05fr] lg:items-center">
        <div>
          <p class="font-bold text-brand">Bantuan sebelum order</p>
          <h2 class="mt-3 text-3xl font-black tracking-tight sm:text-4xl">Tak pasti nak pilih model apa? Tanya dulu, jangan segan</h2>
          <p class="mt-4 text-muted leading-7">Sebelum order, anda boleh tanya dahulu tentang harga cash, rental bulanan, promosi semasa, kelebihan produk, spesifikasi, kapasiti, saiz ruang dan kesesuaian untuk rumah.</p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {['Harga cash & rental', 'Kesesuaian produk', 'Spesifikasi & fungsi', 'Order & pemasangan'].map((title) => (
            <div class="rounded-[1.5rem] bg-cream p-5">
              <h3 class="font-black">{title}</h3>
              <p class="mt-2 text-sm leading-6 text-muted">Bantu anda faham pilihan sebelum buat keputusan untuk kawasan {location.name}.</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<div data-product-selector></div>
<div data-promo></div>
<div data-why-cuckoo></div>

<section class="px-4 py-16 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl rounded-[2rem] bg-white p-6 shadow-soft lg:p-8">
    <div class="grid gap-8 lg:grid-cols-[.8fr_1.2fr] lg:items-center">
      <div>
        <p class="font-bold text-brand">Kenapa pilih kami?</p>
        <h2 class="mt-2 text-3xl font-black tracking-tight">Ejen CUCKOO sejak 2017</h2>
        <p class="mt-4 text-muted leading-7">Kami bantu customer faham produk dengan bahasa mudah dari pilihan model, harga, promo, proses order sampai follow-up selepas pemasangan.</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-4">
        <div class="rounded-[1.5rem] bg-cream p-5 text-center"><p class="text-2xl font-black text-brand">2000+</p><p class="mt-1 text-xs text-muted">Pemasangan diurus seluruh Malaysia</p></div>
        <div class="rounded-[1.5rem] bg-cream p-5 text-center"><p class="text-2xl font-black text-brand">2017</p><p class="mt-1 text-xs text-muted">Ejen sejak</p></div>
        <div class="rounded-[1.5rem] bg-cream p-5 text-center"><p class="text-2xl font-black text-brand">100%</p><p class="mt-1 text-xs text-muted">Boleh urus melalui WhatsApp</p></div>
        <div class="rounded-[1.5rem] bg-cream p-5 text-center"><p class="text-2xl font-black text-brand">MY</p><p class="mt-1 text-xs text-muted">Bantu order seluruh Malaysia</p></div>
      </div>
    </div>
  </div>
</section>

<section class="bg-cream px-4 py-16 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="mb-10 max-w-3xl">
      <p class="font-bold text-brand">Kelebihan produk mengikut kategori</p>
      <h2 class="mt-2 text-3xl font-black tracking-tight sm:text-4xl">Kenapa pilih produk CUCKOO untuk rumah anda?</h2>
      <p class="mt-4 text-muted leading-7">Ringkasan ringkas untuk bantu anda faham teknologi dan kelebihan utama setiap kategori sebelum pilih produk.</p>
    </div>
    <div class="grid gap-6">
      {productBenefits.map((product) => (
        <article class="grid gap-6 rounded-[2rem] bg-white p-6 shadow-soft lg:grid-cols-[260px_1fr] lg:items-center">
          <div class="flex aspect-[4/3] items-center justify-center overflow-hidden rounded-[1.5rem] bg-white p-5 ring-1 ring-brand/10">
            <img src={product.image} alt={product.title} loading="lazy" class="h-full w-full object-contain" />
          </div>
          <div>
            <h3 class="text-2xl font-black">{product.title}</h3>
            <p class="mt-3 max-w-3xl text-muted leading-7">{product.description}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {product.tags.map((tag) => (
                <span class="rounded-full bg-brand-soft px-4 py-2 text-sm font-bold text-brand">{tag}</span>
              ))}
            </div>
            <a href="#kategori-produk" class="mt-6 inline-flex rounded-full bg-brand px-5 py-3 text-sm font-black text-white transition-all duration-300 hover:-translate-y-1 hover:bg-brand-dark hover:shadow-xl">Lihat kategori produk di atas</a>
          </div>
        </article>
      ))}
    </div>
    <p class="mt-6 text-xs leading-6 text-muted">*Ciri tertentu bergantung kepada model, stok dan pakej semasa.</p>
  </div>
</section>

<section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <p class="font-bold text-brand">FAQ {location.name}</p>
    <h2 class="mt-2 text-3xl font-black tracking-tight">Soalan biasa sebelum order</h2>
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      <div class="rounded-[1.5rem] bg-cream p-5"><h3 class="font-black">Boleh pasang CUCKOO di {location.name}?</h3><p class="mt-2 text-sm leading-6 text-muted">Boleh WhatsApp lokasi rumah dahulu untuk semak coverage order dan pemasangan semasa.</p></div>
      <div class="rounded-[1.5rem] bg-cream p-5"><h3 class="font-black">Apa kawasan sekitar yang termasuk?</h3><p class="mt-2 text-sm leading-6 text-muted">Rujuk senarai kawasan di atas. Jika kawasan tidak tersenarai, ejen boleh bantu check dahulu.</p></div>
      <div class="rounded-[1.5rem] bg-cream p-5"><h3 class="font-black">Boleh tanya harga cash dan rental?</h3><p class="mt-2 text-sm leading-6 text-muted">Ya, boleh tanya harga cash, rental bulanan, promo semasa dan kelayakan mengikut produk.</p></div>
      <div class="rounded-[1.5rem] bg-cream p-5"><h3 class="font-black">Produk apa yang boleh order?</h3><p class="mt-2 text-sm leading-6 text-muted">Anda boleh tanya penapis air, penapis udara, aircond, washer dryer, kerusi urut, tilam, treadmill dan produk CUCKOO lain.</p></div>
    </div>
  </div>
</section>

<div data-testimonials></div>

<section class="px-4 py-16 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="rounded-[2rem] bg-gradient-to-br from-cream via-white to-brand-soft p-6 shadow-soft lg:p-10">
      <div class="grid gap-10 lg:grid-cols-[.85fr_1.15fr] lg:items-start">
        <div>
          <p class="font-bold text-brand">Support selepas order</p>
          <h2 class="mt-3 text-3xl font-black tracking-tight sm:text-4xl">Lepas pasang pun masih boleh tanya</h2>
          <p class="mt-4 text-muted leading-7">Kalau selepas pemasangan ada pertanyaan tentang servis, bayaran, cara guna produk atau tukar alamat, anda masih boleh hubungi untuk dapatkan panduan langkah seterusnya.</p>
          <div class="mt-6 flex aspect-[16/9] items-center justify-center rounded-[1.5rem] bg-white text-sm font-bold text-brand shadow-sm">Placeholder gambar servis / technician / ejen</div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {['Servis berkala', 'Bayaran', 'Tukar alamat', 'Cara guna produk', 'Report isu', 'Tambah produk'].map((item) => (
            <div class="rounded-[1.5rem] bg-white p-5 shadow-sm">
              <h3 class="font-black">{item}</h3>
              <p class="mt-2 text-sm leading-6 text-muted">Boleh tanya panduan umum dan saluran seterusnya selepas order.</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<div data-agent-gift></div>
<div data-agent-block></div>

<section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl rounded-[2rem] bg-brand p-8 text-white shadow-glow lg:p-10">
    <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
      <div>
        <h2 class="text-3xl font-black tracking-tight sm:text-4xl">Nak pasang CUCKOO di {location.name}?</h2>
        <p class="mt-3 max-w-2xl text-white/75">WhatsApp lokasi rumah, produk yang anda berminat dan bajet. Saya bantu cadangkan pilihan yang sesuai.</p>
      </div>
      <a href="https://wasap.my/60139916967" class="rounded-full bg-white px-8 py-4 text-center font-black text-brand transition-all duration-300 hover:-translate-y-1 hover:bg-gold hover:shadow-xl">WhatsApp Ejen</a>
    </div>
  </div>
</section>
