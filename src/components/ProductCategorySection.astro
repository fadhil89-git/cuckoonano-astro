      { name: 'Galaxy Tab S10 FE+', url: '/products/samsung/galaxy-tab-s10-fe-plus/', image: '/assets/images/Gambar%20Produk%20png/samsung-s10fe-1.webp', desc: 'Tablet Samsung untuk kerja ringan, belajar, hiburan dan penggunaan harian keluarga.', price: 'Semak plan', bullets: ['Galaxy Tab S10 FE+', 'S Pen support*', 'Sesuai kerja & belajar', 'Samsung ecosystem'] }
