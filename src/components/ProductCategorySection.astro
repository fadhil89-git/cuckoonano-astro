const current = products[initial] || products['water-purifier'];
const rawVisibleProducts = mode === 'all'
  ? Object.entries(products)
  : [[initial, current]];
const categoryLabels = Object.fromEntries(categories);
const categoryGuides = {
  'water-purifier': {
    eyebrow: 'Apa Perlu Semak',
    title: 'Sebelum pilih Penapis Air, semak perkara ini dulu.',
    copy: 'Saiz keluarga, kapasiti tangki, fungsi panas/sejuk dan ruang dapur.',
    items: ['Tangki & suhu air', 'Digital atau mekanikal', 'Anggaran bayaran bulanan']
  }
};
const fallbackGuide = (productCategory) => ({
  eyebrow: 'Apa Perlu Semak',
  title: `Sebelum pilih ${productCategory.title.replace(' CUCKOO', '')}, semak perkara ini dulu.`,
  copy: 'Semak fungsi utama, ruang rumah, bajet bulanan dan keperluan penggunaan harian.',
  items: ['Fungsi utama', 'Ruang penggunaan', 'Anggaran bayaran bulanan']
});
const visibleProducts = rawVisibleProducts.map(([key, productCategory]) => ({
  key,
  productCategory,
  guide: categoryGuides[key] || fallbackGuide(productCategory)
}));
const specLabel = (spec) => String(spec || '')
  .replace(/\bCold\b/gi, 'Sejuk')
  .replace(/\bHot\b/gi, 'Panas')
  .replace(/\bRoom\b/gi, 'Room')
  .replace(/\s+/g, ' ')
  .trim();
const productSpecs = (product) => {
  const firstBullet = product.bullets?.[0] || '';
  if (!firstBullet.includes(',')) return [];
  return firstBullet.split(',').map(specLabel).filter(Boolean).slice(0, 3);
};
const productHighlights = (product) => {
  const hasSpecs = productSpecs(product).length > 0;
  return (product.bullets || []).slice(hasSpecs ? 1 : 0).slice(0, 3);
};
const productWhatsapp = (product) => {
  const text = `Salam Fadhil, saya nak semak promo untuk ${product.name}. Boleh bantu semak harga bulanan, syarat dan produk yang layak?`;
  return `https://api.whatsapp.com/send?phone=60139916967&text=${encodeURIComponent(text)}`;
};
const activeClasses = 'bg-brand text-white shadow-glow';
const inactiveClasses = 'bg-white/90 text-brand shadow-soft ring-1 ring-brand/10 hover:bg-brand-soft';
---

<section id="kategori-produk" class="bg-cream px-4 py-16 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    {mode === 'all' && (
      <>
        <div class="mx-auto max-w-2xl text-center">
          <p class="font-bold text-brand">Produk CUCKOO</p>
          <h2 class="mt-3 text-3xl font-black tracking-tight sm:text-4xl">
            Pilih kategori yang anda berminat
          </h2>
          <p class="mt-4 text-muted">
            Pilih kategori produk untuk semak model, fungsi dan pilihan yang sesuai.
          </p>
        </div>

        <div class="mt-8 flex flex-wrap justify-center gap-3">
          {categories.map(([key, label]) => (
            <button
              type="button"
              data-product-tab={key}
              class:list={[
                'rounded-full px-5 py-3 text-sm font-bold transition-all duration-300 hover:-translate-y-1 hover:shadow-xl',
                key === initial ? activeClasses : inactiveClasses
              ]}
            >
              {label}
            </button>
          ))}
        </div>
      </>
    )}

    {visibleProducts.map(({ key, productCategory, guide }) => (
    <div
      data-product-panel={key}
      class:list={[
        mode === 'single'
          ? ''
          : 'mt-8 rounded-[2rem] bg-cream p-5 shadow-none ring-0 sm:p-6',
        key === initial ? '' : 'hidden'
      ]}
    >
      <div class={mode === 'single' ? 'flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between' : 'flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between'}>
        <div>
          <p class={mode === 'single' ? 'font-bold text-brand' : 'text-xs font-black uppercase tracking-[.18em] text-brand/70'}>
            Kategori Produk
          </p>
          <h3 class={mode === 'single' ? 'mt-3 text-3xl font-black tracking-tight sm:text-4xl' : 'mt-2 text-2xl font-black sm:text-3xl'}>
            {productCategory.title}
          </h3>
          <p class={mode === 'single' ? 'mt-3 max-w-3xl text-sm leading-7 text-muted' : 'mt-3 max-w-2xl text-sm leading-6 text-muted'}>
            {productCategory.desc}
          </p>
        </div>
        <a href={`/products/${key}/`} class={mode === 'single' ? 'inline-flex w-fit rounded-full bg-brand px-6 py-3 text-sm font-black text-white transition-all duration-300 hover:-translate-y-1 hover:bg-brand-dark hover:shadow-xl' : 'inline-flex w-fit rounded-full bg-white px-5 py-3 text-sm font-black text-brand shadow-none transition-all duration-300 hover:-translate-y-1'}>
          {mode === 'single' ? 'Lihat Semua Model' : 'Lihat kategori'}
        </a>
      </div>

      <div class={mode === 'single' ? 'mt-8 grid gap-6 lg:grid-cols-[.58fr_1.42fr] lg:items-start' : 'mt-7'}>
        {mode === 'single' && (
          <aside class="rounded-[1.75rem] bg-brand p-6 text-white shadow-glow lg:sticky lg:top-24">
            <p class="text-xs font-black uppercase tracking-[.2em] text-brand-gold">{guide.eyebrow}</p>
            <h4 class="mt-4 text-2xl font-black leading-tight">Sebelum pilih {categoryLabels[key] || productCategory.title}, semak perkara ini dulu.</h4>
            <p class="mt-4 text-sm font-semibold leading-7 text-white/75">{guide.copy}</p>
            <div class="mt-5 grid gap-2">
              {guide.items.map((item) => (
                <div class="rounded-2xl bg-white/10 px-4 py-3 text-sm font-black text-white ring-1 ring-white/15">
                  {item}
                </div>
              ))}
            </div>
            <a href="#" onclick="this.href=rotatingWhatsapp()" class="mt-6 inline-flex w-full justify-center rounded-full bg-white px-5 py-3 text-sm font-black text-brand transition-all duration-300 hover:-translate-y-1 hover:bg-brand-gold">
              Semak Promo Kategori Ini
            </a>
          </aside>
        )}

        <div class={mode === 'single' ? 'min-w-0 rounded-[2rem] bg-white p-4 ring-1 ring-brand/10 sm:p-5' : ''}>
          <div class="flex snap-x gap-4 overflow-x-auto overflow-y-visible pb-1 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        {productCategory.items.map((product) => (
          <article class={mode === 'single' ? 'group flex w-[310px] shrink-0 snap-start flex-col rounded-[1.75rem] border border-brand/10 bg-white p-4 shadow-none transition-all duration-300 hover:-translate-y-1 hover:border-gold/60 hover:bg-white sm:w-[340px]' : 'group flex w-[300px] shrink-0 snap-start flex-col rounded-[1.75rem] border border-brand/10 bg-white p-4 shadow-none transition-all duration-300 hover:-translate-y-1 hover:border-gold/60 hover:bg-white sm:w-[320px]'}>
            <div class={mode === 'single' ? 'relative flex h-[310px] items-center justify-center overflow-hidden rounded-2xl bg-gradient-to-br from-white to-cream ring-1 ring-brand/10' : 'relative flex h-[260px] items-center justify-center overflow-hidden rounded-2xl bg-gradient-to-br from-white to-cream ring-1 ring-brand/10'}>
              {mode !== 'single' && product.badge && (
                <span class="absolute left-3 top-3 z-10 rounded-full bg-brand px-4 py-1.5 text-[11px] font-black uppercase tracking-[.12em] text-white shadow-soft">
                  {product.badge}
                </span>
              )}
              <img
                src={product.image}
                alt={product.name}
                loading="lazy"
                class:list={[
                  'h-full w-full object-contain p-5 transition-opacity duration-300',
                  product.hoverImage ? 'group-hover:opacity-0' : ''
                ]}
              />
              {product.hoverImage && (
                <img
                  src={product.hoverImage}
                  alt={`${product.name} warna alternatif`}
                  loading="lazy"
                  class="absolute inset-0 h-full w-full object-contain p-5 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
                />
              )}
            </div>

            <div class="mt-5">
              <h3 class={mode === 'single' ? 'text-xl font-black leading-tight' : 'text-lg font-black leading-tight'}>{product.name}</h3>
            </div>

            {mode === 'single' && productSpecs(product).length > 0 && (
              <div class="mt-3 flex flex-wrap gap-2">
                {productSpecs(product).map((spec) => (
                  <span class="rounded-full bg-cream px-3 py-1.5 text-[11px] font-black leading-none text-brand ring-1 ring-brand/10">
                    {spec}
                  </span>
                ))}
              </div>
            )}

            {product.pricePlans?.map((plan) => (
              <div class="mt-4 rounded-2xl bg-brand-soft/70 p-4 ring-1 ring-brand/10">
                <p class="text-[11px] font-black uppercase tracking-[.14em] text-brand">{plan.type}</p>
                <div class="mt-2 flex items-end gap-1">
                  <span class="text-3xl font-black leading-none text-brand">{plan.highlight}</span>
                  <span class="pb-1 text-xs font-black text-brand">/bulan</span>
                </div>
                <div class="mt-3 grid gap-1 border-t border-brand/10 pt-3">
                  {plan.rows.map(([label, value]) => (
                    <div class="flex items-center justify-between gap-3 text-xs">
                      <span class="font-bold text-muted">{label}</span>
                      <span class="font-black text-brand">{value}</span>
                    </div>
                  ))}
                </div>
              </div>
            ))}

            {product.price && (
              <div class="mt-4 rounded-2xl bg-brand-soft/70 p-4 ring-1 ring-brand/10">
                <p class="text-sm font-black text-brand">{product.price}</p>
              </div>
            )}

            <ul class="mt-4 grid gap-2">
              {productHighlights(product).map((bullet) => (
                <li class="flex gap-2 text-xs font-bold leading-5 text-muted">
                  <span class="mt-0.5 flex h-4 w-4 shrink-0 items-center justify-center rounded-full bg-brand text-[10px] text-white">✓</span>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>

            <p class="mt-4 text-sm leading-6 text-muted">{product.desc}</p>

            <div class="mt-auto grid gap-3 pt-7">
              <a href={productWhatsapp(product)} class="inline-flex items-center justify-center rounded-full bg-brand px-5 py-3 text-sm font-black text-white transition-all duration-300 hover:-translate-y-1 hover:bg-brand-dark hover:shadow-xl">
                Semak Promo Produk Ini
              </a>
              <a href={product.url} class="inline-flex items-center justify-center rounded-full bg-white px-5 py-3 text-sm font-black text-brand ring-1 ring-brand/10 transition-all duration-300 hover:-translate-y-1 hover:bg-brand-soft">
                Lihat Detail
              </a>
            </div>
          </article>
        ))}
          </div>
        </div>
      </div>

      <p class="mt-6 text-xs leading-5 text-muted">
        *Harga, promo dan ciri tertentu bergantung kepada model, stok dan kempen semasa. WhatsApp ejen untuk semak pakej terkini.
      </p>
    </div>
    ))}
  </div>

  <script is:inline define:vars={{ activeClasses, inactiveClasses }}>
    document.querySelectorAll('[data-product-tab]').forEach((tab) => {
      tab.addEventListener('click', () => {
        const category = tab.dataset.productTab;

        document.querySelectorAll('[data-product-tab]').forEach((button) => {
          button.className = `rounded-full px-5 py-3 text-sm font-bold transition-all duration-300 hover:-translate-y-1 hover:shadow-xl ${button.dataset.productTab === category ? activeClasses : inactiveClasses}`;
        });

        document.querySelectorAll('[data-product-panel]').forEach((panel) => {
          panel.classList.toggle('hidden', panel.dataset.productPanel !== category);
        });
      });
    });
  </script>
</section>
