---
const {
  image = "/assets/images/gift/SET-PISAU-CUCKOO.webp",
  title = "Free Gift Semasa Promo*",
  description = "Semasa promo berlangsung, pelanggan yang membuat pendaftaran berjaya berpeluang menerima free gift daripada CUCKOO tertakluk kepada stok semasa.",
  whatsappLink = "https://api.whatsapp.com/send?phone=60139916967&text=Salam%20Fadhil,%20saya%20nak%20semak%20free%20gift%20CUCKOO.",
  theme = "maroon"
} = Astro.props;

const isBlue = theme === 'blue';
const panelClass = isBlue
  ? 'overflow-hidden rounded-[2.5rem] bg-[radial-gradient(circle_at_85%_20%,rgba(14,165,233,.28),transparent_34%),linear-gradient(135deg,#061525_0%,#0F2A4A_50%,#0EA5E9_100%)] p-6 text-white shadow-premium ring-1 ring-sky-200/20 sm:p-8 lg:p-10'
  : 'overflow-hidden rounded-[2.5rem] bg-[radial-gradient(circle_at_85%_20%,rgba(216,166,74,.18),transparent_34%),linear-gradient(135deg,#1f1412_0%,#560819_45%,#850f26_100%)] p-6 text-white shadow-premium ring-1 ring-white/10 sm:p-8 lg:p-10';
const eyebrowClass = isBlue
  ? 'text-sm font-black uppercase tracking-[0.24em] text-sky-200'
  : 'text-sm font-black uppercase tracking-[0.24em] text-brand-gold';
---

<section id="free-gift" class="px-4 py-16 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">

    <div class={panelClass}>

      <div class="grid gap-8 lg:grid-cols-[1fr_1fr] lg:items-center">

        <!-- IMAGE -->
        <div class="overflow-hidden rounded-[2rem] bg-white/10 ring-1 ring-white/10">
          <img
            src={image}
            alt="Free Gift CUCKOO"
            loading="lazy"
            class="aspect-[4/3] w-full object-cover"
          />
        </div>

        <!-- CONTENT -->
        <div>

          <p class={eyebrowClass}>
            Bonus Tempahan Semasa Promo*
          </p>

          <h2 class="mt-3 text-4xl font-black leading-tight text-white sm:text-5xl">
            {title}
          </h2>

          <p class="mt-5 text-lg leading-8 text-white/80">
            {description}
          </p>

          <div class="mt-7 grid gap-3 sm:grid-cols-2">

            <div class="rounded-2xl bg-white/10 p-5 ring-1 ring-white/10">
              🎁 Free Gift CUCKOO*
            </div>

            <div class="rounded-2xl bg-white/10 p-5 ring-1 ring-white/10">
              🔥 Tertakluk stok semasa
            </div>

            <div class="rounded-2xl bg-white/10 p-5 ring-1 ring-white/10">
              ✅ Untuk pendaftaran berjaya
            </div>

            <div class="rounded-2xl bg-white/10 p-5 ring-1 ring-white/10">
              📲 Semak dahulu sebelum apply
            </div>

          </div>

          <a
            href={whatsappLink}
            class="mt-8 inline-flex items-center justify-center rounded-full bg-[#25D366] px-8 py-4 text-base font-black text-white shadow-xl transition-all duration-300 hover:-translate-y-1"
          >
            📲 Semak Free Gift
          </a>

        </div>

      </div>

    </div>

  </div>
</section>
