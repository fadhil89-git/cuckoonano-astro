---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  "title": "Produk CUCKOO | Penapis Air, Aircond, Washer Dryer & Kerusi Urut",
  "description": "Senarai produk CUCKOO seperti penapis air, penapis udara, aircond, washer dryer, kerusi urut, tilam dan produk Samsung.",
  "canonical": "https://www.cuckoonano.com/products/",
  "ogImage": "https://www.cuckoonano.com/assets/images/brand/cuckoo-ebrandstore3.png",
  "ogType": "website"
};
---
<BaseLayout {...meta}>
  <section class="hero-pattern px-4 py-16 sm:px-6 lg:px-8"><div class="mx-auto max-w-7xl"><p class="font-bold text-brand">Produk CUCKOO</p><h1 class="mt-3 max-w-3xl text-4xl font-black tracking-tight sm:text-5xl">Senarai Produk CUCKOO</h1><p class="mt-5 max-w-2xl text-lg leading-8 text-muted">Pilih kategori produk CUCKOO seperti penapis air, penapis udara, aircond, washer dryer, kerusi urut dan produk Samsung.</p></div></section><div data-product-selector data-initial="water-purifier"></div><div data-promo></div><div data-agent-block></div>
</BaseLayout>
