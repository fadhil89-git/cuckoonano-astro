---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const base = '/assets/images/products/air-purifier/r-model';
const site = 'https://www.cuckoonano.com';
const pageUrl = `${site}/products/air-purifier/r-model/`;
const priceValidUntil = '2026-12-31';
const dateModified = '2026-06-24';

// ---- Single source of truth: fakta R Model ----
const r = {
  name: 'CUCKOO R Model',
  type: 'Air Purifier / Penapis Udara',
  coverage: '570 sq ft (53m²)',
  weight: '6.7kg',
  cadr: '414 m³/h (243 cfm)',
  power: 'AC 220–240V / 50W',
  noise: '56 dB',
  size: '384(W) × 208(D) × 576(H) mm',
  stages: '3 Filtration Stages',
  filters: 'Pre-Filter · Deodorisation Filter · True HEPA H13',
  priceOutright: 2550,
  rentalY1to3: 77,
  rentalY4to5: 72,
  rentalMonths: 60,
  carePackage: 440, // setahun
  serviceInterval: '4 bulan',
  promoFirst6: 12
};

const heroImg = `${base}/cuckoo-r-model-penapis-udara-air-purifier-malaysia.webp`;
const ogImg = `${site}${heroImg}`;

// Slider gambar produk di hero — sisi 1, 2, 3
const heroSlides = [
  { src: `${base}/cuckoo-r-model-air-purifier-product-angle-left.webp`, alt: 'Penapis Udara CUCKOO R Model — sisi kiri' },
  { src: heroImg, alt: 'Penapis Udara CUCKOO R Model — pandangan hadapan' },
  { src: `${base}/cuckoo-r-model-air-purifier-product-angle-right.webp`, alt: 'Penapis Udara CUCKOO R Model — sisi kanan' }
];
const heroFirst = heroSlides[0].src;

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'CUCKOO R Model Air Purifier',
  alternateName: ['Penapis Udara CUCKOO R Model', 'CUCKOO R Model Air Purifier Malaysia'],
  category: 'Air Purifier',
  brand: { '@type': 'Brand', name: 'CUCKOO' },
  manufacturer: { '@type': 'Organization', name: 'CUCKOO' },
  model: 'R Model',
  award: 'Red Dot Design Award',
  description:
    'Penapis udara CUCKOO R Model yang stylish dan kompak — liputan 570 sq ft, sistem penapisan 3 peringkat True HEPA H13, 7 operating modes dan 8-colour LED air quality indicator. Sewa dari RM77/bulan atau beli terus RM2,550 di Malaysia.',
  url: pageUrl,
  image: [
    ogImg,
    `${site}${base}/cuckoo-r-model-air-purifier-product-angle-right.webp`,
    `${site}${base}/cuckoo-r-model-air-purifier-minimal-room.webp`
  ],
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Coverage', value: r.coverage },
    { '@type': 'PropertyValue', name: 'CADR', value: r.cadr },
    { '@type': 'PropertyValue', name: 'Filtration', value: r.filters },
    { '@type': 'PropertyValue', name: 'Power Consumption', value: r.power },
    { '@type': 'PropertyValue', name: 'Noise Level', value: r.noise },
    { '@type': 'PropertyValue', name: 'Dimensi (W×D×H)', value: r.size },
    { '@type': 'PropertyValue', name: 'Berat', value: r.weight }
  ],
  offers: [
    {
      '@type': 'Offer',
      name: 'Pelan rental CUCKOO (60 bulan)',
      priceCurrency: 'MYR',
      price: String(r.rentalY4to5),
      url: pageUrl,
      availability: 'https://schema.org/InStock',
      itemCondition: 'https://schema.org/NewCondition',
      priceValidUntil,
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: String(r.rentalY4to5),
        priceCurrency: 'MYR',
        unitText: 'MONTH',
        referenceQuantity: { '@type': 'QuantitativeValue', value: String(r.rentalMonths), unitText: 'MONTH' }
      },
      seller: { '@type': 'Organization', name: 'CUCKOO', url: site }
    },
    {
      '@type': 'Offer',
      name: 'Beli terus (outright)',
      priceCurrency: 'MYR',
      price: String(r.priceOutright),
      url: pageUrl,
      availability: 'https://schema.org/InStock',
      itemCondition: 'https://schema.org/NewCondition',
      priceValidUntil,
      seller: { '@type': 'Organization', name: 'CUCKOO', url: site }
    }
  ]
};

const faqs = [
  { q: 'Apa fungsi CUCKOO R Model Air Purifier?', a: 'CUCKOO R Model membantu membersihkan udara dalam rumah dengan menapis habuk, bau, bulu haiwan, alergen, debunga, hama, habuk halus dan asap rokok melalui sistem penapisan 3 peringkat.' },
  { q: 'Adakah CUCKOO R Model sesuai untuk bilik tidur?', a: 'Ya. CUCKOO R Model sesuai digunakan di bilik tidur kerana reka bentuknya kompak dan mempunyai Sleep Mode yang membantu mengurangkan bunyi serta kecerahan lampu ketika waktu tidur.' },
  { q: 'Berapa luas coverage CUCKOO R Model?', a: 'CUCKOO R Model mempunyai coverage sehingga 570 sq ft, sesuai untuk bilik tidur utama, ruang tamu kecil hingga sederhana, apartment atau ruang kerja di rumah.' },
  { q: 'Apakah jenis filter yang digunakan?', a: 'CUCKOO R Model menggunakan Pre-Filter, Deodorisation Filter dan True HEPA H13 Filter.' },
  { q: 'Adakah CUCKOO R Model boleh mengurangkan bau?', a: 'Ya. Deodorisation Filter membantu mengurangkan bau kurang menyenangkan dan gas berbahaya, termasuk bau dari masakan, asap atau haiwan peliharaan.' },
  { q: 'Adakah CUCKOO R Model sesuai untuk rumah yang ada haiwan peliharaan?', a: 'Ya. Pre-Filter membantu menapis bulu haiwan dan partikel besar, manakala Deodorisation Filter membantu mengurangkan bau. Ia sesuai untuk rumah yang mempunyai kucing, anjing atau haiwan peliharaan lain.' },
  { q: 'Apa kelebihan True HEPA H13 Filter?', a: 'True HEPA H13 Filter membantu menapis partikel halus seperti debunga, hama, fine dust dan asap rokok. Ini membantu menjadikan udara dalam rumah lebih bersih dan selesa.' },
  { q: 'Apa fungsi LED Air Quality Indicator?', a: '8-colour LED Air Quality Indicator membantu menunjukkan tahap kualiti udara semasa melalui perubahan warna. Ini memudahkan pengguna melihat keadaan udara dalam bilik.' },
  { q: 'Adakah CUCKOO R Model jimat elektrik?', a: 'CUCKOO R Model menggunakan kuasa 50W dan mempunyai Energy Eye Mode yang membantu menjimatkan tenaga berdasarkan kualiti udara serta kecerahan bilik.' },
  { q: 'Apa beza CUCKOO R Model dengan model yang lebih besar?', a: 'CUCKOO R Model lebih fokus kepada reka bentuk stylish, saiz kompak dan penggunaan ruang kecil hingga sederhana. Model yang lebih besar biasanya menawarkan coverage lebih luas dan CADR lebih tinggi.' }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } }))
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site}/` },
    { '@type': 'ListItem', position: 2, name: 'Produk', item: `${site}/products/` },
    { '@type': 'ListItem', position: 3, name: 'Air Purifier', item: `${site}/products/air-purifier/` },
    { '@type': 'ListItem', position: 4, name: 'R Model', item: pageUrl }
  ]
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Penapis Udara CUCKOO R Model',
  description:
    'Maklumat lengkap CUCKOO R Model Air Purifier termasuk harga, promo, spesifikasi, sistem penapisan True HEPA H13, gambar produk dan FAQ.',
  url: pageUrl,
  inLanguage: 'ms-MY',
  dateModified,
  isPartOf: {
    '@type': 'WebSite',
    name: 'CUCKOONANO',
    url: site
  },
  primaryImageOfPage: {
    '@type': 'ImageObject',
    url: ogImg
  },
  breadcrumb: breadcrumbSchema
};

const modes = [
  { icon: `${base}/cuckoo-r-model-auto-mode-icon.png`, title: 'Auto Mode', desc: 'Laras kelajuan kipas secara automatik ikut keadaan udara sekeliling.' },
  { icon: `${base}/cuckoo-r-model-manual-mode-icon.png`, title: 'Manual Mode', desc: 'Pilih sendiri kelajuan kipas mengikut keselesaan anda.' },
  { icon: `${base}/cuckoo-r-model-turbo-mode-icon.png`, title: 'Turbo Mode', desc: 'Prestasi maksimum untuk bersihkan udara dengan lebih cepat.' },
  { icon: `${base}/cuckoo-r-model-sleep-mode-icon.png`, title: 'Sleep Mode', desc: 'Bunyi dan kecerahan lampu diperlahankan — selesa ketika tidur.' },
  { icon: `${base}/cuckoo-r-model-timer-mode-icon.png`, title: 'Timer Mode', desc: 'Set air purifier tutup sendiri selepas tempoh masa tertentu.' },
  { icon: `${base}/cuckoo-r-model-energy-saving-mode-icon.png`, title: 'Energy Eye Mode', desc: 'Jimat tenaga ikut kualiti udara dan kecerahan bilik.' },
  { icon: `${base}/cuckoo-r-model-sound-mode-icon.png`, title: 'Button Sound Mode', desc: 'Hidup atau matikan bunyi butang ikut keselesaan anda.' }
];

const filtration = [
  { n: '1', title: 'Pre-Filter', desc: 'Menapis habuk, bulu haiwan dan partikel besar daripada udara.' },
  { n: '2', title: 'Deodorisation Filter', desc: 'Membantu mengurangkan bau kurang menyenangkan dan gas berbahaya.' },
  { n: '3', title: 'True HEPA H13 Filter', desc: 'Menapis hama, debunga, habuk halus dan asap rokok.' }
];

const ledLevels = [
  { label: 'Sangat Bersih', dot: '#2f6fed', light: '#74b3ff' },
  { label: 'Bersih', dot: '#19a463', light: '#7fd6a0' },
  { label: 'Sederhana', dot: '#f1c21b', light: '#f59e0b' },
  { label: 'Kurang Baik', dot: '#7c3aed', light: '#e0322f' }
];

const productPhotos = [
  { file: 'cuckoo-r-model-air-purifier-product-angle-right', alt: 'Penapis udara CUCKOO R Model sudut kanan' },
  { file: 'cuckoo-r-model-air-purifier-product-angle-left', alt: 'Penapis udara CUCKOO R Model sudut kiri' },
  { file: 'cuckoo-r-model-air-purifier-minimal-room', alt: 'CUCKOO R Model dalam ruang minimalis moden' },
  { file: 'cuckoo-r-model-air-purifier-bedroom-corner', alt: 'CUCKOO R Model di sudut bilik tidur' },
  { file: 'cuckoo-r-model-air-purifier-ruang-tamu-living-room', alt: 'CUCKOO R Model di ruang tamu' },
  { file: 'cuckoo-r-model-air-purifier-dining-room', alt: 'CUCKOO R Model di ruang makan' },
  { file: 'cuckoo-r-model-air-purifier-rumah-malaysia', alt: 'CUCKOO R Model di rumah moden Malaysia' },
  { file: 'cuckoo-r-model-air-purifier-ruang-tamu-real-home', alt: 'CUCKOO R Model di ruang tamu rumah sebenar' },
  { file: 'cuckoo-r-model-air-purifier-bilik-tidur-bedroom', alt: 'CUCKOO R Model di bilik tidur rumah moden' },
  { file: 'cuckoo-r-model-air-purifier-charming-protection', alt: 'CUCKOO R Model — perlindungan udara bersih yang stylish' },
  { file: 'cuckoo-r-model-air-purifier-pet-fur-home', alt: 'CUCKOO R Model untuk rumah yang ada haiwan peliharaan' },
  { file: 'cuckoo-r-model-air-purifier-kotak-produk', alt: 'Kotak produk CUCKOO R Model air purifier' }
].map((p, index) => ({
  image: `${base}/${p.file}.webp`,
  title: `Gambar Produk #${index + 1}`,
  alt: p.alt
}));

const meta = {
  title: 'Penapis Udara CUCKOO R Model | Harga, Promo & Spesifikasi',
  description:
    'CUCKOO R Model: penapis udara stylish & kompak, 3-stage True HEPA H13, 7 operating modes & 8-colour LED. Liputan 570 sq ft. Sewa dari RM77/bulan atau beli RM2,550.',
  canonical: pageUrl,
  ogImage: ogImg,
  ogType: 'website'
};
---

<BaseLayout {...meta} preloadImages={[heroFirst]}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(webPageSchema)} />

  <!-- HERO -->
  <section id="hero" class="relative overflow-hidden bg-brand-cream px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="absolute left-1/2 top-0 -z-10 h-[620px] w-[620px] -translate-x-1/2 rounded-full bg-brand-soft blur-3xl"></div>

    <div class="mx-auto grid max-w-7xl items-center gap-10 lg:grid-cols-[1.02fr_.98fr]">
      <!-- KIRI: kandungan -->
      <div>
        <div class="mb-5 flex gap-2 overflow-x-auto pb-1 [-ms-overflow-style:none] [scrollbar-width:none] lg:flex-wrap lg:overflow-visible lg:pb-0 [&::-webkit-scrollbar]:hidden">
          <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Red Dot Design Award</span>
          <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Free Installation</span>
          <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Free Servis</span>
        </div>

        <div class="mb-5 inline-flex max-w-full flex-wrap items-center gap-2 rounded-full bg-[linear-gradient(135deg,#4B0715_0%,#7A0E23_58%,#8E1830_100%)] px-4 py-3 text-white shadow-glow ring-1 ring-brand-gold/30 sm:gap-3 sm:px-5">
          <span class="rounded-full bg-white/15 px-3 py-1 text-[11px] font-black uppercase tracking-[.14em] text-brand-gold">Promo Terkini</span>
          <span class="text-sm font-black sm:text-base">RM{r.promoFirst6} x 6 bulan pertama</span>
        </div>

        <h1 class="text-[2.3rem] font-black leading-[1.08] tracking-tight text-brand-ink sm:text-5xl lg:text-[3.4rem]">
          CUCKOO R Model — Penapis Udara Stylish Untuk Rumah Moden
        </h1>

        <!-- Gambar produk (mobile sahaja) — slider 3 sisi -->
        <div class="mt-6 lg:hidden">
          <div id="heroStageM" class="product-blob accent-ring relative mx-auto max-w-sm overflow-hidden rounded-[1.7rem] p-6">
            <div class="absolute bottom-10 left-1/2 h-14 w-[70%] -translate-x-1/2 rounded-full bg-brand-gold/20 blur-2xl"></div>
            <img id="heroImgM" src={heroSlides[0].src} alt={heroSlides[0].alt} width="800" height="1000" loading="eager" fetchpriority="high" class="relative z-10 mx-auto h-[260px] w-auto object-contain drop-shadow-2xl" />
            <button type="button" id="heroPrevM" aria-label="Gambar sebelumnya" class="absolute left-3 top-1/2 z-20 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-xl font-black text-brand-maroon shadow-lg transition hover:bg-white">‹</button>
            <button type="button" id="heroNextM" aria-label="Gambar seterusnya" class="absolute right-3 top-1/2 z-20 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-xl font-black text-brand-maroon shadow-lg transition hover:bg-white">›</button>
          </div>
          <div id="heroDotsM" class="mt-4 flex justify-center gap-2"></div>
        </div>

        <p class="mt-5 max-w-xl text-base leading-8 text-brand-muted sm:text-lg">
          Reka bentuk minimalis dan kompak dengan True HEPA H13, 7 operating modes dan 8-colour LED air quality indicator — udara lebih bersih tanpa mengganggu dekorasi rumah anda.
        </p>

        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <a href="#" onclick="this.href=rotatingWhatsapp()" class="inline-flex items-center justify-center gap-2 rounded-full bg-cta-green px-7 py-4 text-sm font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark">📲 WhatsApp Promo R Model</a>
          <a href="#harga" class="inline-flex items-center justify-center rounded-full border border-brand/15 bg-white px-7 py-4 text-sm font-black text-brand shadow-soft hover:border-brand/30">Lihat Pelan Harga</a>
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <div class="rounded-[1.35rem] bg-brand px-5 py-5 text-white shadow-glow">
            <p class="text-xs font-black uppercase tracking-[.16em] text-brand-gold">Promo Terkini</p>
            <p class="mt-2 text-4xl font-black leading-none">RM{r.promoFirst6}<span class="text-sm font-black">/bulan</span></p>
            <p class="mt-1 text-xs font-bold text-white/75">6 bulan pertama</p>
          </div>
          <a href="#harga" class="rounded-[1.35rem] border border-brand/10 bg-white px-5 py-5 shadow-soft transition hover:-translate-y-1 hover:border-brand/25">
            <p class="text-xs font-black uppercase tracking-[.14em] text-brand-gold">Pelan Rental</p>
            <p class="mt-2 text-xl font-black text-brand">RM{r.rentalY4to5}/bulan · 5 tahun</p>
            <p class="mt-2 text-sm font-bold text-brand-muted">Lihat detail harga →</p>
          </a>
        </div>
      </div>

      <!-- KANAN: kad produk (desktop sahaja) -->
      <div class="hidden rounded-[2rem] border border-white/80 bg-white/70 p-4 shadow-premium backdrop-blur-xl sm:p-6 lg:block">
        <div class="product-blob accent-ring relative overflow-hidden rounded-[1.7rem] p-4 sm:p-6 lg:p-8">
          <div class="flex flex-wrap gap-2">
            <span class="rounded-full bg-white/85 px-4 py-2 text-xs font-black text-brand shadow-soft">Stylish & Kompak</span>
            <span class="rounded-full bg-white/85 px-4 py-2 text-xs font-black text-brand shadow-soft">True HEPA H13</span>
          </div>

          <div id="heroStageD" class="relative mt-5 flex min-h-[300px] items-center justify-center overflow-hidden rounded-[1.5rem] bg-gradient-to-br from-white/80 to-white/35 p-5 sm:min-h-[390px] lg:min-h-[440px]">
            <div class="absolute bottom-12 h-16 w-[72%] rounded-full bg-brand-gold/20 blur-2xl"></div>
            <img id="heroImgD" src={heroSlides[0].src} alt={heroSlides[0].alt} width="800" height="1000" loading="eager" fetchpriority="high" class="relative z-10 h-[290px] w-auto object-contain drop-shadow-2xl sm:h-[380px] lg:h-[425px]" />
            <button type="button" id="heroPrevD" aria-label="Gambar sebelumnya" class="absolute left-4 top-1/2 z-20 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-2xl font-black text-brand-maroon shadow-lg transition hover:bg-white">‹</button>
            <button type="button" id="heroNextD" aria-label="Gambar seterusnya" class="absolute right-4 top-1/2 z-20 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-2xl font-black text-brand-maroon shadow-lg transition hover:bg-white">›</button>
            <div id="heroDotsD" class="absolute bottom-4 left-1/2 flex -translate-x-1/2 gap-2"></div>
          </div>

          <div class="mt-5 flex flex-wrap justify-center gap-2">
            <span class="rounded-full border border-brand/15 bg-brand-soft px-4 py-2 text-xs font-black text-brand">Coverage 570 sq ft</span>
            <span class="rounded-full border border-stone-200 bg-white px-4 py-2 text-xs font-black text-stone-700">8-Colour LED</span>
            <span class="rounded-full border border-brand-gold/30 bg-amber-50 px-4 py-2 text-xs font-black text-brand-gold">3-Stage HEPA H13</span>
          </div>
        </div>

        <div class="mt-4 grid grid-cols-2 gap-2 sm:grid-cols-4">
          <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10"><p class="text-xs font-black text-brand">True HEPA H13</p></div>
          <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10"><p class="text-xs font-black text-brand">7 Modes</p></div>
          <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10"><p class="text-xs font-black text-brand">8-Colour LED</p></div>
          <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10"><p class="text-xs font-black text-brand">Servis Berkala</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- STAT STRIP -->
  <section class="bg-gradient-to-br from-[#4B0715] via-brand-maroon to-[#2f0b10] px-4 py-14 text-white sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl items-center gap-8 sm:grid-cols-3">
      <div class="text-center">
        <p class="text-5xl font-black tracking-tight text-promo-gold sm:text-6xl">570<span class="ml-1 text-2xl font-bold text-white/70">sq ft</span></p>
        <p class="mt-2 text-sm font-bold text-white/70">Liputan sesuai bilik & apartment</p>
      </div>
      <div class="text-center">
        <p class="text-5xl font-black tracking-tight text-promo-gold sm:text-6xl">6.7<span class="ml-1 text-2xl font-bold text-white/70">kg</span></p>
        <p class="mt-2 text-sm font-bold text-white/70">Kompak & mudah dipindahkan</p>
      </div>
      <div class="text-center">
        <p class="text-5xl font-black tracking-tight text-promo-gold sm:text-6xl">3<span class="ml-1 text-2xl font-bold text-white/70">stage</span></p>
        <p class="mt-2 text-sm font-bold text-white/70">Penapisan True HEPA H13</p>
      </div>
    </div>
  </section>

  <!-- RED DOT DESIGN AWARD -->
  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="mx-auto grid max-w-6xl items-center gap-10 lg:grid-cols-2">
      <div>
        <img src={`${base}/cuckoo-r-model-red-dot-award-logo.webp`} alt="Logo Red Dot Design Award" width="120" height="120" loading="lazy" class="h-20 w-auto object-contain" />
        <p class="mt-6 text-sm font-black uppercase tracking-[0.24em] text-brand-maroon">Red Dot Design Award</p>
        <h2 class="mt-4 text-balance text-3xl font-black tracking-tight text-brand-ink sm:text-4xl">Cantik bukan kebetulan — ia direka begitu</h2>
        <p class="mt-5 text-lg leading-8 text-stone-600">CUCKOO R Model direka dan dihasilkan di Korea Selatan serta dipilih untuk <strong class="text-brand-maroon">Red Dot Design Award</strong>. Reka bentuk minimalis dan elegannya mudah dipadankan dengan mana-mana gaya dekorasi rumah — efisien tanpa mengambil ruang, dan kompak supaya boleh diletakkan dengan mudah.</p>
      </div>
      <div class="overflow-hidden rounded-[2rem] bg-brand-soft p-4 shadow-soft ring-1 ring-brand-maroon/10">
        <img src={`${base}/penapis-udara-cuckoo-r-model-red-dot-award.webp`} alt="CUCKOO R Model pemenang Red Dot Design Award" loading="lazy" class="h-full w-full rounded-[1.5rem] object-contain" />
