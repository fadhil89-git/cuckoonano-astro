      </div>

      <div class="mt-10 grid items-start gap-8 lg:grid-cols-[1fr_1.2fr]">
        <div class="overflow-hidden rounded-[2rem] bg-white p-6 shadow-soft ring-1 ring-stone-200">
          <img src={`${base}/cuckoo-r-model-air-purifier-specification-size-weight-black-and-white.png`} alt="Spesifikasi dan dimensi CUCKOO R Model" loading="lazy" class="h-full w-full object-contain" />
        </div>
        <div class="overflow-hidden rounded-[2rem] border border-stone-200 bg-white shadow-soft">
          <table class="w-full text-left text-sm sm:text-base">
            <tbody class="divide-y divide-stone-200">
              <tr><th class="w-2/5 bg-stone-50 p-4 font-black">Model</th><td class="p-4 font-semibold">{r.name}</td></tr>
              <tr><th class="bg-stone-50 p-4 font-black">Jenis Produk</th><td class="p-4 font-semibold">{r.type}</td></tr>
              <tr><th class="bg-stone-50 p-4 font-black">Coverage</th><td class="p-4 font-semibold">{r.coverage}</td></tr>
              <tr><th class="bg-stone-50 p-4 font-black">CADR</th><td class="p-4 font-semibold">{r.cadr}</td></tr>
              <tr><th class="bg-stone-50 p-4 font-black">Filtration</th><td class="p-4 font-semibold">{r.stages} — {r.filters}</td></tr>
              <tr><th class="bg-stone-50 p-4 font-black">Power Consumption</th><td class="p-4 font-semibold">{r.power}</td></tr>
              <tr><th class="bg-stone-50 p-4 font-black">Noise Level</th><td class="p-4 font-semibold">{r.noise}</td></tr>
              <tr><th class="bg-stone-50 p-4 font-black">Saiz Produk</th><td class="p-4 font-semibold">{r.size}</td></tr>
              <tr><th class="bg-stone-50 p-4 font-black">Berat Produk</th><td class="p-4 font-semibold">{r.weight}</td></tr>
            </tbody>
          </table>
        </div>
      </div>
      <p class="mx-auto mt-6 max-w-3xl text-center text-sm font-semibold leading-7 text-stone-500">*Spesifikasi & harga tertakluk kepada maklumat rasmi dan kempen semasa. WhatsApp untuk semak promo dan kesesuaian ruang anda.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="bg-white px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-4xl">
      <div class="text-center">
        <p class="text-sm font-black uppercase tracking-[0.24em] text-brand-maroon">FAQ</p>
        <h2 class="mt-4 text-3xl font-black tracking-tight sm:text-4xl">Soalan lazim tentang CUCKOO R Model</h2>
      </div>
      <div class="mt-10 space-y-4">
        {faqs.map((f, i) => (
          <details class="group rounded-2xl bg-stone-50 p-6 shadow-sm ring-1 ring-stone-100" open={i === 0}>
            <summary class="cursor-pointer list-none text-lg font-black text-brand-dark">{f.q}</summary>
            <p class="mt-4 leading-7 text-stone-600">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-brand-soft px-4 py-16 text-center sm:px-6 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-5xl overflow-hidden rounded-[2.5rem] bg-gradient-to-br from-[#4B0715] via-brand-maroon to-[#2f0b10] p-8 text-white shadow-premium sm:p-12 lg:p-16">
      <div class="mx-auto max-w-3xl">
        <p class="inline-flex rounded-full bg-white/12 px-5 py-2 text-xs font-black uppercase tracking-[0.24em] text-rose-100 ring-1 ring-white/15">Ready Untuk Udara Lebih Bersih?</p>
        <h2 class="mt-6 text-balance text-3xl font-black leading-tight tracking-tight sm:text-5xl">Bawa pulang CUCKOO R Model hari ini</h2>
        <p class="mx-auto mt-6 max-w-2xl text-base leading-8 text-rose-100 sm:text-lg">Stylish. True HEPA H13. Servis berkala diuruskan. Klik WhatsApp untuk semak promo dan dapatkan consultation percuma.</p>
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href="#" onclick="this.href=rotatingWhatsapp()" class="inline-flex items-center justify-center rounded-2xl bg-cta-green px-9 py-5 text-lg font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark">📲 WhatsApp Sekarang</a>
          <a href="#harga" class="inline-flex items-center justify-center rounded-2xl border border-white/20 bg-white/10 px-9 py-5 text-lg font-black text-white backdrop-blur transition hover:bg-white/20">Tengok Harga</a>
        </div>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3 text-sm font-bold text-rose-100">
          <span>✓ Consultation Percuma</span>
          <span class="hidden h-1 w-1 rounded-full bg-white/40 sm:inline-block"></span>
          <span>✓ Servis Setiap {r.serviceInterval}</span>
          <span class="hidden h-1 w-1 rounded-full bg-white/40 sm:inline-block"></span>
          <span>✓ Pemasangan Diuruskan</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Zoom lightbox (galeri gambar produk) -->
  <div id="zoomLightbox" class="fixed inset-0 z-[90] hidden items-center justify-center bg-black/80 p-4 backdrop-blur-sm">
    <button type="button" id="zoomClose" aria-label="Tutup gambar" class="absolute right-4 top-4 z-10 flex h-11 w-11 items-center justify-center rounded-full bg-white/95 text-2xl font-black text-brand-maroon shadow-lg">×</button>
    <img id="zoomImage" src="" alt="" class="max-h-[90vh] w-auto max-w-[94vw] rounded-2xl object-contain shadow-premium" />
  </div>

  <!-- DYNAMIC COMPONENTS -->
  <div data-product-selector data-initial="air-purifier"></div>
  <div data-agent-block></div>
</BaseLayout>

<style is:global>
  html { scroll-behavior: smooth; }
  .text-balance { text-wrap: balance; }
  .product-blob { background: radial-gradient(circle at 40% 35%, rgba(216,166,74,.28), transparent 38%), radial-gradient(circle at 65% 58%, rgba(122,14,35,.18), transparent 42%), linear-gradient(145deg, #fff8f2, #ffffff); }
  .accent-ring { box-shadow: 0 30px 80px rgba(20,20,20,.16); }
</style>

<script is:inline define:vars={{ gSlides: productPhotos.map((p) => ({ src: p.image, alt: p.alt })), heroSlides }}>
  // Hero — slider gambar produk 3 sisi (mobile + desktop selari)
  let hi = 0;
  const heroImgM = document.getElementById('heroImgM');
  const heroImgD = document.getElementById('heroImgD');
  const heroDotsM = document.getElementById('heroDotsM');
  const heroDotsD = document.getElementById('heroDotsD');

  function buildHeroDots(container) {
    if (!container) return;
    container.innerHTML = '';
    heroSlides.forEach((_, di) => {
      const dot = document.createElement('button');
      dot.type = 'button';
      dot.setAttribute('aria-label', 'Lihat sisi ' + (di + 1));
      dot.dataset.i = String(di);
      dot.className = di === hi ? 'h-2.5 w-6 rounded-full bg-brand-maroon transition' : 'h-2.5 w-2.5 rounded-full bg-stone-300 transition hover:bg-brand-maroon';
      dot.addEventListener('click', () => renderHero(di));
      container.appendChild(dot);
    });
  }

  function renderHero(index) {
    hi = (index + heroSlides.length) % heroSlides.length;
    const s = heroSlides[hi];
    if (heroImgM) { heroImgM.src = s.src; heroImgM.alt = s.alt; }
    if (heroImgD) { heroImgD.src = s.src; heroImgD.alt = s.alt; }
    buildHeroDots(heroDotsM);
    buildHeroDots(heroDotsD);
  }

  ['heroPrevM', 'heroPrevD'].forEach((id) => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('click', () => renderHero(hi - 1));
  });
  ['heroNextM', 'heroNextD'].forEach((id) => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('click', () => renderHero(hi + 1));
  });

  // Swipe untuk kedua-dua stage
  ['heroStageM', 'heroStageD'].forEach((id) => {
    const stage = document.getElementById(id);
    if (!stage) return;
    let sx = 0;
    stage.addEventListener('touchstart', (e) => { sx = e.touches[0] ? e.touches[0].clientX : 0; }, { passive: true });
    stage.addEventListener('touchend', (e) => {
      const t = e.changedTouches[0]; if (!t) return;
      const dx = t.clientX - sx;
      if (Math.abs(dx) > 40) renderHero(hi + (dx < 0 ? 1 : -1));
    }, { passive: true });
  });

  if (heroImgM || heroImgD) renderHero(0);

  // Galeri gambar produk — slider gambar besar + zoom
  let gi = 0;
  const gImg = document.getElementById('gImg');
  const gDots = document.getElementById('gDots');
  const gPrev = document.getElementById('gPrev');
  const gNext = document.getElementById('gNext');

  function renderG(index) {
    gi = (index + gSlides.length) % gSlides.length;
    if (gImg) { gImg.src = gSlides[gi].src; gImg.alt = gSlides[gi].alt; }
    if (gDots) {
      gDots.innerHTML = '';
      gSlides.forEach((_, di) => {
        const dot = document.createElement('button');
        dot.type = 'button';
        dot.setAttribute('aria-label', 'Lihat gambar ' + (di + 1));
        dot.className = di === gi ? 'h-3 w-8 rounded-full bg-brand-maroon transition' : 'h-3 w-3 rounded-full bg-stone-300 transition hover:bg-brand-maroon';
        dot.addEventListener('click', () => renderG(di));
        gDots.appendChild(dot);
      });
    }
  }
  if (gPrev) gPrev.addEventListener('click', () => renderG(gi - 1));
  if (gNext) gNext.addEventListener('click', () => renderG(gi + 1));
  if (gImg) {
    renderG(0);
    let sx = 0, swiped = false;
    const stage = gImg.parentElement;
    stage.addEventListener('touchstart', (e) => { sx = e.touches[0] ? e.touches[0].clientX : 0; swiped = false; }, { passive: true });
    stage.addEventListener('touchend', (e) => {
      const t = e.changedTouches[0]; if (!t) return;
      const dx = t.clientX - sx;
      if (Math.abs(dx) > 40) { swiped = true; renderG(gi + (dx < 0 ? 1 : -1)); }
    }, { passive: true });
    gImg.addEventListener('click', () => { if (swiped) { swiped = false; return; } openZoom(gImg.currentSrc || gImg.src, gImg.alt); });
  }

  // Zoom lightbox
  const zoomLightbox = document.getElementById('zoomLightbox');
  const zoomImage = document.getElementById('zoomImage');
  function openZoom(src, alt) {
    if (!zoomLightbox || !zoomImage || !src) return;
    zoomImage.src = src; zoomImage.alt = alt || '';
    zoomLightbox.classList.remove('hidden'); zoomLightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }
  function closeZoom() {
    if (!zoomLightbox) return;
    zoomLightbox.classList.add('hidden'); zoomLightbox.classList.remove('flex');
    document.body.style.overflow = '';
  }
  if (zoomLightbox) {
    zoomLightbox.addEventListener('click', (e) => { if (e.target === zoomLightbox || e.target.id === 'zoomClose') closeZoom(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeZoom(); });
  }

  // Testimoni slider — butang + drag
  const testiTrack = document.getElementById('testiTrack');
  const testiPrev = document.getElementById('testiPrev');
  const testiNext = document.getElementById('testiNext');
  if (testiTrack) {
    const stepWidth = () => {
      const slide = testiTrack.querySelector('.testi-slide');
      const gap = parseFloat(getComputedStyle(testiTrack).columnGap || '20') || 20;
      return slide ? slide.getBoundingClientRect().width + gap : testiTrack.clientWidth * 0.8;
    };
    if (testiPrev) testiPrev.addEventListener('click', () => testiTrack.scrollBy({ left: -stepWidth(), behavior: 'smooth' }));
    if (testiNext) testiNext.addEventListener('click', () => testiTrack.scrollBy({ left: stepWidth(), behavior: 'smooth' }));
    let isDown = false, startX = 0, startScroll = 0, moved = false;
    testiTrack.addEventListener('pointerdown', (e) => { isDown = true; moved = false; startX = e.clientX; startScroll = testiTrack.scrollLeft; testiTrack.classList.add('cursor-grabbing'); });
    testiTrack.addEventListener('pointermove', (e) => { if (!isDown) return; const delta = e.clientX - startX; if (Math.abs(delta) > 4) moved = true; testiTrack.scrollLeft = startScroll - delta; });
    const endDrag = () => { isDown = false; testiTrack.classList.remove('cursor-grabbing'); };
    testiTrack.addEventListener('pointerup', endDrag);
    testiTrack.addEventListener('pointerleave', endDrag);
    testiTrack.addEventListener('click', (e) => { if (moved) { e.preventDefault(); e.stopPropagation(); } }, true);
  }
</script>
