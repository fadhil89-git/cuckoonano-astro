---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const base = '/assets/images/products/air-purifier/u-model';
const site = 'https://www.cuckoonano.com';
const pageUrl = `${site}/products/air-purifier/u-model/`;
const priceValidUntil = '2026-12-31';
const dateModified = '2026-06-24';

// ---- Single source of truth: fakta U Model ----
const u = {
  name: 'CUCKOO U Model',
  type: 'Air Purifier / Penapis Udara',
  coverage: '1161 sq ft (107.9m²)',
  weight: '14kg',
  power: 'AC 220–240V / 50Hz',
  ratedPower: '80W / 1.5A',
  noise: '53.7 dBA',
  size: '410(W) × 410(D) × 895(H) mm',
  stages: '4-Stage Filtration System',
  filters: 'Pre-Filter · Allergen Filter · True HEPA+ H14 · Deodorisation Filter',
  priceOutright: 4400,
  rentalY1to3: 143,
  rentalY4to5: 143,
  rentalMonths: 60,
  carePackage: 770 // setahun
};

// Gambar produk studio (disahkan) untuk slider hero
const heroSlides = [
  { src: `${base}/cuckoo-u-model-front-led-on.webp`, alt: 'Penapis Udara CUCKOO U Model — paparan hadapan dengan LED biru menyala' },
  { src: `${base}/cuckoo-u-model-front-white.webp`, alt: 'Penapis Udara CUCKOO U Model — paparan hadapan' },
  { src: `${base}/cuckoo-u-model-studio-podium.webp`, alt: 'Penapis Udara CUCKOO U Model di atas podium studio premium' }
];
const heroFirst = heroSlides[0].src;
const ogImg = `${site}${base}/cuckoo-u-model-banner-1161-sqft-coverage.webp`;

const featureIcons = [
  { icon: `${base}/cuckoo-u-model-icon-coverage-1161.png`, label: 'Liputan 1161 sq ft' },
  { icon: `${base}/cuckoo-u-model-icon-360-absorption.png`, label: '360° Absorption' },
  { icon: `${base}/cuckoo-u-model-icon-air-quality.png`, label: '8-Colour Air Quality' },
  { icon: `${base}/cuckoo-u-model-icon-commercial.png`, label: 'Gred Komersial' },
  { icon: `${base}/cuckoo-u-model-icon-easy-control.png`, label: '10 Operating Modes' }
];

const filtration = [
  { n: '1', title: 'Pre-Filter', desc: 'Menangkap pencemar besar seperti habuk, rambut dan bulu haiwan.' },
  { n: '2', title: 'Allergen Filter', desc: 'Membantu menangkap bahan penyebab alahan yang terapung di udara.' },
  { n: '3', title: 'True HEPA+ H14 Filter', desc: 'Menapis partikel halus & diuji menyingkir 99.995% partikel udara. Dengan copper sulphide coating — antibakteria, antivirus & antikulat.' },
  { n: '4', title: 'Deodorisation Filter', desc: 'Mengurangkan bau kurang menyenangkan & gas berbahaya — masakan, asap, haiwan dan ruang tertutup.' }
];

const copperAdvantages = [
  { title: 'Antibakteria & antivirus', desc: 'Bantu kurangkan risiko pencemaran mikrob bawaan udara pada permukaan filter.' },
  { title: 'Kurangkan bau', desc: 'Bantu kurangkan bau daripada masakan, haiwan peliharaan atau asap rokok.' },
  { title: 'Kekalkan kecekapan filter', desc: 'Permukaan filter dilindungi daripada pertumbuhan kulat dan bakteria.' },
  { title: 'Penapisan tambahan', desc: 'Bantu memerangkap dan menyahaktif patogen bawaan udara dengan lebih berkesan.' },
  { title: 'Perlindungan tahan lama', desc: 'Memberi perlindungan lebih lama terhadap pencemaran mikrob di udara.' },
  { title: 'Permukaan mudah dibersih', desc: 'Permukaan self-cleaning memudahkan pembersihan komponen dalaman.' }
];

const ledLevels = [
  { c: '#2f6fed', label: 'Baik' },
  { c: '#38bdf8', label: 'Sederhana' },
  { c: '#22c55e', label: 'Sederhana' },
  { c: '#84cc16', label: 'Sederhana' },
  { c: '#eab308', label: 'Kurang Baik' },
  { c: '#f97316', label: 'Kurang Baik' },
  { c: '#a855f7', label: 'Kurang Baik' },
  { c: '#ef4444', label: 'Sangat Teruk' }
];

const modes = [
  { icon: `${base}/cuckoo-u-model-mode-smart.png`, title: 'Smart Mode', desc: 'Mengesan kualiti udara & melaras kelajuan kipas secara automatik.' },
  { icon: `${base}/cuckoo-u-model-mode-eco.png`, title: 'ECO Mode', desc: 'Apabila udara kekal bersih, penggunaan tenaga dikawal lebih cekap.' },
  { icon: `${base}/cuckoo-u-model-mode-repeat.png`, title: 'Repeat Mode', desc: 'Beroperasi & berhenti automatik ikut tempoh masa yang ditetapkan.' },
  { icon: `${base}/cuckoo-u-model-mode-fine-dust.png`, title: 'Fine Dust Mode', desc: 'Bertindak automatik mengurangkan habuk halus apabila dikesan.' },
  { icon: `${base}/cuckoo-u-model-mode-sleep.png`, title: 'Sleep Mode', desc: 'Mengurangkan isipadu udara & beroperasi lebih senyap untuk waktu tidur.' },
  { icon: `${base}/cuckoo-u-model-mode-baby.png`, title: 'Baby Mode', desc: 'Isipadu udara & bunyi minimum dengan mood lamp untuk tidur lebih selesa.' },
  { icon: `${base}/cuckoo-u-model-mode-energy-eye.png`, title: 'Energy Eye Mode', desc: 'Apabila bilik gelap, semua indikator dimatikan secara automatik.' },
  { icon: `${base}/cuckoo-u-model-mode-manual.png`, title: 'Manual Mode', desc: 'Pilih sendiri tahap kekuatan kipas mengikut keperluan anda.' },
  { icon: `${base}/cuckoo-u-model-mode-turbo-plus.png`, title: 'Turbo Plus Mode', desc: 'Membersihkan habuk dengan cepat pada kelajuan kipas maksimum.' },
  { icon: `${base}/cuckoo-u-model-mode-refresh.png`, title: 'Refresh Mode', desc: 'Beri amaran apabila udara dalaman tidak sihat & ruang perlu pengudaraan.' }
];

// Kesan habuk & pencemar dalaman (pill dalam kotak bukti filter)
const dustEffects = ['Cetus alahan & asma', 'Selsema & bersin', 'Mata & tekak gatal', 'Bau hapak terperangkap', 'Habuk pada perabot', 'Jangkitan bawaan udara'];

const places = [
  'Rumah besar / konsep open-plan',
  'Ruang tamu besar & ruang keluarga',
  'Bilik tidur utama',
  'Pejabat / ofis',
  'Bilik meeting / boardroom',
  'Masjid & surau',
  'Sekolah & kelas',
  'Tadika & taska',
  'Klinik & ruang menunggu',
  'Homestay & Airbnb',
  'Showroom & kedai',
  'Gym & studio senaman'
];

const productPhotos = [
  { file: 'cuckoo-u-model-front-led-on', alt: 'CUCKOO U Model — paparan hadapan dengan LED biru menyala' },
  { file: 'cuckoo-u-model-front-white', alt: 'CUCKOO U Model — paparan hadapan kemas' },
  { file: 'cuckoo-u-model-studio-podium', alt: 'CUCKOO U Model di atas podium studio premium' },
  { file: 'cuckoo-u-model-real-home-room', alt: 'CUCKOO U Model di ruang rumah sebenar dengan indikator hijau' },
  { file: 'cuckoo-u-model-real-living-room', alt: 'CUCKOO U Model di ruang tamu dengan indikator udara menyala' },
  { file: 'cuckoo-u-model-real-room-quiet', alt: 'CUCKOO U Model di sudut ruang dalaman' }
].map((p, index) => ({ image: `${base}/${p.file}.webp`, title: `Gambar Produk #${index + 1}`, alt: p.alt }));

const faqs = [
  { q: 'Apa fungsi CUCKOO U Model Air Purifier?', a: 'CUCKOO U Model membantu membersihkan udara dalam ruang besar dengan menapis habuk, alergen, bau, gas berbahaya, partikel halus dan pencemar udara melalui sistem penapisan 4 peringkat.' },
  { q: 'Berapa luas coverage CUCKOO U Model?', a: 'CUCKOO U Model mempunyai coverage sehingga 1161 sq ft (107.9m²), sesuai untuk rumah besar, pejabat, sekolah, tadika, masjid, klinik, showroom dan ruang komersial.' },
  { q: 'Adakah CUCKOO U Model sesuai untuk commercial use?', a: 'Ya. CUCKOO U Model sesuai untuk kegunaan komersial kerana mempunyai coverage besar, 360° absorption, sensor kualiti udara, TVOC Sensor, PM1.0 Sensor dan sistem penapisan True HEPA+ H14.' },
  { q: 'Adakah CUCKOO U Model sesuai untuk rumah yang ada anak kecil?', a: 'Ya. Ia membantu mengurangkan habuk, bau dan partikel udara, serta mempunyai Baby Mode dan Sleep Mode untuk operasi yang lebih senyap dan selesa.' },
  { q: 'Adakah CUCKOO U Model sesuai untuk orang yang ada alahan atau asma?', a: 'CUCKOO U Model boleh membantu mengurangkan habuk, debunga, bulu haiwan dan partikel halus yang boleh mengganggu keselesaan pernafasan. Namun, ia bukan alat rawatan perubatan dan tidak menggantikan nasihat doktor.' },
  { q: 'Adakah CUCKOO U Model boleh membantu ketika musim jerebu?', a: 'Ya. Sistem penapisan HEPA+ membantu menapis partikel halus di udara termasuk fine dust yang biasa berlaku ketika musim jerebu, menjadikan udara dalaman lebih bersih apabila kualiti udara luar kurang baik.' },
  { q: 'Apa fungsi TVOC Sensor?', a: 'TVOC Sensor membantu mengesan gas atau bau daripada bahan seperti cat, bahan binaan, produk pembersih, asap dan pencemar udara lain yang tidak kelihatan.' },
  { q: 'Apa fungsi PM1.0 Fine Dust Sensor?', a: 'PM1.0 Fine Dust Sensor membantu mengesan partikel udara yang sangat halus supaya air purifier boleh bertindak dengan lebih tepat berdasarkan keadaan udara semasa.' },
  { q: 'Adakah CUCKOO U Model bising?', a: 'CUCKOO U Model mempunyai tahap bunyi sekitar 53.7 dBA. Ia juga mempunyai Sleep Mode dan Baby Mode untuk operasi yang lebih senyap apabila diperlukan.' },
  { q: 'Adakah CUCKOO U Model jimat elektrik?', a: 'CUCKOO U Model mempunyai ECO Mode dan Energy Eye Mode yang membantu mengawal penggunaan tenaga berdasarkan keadaan udara dan kecerahan bilik.' },
  { q: 'Apa beza U Model dengan R Model dan K Model?', a: 'U Model mempunyai coverage paling besar (sehingga 1161 sq ft) dan menggunakan True HEPA+ H14 Filter — lebih sesuai untuk ruang besar dan kegunaan komersial. R Model lebih compact & stylish untuk bilik atau ruang sederhana, manakala K Model sesuai untuk ruang lebih besar daripada R tetapi lebih kecil berbanding U.' },
  { q: 'Adakah CUCKOO U Model sesuai untuk masjid atau surau?', a: 'Ya. CUCKOO U Model sesuai untuk masjid atau surau kerana ruang ini digunakan ramai orang dan memerlukan udara yang lebih segar, terutama jika menggunakan penghawa dingin.' },
  { q: 'Adakah CUCKOO U Model sesuai untuk tadika atau taska?', a: 'Ya. Ia sesuai untuk ruang aktiviti, ruang tidur atau ruang menunggu di tadika dan taska kerana membantu mengurangkan habuk, bau dan partikel udara supaya ruang lebih selesa untuk kanak-kanak.' },
  { q: 'Adakah CUCKOO U Model sesuai untuk klinik?', a: 'Ya, ia boleh digunakan di ruang menunggu, kaunter pendaftaran atau bilik konsultasi untuk membantu meningkatkan keselesaan udara. Namun, ia bukan pengganti sistem ventilasi, sanitasi atau peralatan perubatan khusus.' },
  { q: 'Kenapa perlu pilih rental plan?', a: 'Rental plan sesuai untuk pelanggan yang tidak mahu bayar jumlah besar secara terus. Dengan bayaran bulanan, pelanggan boleh menikmati CUCKOO U Model bersama servis dan warranty sepanjang tempoh pelan.' }
];

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'CUCKOO U Model Air Purifier',
  alternateName: ['Penapis Udara CUCKOO U Model', 'CUCKOO U Model Air Purifier Malaysia'],
  category: 'Air Purifier',
  brand: { '@type': 'Brand', name: 'CUCKOO' },
  manufacturer: { '@type': 'Organization', name: 'CUCKOO' },
  model: 'U Model',
  description:
    'Penapis udara CUCKOO U Model untuk ruang besar & kegunaan komersial — liputan sehingga 1161 sq ft, 360° absorption, sistem penapisan 4 peringkat True HEPA+ H14 (99.995%), PM1.0 & TVOC sensor, Plasma Ioniser dan 10 operating modes. Sewa dari RM143/bulan atau beli RM4,400 di Malaysia.',
  url: pageUrl,
  image: [
    ogImg,
    `${site}${base}/cuckoo-u-model-front-led-on.webp`,
    `${site}${base}/cuckoo-u-model-4-stage-filtration-99995.webp`
  ],
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Coverage', value: u.coverage },
    { '@type': 'PropertyValue', name: 'Filtration', value: u.filters },
    { '@type': 'PropertyValue', name: 'Power Consumption', value: u.power },
    { '@type': 'PropertyValue', name: 'Rated Power', value: u.ratedPower },
    { '@type': 'PropertyValue', name: 'Noise Level', value: u.noise },
    { '@type': 'PropertyValue', name: 'Dimensi (W×D×H)', value: u.size },
    { '@type': 'PropertyValue', name: 'Berat', value: u.weight }
  ],
  offers: [
    {
      '@type': 'Offer',
      name: 'Pelan rental CUCKOO (60 bulan)',
      priceCurrency: 'MYR',
      price: String(u.rentalY4to5),
      url: pageUrl,
      availability: 'https://schema.org/InStock',
      itemCondition: 'https://schema.org/NewCondition',
      priceValidUntil,
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: String(u.rentalY4to5),
        priceCurrency: 'MYR',
        unitText: 'MONTH',
        referenceQuantity: { '@type': 'QuantitativeValue', value: String(u.rentalMonths), unitText: 'MONTH' }
      },
      seller: { '@type': 'Organization', name: 'CUCKOO', url: site }
    },
    {
      '@type': 'Offer',
      name: 'Beli terus (outright)',
      priceCurrency: 'MYR',
      price: String(u.priceOutright),
      url: pageUrl,
      availability: 'https://schema.org/InStock',
      itemCondition: 'https://schema.org/NewCondition',
      priceValidUntil,
      seller: { '@type': 'Organization', name: 'CUCKOO', url: site }
    }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } }))
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site}/` },
    { '@type': 'ListItem', position: 2, name: 'Produk', item: `${site}/products/` },
    { '@type': 'ListItem', position: 3, name: 'Air Purifier', item: `${site}/products/air-purifier/` },
    { '@type': 'ListItem', position: 4, name: 'U Model', item: pageUrl }
  ]
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Penapis Udara CUCKOO U Model',
  description:
    'Maklumat lengkap CUCKOO U Model Air Purifier — liputan 1161 sq ft untuk ruang besar & komersial, harga, promo, spesifikasi, sistem penapisan True HEPA+ H14, gambar produk dan FAQ.',
  url: pageUrl,
  inLanguage: 'ms-MY',
  dateModified,
  isPartOf: { '@type': 'WebSite', name: 'CUCKOONANO', url: site },
  primaryImageOfPage: { '@type': 'ImageObject', url: ogImg },
  breadcrumb: breadcrumbSchema
};

const meta = {
  title: 'Penapis Udara CUCKOO U Model | Liputan 1161 sq ft, Harga & Promo',
  description:
    'CUCKOO U Model: penapis udara gred komersial ruang besar — liputan 1161 sq ft, True HEPA+ H14 (99.995%), PM1.0 & TVOC sensor, 10 modes. Sewa dari RM143/bulan.',
  canonical: pageUrl,
  ogImage: ogImg,
  ogType: 'website'
};
---

<BaseLayout {...meta} preloadImages={[heroFirst]}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(webPageSchema)} />

  <!-- HERO -->
  <section id="hero" class="relative overflow-hidden bg-brand-cream px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="absolute left-1/2 top-0 -z-10 h-[620px] w-[620px] -translate-x-1/2 rounded-full bg-brand-soft blur-3xl"></div>

    <div class="mx-auto grid max-w-7xl items-center gap-10 lg:grid-cols-[1.02fr_.98fr]">
      <!-- KIRI -->
      <div>
        <div class="mb-5 flex gap-2 overflow-x-auto pb-1 [-ms-overflow-style:none] [scrollbar-width:none] lg:flex-wrap lg:overflow-visible lg:pb-0 [&::-webkit-scrollbar]:hidden">
          <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Liputan 1161 sq ft</span>
          <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Gred Komersial</span>
          <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Antiviral &amp; Antifungal</span>
        </div>

        <div class="mb-5 inline-flex max-w-full flex-wrap items-center gap-2 rounded-full bg-[linear-gradient(135deg,#4B0715_0%,#7A0E23_58%,#8E1830_100%)] px-4 py-3 text-white shadow-glow ring-1 ring-brand-gold/30 sm:gap-3 sm:px-5">
          <span class="rounded-full bg-white/15 px-3 py-1 text-[11px] font-black uppercase tracking-[.14em] text-brand-gold">Liputan Terluas</span>
          <span class="text-sm font-black sm:text-base">Sehingga 1161 sq ft · 360° absorption</span>
        </div>

        <h1 class="text-[2.3rem] font-black leading-[1.08] tracking-tight text-brand-ink sm:text-5xl lg:text-[3.4rem]">
          CUCKOO U Model — Penapis Udara Ruang Besar &amp; Komersial
        </h1>

        <!-- Gambar produk (mobile) -->
        <div class="mt-6 lg:hidden">
          <div id="heroStageM" class="product-blob accent-ring relative mx-auto max-w-sm overflow-hidden rounded-[1.7rem] p-6">
            <div class="absolute bottom-10 left-1/2 h-14 w-[70%] -translate-x-1/2 rounded-full bg-brand-gold/20 blur-2xl"></div>
            <img id="heroImgM" src={heroSlides[0].src} alt={heroSlides[0].alt} width="800" height="1000" loading="eager" fetchpriority="high" class="relative z-10 mx-auto h-[260px] w-auto object-contain drop-shadow-2xl" />
            <button type="button" id="heroPrevM" aria-label="Gambar sebelumnya" class="absolute left-3 top-1/2 z-20 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-xl font-black text-brand-maroon shadow-lg transition hover:bg-white">‹</button>
            <button type="button" id="heroNextM" aria-label="Gambar seterusnya" class="absolute right-3 top-1/2 z-20 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-xl font-black text-brand-maroon shadow-lg transition hover:bg-white">›</button>
          </div>
          <div id="heroDotsM" class="mt-4 flex justify-center gap-2"></div>
        </div>

        <p class="mt-5 max-w-xl text-base leading-8 text-brand-muted sm:text-lg">
          Penapis udara premium untuk ruang besar — rumah besar, pejabat, masjid, sekolah, tadika, klinik, homestay dan showroom. True HEPA+ H14, PM1.0 &amp; TVOC sensor, Plasma Ioniser dan 10 operating modes untuk udara lebih bersih, segar dan selesa.
        </p>

        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <a href="#" onclick="this.href=rotatingWhatsapp()" class="inline-flex items-center justify-center gap-2 rounded-full bg-cta-green px-7 py-4 text-sm font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark">📲 WhatsApp Promo U Model</a>
          <a href="#korporat" class="inline-flex items-center justify-center rounded-full border border-brand/15 bg-white px-7 py-4 text-sm font-black text-brand shadow-soft hover:border-brand/30">🏢 Untuk Pejabat / Komersial</a>
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <a href="#harga" class="rounded-[1.35rem] bg-brand px-5 py-5 text-white shadow-glow transition hover:-translate-y-1">
            <p class="text-xs font-black uppercase tracking-[.16em] text-brand-gold">Pelan Rental</p>
            <p class="mt-2 text-4xl font-black leading-none">RM{u.rentalY1to3}<span class="text-sm font-black">/bulan</span></p>
            <p class="mt-1 text-xs font-bold text-white/75">Termasuk 5 tahun servis &amp; warranty</p>
          </a>
          <a href="#harga" class="rounded-[1.35rem] border border-brand/10 bg-white px-5 py-5 shadow-soft transition hover:-translate-y-1 hover:border-brand/25">
            <p class="text-xs font-black uppercase tracking-[.14em] text-brand-gold">Beli Terus</p>
            <p class="mt-2 text-xl font-black text-brand">RM{u.priceOutright.toLocaleString()}</p>
            <p class="mt-2 text-sm font-bold text-brand-muted">Lihat detail harga →</p>
          </a>
        </div>
      </div>

      <!-- KANAN (desktop) -->
      <div class="hidden rounded-[2rem] border border-white/80 bg-white/70 p-4 shadow-premium backdrop-blur-xl sm:p-6 lg:block">
        <div class="product-blob accent-ring relative overflow-hidden rounded-[1.7rem] p-4 sm:p-6 lg:p-8">
          <div class="flex flex-wrap gap-2">
            <span class="rounded-full bg-white/85 px-4 py-2 text-xs font-black text-brand shadow-soft">360° Absorption</span>
            <span class="rounded-full bg-white/85 px-4 py-2 text-xs font-black text-brand shadow-soft">True HEPA+ H14</span>
          </div>

          <div id="heroStageD" class="relative mt-5 flex min-h-[300px] items-center justify-center overflow-hidden rounded-[1.5rem] bg-gradient-to-br from-white/80 to-white/35 p-5 sm:min-h-[390px] lg:min-h-[440px]">
            <div class="absolute bottom-12 h-16 w-[72%] rounded-full bg-brand-gold/20 blur-2xl"></div>
            <img id="heroImgD" src={heroSlides[0].src} alt={heroSlides[0].alt} width="800" height="1000" loading="eager" fetchpriority="high" class="relative z-10 h-[290px] w-auto object-contain drop-shadow-2xl sm:h-[380px] lg:h-[425px]" />
            <button type="button" id="heroPrevD" aria-label="Gambar sebelumnya" class="absolute left-4 top-1/2 z-20 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-2xl font-black text-brand-maroon shadow-lg transition hover:bg-white">‹</button>
            <button type="button" id="heroNextD" aria-label="Gambar seterusnya" class="absolute right-4 top-1/2 z-20 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-2xl font-black text-brand-maroon shadow-lg transition hover:bg-white">›</button>
            <div id="heroDotsD" class="absolute bottom-4 left-1/2 flex -translate-x-1/2 gap-2"></div>
