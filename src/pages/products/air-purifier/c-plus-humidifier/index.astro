---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ProductGallerySlider from '../../../../components/ProductGallerySlider.astro';

const base = '/assets/images/products/air-purifier/c-humidifier';
const site = 'https://www.cuckoonano.com';
const pageUrl = `${site}/products/air-purifier/c-plus-humidifier/`;
const priceValidUntil = '2026-12-31';
const dateModified = '2026-06-27';

// ---- Single source of truth: fakta C+ Model ----
const c = {
  name: 'CUCKOO C+ Model',
  type: 'Penapis Udara + Humidifier',
  coverage: '402 sq ft (37.4m²)',
  weight: '9.2kg',
  size: '430(W) × 276(D) × 550(H) mm',
  power: '25W',
  humidify: '300mL/h',
  tank: '2.5L',
  sensor: 'Fine Dust Sensor · Humidification Sensor',
  stages: '5-Stage Filtration System',
  filters: 'Pre-Filter · Harmful Gas Relax Filter · Deodorisation Filter · True HEPA H14 · Humidification Filter',
  voice: 'English · Malay · Chinese · Korean',
  priceOutright: 3100,
  promoFirst6: 12,
  rentalY1to3: 121,
  rentalY4to5: 121,
  rentalMonths: 60,
  carePackage: 660
};

const heroImg = `${base}/penapis-udara-cuckoo-c-plus-humidifier-air-purifier-malaysia.webp`;
const ogImg = `${site}${heroImg}`;

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'CUCKOO C+ Model Air Purifier + Humidifier',
  alternateName: ['Penapis Udara CUCKOO C+ Humidifier', 'CUCKOO C+ Air Purifier Humidifier Malaysia'],
  category: 'Air Purifier',
  brand: { '@type': 'Brand', name: 'CUCKOO' },
  manufacturer: { '@type': 'Organization', name: 'CUCKOO' },
  model: 'C+ Model',
  description:
    'CUCKOO C+ Model — gabungan air purifier + humidifier 2-in-1 dengan True HEPA H14 Filter, 5-stage filtration, tangki air 2.5L (300mL/h), Plasma Ioniser, 11 operating modes dan voice guide 4 bahasa. Liputan 402 sq ft. Promo dari RM12/bulan atau beli terus RM3,100 di Malaysia.',
  url: pageUrl,
  image: [
    ogImg,
    `${site}${base}/penapis-udara-cuckoo-c-plus-humidifier-bilik-tidur.webp`,
    `${site}${base}/penapis-udara-cuckoo-c-plus-humidifier-bilik-anak.webp`
  ],
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Coverage', value: c.coverage },
    { '@type': 'PropertyValue', name: 'Filtration', value: c.filters },
    { '@type': 'PropertyValue', name: 'Humidifying Capability', value: c.humidify },
    { '@type': 'PropertyValue', name: 'Water Tank Size', value: c.tank },
    { '@type': 'PropertyValue', name: 'Sensor', value: c.sensor },
    { '@type': 'PropertyValue', name: 'Voice Navigation', value: c.voice },
    { '@type': 'PropertyValue', name: 'Power Consumption', value: c.power },
    { '@type': 'PropertyValue', name: 'Dimensi (W×D×H)', value: c.size },
    { '@type': 'PropertyValue', name: 'Berat', value: c.weight }
  ],
  offers: [
    {
      '@type': 'Offer',
      name: 'Pelan rental CUCKOO (60 bulan)',
      priceCurrency: 'MYR',
      price: String(c.rentalY4to5),
      url: pageUrl,
      availability: 'https://schema.org/InStock',
      itemCondition: 'https://schema.org/NewCondition',
      priceValidUntil,
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: String(c.rentalY4to5),
        priceCurrency: 'MYR',
        unitText: 'MONTH',
        referenceQuantity: { '@type': 'QuantitativeValue', value: String(c.rentalMonths), unitText: 'MONTH' }
      },
      seller: { '@type': 'Organization', name: 'CUCKOO', url: site }
    },
    {
      '@type': 'Offer',
      name: 'Beli terus (outright)',
      priceCurrency: 'MYR',
      price: String(c.priceOutright),
      url: pageUrl,
      availability: 'https://schema.org/InStock',
      itemCondition: 'https://schema.org/NewCondition',
      priceValidUntil,
      seller: { '@type': 'Organization', name: 'CUCKOO', url: site }
    }
  ]
};

const faqs = [
  { q: 'Apa itu CUCKOO C+ Model?', a: 'CUCKOO C+ Model ialah produk 2-in-1 yang menggabungkan fungsi air purifier dan humidifier. Ia membantu menapis udara serta menambah kelembapan udara dalam ruang rumah.' },
  { q: 'Apa beza air purifier dan humidifier?', a: 'Air purifier membantu menapis udara daripada habuk, bau, alergen dan partikel halus. Humidifier pula membantu menambah kelembapan udara supaya ruang tidak terlalu kering.' },
  { q: 'Adakah CUCKOO C+ hanya humidifier sahaja?', a: 'Tidak. CUCKOO C+ ialah gabungan air purifier dan humidifier. Ia mempunyai sistem penapisan udara 5 peringkat dan juga fungsi humidification.' },
  { q: 'Berapa luas coverage CUCKOO C+?', a: 'CUCKOO C+ mempunyai recommended coverage sekitar 37.4m² / 402.57 sq ft, sesuai untuk bilik tidur, ruang keluarga kecil, apartment atau ruang rumah sederhana.' },
  { q: 'Berapa besar tangki air CUCKOO C+?', a: 'CUCKOO C+ mempunyai water tank bersaiz 2.5L, dengan humidifying capability sehingga 300mL/h.' },
  { q: 'Adakah CUCKOO C+ menggunakan HEPA H14?', a: 'Ya. CUCKOO C+ menggunakan True HEPA H14 Filter yang membantu menapis PM2.5, fine dust dan partikel jerebu sekecil 0.3 microns.' },
  { q: 'Apakah filter yang digunakan oleh CUCKOO C+?', a: 'CUCKOO C+ menggunakan Pre-Filter, Harmful Gas Relax Filter, Deodorisation Filter, True HEPA H14 Filter dan Humidification Filter dalam 5-Stage Filtration System.' },
  { q: 'Adakah CUCKOO C+ sesuai untuk bilik tidur?', a: 'Ya. CUCKOO C+ sesuai untuk bilik tidur, terutama bilik yang selalu menggunakan aircond atau terasa kering. Baby Mode dan Auto Humidity Mode menjadikannya lebih selesa untuk penggunaan waktu malam.' },
  { q: 'Adakah CUCKOO C+ sesuai untuk bayi dan anak kecil?', a: 'Ya, CUCKOO C+ sesuai digunakan di rumah yang mempunyai bayi atau anak kecil. Namun, ia bukan alat rawatan perubatan. Jika anak mempunyai masalah kesihatan serius, dapatkan nasihat doktor.' },
  { q: 'Adakah CUCKOO C+ boleh membantu mengurangkan bau?', a: 'Ya. Deodorisation Filter membantu mengurangkan bau kurang menyenangkan seperti bau asap, bau masakan, bau haiwan peliharaan dan bau ruang tertutup.' },
  { q: 'Adakah CUCKOO C+ membantu ketika musim jerebu?', a: 'Ya. True HEPA H14 Filter membantu menapis PM2.5, fine dust dan partikel jerebu. Yellow Dust Mode juga sesuai digunakan apabila kualiti udara kurang baik.' },
  { q: 'Bila filter CUCKOO C+ perlu ditukar?', a: 'Pre-Filter perlu dibersihkan setiap 2 minggu. Harmful Gas Relax Filter dan Humidification Filter ditukar setiap 4 bulan. Deodorisation Filter dan True HEPA H14 Filter ditukar setiap 12 bulan.' },
  { q: 'Adakah CUCKOO C+ jimat elektrik?', a: 'CUCKOO C+ menggunakan kuasa 25W dan dilengkapi Energy Eye Mode untuk membantu penggunaan tenaga yang lebih bijak.' },
  { q: 'Adakah CUCKOO C+ sesuai untuk ruang besar?', a: 'CUCKOO C+ sesuai untuk ruang sekitar 402 sq ft. Untuk ruang yang sangat besar seperti pejabat besar atau ruang tamu besar, model lain seperti D Model atau K Model mungkin lebih sesuai.' },
  { q: 'Berapa harga promo CUCKOO C+?', a: 'Untuk promo semasa, bayaran ialah RM12 sebulan untuk 6 bulan pertama, kemudian RM121 sebulan (kadar rata) untuk bulan ke-7 hingga 60. Tertakluk kepada stok, kawasan, kelulusan dan terma semasa.' }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } }))
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site}/` },
    { '@type': 'ListItem', position: 2, name: 'Produk', item: `${site}/products/` },
    { '@type': 'ListItem', position: 3, name: 'Air Purifier', item: `${site}/products/air-purifier/` },
    { '@type': 'ListItem', position: 4, name: 'C+ Humidifier', item: pageUrl }
  ]
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Penapis Udara CUCKOO C+ Model (Air Purifier + Humidifier)',
  description:
    'Maklumat lengkap CUCKOO C+ Model — air purifier + humidifier 2-in-1: harga, promo, spesifikasi, True HEPA H14, 5-stage filtration, fungsi humidifier dan FAQ.',
  url: pageUrl,
  inLanguage: 'ms-MY',
  dateModified,
  isPartOf: { '@type': 'WebSite', name: 'CUCKOONANO', url: site },
  primaryImageOfPage: { '@type': 'ImageObject', url: ogImg },
  breadcrumb: breadcrumbSchema
};

// Masalah pelanggan (problem section)
const problems = [
  { icon: '🌫️', title: 'Rumah cepat berhabuk', desc: 'Baru lap, esok berdebu balik di perabot, lantai dan permukaan rumah.' },
  { icon: '🐱', title: 'Ada kucing / haiwan', desc: 'Bulu haiwan peliharaan berterbangan dan mudah terkumpul dalam ruang.' },
  { icon: '🏗️', title: 'Dekat jalan & pembinaan', desc: 'Berhampiran jalan besar, tapak pembinaan, pembakaran terbuka atau kawasan berdebu.' },
  { icon: '👃', title: 'Bau terperangkap', desc: 'Bau masakan, asap rokok dan bau ruang tertutup yang kurang menyenangkan.' },
  { icon: '❄️', title: 'Bilik aircond kering', desc: 'Bilik berhawa dingin sering terasa terlalu kering dan kurang selesa.' },
  { icon: '💧', title: 'Kulit & tekak kering', desc: 'Kulit, hidung atau tekak terasa kering akibat udara yang kurang lembap.' },
  { icon: '🤧', title: 'Sensitif dengan habuk', desc: 'Mudah bersin atau terganggu dengan habuk halus, debunga dan udara berdebu.' },
  { icon: '🏡', title: 'Mahu udara lebih selesa', desc: 'Mahukan udara rumah yang lebih bersih, segar dan selesa untuk seisi keluarga.' }
];

// Jadual pertukaran filter (rasmi)
const filterTable = [
  { level: 'Level 1', type: 'Pre-Filter', fn: 'Membantu menapis habuk besar di udara.', life: '2 minggu', action: 'Cuci' },
  { level: 'Level 2', type: 'Harmful Gas Easy Filter S', fn: 'Membantu mengurangkan sulfur dioxide dan nitrogen dioxide.', life: '4 bulan', action: 'Tukar' },
  { level: 'Level 3', type: 'Deodorisation Filter', fn: 'Membantu mengurangkan ammonia, acetaldehyde, acetic acid, gas tertentu dan bau kurang menyenangkan.', life: '12 bulan', action: 'Tukar' },
  { level: 'Level 4–7', type: 'Ultra PM2.5 Filter (Anti-Bacterial · Anti-Mold · Anti-Virus · Allergen)', fn: 'Membantu menapis habuk halus (micro dust) dan asap rokok. Lapisan dengan ciri anti-bakteria, anti-kulat, anti-alergen & anti-virus.', life: '12 bulan', action: 'Tukar' },
  { level: '—', type: 'Humidification Filter', fn: 'Membantu penyerapan air & kecekapan penyejatan untuk melembapkan udara.', life: '1 minggu / 4 bulan', action: 'Cuci / Tukar', humid: true }
];

// Filter kotor (agitate slider) — kesan habuk pada kesihatan & kebersihan
const dirtyFilters = [
  { img: `${base}/penapis-udara-cuckoo-c-plus-humidifier-filter-kotor-1.webp`, title: 'Habuk tebal dalam 1 filter sahaja', desc: 'Inilah habuk yang terperangkap dalam filter — semua ini sepatutnya tidak masuk ke dalam paru-paru anda.' },
  { img: `${base}/penapis-udara-cuckoo-c-plus-humidifier-filter-kotor-2.webp`, title: 'Filter dekat ruang tamu', desc: 'Ruang yang paling kerap diguna selalunya paling tebal habuk — tanpa anda perasan.' },
  { img: `${base}/penapis-udara-cuckoo-c-plus-humidifier-filter-kotor-3.webp`, title: 'Habuk halus & PM2.5', desc: 'Zarah halus yang mata tak nampak boleh menyebabkan bersin, hidung & mata gatal dan kurang selesa bernafas.' },
  { img: `${base}/penapis-udara-cuckoo-c-plus-humidifier-filter-kotor-4.webp`, title: 'Bulu haiwan & debunga', desc: 'Bulu haiwan, debunga dan habuk rumah bercampur dalam udara yang anda hirup setiap hari.' },
  { img: `${base}/penapis-udara-cuckoo-c-plus-humidifier-filter-kotor-5.webp`, title: 'Ditangkap sebelum beredar semula', desc: 'CUCKOO C+ membantu menangkap habuk ini supaya udara rumah lebih bersih dan rumah tak cepat berdebu.' }
];

// Galeri rumah sebenar
const realGalleryItems = Array.from({ length: 15 }, (_, index) => {
  const n = index + 1;
  return {
    image: `${base}/penapis-udara-cuckoo-c-plus-humidifier-rumah-${n}.webp`,
    title: `Gambar Sebenar #${n}`,
    copy: 'Gambar sebenar penapis udara CUCKOO C+ Humidifier di rumah pelanggan.',
    alt: `Gambar sebenar penapis udara CUCKOO C+ Humidifier di rumah pelanggan ${n}`
  };
});

// 11 operating modes (emoji)
const modes = [
  { emoji: '🔄', title: 'Auto Mode', desc: 'Melaras pembersihan udara & kelajuan kipas automatik ikut tahap kebersihan udara.' },
  { emoji: '🌙', title: 'Baby Mode', desc: 'Mengurangkan bunyi & gangguan cahaya, sesuai ketika bayi atau anak kecil berehat.' },
  { emoji: '🔒', title: 'Lock Mode', desc: 'Mengunci butang supaya tetapan tidak berubah secara tidak sengaja.' },
  { emoji: '💧', title: 'Auto Humidity Mode', desc: 'Memaparkan & membantu mengawal tahap kelembapan udara sekeliling.' },
  { emoji: '⏱️', title: 'Repeat Mode', desc: 'Membolehkan operasi mengikut tetapan masa tertentu.' },
  { emoji: '👁️', title: 'Energy Eye Mode', desc: 'Mengesan keadaan gelap & matikan indikator untuk jimat tenaga.' },
  { emoji: '💨', title: 'Turbo Mode', desc: 'Meningkatkan kelajuan kipas untuk mempercepatkan pembersihan udara.' },
  { emoji: '🔔', title: 'Filter Replacement Indicator', desc: 'Memberi peringatan apabila filter perlu ditukar.' },
  { emoji: '✨', title: 'Sterilisation Mode', desc: 'Mengaktifkan Plasma Ioniser untuk menyokong proses pembersihan udara.' },
  { emoji: '🏠', title: 'Room Care Mode', desc: 'Melaras kelajuan kipas mengikut saiz ruang untuk pembersihan lebih sesuai.' },
  { emoji: '🌪️', title: 'Yellow Dust Mode', desc: 'Sesuai apabila ada habuk halus, partikel jerebu atau udara luar kurang baik.' }
];

// Manfaat air purifier
const purifierBenefits = [
  'Membantu menapis habuk dan debu halus',
  'Membantu mengurangkan bau kurang menyenangkan',
  'Membantu menapis bulu haiwan peliharaan yang berterbangan',
  'Membantu mengurangkan partikel jerebu dan PM2.5',
  'Membantu menjadikan udara dalam rumah lebih bersih dan segar'
];

// Manfaat humidifier (bahasa selamat)
const humidifierBenefits = [
  'Membantu melembapkan udara dalam rumah',
  'Membantu mengurangkan rasa kering pada kulit',
  'Membantu melindungi rambut & kulit kepala daripada kekeringan',
  'Membantu tidur terasa lebih selesa bila udara bilik tidak terlalu kering',
  'Sesuai untuk bilik yang menggunakan aircond',
  'Membantu menjadikan ruang rumah terasa lebih nyaman',
  'Membantu memberi suasana lebih baik untuk tanaman indoor',
  'Membantu mengekalkan kelembapan ruang untuk perabot kayu'
];

const voiceLangs = [
  { flag: '🇬🇧', label: 'English' },
  { flag: '🇲🇾', label: 'Bahasa Malaysia' },
  { flag: '🇨🇳', label: 'Chinese / 中文' },
  { flag: '🇰🇷', label: 'Korean / 한국어' }
];

const audience = [
  { emoji: '🌬️', title: 'Mahu purifier + humidifier', desc: 'Keluarga yang mahu udara lebih bersih dan lebih lembap dalam satu produk.' },
  { emoji: '👶', title: 'Ada bayi / anak kecil', desc: 'Rumah dengan bayi atau anak kecil yang mahukan udara lebih selesa.' },
  { emoji: '🐾', title: 'Ada haiwan peliharaan', desc: 'Bantu kurangkan bulu haiwan, habuk dan bau dalam rumah.' },
  { emoji: '❄️', title: 'Bilik kerap guna aircond', desc: 'Bilik tidur berhawa dingin yang sering terasa kering.' },
  { emoji: '🏢', title: 'Apartment & kondominium', desc: 'Apartment, kondo atau bilik tidur utama bersaiz sederhana.' },
  { emoji: '🛣️', title: 'Kawasan berdebu', desc: 'Rumah berdekatan jalan besar atau kawasan yang kerap berdebu.' }
];

const productPhotos = [
  { file: 'penapis-udara-cuckoo-c-plus-humidifier-air-purifier-malaysia', alt: 'Penapis udara CUCKOO C+ Humidifier — paparan hadapan studio' },
  { file: 'penapis-udara-cuckoo-c-plus-humidifier-bilik-tidur', alt: 'CUCKOO C+ Humidifier di bilik tidur bersebelahan kerusi' },
  { file: 'penapis-udara-cuckoo-c-plus-humidifier-bilik-anak', alt: 'CUCKOO C+ Humidifier di bilik anak dengan teddy bear' },
  { file: 'penapis-udara-cuckoo-c-plus-humidifier-tepi-katil', alt: 'CUCKOO C+ Humidifier di tepi katil bilik tidur' }
].map((p, index) => ({ image: `${base}/${p.file}.webp`, title: `Gambar Produk #${index + 1}`, alt: p.alt }));

const meta = {
  title: 'Penapis Udara CUCKOO C+ | Air Purifier + Humidifier H14',
  description:
    'CUCKOO C+ Model: air purifier + humidifier 2-in-1 — True HEPA H14, 5-stage filtration, tangki 2.5L, 11 modes & voice guide 4 bahasa. Promo dari RM12/bulan.',
  canonical: pageUrl,
  ogImage: ogImg,
  ogType: 'website'
};
---

<BaseLayout {...meta} preloadImages={[heroImg]}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(webPageSchema)} />

  <!-- HERO -->
  <section id="hero" class="relative overflow-hidden bg-brand-cream px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="absolute left-1/2 top-0 -z-10 h-[620px] w-[620px] -translate-x-1/2 rounded-full bg-brand-soft blur-3xl"></div>

    <div class="mx-auto grid max-w-7xl items-center gap-10 lg:grid-cols-[1.02fr_.98fr]">
      <!-- KIRI: kandungan -->
      <div>
        <div class="mb-5 flex gap-2 overflow-x-auto pb-1 [-ms-overflow-style:none] [scrollbar-width:none] lg:flex-wrap lg:overflow-visible lg:pb-0 [&::-webkit-scrollbar]:hidden">
          <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Air Purifier + Humidifier</span>
          <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">True HEPA H14</span>
          <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Voice Guide 4 Bahasa</span>
        </div>

        <div class="mb-5 inline-flex max-w-full flex-wrap items-center gap-2 rounded-full bg-[linear-gradient(135deg,#4B0715_0%,#7A0E23_58%,#8E1830_100%)] px-4 py-3 text-white shadow-glow ring-1 ring-brand-gold/30 sm:gap-3 sm:px-5">
          <span class="rounded-full bg-white/15 px-3 py-1 text-[11px] font-black uppercase tracking-[.14em] text-brand-gold">Promo Terkini</span>
          <span class="text-sm font-black sm:text-base">RM{c.promoFirst6} x 6 bulan pertama</span>
        </div>

        <h1 class="text-[2.3rem] font-black leading-[1.08] tracking-tight text-brand-ink sm:text-5xl lg:text-[3.4rem]">
          CUCKOO C+ Model — Air Purifier + Humidifier 2-in-1
        </h1>

        <!-- Gambar produk (mobile sahaja) -->
        <div class="mt-6 lg:hidden">
          <div class="product-blob accent-ring relative mx-auto max-w-sm overflow-hidden rounded-[1.7rem] p-6">
            <div class="absolute bottom-10 left-1/2 h-14 w-[70%] -translate-x-1/2 rounded-full bg-brand-gold/20 blur-2xl"></div>
            <img src={heroImg} alt="Penapis Udara CUCKOO C+ Humidifier — paparan hadapan" width="800" height="900" loading="eager" fetchpriority="high" class="relative z-10 mx-auto h-[260px] w-auto object-contain drop-shadow-2xl" />
          </div>
        </div>

        <p class="mt-5 max-w-xl text-base leading-8 text-brand-muted sm:text-lg">
          Penapis udara dan humidifier dalam satu produk — bukan sahaja membantu menapis habuk, bau, alergen dan PM2.5 dengan True HEPA H14, malah menambah kelembapan udara supaya bilik tidur, bilik anak dan apartment terasa lebih bersih, segar dan selesa.
        </p>

        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <a href="#" onclick="this.href=rotatingWhatsapp()" class="inline-flex items-center justify-center gap-2 rounded-full bg-cta-green px-7 py-4 text-sm font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark">📲 WhatsApp Promo C+</a>
          <a href="#harga" class="inline-flex items-center justify-center rounded-full border border-brand/15 bg-white px-7 py-4 text-sm font-black text-brand shadow-soft hover:border-brand/30">Lihat Pelan Harga</a>
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <div class="rounded-[1.35rem] bg-brand px-5 py-5 text-white shadow-glow">
            <p class="text-xs font-black uppercase tracking-[.16em] text-brand-gold">Promo Terkini</p>
            <p class="mt-2 text-4xl font-black leading-none">RM{c.promoFirst6}<span class="text-sm font-black">/bulan</span></p>
            <p class="mt-1 text-xs font-bold text-white/75">6 bulan pertama</p>
          </div>
          <a href="#harga" class="rounded-[1.35rem] border border-brand/10 bg-white px-5 py-5 shadow-soft transition hover:-translate-y-1 hover:border-brand/25">
            <p class="text-xs font-black uppercase tracking-[.14em] text-brand-gold">Beli Terus</p>
            <p class="mt-2 text-xl font-black text-brand">RM{c.priceOutright.toLocaleString()}</p>
            <p class="mt-2 text-sm font-bold text-brand-muted">Lihat detail harga →</p>
          </a>
        </div>
      </div>

