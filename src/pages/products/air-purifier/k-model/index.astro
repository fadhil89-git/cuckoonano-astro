---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ProductGallerySlider from '../../../../components/ProductGallerySlider.astro';

const base = '/assets/images/products/air-purifier/k-model';
const site = 'https://www.cuckoonano.com';
const pageUrl = `${site}/products/air-purifier/k-model/`;
const priceValidUntil = '2026-12-31';
const dateModified = '2026-06-23';

// ---- Single source of truth: fakta K Model ----
const k = {
  name: 'CUCKOO K Model',
  type: 'Air Purifier / Penapis Udara',
  coverage: '710 sq ft (66m²)',
  weight: '7.0kg',
  cadr: '520 m³/h',
  power: 'AC 220–240V / 60W',
  noise: '< 60 dB(A)',
  size: '336(W) × 336(D) × 650(H) mm',
  stages: '4 Filtration Stages',
  filters: 'Pre Filter · Allergen Filter · Ultra-Deo HEPA13 · True HEPA H13 & Deodorisation',
  priceOutright: 2750,
  rentalY1to3: 94,
  rentalY4to5: 89,
  rentalMonths: 60,
  carePackage: 605, // setahun
  serviceInterval: '4 bulan',
  promoFirst6: 12
};

const heroImg = `${base}/K-Model.webp`;
const ogImg = `${site}${heroImg}`;

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'CUCKOO K Model Air Purifier',
  alternateName: ['Penapis Udara CUCKOO K Model', 'CUCKOO K Model Air Purifier Malaysia'],
  category: 'Air Purifier',
  brand: { '@type': 'Brand', name: 'CUCKOO' },
  manufacturer: { '@type': 'Organization', name: 'CUCKOO' },
  model: 'K Model',
  description:
    'Penapis udara CUCKOO K Model dengan liputan luas 710 sq ft, sistem penapisan 4 peringkat (Ultra-Deo HEPA13 & True HEPA H13), indikator kualiti udara dan 360° purification. Sewa dari RM89/bulan atau beli terus RM2,750 di Malaysia.',
  url: pageUrl,
  image: [ogImg, `${site}${base}/photo-1a-1200x800.webp`, `${site}${base}/photo-2-1-1200x800.webp`],
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Coverage', value: k.coverage },
    { '@type': 'PropertyValue', name: 'CADR', value: k.cadr },
    { '@type': 'PropertyValue', name: 'Filtration', value: k.filters },
    { '@type': 'PropertyValue', name: 'Power Consumption', value: k.power },
    { '@type': 'PropertyValue', name: 'Noise Level', value: k.noise },
    { '@type': 'PropertyValue', name: 'Dimensi (W×D×H)', value: k.size },
    { '@type': 'PropertyValue', name: 'Berat', value: k.weight }
  ],
  offers: [
    {
      '@type': 'Offer',
      name: 'Pelan rental CUCKOO (60 bulan)',
      priceCurrency: 'MYR',
      price: String(k.rentalY4to5),
      url: pageUrl,
      availability: 'https://schema.org/InStock',
      itemCondition: 'https://schema.org/NewCondition',
      priceValidUntil,
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: String(k.rentalY4to5),
        priceCurrency: 'MYR',
        unitText: 'MONTH',
        referenceQuantity: { '@type': 'QuantitativeValue', value: String(k.rentalMonths), unitText: 'MONTH' }
      },
      seller: { '@type': 'Organization', name: 'CUCKOO', url: site }
    },
    {
      '@type': 'Offer',
      name: 'Beli terus (outright)',
      priceCurrency: 'MYR',
      price: String(k.priceOutright),
      url: pageUrl,
      availability: 'https://schema.org/InStock',
      itemCondition: 'https://schema.org/NewCondition',
      priceValidUntil,
      seller: { '@type': 'Organization', name: 'CUCKOO', url: site }
    }
  ]
};

const faqs = [
  { q: 'Apa fungsi air purifier?', a: 'Air purifier membantu meningkatkan kualiti udara dalam rumah dengan menapis habuk, alergen, bakteria, bau dan zarah halus seperti PM2.5. Ia menyedut udara sekeliling, menapisnya, kemudian melepaskan semula udara yang lebih bersih ke dalam bilik.' },
  { q: 'Adakah CUCKOO K Model boleh meningkatkan kualiti udara dalam rumah?', a: 'Ya. K Model dilengkapi sistem penapisan 4 peringkat termasuk Ultra-Deo HEPA13 Filter yang membantu mengurangkan habuk, alergen, bau dan zarah halus di udara — sesuai untuk rumah yang mahukan udara dalaman lebih bersih dan selesa.' },
  { q: 'Kenapa saya perlukan air purifier di rumah?', a: 'Udara dalam rumah boleh mengandungi habuk, bulu haiwan, debunga, asap masakan, bau, bakteria dan partikel halus. Air purifier membantu mengurangkan pencemar ini supaya rumah terasa lebih segar dan selesa.' },
  { q: 'Adakah CUCKOO K Model sesuai untuk ruang besar?', a: 'Ya. K Model mempunyai liputan sehingga 710 sq ft, menjadikannya sesuai untuk ruang tamu, bilik tidur utama, ruang keluarga atau pejabat kecil.' },
  { q: 'Adakah air purifier boleh mengurangkan habuk?', a: 'Ya. Air purifier membantu mengurangkan habuk yang terapung di udara dengan menapis partikel halus. Namun, ia tidak menggantikan kerja mengelap habuk yang sudah melekat pada permukaan perabot.' },
  { q: 'Adakah CUCKOO K Model boleh mengurangkan bau?', a: 'Ya. K Model menggunakan Ultra-Deo HEPA13 Filter bersama fungsi deodorisation yang membantu mengurangkan bau seperti bau masakan, asap, haiwan peliharaan dan bau dalam rumah.' },
  { q: 'Adakah air purifier membantu ketika musim jerebu di Malaysia?', a: 'Ya. Air purifier dengan penapisan HEPA boleh membantu menapis zarah halus seperti PM2.5 yang biasa berlaku ketika musim jerebu, menjadikan udara dalam rumah lebih bersih apabila kualiti udara luar kurang baik.' },
  { q: 'Adakah CUCKOO K Model jimat elektrik?', a: 'K Model mempunyai penggunaan kuasa 60W dan dilengkapi Auto Mode serta Energy Eye Mode yang membantu melaras operasi berdasarkan kualiti udara dan kecerahan bilik untuk penggunaan tenaga yang lebih bijak.' },
  { q: 'Di mana tempat terbaik untuk letak CUCKOO K Model?', a: 'Letakkan di kawasan terbuka yang tidak terhalang oleh dinding, langsir atau perabot besar — seperti ruang tamu, bilik tidur utama atau kawasan rumah yang paling kerap digunakan.' },
  { q: 'Perlukah air purifier dipasang sepanjang hari?', a: 'Air purifier biasanya sesuai digunakan secara berterusan untuk mengekalkan kualiti udara dalaman. Dengan Auto Mode, K Model boleh melaras kelajuan kipas mengikut keadaan udara semasa.' },
  { q: 'Adakah CUCKOO K Model sesuai untuk bilik tidur?', a: 'Ya. Baby Mode membantu mengurangkan bunyi dan kecerahan lampu, menjadikannya lebih selesa untuk digunakan ketika waktu tidur.' },
  { q: 'Apa beza Auto Mode dan Turbo Mode?', a: 'Auto Mode melaras kelajuan kipas secara automatik berdasarkan kualiti udara dan kecerahan bilik. Turbo Mode pula menggunakan kuasa pembersihan maksimum untuk membersihkan udara dengan lebih cepat.' }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } }))
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site}/` },
    { '@type': 'ListItem', position: 2, name: 'Produk', item: `${site}/products/` },
    { '@type': 'ListItem', position: 3, name: 'Air Purifier', item: `${site}/products/air-purifier/` },
    { '@type': 'ListItem', position: 4, name: 'K Model', item: pageUrl }
  ]
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Penapis Udara CUCKOO K Model',
  description:
    'Maklumat lengkap CUCKOO K Model Air Purifier termasuk harga, promo, spesifikasi, sistem penapisan HEPA13, gambar produk dan FAQ.',
  url: pageUrl,
  inLanguage: 'ms-MY',
  dateModified,
  isPartOf: {
    '@type': 'WebSite',
    name: 'CUCKOONANO',
    url: site
  },
  primaryImageOfPage: {
    '@type': 'ImageObject',
    url: ogImg
  },
  breadcrumb: breadcrumbSchema
};

const modes = [
  { icon: `${base}/icon-eco-mode.webp`, title: 'Auto Mode', desc: 'Set sekali, lupakan — laras sendiri ikut kualiti udara, jimat elektrik tanpa fikir.' },
  { icon: `${base}/icon-sleep-mode.webp`, title: 'Baby Mode', desc: 'Senyap masa baby tidur — bunyi dan kecerahan lampu diperlahankan.' },
  { icon: `${base}/icon-turbo-mode.webp`, title: 'Turbo Mode', desc: 'Udara berasap atau berbau? Satu tekan, bersih dengan laju.' },
  { icon: `${base}/icon-manual-mode.webp`, title: 'Manual Mode', desc: 'Kawal sendiri — 3 tahap laju kipas ikut keperluan anda.' },
  { icon: `${base}/icon-energy-saving-mode.webp`, title: 'Energy Eye Mode', desc: 'Auto jimat tenaga bila bilik gelap atau udara sudah bersih.' },
  { icon: `${base}/icon-button-sound-mode.webp`, title: 'Button Sound Mode', desc: 'Hidup atau matikan bunyi butang ikut keselesaan anda.' }
];

const filtration = [
  { n: '1', title: 'Pre Filter', desc: 'Memerangkap habuk kasar, bulu dan zarah besar di udara.' },
  { n: '2', title: 'Allergen Filter', desc: 'Membantu mengurangkan alergen seperti debunga dan hama habuk.' },
  { n: '3', title: 'Ultra-Deo HEPA13 Filter', desc: 'Menapis zarah halus sambil mengurangkan bau kurang menyenangkan.' },
  { n: '4', title: 'True HEPA H13 & Deodorisation', desc: 'Memerangkap partikel halus seperti PM2.5 dan menyahbau udara.' }
];

const realGalleryItems = Array.from({ length: 13 }, (_, index) => {
  const n = index + 1;
  return {
    image: `${base}/gambar-penapis-udara-cuckoo-k-model-image-real-${n}.webp`,
    title: `Pemasangan Sebenar #${n}`,
    copy: 'Gambar sebenar penapis udara CUCKOO K Model yang dipasang di rumah pelanggan.',
    alt: `Gambar sebenar penapis udara CUCKOO K Model dipasang di rumah pelanggan ${n}`
  };
});

const productPhotos = [
  'photo-1a-1200x800',
  'photo-2-1-1200x800',
  'photo-3-1-1200x800',
  'photo-4-1-1171x800',
  'photo-5-1-1200x800',
  'photo-6-1-1200x800'
].map((file, index) => ({
  image: `${base}/${file}.webp`,
  title: `Gambar Produk #${index + 1}`,
  copy: 'Rujukan gambar produk CUCKOO K Model untuk lihat rupa, rekaan dan sudut produk.',
  alt: `Gambar produk penapis udara CUCKOO K Model ${index + 1}`
}));

const meta = {
  title: 'Penapis Udara CUCKOO K Model | Harga, Promo & Spesifikasi',
  description:
    'CUCKOO K Model: penapis udara liputan luas 710 sq ft, 4-stage HEPA13, 360° purification & indikator kualiti udara. Sewa dari RM89/bulan atau beli RM2,750.',
  canonical: pageUrl,
  ogImage: ogImg,
  ogType: 'website'
};
---

<BaseLayout {...meta} preloadImages={[heroImg]}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(webPageSchema)} />

  <!-- HERO (gaya King Top 2) -->
  <section id="hero" class="relative overflow-hidden bg-brand-cream px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="absolute left-1/2 top-0 -z-10 h-[620px] w-[620px] -translate-x-1/2 rounded-full bg-brand-soft blur-3xl"></div>

    <div class="mx-auto grid max-w-7xl items-center gap-10 lg:grid-cols-[1.02fr_.98fr]">
      <!-- KIRI: kandungan -->
      <div>
        <div class="mb-5 flex gap-2 overflow-x-auto pb-1 [-ms-overflow-style:none] [scrollbar-width:none] lg:flex-wrap lg:overflow-visible lg:pb-0 [&::-webkit-scrollbar]:hidden">
          <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Ejen CUCKOO sejak 2017</span>
          <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Free Installation</span>
          <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Free Servis</span>
        </div>

        <div class="mb-5 inline-flex max-w-full flex-wrap items-center gap-2 rounded-full bg-[linear-gradient(135deg,#4B0715_0%,#7A0E23_58%,#8E1830_100%)] px-4 py-3 text-white shadow-glow ring-1 ring-brand-gold/30 sm:gap-3 sm:px-5">
          <span class="rounded-full bg-white/15 px-3 py-1 text-[11px] font-black uppercase tracking-[.14em] text-brand-gold">Promo Terkini</span>
          <span class="text-sm font-black sm:text-base">RM{k.promoFirst6} x 6 bulan pertama</span>
        </div>

        <h1 class="text-[2.3rem] font-black leading-[1.08] tracking-tight text-brand-ink sm:text-5xl lg:text-[3.4rem]">
          CUCKOO K Model — Udara Bersih 710 sq ft Untuk Seluruh Rumah
        </h1>

        <!-- Gambar produk (mobile sahaja) -->
        <div class="mt-6 lg:hidden">
          <div class="product-blob accent-ring relative mx-auto max-w-sm overflow-hidden rounded-[1.7rem] p-6">
            <div class="absolute bottom-10 left-1/2 h-14 w-[70%] -translate-x-1/2 rounded-full bg-brand-gold/20 blur-2xl"></div>
            <img src={heroImg} alt="Penapis Udara CUCKOO K Model" width="800" height="1000" loading="eager" fetchpriority="high" class="relative z-10 mx-auto h-[260px] w-auto object-contain drop-shadow-2xl" />
          </div>
        </div>

        <p class="mt-5 max-w-xl text-base leading-8 text-brand-muted sm:text-lg">
          Penapis udara ringan dengan sistem 4-stage Ultra-Deo HEPA13, 360° purification dan servis berkala CUCKOO — udara lebih bersih untuk seluruh rumah pada harga lebih ekonomi.
        </p>

        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <a href="#" onclick="this.href=rotatingWhatsapp()" class="inline-flex items-center justify-center gap-2 rounded-full bg-cta-green px-7 py-4 text-sm font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark">📲 WhatsApp Promo K Model</a>
          <a href="#harga" class="inline-flex items-center justify-center rounded-full border border-brand/15 bg-white px-7 py-4 text-sm font-black text-brand shadow-soft hover:border-brand/30">Lihat Pelan Harga</a>
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <div class="rounded-[1.35rem] bg-brand px-5 py-5 text-white shadow-glow">
            <p class="text-xs font-black uppercase tracking-[.16em] text-brand-gold">Promo Terkini</p>
            <p class="mt-2 text-4xl font-black leading-none">RM{k.promoFirst6}<span class="text-sm font-black">/bulan</span></p>
            <p class="mt-1 text-xs font-bold text-white/75">6 bulan pertama</p>
          </div>
          <a href="#harga" class="rounded-[1.35rem] border border-brand/10 bg-white px-5 py-5 shadow-soft transition hover:-translate-y-1 hover:border-brand/25">
            <p class="text-xs font-black uppercase tracking-[.14em] text-brand-gold">Pelan Rental</p>
            <p class="mt-2 text-xl font-black text-brand">RM{k.rentalY4to5}/bulan · 5 tahun</p>
            <p class="mt-2 text-sm font-bold text-brand-muted">Lihat detail harga →</p>
          </a>
        </div>
      </div>

      <!-- KANAN: kad produk (desktop sahaja) -->
      <div class="hidden rounded-[2rem] border border-white/80 bg-white/70 p-4 shadow-premium backdrop-blur-xl sm:p-6 lg:block">
        <div class="product-blob accent-ring relative overflow-hidden rounded-[1.7rem] p-4 sm:p-6 lg:p-8">
          <div class="flex flex-wrap gap-2">
            <span class="rounded-full bg-white/85 px-4 py-2 text-xs font-black text-brand shadow-soft">Best Seller</span>
            <span class="rounded-full bg-white/85 px-4 py-2 text-xs font-black text-brand shadow-soft">Ultra-Deo HEPA13</span>
          </div>

          <div class="relative mt-5 flex min-h-[300px] items-center justify-center overflow-hidden rounded-[1.5rem] bg-gradient-to-br from-white/80 to-white/35 p-5 sm:min-h-[390px] lg:min-h-[440px]">
            <div class="absolute bottom-12 h-16 w-[72%] rounded-full bg-brand-gold/20 blur-2xl"></div>
            <img src={heroImg} alt="Penapis Udara CUCKOO K Model dengan liputan 710 sq ft" width="800" height="1000" loading="eager" fetchpriority="high" class="relative z-10 h-[290px] w-auto object-contain drop-shadow-2xl sm:h-[380px] lg:h-[425px]" />
          </div>

          <div class="mt-5 flex flex-wrap justify-center gap-2">
            <span class="rounded-full border border-brand/15 bg-brand-soft px-4 py-2 text-xs font-black text-brand">Coverage 710 sq ft</span>
            <span class="rounded-full border border-stone-200 bg-white px-4 py-2 text-xs font-black text-stone-700">360° Purification</span>
            <span class="rounded-full border border-brand-gold/30 bg-amber-50 px-4 py-2 text-xs font-black text-brand-gold">4-Stage HEPA13</span>
          </div>
        </div>

        <div class="mt-4 grid grid-cols-2 gap-2 sm:grid-cols-4">
          <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10"><p class="text-xs font-black text-brand">Ultra-Deo HEPA13</p></div>
          <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10"><p class="text-xs font-black text-brand">360° Purification</p></div>
          <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10"><p class="text-xs font-black text-brand">1-Button Control</p></div>
          <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10"><p class="text-xs font-black text-brand">Servis Berkala</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- COVERAGE STRIP -->
  <section class="bg-gradient-to-br from-[#4B0715] via-brand-maroon to-[#2f0b10] px-4 py-14 text-white sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl items-center gap-8 sm:grid-cols-3">
      <div class="text-center">
        <p class="text-5xl font-black tracking-tight text-promo-gold sm:text-6xl">710<span class="ml-1 text-2xl font-bold text-white/70">sq ft</span></p>
        <p class="mt-2 text-sm font-bold text-white/70">Liputan luas — satu unit, satu rumah</p>
      </div>
      <div class="text-center">
        <p class="text-5xl font-black tracking-tight text-promo-gold sm:text-6xl">7<span class="ml-1 text-2xl font-bold text-white/70">kg</span></p>
        <p class="mt-2 text-sm font-bold text-white/70">Ringan — pindah ikut suka</p>
      </div>
      <div class="text-center">
        <p class="text-5xl font-black tracking-tight text-promo-gold sm:text-6xl">4<span class="ml-1 text-2xl font-bold text-white/70">stage</span></p>
        <p class="mt-2 text-sm font-bold text-white/70">Penapisan HEPA13 + True HEPA H13</p>
      </div>
    </div>
  </section>

  <!-- PROBLEM (PAS) -->
  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-black uppercase tracking-[0.24em] text-brand-maroon">Kenapa Udara Rumah Penting</p>
        <h2 class="mt-4 text-balance text-3xl font-black tracking-tight sm:text-4xl">Udara rumah selalu nampak bersih — sampai anda lihat habuknya</h2>
        <p class="mt-5 text-lg leading-8 text-stone-600">Setiap hari, keluarga anda hirup zarah yang mata tak nampak.</p>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-[1.75rem] bg-stone-50 p-7 ring-1 ring-stone-100">
          <span class="text-3xl">🌫️</span>
          <h3 class="mt-4 text-lg font-black text-brand-ink">Habuk tak habis-habis</h3>
          <p class="mt-2 text-sm leading-6 text-stone-600">Baru lap, esok berdebu balik di perabot dan lantai.</p>
        </div>
        <div class="rounded-[1.75rem] bg-stone-50 p-7 ring-1 ring-stone-100">
          <span class="text-3xl">🤧</span>
          <h3 class="mt-4 text-lg font-black text-brand-ink">Bersin & gatal hidung</h3>
          <p class="mt-2 text-sm leading-6 text-stone-600">Anak asyik selsema, mata berair tanpa sebab yang jelas.</p>
        </div>
        <div class="rounded-[1.75rem] bg-stone-50 p-7 ring-1 ring-stone-100">
          <span class="text-3xl">👃</span>
          <h3 class="mt-4 text-lg font-black text-brand-ink">Bau terperangkap</h3>
          <p class="mt-2 text-sm leading-6 text-stone-600">Bau masakan, peluh, haiwan dan hapak lekat dalam rumah.</p>
        </div>
        <div class="rounded-[1.75rem] bg-stone-50 p-7 ring-1 ring-stone-100">
          <span class="text-3xl">🏭</span>
          <h3 class="mt-4 text-lg font-black text-brand-ink">Jerebu masuk rumah</h3>
          <p class="mt-2 text-sm leading-6 text-stone-600">Bila udara luar teruk, PM2.5 menyelinap masuk.</p>
        </div>
      </div>

      <div class="mx-auto mt-10 max-w-3xl rounded-[2rem] bg-gradient-to-br from-brand-soft to-rose-soft p-7 text-center ring-1 ring-brand-maroon/10">
        <p class="text-lg font-bold leading-8 text-brand-ink">Inilah sebab <strong class="text-brand-maroon">CUCKOO K Model</strong> wujud — menapis apa yang mata tak nampak, supaya setiap nafas dalam rumah lebih bersih dan selesa.</p>
      </div>
    </div>
  </section>

  <!-- 4-STAGE FILTRATION -->
  <section class="bg-brand-soft px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-black uppercase tracking-[0.24em] text-brand-maroon">4-Stage Filtration System</p>
        <h2 class="mt-4 text-balance text-3xl font-black tracking-tight sm:text-4xl">Empat peringkat penapisan, satu udara lebih bersih</h2>
        <p class="mt-5 text-lg leading-8 text-stone-600">Setiap lapisan menapis perkara berbeza — dari habuk kasar hingga PM2.5 dan bau.</p>
      </div>

