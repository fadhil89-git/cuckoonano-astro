---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const base = '/assets/images/products/air-purifier/l-model';
const img = `${base}/penapis-udara-cuckoo-l-model`;
const site = 'https://www.cuckoonano.com';
const pageUrl = `${site}/products/air-purifier/l-model/`;
const priceValidUntil = '2026-12-31';
const dateModified = '2026-06-30';

// ---- Single source of truth: fakta L Model ----
const l = {
  name: 'CUCKOO L Model',
  modelCode: 'CACL1510FW',
  type: 'Air Purifier / Penapis Udara',
  coverage: '600 sq ft (55.7m²)',
  weight: '7kg',
  cadr: '474 m³/h',
  power: '220–240V / 50Hz · 60W',
  noise: '55 dB',
  size: '384(W) × 218(D) × 576(H) mm',
  stages: '4-Stage Filtration System',
  filters: 'Pre-Filter · Allergen Filter · Ultra-Deo HEPA+ H13 (Copper Sulphide) · Deodorisation',
  priceOutright: 3200,
  rentalY1to3: 105,
  rentalY4to5: 100,
  rentalMonths: 60,
  serviceInterval: '4 bulan',
  promoFirst6: 12,
  saving6: 558
};

const heroImg = `${img}-air-purifier-malaysia.webp`;
const ogImg = `${site}${heroImg}`;

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'CUCKOO L Model Air Purifier',
  alternateName: ['Penapis Udara CUCKOO L Model', 'CUCKOO L Model Air Purifier Malaysia'],
  category: 'Air Purifier',
  brand: { '@type': 'Brand', name: 'CUCKOO' },
  manufacturer: { '@type': 'Organization', name: 'CUCKOO' },
  model: 'L Model',
  mpn: l.modelCode,
  sku: l.modelCode,
  description:
    'Penapis udara CUCKOO L Model dengan reka bentuk slim, liputan 600 sq ft, Ultra-Deo HEPA+ H13 Filter (Copper Sulphide), 4-stage filtration, PM2.5 8-colour LED indicator, Plasma Ioniser dan voice navigation 3 bahasa. Sewa dari RM100/bulan atau beli terus RM3,200 di Malaysia. Promo RM12/bulan untuk 6 bulan pertama.',
  url: pageUrl,
  image: [
    ogImg,
    `${site}${img}-front.webp`,
    `${site}${img}-angle-right.webp`,
    `${site}${img}-side-profile.webp`
  ],
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Model Code', value: l.modelCode },
    { '@type': 'PropertyValue', name: 'Coverage', value: l.coverage },
    { '@type': 'PropertyValue', name: 'CADR', value: l.cadr },
    { '@type': 'PropertyValue', name: 'Filtration', value: l.filters },
    { '@type': 'PropertyValue', name: 'Power Consumption', value: l.power },
    { '@type': 'PropertyValue', name: 'Noise Level', value: l.noise },
    { '@type': 'PropertyValue', name: 'Dimensi (W×D×H)', value: l.size },
    { '@type': 'PropertyValue', name: 'Berat', value: l.weight }
  ],
  offers: [
    {
      '@type': 'Offer',
      name: 'Pelan rental CUCKOO (60 bulan)',
      priceCurrency: 'MYR',
      price: String(l.rentalY4to5),
      url: pageUrl,
      availability: 'https://schema.org/InStock',
      itemCondition: 'https://schema.org/NewCondition',
      priceValidUntil,
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: String(l.rentalY4to5),
        priceCurrency: 'MYR',
        unitText: 'MONTH',
        referenceQuantity: { '@type': 'QuantitativeValue', value: String(l.rentalMonths), unitText: 'MONTH' }
      },
      seller: { '@type': 'Organization', name: 'CUCKOO', url: site }
    },
    {
      '@type': 'Offer',
      name: 'Beli terus (outright)',
      priceCurrency: 'MYR',
      price: String(l.priceOutright),
      url: pageUrl,
      availability: 'https://schema.org/InStock',
      itemCondition: 'https://schema.org/NewCondition',
      priceValidUntil,
      seller: { '@type': 'Organization', name: 'CUCKOO', url: site }
    }
  ]
};

const faqs = [
  { q: 'Apa itu CUCKOO L Model?', a: 'CUCKOO L Model ialah air purifier slim dan moden yang direka untuk membantu membersihkan udara dalam bilik sederhana, home office, studio, ruang tamu sederhana atau pejabat kecil.' },
  { q: 'Berapa luas coverage CUCKOO L Model?', a: 'CUCKOO L Model mempunyai coverage sehingga 600 sq ft / 55.7m², sesuai untuk ruang bersaiz sederhana.' },
  { q: 'Apakah filter yang digunakan oleh CUCKOO L Model?', a: 'CUCKOO L Model menggunakan Pre-Filter, Allergen Filter dan Ultra-Deo HEPA+ H13 Filter dengan Copper Sulphide coating.' },
  { q: 'Apa kelebihan Ultra-Deo HEPA+ H13 Filter?', a: 'Ultra-Deo HEPA+ H13 Filter membantu menapis fine dust, asap, alergen, bau kurang menyenangkan dan gas tertentu. Ia juga mempunyai Copper Sulphide coating untuk menyokong fungsi deodorising dan filter hygiene.' },
  { q: 'Adakah CUCKOO L Model sesuai untuk bilik tidur?', a: 'Ya. CUCKOO L Model sesuai untuk bilik tidur kerana saiznya slim, noise level sekitar 55dB dan mempunyai Sleep Mode untuk penggunaan waktu malam.' },
  { q: 'Adakah CUCKOO L Model sesuai untuk pejabat kecil?', a: 'Ya. Dengan coverage sehingga 600 sq ft dan reka bentuk moden, CUCKOO L Model sesuai untuk office room, home office, studio atau ruang kerja kecil.' },
  { q: 'Adakah CUCKOO L Model sesuai untuk rumah yang ada haiwan peliharaan?', a: 'Ya. Pre-Filter membantu menangkap bulu haiwan, manakala deodorisation function membantu mengurangkan bau kurang menyenangkan.' },
  { q: 'Apa fungsi PM2.5 Air Quality Indicator?', a: 'PM2.5 Air Quality Indicator membantu menunjukkan tahap kualiti udara semasa melalui indikator warna yang mudah difahami.' },
  { q: 'Berapa warna LED indicator CUCKOO L Model?', a: 'CUCKOO L Model mempunyai 8-colour LED Air Quality Indicator — Blue, Teal, Green, Light Green, Yellow, Orange, Purple dan Red.' },
  { q: 'Apa bahasa voice navigation CUCKOO L Model?', a: 'Voice navigation CUCKOO L Model menyokong English, Malay dan Mandarin.' },
  { q: 'Adakah CUCKOO L Model ada Child Lock?', a: 'Ya. CUCKOO L Model mempunyai Child Lock untuk mengelakkan tetapan diubah secara tidak sengaja.' },
  { q: 'Berapa harga promo CUCKOO L Model?', a: 'Untuk promo semasa, bayaran ialah RM12 sebulan untuk 6 bulan pertama, kemudian RM105 sebulan untuk bulan ke-7 hingga 36, dan RM100 sebulan untuk bulan ke-37 hingga 60. Promo tertakluk kepada stok, kawasan, kelulusan dan terma semasa.' }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } }))
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site}/` },
    { '@type': 'ListItem', position: 2, name: 'Produk', item: `${site}/products/` },
    { '@type': 'ListItem', position: 3, name: 'Air Purifier', item: `${site}/products/air-purifier/` },
    { '@type': 'ListItem', position: 4, name: 'L Model', item: pageUrl }
  ]
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Penapis Udara CUCKOO L Model',
  description:
    'Maklumat lengkap CUCKOO L Model Air Purifier termasuk harga, promo RM12, spesifikasi, Ultra-Deo HEPA+ H13, gambar produk dan FAQ.',
  url: pageUrl,
  inLanguage: 'ms-MY',
  dateModified,
  isPartOf: { '@type': 'WebSite', name: 'CUCKOONANO', url: site },
  primaryImageOfPage: { '@type': 'ImageObject', url: ogImg },
  breadcrumb: breadcrumbSchema
};

// ---- Data seksyen ----
const filtration = [
  { n: '1', title: 'Pre-Filter', desc: 'Menapis habuk besar, rambut dan bulu haiwan sambil melindungi filter lain.', care: 'Pembersihan setiap 2 minggu' },
  { n: '2', title: 'Allergen Filter', desc: 'Menangkap alergen seperti debunga, habuk halus dan partikel pernafasan.', care: 'Pertukaran setiap 4 bulan' },
  { n: '3', title: 'Ultra-Deo HEPA+ H13', desc: 'Menapis fine dust, asap, alergen dan gas tertentu dengan True HEPA+ H13.', care: 'Pertukaran setiap 12 bulan' },
  { n: '4', title: 'Deodorisation', desc: 'Mengurangkan bau kurang menyenangkan untuk udara yang lebih segar.', care: 'Sebahagian filter HEPA+ H13' }
];

const ledColours = [
  { name: 'Blue', hex: '#2563eb', tier: 'Excellent' },
  { name: 'Teal', hex: '#0d9488', tier: 'Excellent' },
  { name: 'Green', hex: '#16a34a', tier: 'Good' },
  { name: 'Light Green', hex: '#84cc16', tier: 'Good' },
  { name: 'Yellow', hex: '#eab308', tier: 'Moderate' },
  { name: 'Orange', hex: '#f97316', tier: 'Moderate' },
  { name: 'Purple', hex: '#9333ea', tier: 'Bad' },
  { name: 'Red', hex: '#dc2626', tier: 'Bad' }
];

const supportFeatures = [
  { image: `${img}-copper-sulphide.webp`, title: 'Copper Sulphide Coating', desc: 'Sokongan antimicrobial & deodorising untuk hygiene filter yang lebih baik.', alt: 'Ultra-Deo HEPA+ H13 filter CUCKOO L Model dengan Copper Sulphide coating' },
  { image: `${img}-voice-navigation.webp`, title: 'Voice Navigation 3 Bahasa', desc: 'Panduan suara dalam English, Malay & Mandarin — status mesin mudah difahami.', alt: 'Voice navigation CUCKOO L Model dalam 3 bahasa English Malay Mandarin' },
  { image: `${img}-sleep-mode-55db.webp`, title: 'Senyap 55dB · Sleep Mode', desc: 'Setenang hujan renyai — selesa untuk waktu tidur tanpa gangguan bunyi.', alt: 'CUCKOO L Model beroperasi senyap pada 55dB untuk waktu tidur' },
  { image: `${img}-smart-lights.webp`, title: 'Smart Lights, Smart Saving', desc: 'LED auto-redup bila bilik gelap selama 1 minit — jimat tenaga waktu malam.', alt: 'CUCKOO L Model meredupkan LED secara automatik ketika gelap' }
];

const modes = [
  { icon: '🔄', title: 'Auto / Eco Mode', desc: 'Melaras operasi automatik ikut kualiti udara semasa.' },
  { icon: '⚡', title: 'Turbo Mode', desc: 'Meningkatkan kelajuan kipas untuk pembersihan lebih cepat.' },
  { icon: '🌿', title: 'Energy Conservation', desc: 'Penggunaan tenaga yang lebih bijak dan ekonomi.' },
  { icon: '🌙', title: 'Sleep Mode', desc: 'Bunyi dan gangguan minimum untuk waktu tidur.' },
  { icon: '🎚️', title: 'Manual Mode', desc: 'Pilih tahap kelajuan kipas secara manual.' },
  { icon: '⏱️', title: 'Timer Mode', desc: 'Tetapan operasi 1 jam, 4 jam atau 8 jam.' },
  { icon: '🔒', title: 'Child Lock', desc: 'Tekan timer 3 saat — kunci tetapan daripada anak kecil.' }
];

const galleryItems = [
  { image: `${img}-front.webp`, title: 'Pandangan Hadapan', copy: 'Reka bentuk slim dengan butang sentuhan dan air quality ring di atas.', alt: 'Penapis udara CUCKOO L Model pandangan hadapan warna putih' },
  { image: `${img}-angle-right.webp`, title: 'Sudut Kanan', copy: 'Profil nipis yang mudah diletakkan di tepi katil atau sudut bilik.', alt: 'Penapis udara CUCKOO L Model sudut kanan menunjukkan rekaan slim' },
  { image: `${img}-angle-left.webp`, title: 'Sudut Kiri', copy: 'Pemegang sisi memudahkan unit dipindahkan antara ruang.', alt: 'Penapis udara CUCKOO L Model sudut kiri dengan pemegang sisi' },
  { image: `${img}-side-profile.webp`, title: 'Profil Sisi', copy: 'Ketebalan kemas — hanya 218mm, sesuai untuk ruang terhad.', alt: 'Penapis udara CUCKOO L Model profil sisi yang nipis' },
  { image: `${img}-control-panel.webp`, title: 'Panel Kawalan', copy: 'Kawalan one-touch: ON/OFF, modes, timer dan child lock.', alt: 'Panel kawalan sentuhan CUCKOO L Model dengan butang one-touch' },
  { image: `${img}-filter-side.webp`, title: 'Ultra-Deo HEPA+ H13', copy: 'Filter premium dengan Copper Sulphide coating.', alt: 'Ultra-Deo HEPA+ H13 filter CUCKOO L Model dari sisi' }
];

const meta = {
  title: 'Penapis Udara CUCKOO L Model | Harga, Promo RM12 & Spesifikasi',
  description:
    'CUCKOO L Model: penapis udara slim 600 sq ft, Ultra-Deo HEPA+ H13, PM2.5 8-colour LED, Plasma Ioniser & voice 3 bahasa. Promo RM12/bulan, sewa RM100 atau beli RM3,200.',
  canonical: pageUrl,
  ogImage: ogImg,
  ogType: 'website'
};
---

<BaseLayout {...meta} preloadImages={[heroImg]}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(webPageSchema)} />

  <!-- HERO -->
  <section id="hero" class="relative overflow-hidden bg-brand-cream px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="absolute left-1/2 top-0 -z-10 h-[620px] w-[620px] -translate-x-1/2 rounded-full bg-brand-soft blur-3xl"></div>

    <div class="mx-auto grid max-w-7xl items-center gap-10 lg:grid-cols-[1.02fr_.98fr]">
      <div>
        <div class="mb-5 flex gap-2 overflow-x-auto pb-1 [-ms-overflow-style:none] [scrollbar-width:none] lg:flex-wrap lg:overflow-visible lg:pb-0 [&::-webkit-scrollbar]:hidden">
          <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Ejen CUCKOO sejak 2017</span>
          <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Free Installation</span>
          <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Free Servis</span>
        </div>

        <div class="mb-5 inline-flex max-w-full flex-wrap items-center gap-2 rounded-full bg-[linear-gradient(135deg,#4B0715_0%,#7A0E23_58%,#8E1830_100%)] px-4 py-3 text-white shadow-glow ring-1 ring-brand-gold/30 sm:gap-3 sm:px-5">
          <span class="rounded-full bg-white/15 px-3 py-1 text-[11px] font-black uppercase tracking-[.14em] text-brand-gold">Promo Terkini</span>
          <span class="text-sm font-black sm:text-base">RM{l.promoFirst6} x 6 bulan pertama</span>
        </div>

        <h1 class="text-[2.3rem] font-black leading-[1.08] tracking-tight text-brand-ink sm:text-5xl lg:text-[3.4rem]">
          CUCKOO L Model — Penapis Udara Slim 600 sq ft Untuk Bilik & Ruang Sederhana
        </h1>

        <!-- Gambar produk (mobile sahaja) -->
        <div class="mt-6 lg:hidden">
          <div class="product-blob accent-ring relative mx-auto max-w-sm overflow-hidden rounded-[1.7rem] p-6">
            <div class="absolute bottom-10 left-1/2 h-14 w-[70%] -translate-x-1/2 rounded-full bg-brand-gold/20 blur-2xl"></div>
            <img src={heroImg} alt="Penapis Udara CUCKOO L Model slim warna putih" width="800" height="1000" loading="eager" fetchpriority="high" class="relative z-10 mx-auto h-[280px] w-auto object-contain drop-shadow-2xl" />
          </div>
        </div>

        <p class="mt-5 max-w-xl text-base leading-8 text-brand-muted sm:text-lg">
          Penapis udara moden dengan reka bentuk slim, Ultra-Deo HEPA+ H13, PM2.5 8-colour LED indicator dan Plasma Ioniser — udara lebih bersih untuk bilik tidur, home office, studio atau ruang tamu sederhana.
        </p>

        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <a href="#" onclick="this.href=rotatingWhatsapp()" class="inline-flex items-center justify-center gap-2 rounded-full bg-cta-green px-7 py-4 text-sm font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark">📲 WhatsApp Promo L Model</a>
          <a href="#harga" class="inline-flex items-center justify-center rounded-full border border-brand/15 bg-white px-7 py-4 text-sm font-black text-brand shadow-soft hover:border-brand/30">Lihat Pelan Harga</a>
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <div class="rounded-[1.35rem] bg-brand px-5 py-5 text-white shadow-glow">
            <p class="text-xs font-black uppercase tracking-[.16em] text-brand-gold">Promo Terkini</p>
            <p class="mt-2 text-4xl font-black leading-none">RM{l.promoFirst6}<span class="text-sm font-black">/bulan</span></p>
            <p class="mt-1 text-xs font-bold text-white/75">6 bulan pertama · jimat RM{l.saving6}</p>
          </div>
          <a href="#harga" class="rounded-[1.35rem] border border-brand/10 bg-white px-5 py-5 shadow-soft transition hover:-translate-y-1 hover:border-brand/25">
            <p class="text-xs font-black uppercase tracking-[.14em] text-brand-gold">Pelan Rental</p>
            <p class="mt-2 text-xl font-black text-brand">RM{l.rentalY4to5}/bulan · 5 tahun</p>
            <p class="mt-2 text-sm font-bold text-brand-muted">Lihat detail harga →</p>
          </a>
        </div>
      </div>

      <!-- KANAN: kad produk (desktop sahaja) -->
      <div class="hidden rounded-[2rem] border border-white/80 bg-white/70 p-4 shadow-premium backdrop-blur-xl sm:p-6 lg:block">
        <div class="product-blob accent-ring relative overflow-hidden rounded-[1.7rem] p-4 sm:p-6 lg:p-8">
          <div class="flex flex-wrap gap-2">
            <span class="rounded-full bg-white/85 px-4 py-2 text-xs font-black text-brand shadow-soft">Slim & Modern</span>
            <span class="rounded-full bg-white/85 px-4 py-2 text-xs font-black text-brand shadow-soft">Ultra-Deo HEPA+ H13</span>
          </div>

          <div class="relative mt-5 flex min-h-[300px] items-center justify-center overflow-hidden rounded-[1.5rem] bg-gradient-to-br from-white/80 to-white/35 p-5 sm:min-h-[390px] lg:min-h-[440px]">
            <div class="absolute bottom-12 h-16 w-[72%] rounded-full bg-brand-gold/20 blur-2xl"></div>
            <img src={heroImg} alt="Penapis Udara CUCKOO L Model slim dengan liputan 600 sq ft" width="800" height="1000" loading="eager" fetchpriority="high" class="relative z-10 h-[290px] w-auto object-contain drop-shadow-2xl sm:h-[380px] lg:h-[425px]" />
          </div>

          <div class="mt-5 flex flex-wrap justify-center gap-2">
            <span class="rounded-full border border-brand/15 bg-brand-soft px-4 py-2 text-xs font-black text-brand">Coverage 600 sq ft</span>
            <span class="rounded-full border border-stone-200 bg-white px-4 py-2 text-xs font-black text-stone-700">PM2.5 Indicator</span>
            <span class="rounded-full border border-brand-gold/30 bg-amber-50 px-4 py-2 text-xs font-black text-brand-gold">Plasma Ioniser</span>
          </div>
        </div>

        <div class="mt-4 grid grid-cols-2 gap-2 sm:grid-cols-4">
          <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10"><p class="text-xs font-black text-brand">8-Colour LED</p></div>
          <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10"><p class="text-xs font-black text-brand">Voice 3 Bahasa</p></div>
          <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10"><p class="text-xs font-black text-brand">7 Modes</p></div>
          <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10"><p class="text-xs font-black text-brand">Senyap 55dB</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- COVERAGE STRIP -->
  <section class="bg-gradient-to-br from-[#4B0715] via-brand-maroon to-[#2f0b10] px-4 py-14 text-white sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl items-center gap-8 sm:grid-cols-4">
      <div class="text-center">
        <p class="text-4xl font-black tracking-tight text-promo-gold sm:text-5xl">600<span class="ml-1 text-xl font-bold text-white/70">sq ft</span></p>
        <p class="mt-2 text-sm font-bold text-white/70">Liputan ruang sederhana</p>
      </div>
      <div class="text-center">
        <p class="text-4xl font-black tracking-tight text-promo-gold sm:text-5xl">7<span class="ml-1 text-xl font-bold text-white/70">kg</span></p>
        <p class="mt-2 text-sm font-bold text-white/70">Ringan & slim — mudah pindah</p>
      </div>
      <div class="text-center">
        <p class="text-4xl font-black tracking-tight text-promo-gold sm:text-5xl">4<span class="ml-1 text-xl font-bold text-white/70">stage</span></p>
        <p class="mt-2 text-sm font-bold text-white/70">Penapisan HEPA+ H13</p>
      </div>
      <div class="text-center">
        <p class="text-4xl font-black tracking-tight text-promo-gold sm:text-5xl">55<span class="ml-1 text-xl font-bold text-white/70">dB</span></p>
        <p class="mt-2 text-sm font-bold text-white/70">Senyap untuk waktu tidur</p>
      </div>
    </div>
  </section>

  <!-- PROBLEM (PAS) -->
  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-black uppercase tracking-[0.24em] text-brand-maroon">Kenapa Udara Rumah Penting</p>
        <h2 class="mt-4 text-balance text-3xl font-black tracking-tight sm:text-4xl">Bilik nampak bersih — tapi udaranya belum tentu</h2>
        <p class="mt-5 text-lg leading-8 text-stone-600">Setiap hari kita hirup zarah halus yang mata tak nampak, terutama dalam ruang tertutup.</p>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-[1.75rem] bg-stone-50 p-7 ring-1 ring-stone-100">
          <span class="text-3xl">🌫️</span>
          <h3 class="mt-4 text-lg font-black text-brand-ink">Habuk halus & PM2.5</h3>
          <p class="mt-2 text-sm leading-6 text-stone-600">Fine dust terapung di udara bilik yang sukar dilihat mata.</p>
        </div>
        <div class="rounded-[1.75rem] bg-stone-50 p-7 ring-1 ring-stone-100">
          <span class="text-3xl">🤧</span>
          <h3 class="mt-4 text-lg font-black text-brand-ink">Alergen & bersin</h3>
          <p class="mt-2 text-sm leading-6 text-stone-600">Debunga, hama habuk dan bulu haiwan ganggu pernafasan.</p>
        </div>
        <div class="rounded-[1.75rem] bg-stone-50 p-7 ring-1 ring-stone-100">
          <span class="text-3xl">👃</span>
          <h3 class="mt-4 text-lg font-black text-brand-ink">Bau terperangkap</h3>
