<style is:global>
  html { scroll-behavior: smooth; }
  .text-balance { text-wrap: balance; }
  .product-blob { background: radial-gradient(circle at 40% 35%, rgba(216,166,74,.28), transparent 38%), radial-gradient(circle at 65% 58%, rgba(122,14,35,.18), transparent 42%), linear-gradient(145deg, #fff8f2, #ffffff); }
  .accent-ring { box-shadow: 0 30px 80px rgba(20,20,20,.16); }
</style>

<script is:inline define:vars={{ gSlides: productPhotos.map((p) => ({ src: p.image, alt: p.alt })) }}>
  // Galeri gambar produk — slider gambar besar + zoom
  let gi = 0;
  const gImg = document.getElementById('gImg');
  const gDots = document.getElementById('gDots');
  const gPrev = document.getElementById('gPrev');
  const gNext = document.getElementById('gNext');

  function renderG(index) {
    gi = (index + gSlides.length) % gSlides.length;
    if (gImg) { gImg.src = gSlides[gi].src; gImg.alt = gSlides[gi].alt; }
    if (gDots) {
      gDots.innerHTML = '';
      gSlides.forEach((_, di) => {
        const dot = document.createElement('button');
        dot.type = 'button';
        dot.setAttribute('aria-label', 'Lihat gambar ' + (di + 1));
        dot.className = di === gi ? 'h-3 w-8 rounded-full bg-brand-maroon transition' : 'h-3 w-3 rounded-full bg-stone-300 transition hover:bg-brand-maroon';
        dot.addEventListener('click', () => renderG(di));
        gDots.appendChild(dot);
      });
    }
  }
  if (gPrev) gPrev.addEventListener('click', () => renderG(gi - 1));
  if (gNext) gNext.addEventListener('click', () => renderG(gi + 1));
  if (gImg) {
    renderG(0);
    let sx = 0, swiped = false;
    const stage = gImg.parentElement;
    stage.addEventListener('touchstart', (e) => { sx = e.touches[0] ? e.touches[0].clientX : 0; swiped = false; }, { passive: true });
    stage.addEventListener('touchend', (e) => {
      const t = e.changedTouches[0]; if (!t) return;
      const dx = t.clientX - sx;
      if (Math.abs(dx) > 40) { swiped = true; renderG(gi + (dx < 0 ? 1 : -1)); }
    }, { passive: true });
    gImg.addEventListener('click', () => { if (swiped) { swiped = false; return; } openZoom(gImg.currentSrc || gImg.src, gImg.alt); });
  }

  // Zoom lightbox
  const zoomLightbox = document.getElementById('zoomLightbox');
  const zoomImage = document.getElementById('zoomImage');
  function openZoom(src, alt) {
    if (!zoomLightbox || !zoomImage || !src) return;
    zoomImage.src = src; zoomImage.alt = alt || '';
    zoomLightbox.classList.remove('hidden'); zoomLightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }
  function closeZoom() {
    if (!zoomLightbox) return;
    zoomLightbox.classList.add('hidden'); zoomLightbox.classList.remove('flex');
    document.body.style.overflow = '';
  }
  if (zoomLightbox) {
    zoomLightbox.addEventListener('click', (e) => { if (e.target === zoomLightbox || e.target.id === 'zoomClose') closeZoom(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeZoom(); });
  }

  // Testimoni slider — butang + drag
  const testiTrack = document.getElementById('testiTrack');
  const testiPrev = document.getElementById('testiPrev');
  const testiNext = document.getElementById('testiNext');
  if (testiTrack) {
    const stepWidth = () => {
      const slide = testiTrack.querySelector('.testi-slide');
      const gap = parseFloat(getComputedStyle(testiTrack).columnGap || '20') || 20;
      return slide ? slide.getBoundingClientRect().width + gap : testiTrack.clientWidth * 0.8;
    };
    if (testiPrev) testiPrev.addEventListener('click', () => testiTrack.scrollBy({ left: -stepWidth(), behavior: 'smooth' }));
    if (testiNext) testiNext.addEventListener('click', () => testiTrack.scrollBy({ left: stepWidth(), behavior: 'smooth' }));
    let isDown = false, startX = 0, startScroll = 0, moved = false;
    testiTrack.addEventListener('pointerdown', (e) => { isDown = true; moved = false; startX = e.clientX; startScroll = testiTrack.scrollLeft; testiTrack.classList.add('cursor-grabbing'); });
    testiTrack.addEventListener('pointermove', (e) => { if (!isDown) return; const delta = e.clientX - startX; if (Math.abs(delta) > 4) moved = true; testiTrack.scrollLeft = startScroll - delta; });
    const endDrag = () => { isDown = false; testiTrack.classList.remove('cursor-grabbing'); };
    testiTrack.addEventListener('pointerup', endDrag);
    testiTrack.addEventListener('pointerleave', endDrag);
    testiTrack.addEventListener('click', (e) => { if (moved) { e.preventDefault(); e.stopPropagation(); } }, true);
  }
</script>
