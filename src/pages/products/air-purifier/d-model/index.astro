---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ProductGallerySlider from '../../../../components/ProductGallerySlider.astro';

const base = '/assets/images/products/air-purifier/d-model';
const site = 'https://www.cuckoonano.com';
const pageUrl = `${site}/products/air-purifier/d-model/`;
const priceValidUntil = '2026-12-31';
const dateModified = '2026-06-27';

// ---- Single source of truth: fakta D Model ----
const d = {
  name: 'CUCKOO D Model',
  type: 'Air Purifier / Penapis Udara',
  coverage: '710 sq ft (66m²)',
  weight: '11kg',
  power: 'AC 220–240V / 65W',
  sensor: 'Fine Dust Sensor',
  size: '396(W) × 396(D) × 755(H) mm',
  stages: '4-Stage Filtration System (3 Filters)',
  filters: 'Pre-Filter · Allergen Filter · Ultra-Deo HEPA14',
  voice: 'English · Malay · Chinese · Korean',
  priceOutright: 3550,
  rentalY1to3: 127,
  rentalY4to5: 122,
  rentalMonths: 60,
  carePackage: 605, // setahun
  serviceInterval: '4 bulan',
  processingFee: 250
};

const heroImg = `${base}/penapis-udara-cuckoo-d-model-air-purifier-malaysia.webp`;
const ogImg = `${site}${heroImg}`;

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'CUCKOO D Model Air Purifier',
  alternateName: ['Penapis Udara CUCKOO D Model', 'CUCKOO D Model Air Purifier Malaysia'],
  category: 'Air Purifier',
  brand: { '@type': 'Brand', name: 'CUCKOO' },
  manufacturer: { '@type': 'Organization', name: 'CUCKOO' },
  model: 'D Model',
  description:
    'Penapis udara CUCKOO D Model — premium untuk ruang besar dengan liputan 710 sq ft, 360° absorption, Ultra-Deo HEPA14 Filter, Plasma Ioniser, 10 operating modes dan voice navigation 4 bahasa. Sewa dari RM127/bulan atau beli terus RM3,550 di Malaysia.',
  url: pageUrl,
  image: [
    ogImg,
    `${site}${base}/penapis-udara-cuckoo-d-model-ruang-tamu.webp`,
    `${site}${base}/penapis-udara-cuckoo-d-model-99-buang-bakteria-toksik.webp`
  ],
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Coverage', value: d.coverage },
    { '@type': 'PropertyValue', name: 'Filtration', value: d.filters },
    { '@type': 'PropertyValue', name: 'Sensor', value: d.sensor },
    { '@type': 'PropertyValue', name: 'Voice Navigation', value: d.voice },
    { '@type': 'PropertyValue', name: 'Power Consumption', value: d.power },
    { '@type': 'PropertyValue', name: 'Dimensi (W×D×H)', value: d.size },
    { '@type': 'PropertyValue', name: 'Berat', value: d.weight }
  ],
  offers: [
    {
      '@type': 'Offer',
      name: 'Pelan rental CUCKOO (60 bulan)',
      priceCurrency: 'MYR',
      price: String(d.rentalY4to5),
      url: pageUrl,
      availability: 'https://schema.org/InStock',
      itemCondition: 'https://schema.org/NewCondition',
      priceValidUntil,
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: String(d.rentalY4to5),
        priceCurrency: 'MYR',
        unitText: 'MONTH',
        referenceQuantity: { '@type': 'QuantitativeValue', value: String(d.rentalMonths), unitText: 'MONTH' }
      },
      seller: { '@type': 'Organization', name: 'CUCKOO', url: site }
    },
    {
      '@type': 'Offer',
      name: 'Beli terus (outright)',
      priceCurrency: 'MYR',
      price: String(d.priceOutright),
      url: pageUrl,
      availability: 'https://schema.org/InStock',
      itemCondition: 'https://schema.org/NewCondition',
      priceValidUntil,
      seller: { '@type': 'Organization', name: 'CUCKOO', url: site }
    }
  ]
};

const faqs = [
  { q: 'Apa fungsi CUCKOO D Model Air Purifier?', a: 'CUCKOO D Model membantu membersihkan udara dalam ruang dalaman dengan sistem penapisan 4 peringkat, Ultra-Deo HEPA14 Filter, 360° absorption, Plasma Ioniser dan air quality indicator. Ia sesuai untuk ruang besar seperti ruang tamu, pejabat, pantry dan bilik keluarga.' },
  { q: 'Berapa luas coverage CUCKOO D Model?', a: 'CUCKOO D Model mempunyai recommended coverage sekitar 66m² / 710 sq ft, sesuai untuk ruang tamu besar, pejabat, pantry, bilik mesyuarat atau ruang keluarga.' },
  { q: 'Adakah CUCKOO D Model sesuai untuk pejabat?', a: 'Ya. Dengan coverage luas, 360° absorption, 10 operating modes dan air quality detection, CUCKOO D Model sesuai digunakan di pejabat, bilik mesyuarat, pantry atau ruang kerja.' },
  { q: 'Apa kelebihan 360° absorption?', a: '360° absorption membolehkan CUCKOO D Model menyerap udara dari pelbagai arah. Ini membantu proses pembersihan udara menjadi lebih menyeluruh, terutama untuk ruang yang luas.' },
  { q: 'Apakah filter yang digunakan oleh CUCKOO D Model?', a: 'CUCKOO D Model menggunakan Pre-Filter, Allergen Filter dan Ultra-Deo HEPA14 Filter. Ultra-Deo HEPA Filter menggabungkan fungsi deodorisation filter dan True HEPA filter.' },
  { q: 'Apa beza HEPA14 dengan HEPA13?', a: 'Secara umum, HEPA14 ialah tahap penapisan yang lebih tinggi berbanding HEPA13. Untuk CUCKOO D Model, penggunaan Ultra-Deo HEPA14 Filter menjadikannya pilihan yang lebih premium dalam kategori air purifier CUCKOO.' },
  { q: 'Adakah CUCKOO D Model boleh membantu ketika musim jerebu?', a: 'Ya. CUCKOO D Model sesuai digunakan ketika musim jerebu kerana ia membantu menapis habuk halus dan partikel udara. Yellow Dust Mode juga sesuai digunakan apabila keadaan udara kurang baik.' },
  { q: 'Adakah CUCKOO D Model boleh mengurangkan bau?', a: 'Ya. Ultra-Deo HEPA14 Filter membantu mengurangkan bau kurang menyenangkan seperti bau asap, bau masakan, bau haiwan peliharaan dan bau dalam ruang tertutup.' },
  { q: 'Apa fungsi Plasma Ioniser?', a: 'Plasma Ioniser membantu menyokong proses pembersihan udara dengan menghasilkan ion negatif yang membantu mengumpulkan partikel halus supaya udara lebih mudah ditapis dan terasa lebih segar.' },
  { q: 'Apa fungsi voice navigation?', a: 'Voice navigation membantu pengguna memahami status atau fungsi mesin melalui panduan suara. CUCKOO D Model menyokong 4 bahasa iaitu English, Malay, Chinese dan Korean.' },
  { q: 'Adakah CUCKOO D Model ada indikator kualiti udara?', a: 'Ya. CUCKOO D Model mempunyai air quality detection dan 6-colour air cleanliness indicator untuk menunjukkan tahap kebersihan udara semasa.' },
  { q: 'Bila filter CUCKOO D Model perlu dibersihkan atau ditukar?', a: 'Pre-Filter disarankan untuk dibersihkan setiap 2 minggu. Allergen Filter disarankan ditukar setiap 4 bulan. Ultra-Deo HEPA14 Filter disarankan ditukar setiap 12 bulan. CUCKOO D Model juga mempunyai filter replacement indicator sebagai peringatan.' },
  { q: 'Apa beza CUCKOO D Model dengan R Model dan K Model?', a: 'CUCKOO D Model lebih premium dengan Ultra-Deo HEPA14 Filter, voice navigation 4 bahasa, 10 operating modes dan 360° absorption. R Model lebih compact dan stylish untuk ruang kecil hingga sederhana, manakala K Model memberi coverage besar dengan harga lebih rendah.' }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } }))
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site}/` },
    { '@type': 'ListItem', position: 2, name: 'Produk', item: `${site}/products/` },
    { '@type': 'ListItem', position: 3, name: 'Air Purifier', item: `${site}/products/air-purifier/` },
    { '@type': 'ListItem', position: 4, name: 'D Model', item: pageUrl }
  ]
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Penapis Udara CUCKOO D Model',
  description:
    'Maklumat lengkap CUCKOO D Model Air Purifier — premium untuk ruang besar: harga, promo, spesifikasi, Ultra-Deo HEPA14, Plasma Ioniser, voice navigation 4 bahasa, gambar produk dan FAQ.',
  url: pageUrl,
  inLanguage: 'ms-MY',
  dateModified,
  isPartOf: { '@type': 'WebSite', name: 'CUCKOONANO', url: site },
  primaryImageOfPage: { '@type': 'ImageObject', url: ogImg },
  breadcrumb: breadcrumbSchema
};

const modes = [
  { icon: `${base}/penapis-udara-cuckoo-d-model-mode-auto.webp`, title: 'Auto Mode', desc: 'Mengesan kualiti udara dan melaras tetapan pembersihan secara automatik.' },
  { icon: `${base}/penapis-udara-cuckoo-d-model-mode-sterilisation.webp`, title: 'Sterilisation Mode', desc: 'Mengaktifkan Plasma Ioniser untuk membantu pembersihan & penyegaran udara.' },
  { icon: `${base}/penapis-udara-cuckoo-d-model-mode-turbo.webp`, title: 'Turbo Mode', desc: 'Meningkatkan kelajuan kipas untuk pembersihan udara dengan lebih pantas.' },
  { icon: `${base}/penapis-udara-cuckoo-d-model-mode-baby.webp`, title: 'Baby Mode', desc: 'Mengurangkan cahaya & bunyi supaya selesa ketika bayi atau anak kecil berehat.' },
  { icon: `${base}/penapis-udara-cuckoo-d-model-mode-room-care.webp`, title: 'Room Care Mode', desc: 'Melaras kelajuan kipas berdasarkan saiz ruang untuk pembersihan lebih sesuai.' },
  { icon: `${base}/penapis-udara-cuckoo-d-model-mode-yellow-dust.webp`, title: 'Yellow Dust Mode', desc: 'Membantu menapis habuk halus, partikel jerebu dan udara luar yang kurang baik.' },
  { icon: `${base}/penapis-udara-cuckoo-d-model-mode-energy-eye.webp`, title: 'Energy Eye Mode', desc: 'Mengesan keadaan bilik & mengurangkan cahaya untuk penggunaan tenaga lebih bijak.' },
  { icon: `${base}/penapis-udara-cuckoo-d-model-mode-repeat.webp`, title: 'Repeat Mode', desc: 'Beroperasi mengikut tetapan masa tertentu untuk penggunaan lebih konsisten.' },
  { icon: `${base}/penapis-udara-cuckoo-d-model-mode-lock.webp`, title: 'Lock Mode', desc: 'Mengunci butang supaya tetapan tidak mudah berubah secara tidak sengaja.' },
  { icon: `${base}/penapis-udara-cuckoo-d-model-mode-filter-indicator.webp`, title: 'Filter Replacement Indicator', desc: 'Memberi peringatan apabila filter perlu dibersihkan atau ditukar.' }
];

const filtration = [
  { n: '1', title: 'Pre-Filter', desc: 'Menapis habuk kasar, rambut, bulu haiwan dan partikel besar daripada udara.', period: 'Bersihkan setiap 2 minggu' },
  { n: '2', title: 'Allergen Filter', desc: 'Menapis alergen di udara seperti habuk halus, debunga dan partikel pengganggu pernafasan.', period: 'Tukar setiap 4 bulan' },
  { n: '3', title: 'Ultra-Deo HEPA14 Filter', desc: 'Gabungan deodorisation filter & True HEPA — tapis partikel halus dan kurangkan bau kurang menyenangkan.', period: 'Tukar setiap 12 bulan' }
];

const plasmaSteps = [
  { icon: `${base}/penapis-udara-cuckoo-d-model-plasma-ioniser-generate.webp`, title: 'Hasil Ion Negatif', desc: 'Plasma Ioniser menghasilkan ion negatif yang mencas partikel halus di udara.' },
  { icon: `${base}/penapis-udara-cuckoo-d-model-plasma-ioniser-destroy.webp`, title: 'Ikat Pencemar', desc: 'Ion membantu mengumpul & menyahaktif kontaminan bawaan udara supaya mudah ditapis.' },
  { icon: `${base}/penapis-udara-cuckoo-d-model-plasma-ioniser-create.webp`, title: 'Udara Lebih Segar', desc: 'Hasilnya udara dalaman yang terasa lebih bersih, ringan dan segar sepanjang hari.' }
];

const airColours = [
  { c: '#2563eb', label: 'Sangat Bersih' },
  { c: '#22c55e', label: 'Bersih' },
  { c: '#84cc16', label: 'Sederhana' },
  { c: '#eab308', label: 'Kurang Baik' },
  { c: '#f97316', label: 'Buruk' },
  { c: '#ef4444', label: 'Sangat Buruk' }
];

const voiceLangs = [
  { flag: '🇬🇧', label: 'English' },
  { flag: '🇲🇾', label: 'Bahasa Malaysia' },
  { flag: '🇨🇳', label: 'Chinese / 中文' },
  { flag: '🇰🇷', label: 'Korean / 한국어' }
];

const audience = [
  { icon: `${base}/penapis-udara-cuckoo-d-model-icon-keluarga-bayi.webp`, title: 'Keluarga dengan bayi', desc: 'Rumah yang ada bayi atau anak kecil mahukan udara lebih bersih & selesa.' },
  { icon: `${base}/penapis-udara-cuckoo-d-model-icon-haiwan-peliharaan.webp`, title: 'Ada haiwan peliharaan', desc: 'Bantu kurangkan bulu haiwan, habuk dan bau dalam rumah.' },
  { icon: `${base}/penapis-udara-cuckoo-d-model-icon-alahan-asma.webp`, title: 'Ada alahan / asma', desc: 'Kurangkan debunga, habuk halus dan alergen yang terapung di udara.' },
  { icon: `${base}/penapis-udara-cuckoo-d-model-icon-udara-segar.webp`, title: 'Mahu udara segar', desc: 'Untuk ruang tamu besar, pejabat, pantry atau bilik keluarga.' },
  { icon: `${base}/penapis-udara-cuckoo-d-model-icon-pencemaran-udara.webp`, title: 'Kawasan berjerebu', desc: 'Kawasan terdedah jerebu, asap kenderaan atau udara luar kurang baik.' }
];

const realGalleryItems = Array.from({ length: 20 }, (_, index) => {
  const n = index + 1;
  return {
    image: `${base}/penapis-udara-cuckoo-d-model-rumah-sebenar-${n}.webp`,
    title: `Pemasangan Sebenar #${n}`,
    copy: 'Gambar sebenar penapis udara CUCKOO D Model di rumah pelanggan.',
    alt: `Gambar sebenar penapis udara CUCKOO D Model dipasang di rumah pelanggan ${n}`
  };
});

const productPhotos = [
  { file: 'penapis-udara-cuckoo-d-model-air-purifier-malaysia', alt: 'Penapis udara CUCKOO D Model — paparan hadapan studio dengan LED biru' },
  { file: 'penapis-udara-cuckoo-d-model-ruang-tamu', alt: 'CUCKOO D Model di ruang tamu rumah yang kemas' },
  { file: 'penapis-udara-cuckoo-d-model-rumah-sebenar-1', alt: 'CUCKOO D Model dipasang di rumah pelanggan' },
  { file: 'penapis-udara-cuckoo-d-model-rumah-sebenar-8', alt: 'CUCKOO D Model di ruang dalaman rumah pelanggan' },
  { file: 'penapis-udara-cuckoo-d-model-rumah-sebenar-16', alt: 'CUCKOO D Model di sudut ruang rumah pelanggan' },
  { file: 'penapis-udara-cuckoo-d-model-rumah-sebenar-20', alt: 'CUCKOO D Model di rumah pelanggan dengan LED menyala' }
].map((p, index) => ({ image: `${base}/${p.file}.webp`, title: `Gambar Produk #${index + 1}`, alt: p.alt }));

const meta = {
  title: 'Penapis Udara CUCKOO D Model | HEPA14, 710 sq ft & Harga',
  description:
    'CUCKOO D Model: penapis udara premium 710 sq ft — Ultra-Deo HEPA14, 360° absorption, Plasma Ioniser, voice navigation 4 bahasa & 10 modes. Sewa dari RM127/bulan.',
  canonical: pageUrl,
  ogImage: ogImg,
  ogType: 'website'
};
---

<BaseLayout {...meta} preloadImages={[heroImg]}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(webPageSchema)} />

  <!-- HERO -->
  <section id="hero" class="relative overflow-hidden bg-brand-cream px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="absolute left-1/2 top-0 -z-10 h-[620px] w-[620px] -translate-x-1/2 rounded-full bg-brand-soft blur-3xl"></div>

    <div class="mx-auto grid max-w-7xl items-center gap-10 lg:grid-cols-[1.02fr_.98fr]">
      <!-- KIRI: kandungan -->
      <div>
        <div class="mb-5 flex gap-2 overflow-x-auto pb-1 [-ms-overflow-style:none] [scrollbar-width:none] lg:flex-wrap lg:overflow-visible lg:pb-0 [&::-webkit-scrollbar]:hidden">
          <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Liputan 710 sq ft</span>
          <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Ultra-Deo HEPA14</span>
          <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Voice Navigation 4 Bahasa</span>
        </div>

        <div class="mb-5 inline-flex max-w-full flex-wrap items-center gap-2 rounded-full bg-[linear-gradient(135deg,#4B0715_0%,#7A0E23_58%,#8E1830_100%)] px-4 py-3 text-white shadow-glow ring-1 ring-brand-gold/30 sm:gap-3 sm:px-5">
          <span class="rounded-full bg-white/15 px-3 py-1 text-[11px] font-black uppercase tracking-[.14em] text-brand-gold">Premium</span>
          <span class="text-sm font-black sm:text-base">Ultra-Deo HEPA14 · 360° absorption</span>
        </div>

        <h1 class="text-[2.3rem] font-black leading-[1.08] tracking-tight text-brand-ink sm:text-5xl lg:text-[3.4rem]">
          CUCKOO D Model — Penapis Udara Premium Ruang Besar
        </h1>

        <!-- Gambar produk (mobile sahaja) -->
        <div class="mt-6 lg:hidden">
          <div class="product-blob accent-ring relative mx-auto max-w-sm overflow-hidden rounded-[1.7rem] p-6">
            <div class="absolute bottom-10 left-1/2 h-14 w-[70%] -translate-x-1/2 rounded-full bg-brand-gold/20 blur-2xl"></div>
            <img src={heroImg} alt="Penapis Udara CUCKOO D Model — paparan hadapan dengan LED biru" width="800" height="1000" loading="eager" fetchpriority="high" class="relative z-10 mx-auto h-[260px] w-auto object-contain drop-shadow-2xl" />
          </div>
        </div>

        <p class="mt-5 max-w-xl text-base leading-8 text-brand-muted sm:text-lg">
          Penapis udara premium untuk ruang tamu besar, pejabat, pantry & bilik keluarga — Ultra-Deo HEPA14, 360° absorption, Plasma Ioniser, 10 operating modes dan voice navigation 4 bahasa untuk udara lebih bersih dan segar.
        </p>

        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <a href="#" onclick="this.href=rotatingWhatsapp()" class="inline-flex items-center justify-center gap-2 rounded-full bg-cta-green px-7 py-4 text-sm font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark">📲 WhatsApp Promo D Model</a>
          <a href="#harga" class="inline-flex items-center justify-center rounded-full border border-brand/15 bg-white px-7 py-4 text-sm font-black text-brand shadow-soft hover:border-brand/30">Lihat Pelan Harga</a>
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <a href="#harga" class="rounded-[1.35rem] bg-brand px-5 py-5 text-white shadow-glow transition hover:-translate-y-1">
            <p class="text-xs font-black uppercase tracking-[.16em] text-brand-gold">Pelan Rental</p>
            <p class="mt-2 text-4xl font-black leading-none">RM{d.rentalY1to3}<span class="text-sm font-black">/bulan</span></p>
            <p class="mt-1 text-xs font-bold text-white/75">Termasuk 5 tahun servis & warranty</p>
          </a>
          <a href="#harga" class="rounded-[1.35rem] border border-brand/10 bg-white px-5 py-5 shadow-soft transition hover:-translate-y-1 hover:border-brand/25">
            <p class="text-xs font-black uppercase tracking-[.14em] text-brand-gold">Beli Terus</p>
            <p class="mt-2 text-xl font-black text-brand">RM{d.priceOutright.toLocaleString()}</p>
            <p class="mt-2 text-sm font-bold text-brand-muted">Lihat detail harga →</p>
          </a>
        </div>
      </div>

      <!-- KANAN: kad produk (desktop sahaja) -->
      <div class="hidden rounded-[2rem] border border-white/80 bg-white/70 p-4 shadow-premium backdrop-blur-xl sm:p-6 lg:block">
        <div class="product-blob accent-ring relative overflow-hidden rounded-[1.7rem] p-4 sm:p-6 lg:p-8">
          <div class="flex flex-wrap gap-2">
            <span class="rounded-full bg-white/85 px-4 py-2 text-xs font-black text-brand shadow-soft">360° Absorption</span>
            <span class="rounded-full bg-white/85 px-4 py-2 text-xs font-black text-brand shadow-soft">Ultra-Deo HEPA14</span>
          </div>

          <div class="relative mt-5 flex min-h-[300px] items-center justify-center overflow-hidden rounded-[1.5rem] bg-gradient-to-br from-white/80 to-white/35 p-5 sm:min-h-[390px] lg:min-h-[440px]">
            <div class="absolute bottom-12 h-16 w-[72%] rounded-full bg-brand-gold/20 blur-2xl"></div>
            <img src={heroImg} alt="Penapis Udara CUCKOO D Model dengan liputan 710 sq ft" width="800" height="1000" loading="eager" fetchpriority="high" class="relative z-10 h-[290px] w-auto object-contain drop-shadow-2xl sm:h-[380px] lg:h-[425px]" />
          </div>

          <div class="mt-5 flex flex-wrap justify-center gap-2">
            <span class="rounded-full border border-brand/15 bg-brand-soft px-4 py-2 text-xs font-black text-brand">Coverage 710 sq ft</span>
            <span class="rounded-full border border-stone-200 bg-white px-4 py-2 text-xs font-black text-stone-700">10 Modes</span>
            <span class="rounded-full border border-brand-gold/30 bg-amber-50 px-4 py-2 text-xs font-black text-brand-gold">Plasma Ioniser</span>
          </div>
        </div>

        <div class="mt-4 grid grid-cols-2 gap-2 sm:grid-cols-4">
          <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10"><p class="text-xs font-black text-brand">Ultra-Deo HEPA14</p></div>
          <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10"><p class="text-xs font-black text-brand">360° Absorption</p></div>
          <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10"><p class="text-xs font-black text-brand">Voice Nav 4 Bahasa</p></div>
          <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10"><p class="text-xs font-black text-brand">Plasma Ioniser</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- COVERAGE STRIP -->
  <section class="bg-gradient-to-br from-[#4B0715] via-brand-maroon to-[#2f0b10] px-4 py-14 text-white sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl items-center gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div class="text-center">
        <p class="text-5xl font-black tracking-tight text-promo-gold sm:text-6xl">710<span class="ml-1 text-xl font-bold text-white/70">sq ft</span></p>
