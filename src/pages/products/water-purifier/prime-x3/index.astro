---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import AgentSection from '../../../../components/AgentSection.astro';
import CustomerProofSection from '../../../../components/CustomerProofSection.astro';
import PromoBannerSection from '../../../../components/PromoBannerSection.astro';
import ProductCategorySection from '../../../../components/ProductCategorySection.astro';
import ProductGallerySlider from '../../../../components/ProductGallerySlider.astro';

const whatsappPrimeX3Url =
  'https://api.whatsapp.com/send?phone=60139916967&text=Salam%20Fadhil%2C%20saya%20berminat%20dengan%20promo%20CUCKOO%20Prime%20X3.%20Boleh%20bantu%20saya%3F';

const assetBase = '/assets/images/products/water-purifier/prime-x3';
const pageUrl = 'https://www.cuckoonano.com/products/water-purifier/prime-x3/';

const img = {
  heroMain: `${assetBase}/PRIME-X3_1.webp`,
  heroAngle: `${assetBase}/cuckoo-prime-X3-Outdoor-water-filter-penapis-air-luar-rumah-9.webp`,
  heroSide: `${assetBase}/cuckoo-prime-X3-Outdoor-water-filter-penapis-air-luar-rumah-7.webp`,
  installTeal: `${assetBase}/cuckoo-prime-x3-outdoor-filter-penapis-air-luar-rumah-poe-1.webp`,
  installGrey: `${assetBase}/cuckoo-prime-x3-outdoor-filter-penapis-air-luar-rumah-poe-2.webp`,
  installGate: `${assetBase}/cuckoo-prime-x3-outdoor-filter-penapis-air-luar-rumah-poe-3.webp`,
  installGrass: `${assetBase}/cuckoo-prime-x3-outdoor-filter-penapis-air-luar-rumah-poe-4.webp`,
  installTank: `${assetBase}/cuckoo-prime-x3-outdoor-filter-penapis-air-luar-rumah-poe-7.webp`,
  installFence: `${assetBase}/cuckoo-prime-x3-outdoor-filter-penapis-air-luar-rumah-poe-8.webp`,
  installGarden: `${assetBase}/cuckoo-prime-x3-outdoor-filter-penapis-air-luar-rumah-poe-10.webp`,
  valveClose: `${assetBase}/cuckoo-prime-x3-outdoor-filter-penapis-air-luar-rumah-poe-11.webp`,
  timerClose: `${assetBase}/cuckoo-prime-x1-gambar-2.webp`,
  filterDirty: `${assetBase}/cuckoo-prime-x3-outdoor-filter-penapis-air-luar-rumah-poe-cuci-filter-kotor.webp`,
  filterDirtyClean: `${assetBase}/cuckoo-prime-x3-outdoor-filter-penapis-air-luar-rumah-poe-filter-kotor-3.webp`,
  filterClean: `${assetBase}/cuckoo-prime-x3-outdoor-filter-penapis-air-luar-rumah-poe-filter-bersih.webp`,
  dirtyWater: `${assetBase}/air-paip-tangki-kotor-berkeladak-kuning-najis-bangkai-penapis-air-cuckoo-3.webp`,
  threeWays: `${assetBase}/prime-x3-outdoor-water-filter-penapis-air-luar-rumah-cuckoo-3%20(1).webp`,
  pvdfVideo: `${assetBase}/PDVF.mp4`,
  flushGif: `${assetBase}/prime-x-flush.gif`,
  autoFlushGif: `${assetBase}/automated-04.gif`,
  zoomVideo: `${assetBase}/filter_zoom-in-01.mp4`,
  outToInCut: `${assetBase}/Updated-Outdoor-Filter@2x.webp`,
  productZoom: `${assetBase}/prime-x3-zoom@3x.webp`,
  natCareInfo: `${assetBase}/natural-care-primex3@mobile-01-1-1939x2048.webp`,
  spec: `${assetBase}/Prime-X3-spec-image@2x.webp`,
  comparisonIcons: `${assetBase}/Comparison-ABC@3x-2048x508.webp`
};

const heroThumbs = [
  { src: img.heroMain, label: 'Produk' },
  { src: img.heroAngle, label: '3/4' },
  { src: img.heroSide, label: 'Sisi' }
];

// 6 kesan air kotor
const dirtyEffects = [
  { icon: `${assetBase}/comparison-08@3x.webp`, title: 'Cirit-birit', copy: 'Bakteria & kuman dalam air boleh ganggu perut dan sistem penghadaman.' },
  { icon: `${assetBase}/comparison-02@3x.webp`, title: 'Air Keruh', copy: 'Sedimen & karat buatkan air nampak keruh dan tak selesa digunakan.' },
  { icon: `${assetBase}/comparision-06@3x.webp`, title: 'Mulut Berbau', copy: 'Air berbau hapak atau berklorin tinggi boleh menjejaskan bau & rasa.' },
  { icon: `${assetBase}/comparison-09@3x.webp`, title: 'Masalah Buah Pinggang & Perut', copy: 'Logam berat & bahan terlarut yang terkumpul boleh membebankan buah pinggang.' },
  { icon: `${assetBase}/comparison-04@3x.webp`, title: 'Kesan Kuning Pada Pakaian', copy: 'Karat & mendapan meninggalkan kesan kuning pada pakaian putih.' },
  { icon: `${assetBase}/comparison-03@3x.webp`, title: 'Masalah Kulit & Alahan', copy: 'Klorin & kotoran air boleh keringkan kulit dan cetuskan gatal atau alahan.' }
];

// 3 video bukti (phone-frame)
const proofVideos = [
  { id: 'hYvSz7C5FZc', title: 'Air Kotor Dari Paip', sub: 'Rakaman servis sebenar' },
  { id: 'Y9f8huOmEH8', title: 'Servis & Cuci Filter', sub: 'Apa yang filter tahan' },
  { id: 'vxJ53Jtzmvw', title: 'Test Filter Prime X3', sub: 'Beza sebelum & selepas' }
];

// 6 kegunaan
const usageItems = [
  { icon: `${assetBase}/gif-01a@3x.webp`, title: 'Kegunaan Luar Rumah', copy: 'Basuh kereta, siram pokok, bersihkan laman.' },
  { icon: `${assetBase}/gift-2a@3x.webp`, title: 'Memasak', copy: 'Air lebih bersih untuk dapur & masakan harian.' },
  { icon: `${assetBase}/gift-3a@3x.webp`, title: 'Membasuh & Cuci', copy: 'Pinggan, sayur dan keperluan dapur.' },
  { icon: `${assetBase}/gift-4a@3x.webp`, title: 'Mandi', copy: 'Air mandi yang lebih selesa untuk kulit.' },
  { icon: `${assetBase}/gift-5a@3x.webp`, title: 'Laundry', copy: 'Bantu jaga warna pakaian dan mesin basuh.' },
  { icon: `${assetBase}/gitf-6a@3x.webp`, title: 'Kebersihan Diri', copy: 'Basuh muka dan rutin harian lebih yakin.' }
];

// Other features
const otherFeatures = [
  { icon: `${assetBase}/ss304@3x.webp`, title: 'SS304 Stainless Steel Vessel', copy: 'Reka bentuk stainless steel tanpa sambungan — kalis air dan tahan lasak untuk pemasangan luar.' },
  { icon: `${assetBase}/non-electric-icon@3x.webp`, title: 'Non-Electric Filter', copy: 'Sistem tanpa elektrik — lebih selamat, jimat dan mudah digunakan setiap hari.' },
  { icon: `${assetBase}/compact-icon@3x.webp`, title: 'Reka Bentuk Kompak', copy: 'Saiz kecil tapi berkuasa — sesuai untuk rumah pelbagai saiz.' }
];

const ufBenefits = [
  'Beroperasi lancar pada tekanan air rendah',
  'Membantu menapis bakteria',
  'Mengekalkan mineral penting dalam air',
  'Tiada tangki simpanan diperlukan',
  'Sifar pembaziran air (zero waste)'
];

// Kelebihan Royal Out-to-In (pill, ganti gambar badge)
const royalBenefits = [
  'Tapis lebih pantas & efektif',
  'Risiko tersumbat rendah',
  'Keberkesanan tinggi',
  'Tahan klorin tinggi',
  'Kelajuan tinggi'
];

// Jadual perbandingan sistem penapisan (susunan ikut HQ)
const compareRows = [
  ['Saiz liang membrane', '0.01 µm', '0.1 – 10 µm', '> 1.0 µm'],
  ['Keupayaan penapisan', 'Kuat', 'Sederhana', 'Lemah'],
  ['Buang bakteria', 'Ya', 'Ya', 'Tidak'],
  ['Kelajuan flush', 'Pantas', 'Sederhana', 'Perlahan'],
  ['Kos penyelenggaraan', 'Rendah', 'Sederhana', 'Tinggi'],
  ['Ketahanan badan filter', 'Kuat', 'Sederhana', 'Lemah']
];

const serviceItems = [
  { title: 'Nationwide Service', copy: 'Disokong lebih 2,000 CUCKOO+ Service Team di seluruh Malaysia.' },
  { title: 'Scheduled Service', copy: 'Servis berkala setiap 6 bulan untuk bantu jaga prestasi filter.' },
  { title: '1-to-1 Customised', copy: 'Service specialist semak keadaan produk mengikut pemasangan rumah anda.' },
  { title: 'Worry-Free Service', copy: 'Anda dimaklumkan butiran service specialist yang dilantik lebih awal.' }
];

const galleryItems = [
  { image: img.installGrey, title: 'Prime X3 + auto flush timer', copy: 'Piping kemas dengan timer auto flush.', alt: 'CUCKOO Prime X3 outdoor filter dengan auto flush timer' },
  { image: img.installGate, title: 'Pemasangan di laluan tepi', copy: 'Outdoor filter di laluan tepi rumah teres.', alt: 'CUCKOO Prime X3 dipasang di laluan tepi rumah teres' },
  { image: img.installGarden, title: 'Pemasangan kawasan taman', copy: 'Berhampiran pagar & kawasan taman.', alt: 'CUCKOO Prime X3 outdoor filter di kawasan taman rumah' },
  { image: img.installTank, title: 'Prime X3 + tangki air', copy: 'Sesuai dipasang bersama tangki air rumah.', alt: 'CUCKOO Prime X3 dipasang bersama tangki air' },
  { image: img.installFence, title: 'Pemasangan luar rumah', copy: 'Vessel SS304 tahan untuk pemasangan luar.', alt: 'CUCKOO Prime X3 outdoor water filter dipasang di luar rumah' },
  { image: img.valveClose, title: 'Cuckoo Multi-Way Valve', copy: 'Kepala valve untuk backwash & bypass.', alt: 'Kepala valve CUCKOO Prime X3' },
  { image: img.timerClose, title: 'Auto Flush Timer', copy: 'Timer digital untuk automated flushing.', alt: 'Timer digital automated flushing CUCKOO Prime X3' },
  { image: img.installTeal, title: 'Pemasangan Prime X3 — dinding luar', copy: 'Pemasangan kemas di dinding luar rumah.', alt: 'Pemasangan CUCKOO Prime X3 outdoor water filter di dinding luar' }
];

const faqItems = [
  { q: 'Kawasan saya air okay je, perlu ke pasang?', a: 'Air yang nampak jernih bukan bermakna bersih. Sedimen, karat dan bakteria tidak boleh dilihat dengan mata kasar. Lebih baik lindungi awal daripada tunggu masalah berlaku pada kesihatan keluarga anda.' },
  { q: 'Apa beza dengan penapis air dalam rumah biasa?', a: 'Penapis dalam rumah hanya tapis air di satu pili (biasanya dapur). Prime X3 dipasang di titik masuk utama — semua air dalam rumah (mandi, basuh, masak) sudah ditapis sebelum masuk. Satu penapis, perlindungan menyeluruh.' },
  { q: 'Saya sewa rumah. Boleh pasang tak?', a: 'Prime X3 dipasang pada paip utama dan boleh dialih semula. Untuk apartment atau rumah sewa, lokasi, drain outlet dan kebenaran tuan rumah / management perlu disahkan dahulu. WhatsApp kami untuk semakan.' },
  { q: 'Berapa harga rental & outright?', a: 'Rental promo RM12/bulan untuk 6 bulan pertama, kemudian RM88/bulan sehingga bulan ke-60. Outright promo RM2100 (normal RM2600). Harga tertakluk kepada promo semasa.' },
  { q: 'Berapa kerap perlu servis & flush?', a: 'Servis CUCKOO+ Care Service setiap 6 bulan. Untuk manual Prime-X Flush, disyorkan sekali sebulan (± 10 minit). Automated flushing pula berjalan automatik.' },
  { q: 'Boleh guna untuk air telaga / underground water?', a: 'Prime X3 hanya sesuai untuk rumah dengan sumber air kerajaan. Untuk sumber lain, perlu semakan lanjut dahulu.' },
  { q: 'Adakah tekanan air akan berkurang?', a: 'Tekanan air boleh berkurang sedikit semasa proses filtrasi. Sebab itu semakan tekanan air dan lokasi paip utama penting sebelum pemasangan.' },
  { q: 'Berapa lama proses pemasangan?', a: 'Pemasangan diuruskan sepenuhnya oleh juruteknik CUCKOO. Tempoh bergantung pada lokasi paip, jarak piping dan aksesori. Semak dengan ejen sebelum confirm order.' }
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'CUCKOO Prime X3 Outdoor Water Filter',
  brand: { '@type': 'Brand', name: 'CUCKOO' },
  image: [`https://www.cuckoonano.com${img.heroMain}`, `https://www.cuckoonano.com${img.heroAngle}`],
  description:
    'Outdoor whole-house water filter dengan PVDF 2.0 Ultra-Filtration Membrane, Royal Out-to-In Filtration System, Prime-X Flush, Automated Flushing dan SS304 Stainless Steel Vessel.',
  offers: [
    { '@type': 'Offer', priceCurrency: 'MYR', price: '12', description: 'Promo RM12/bulan untuk 6 bulan pertama. Bulan 7 hingga 60 ialah RM88/bulan tertakluk kepada promo semasa.' },
    { '@type': 'Offer', priceCurrency: 'MYR', price: '2100', description: 'Outright promo RM2100 tertakluk kepada promosi semasa.' }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({ '@type': 'Question', name: item.q, acceptedAnswer: { '@type': 'Answer', text: item.a } }))
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.cuckoonano.com/' },
    { '@type': 'ListItem', position: 2, name: 'Produk', item: 'https://www.cuckoonano.com/products/' },
    { '@type': 'ListItem', position: 3, name: 'Water Purifier', item: 'https://www.cuckoonano.com/products/water-purifier/' },
    { '@type': 'ListItem', position: 4, name: 'CUCKOO Prime X3', item: pageUrl }
  ]
};

const meta = {
  title: 'CUCKOO Prime X3 Outdoor Water Filter | Harga, Spec & Promo Terkini',
  description:
    'CUCKOO Prime X3 Outdoor Water Filter menapis air dari paip utama sebelum sampai ke dapur, bilik air, laundry dan seluruh rumah. Semak harga RM12 promo, rental plan 60 bulan dan outright RM2100.',
  canonical: pageUrl,
  ogImage: `https://www.cuckoonano.com${img.heroMain}`,
  ogType: 'product'
};
---

<BaseLayout {...meta}>
  <style is:inline>
    html { scroll-behavior: smooth; }
    .warm-blob { background: radial-gradient(circle at 40% 32%, rgba(122,14,35,.08), transparent 44%), radial-gradient(circle at 72% 64%, rgba(215,168,79,.16), transparent 46%), linear-gradient(145deg, #fff7f3, #ffffff); }
    .ink-panel { background: radial-gradient(circle at 78% 12%, rgba(216,166,74,.16), transparent 34%), linear-gradient(135deg, #35040f 0%, #6f0b20 48%, #8E1830 100%); }
    .floating { animation: floating 5.5s ease-in-out infinite; }
    @keyframes floating { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
    .fade-up { opacity: 0; transform: translateY(24px); transition: opacity .55s ease, transform .55s ease; }
    .fade-up.visible { opacity: 1; transform: translateY(0); }
    .media-frame video { width: 100%; height: 100%; object-fit: contain; }
    .video-frame iframe { width: 100%; height: 100%; border: 0; }
    /* Phone-frame video slider */
    .phone-frame { background: #21181A; border-radius: 2rem; padding: .5rem; box-shadow: 0 25px 50px rgba(0,0,0,.4), inset 0 0 0 2px rgba(255,255,255,.08); position: relative; }
    .phone-frame::before { content: ''; position: absolute; top: .5rem; left: 50%; transform: translateX(-50%); width: 3rem; height: .35rem; background: rgba(255,255,255,.18); border-radius: 9999px; z-index: 10; }
    .phone-frame iframe { border-radius: 1.5rem; display: block; width: 100%; aspect-ratio: 9/16; border: 0; }
    /* Comparison table */
    .compare-best { background: #FBECEF; }
    @media (prefers-reduced-motion: reduce) { .floating, .fade-up { animation: none; transition: none; opacity: 1; transform: none; } }
  </style>

  <div class="bg-brand-cream text-brand-ink antialiased">

    <!-- ============================ 1 · HERO (maroon) ============================ -->
    <section id="hero" class="warm-blob relative overflow-hidden px-4 py-10 text-brand-ink sm:px-6 lg:px-8 lg:py-16">
      <div class="pointer-events-none absolute -right-24 top-1/2 h-[560px] w-[560px] -translate-y-1/2 rounded-full bg-brand-soft/50 blur-3xl"></div>
      <div class="pointer-events-none absolute -left-32 bottom-0 h-80 w-80 rounded-full bg-gold/10 blur-3xl"></div>

      <div class="relative mx-auto grid max-w-7xl gap-7 lg:grid-cols-[1.04fr_.96fr] lg:items-start lg:gap-10">

        <!-- A · Copy -->
        <div class="order-1 text-center lg:col-start-1 lg:row-start-1 lg:text-left">
          <div class="mb-5 flex flex-wrap justify-center gap-2 lg:justify-start">
            <span class="rounded-full bg-white/85 px-4 py-2 text-xs font-black uppercase tracking-[.16em] text-brand shadow-soft ring-1 ring-brand/10">🔥 Promo RM12</span>
            <span class="rounded-full bg-white/70 px-4 py-2 text-xs font-black uppercase tracking-[.16em] text-brand-ink shadow-soft ring-1 ring-brand/10">Outdoor Water Filter</span>
          </div>

          <p class="text-xs font-black uppercase tracking-[.24em] text-brand-gold sm:text-sm">CUCKOO Outdoor Water Filter Malaysia</p>

          <h1 class="mt-3 text-[2.1rem] font-black leading-[1.05] tracking-tight text-brand-ink sm:text-5xl lg:text-[3.4rem]">
            CUCKOO Prime X3 — Air Bersih Seluruh Rumah
            <span class="mt-1 block bg-gradient-to-r from-brand to-gold bg-clip-text text-transparent">Dari RM12/Bulan</span>
          </h1>

          <p class="mx-auto mt-4 max-w-xl text-base leading-8 text-brand-muted sm:text-lg lg:mx-0">
            Tapis semua air dari paip utama sebelum sampai ke dapur, bilik air, mesin basuh & kawasan luar. <strong class="text-brand-ink">Cleans 3 Ways — clean water always.</strong>
          </p>
        </div>

        <!-- B · Product showcase -->
        <div class="order-2 relative lg:col-start-2 lg:row-span-2 lg:row-start-1">
          <div class="absolute -inset-4 rounded-[2.8rem] bg-white/40 blur-2xl"></div>
          <div class="relative overflow-hidden rounded-[2.2rem] border border-white bg-white/70 p-4 shadow-premium backdrop-blur-xl sm:p-6">
            <div class="mb-4 flex flex-wrap justify-center gap-2">
              <span class="rounded-full bg-brand px-4 py-1.5 text-[11px] font-black uppercase tracking-wide text-white sm:text-xs">PVDF 2.0</span>
              <span class="rounded-full bg-white px-4 py-1.5 text-[11px] font-black uppercase tracking-wide text-brand-ink ring-1 ring-brand/15 sm:text-xs">Cleans 3 Ways</span>
            </div>

            <div class="relative flex min-h-[260px] items-center justify-center overflow-hidden rounded-[1.6rem] bg-gradient-to-br from-white to-brand-soft p-5 sm:min-h-[360px]">
              <div class="absolute bottom-8 h-16 w-3/5 rounded-full bg-brand/10 blur-2xl"></div>
              <img id="heroImg" src={img.heroMain} alt="CUCKOO Prime X3 Outdoor Water Filter" class="floating relative z-10 max-h-[240px] w-auto max-w-full object-contain drop-shadow-2xl transition duration-300 sm:max-h-[340px]" />
            </div>

            <div class="mt-4 flex flex-wrap justify-center gap-2">
              {heroThumbs.map((thumb, index) => (
                <button type="button" data-hero-thumb={thumb.src} class={`hero-thumb whitespace-nowrap rounded-full px-4 py-1.5 text-[11px] font-black uppercase tracking-wide transition sm:text-xs ${index === 0 ? 'bg-white text-brand-ink ring-2 ring-brand' : 'bg-brand/5 text-brand-ink/60'}`}>{thumb.label}</button>
              ))}
            </div>

            <div class="mt-4 grid grid-cols-3 gap-2">
              <div class="rounded-2xl bg-white px-2 py-2.5 text-center shadow-soft ring-1 ring-brand/10"><p class="text-sm font-black text-brand-ink sm:text-base">2000L/H</p><p class="text-[9px] font-bold uppercase tracking-wide text-brand-muted sm:text-[10px]">Capacity</p></div>
              <div class="rounded-2xl bg-white px-2 py-2.5 text-center shadow-soft ring-1 ring-brand/10"><p class="text-sm font-black text-brand-ink sm:text-base">SS304</p><p class="text-[9px] font-bold uppercase tracking-wide text-brand-muted sm:text-[10px]">Material</p></div>
              <div class="rounded-2xl bg-white px-2 py-2.5 text-center shadow-soft ring-1 ring-brand/10"><p class="text-sm font-black text-brand-ink sm:text-base">6 Bulan</p><p class="text-[9px] font-bold uppercase tracking-wide text-brand-muted sm:text-[10px]">Service</p></div>
            </div>
          </div>

          <div class="ink-panel relative mx-auto mt-4 w-11/12 rounded-3xl px-5 py-3.5 text-center text-white shadow-glow">
            <p class="text-[10px] font-bold uppercase tracking-[.14em] text-white/70 sm:text-[11px]">Penapis Seluruh Rumah</p>
            <p class="text-[13px] font-black sm:text-sm">Tanpa Elektrik · Air Bersih Sepanjang Masa</p>
          </div>
        </div>

        <!-- C · Pricing + CTA -->
        <div class="order-3 lg:col-start-1 lg:row-start-2">
          <div class="ink-panel mx-auto max-w-xl rounded-[1.75rem] p-4 shadow-premium sm:p-5">
            <div class="rounded-[1.4rem] p-5 text-ink shadow-glow" style="background: linear-gradient(135deg, #fff7de, #ffe7a8, #d6b679);">
              <p class="text-center text-xs font-black uppercase tracking-[.2em] text-amber-800">6 Bulan Pertama</p>
              <p class="mt-1 text-center font-black tracking-tight text-slate-950" style="line-height:1;">
                <span style="font-size: clamp(3.5rem, 17vw, 5.5rem);">RM12</span><span class="font-bold text-slate-700" style="font-size: clamp(1.1rem, 4.5vw, 1.5rem);">/bulan</span>
              </p>
              <p class="mt-2 text-center text-sm font-bold text-amber-800">Lepas promo — RM88/bulan hingga 60 bulan</p>
            </div>
            <div class="mt-3 grid gap-2 sm:grid-cols-2">
              <div class="rounded-2xl bg-white/10 px-4 py-3 text-center text-sm font-bold text-white ring-1 ring-white/15">Servis berkala setiap 6 bulan</div>
              <div class="rounded-2xl bg-white/10 px-4 py-3 text-center text-sm font-bold text-white ring-1 ring-white/15">Pemasangan diuruskan CUCKOO</div>
            </div>
            <p class="mt-3 text-center text-[11px] font-semibold leading-5 text-rose-200">Tertakluk kepada stok, kelayakan, tekanan air & terma semasa.</p>
          </div>

          <div class="mt-6 flex flex-col justify-center gap-3 sm:flex-row lg:justify-start">
            <a href={whatsappPrimeX3Url} class="inline-flex items-center justify-center gap-2 rounded-full bg-cta-green px-7 py-4 text-sm font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark">
              <img src="/assets/images/misc/whatsapp-png.webp" alt="" aria-hidden="true" class="h-5 w-5" />
              WhatsApp Promo Prime X3
            </a>
            <a href="#bukti" class="inline-flex items-center justify-center rounded-full border border-brand/20 bg-white px-7 py-4 text-sm font-black text-brand-ink shadow-soft hover:border-brand/40">Lihat Bukti Sebenar ↓</a>
          </div>

          <p class="mt-3 text-center text-xs font-semibold text-brand-muted lg:text-left">Boleh WhatsApp untuk semak kelayakan rumah, tekanan air & promo terkini.</p>
        </div>
      </div>
    </section>

