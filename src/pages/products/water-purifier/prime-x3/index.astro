  <script is:inline>
    (function () {
      const img = document.getElementById('heroImg');
      const btns = document.querySelectorAll('.hero-thumb');
      btns.forEach((btn) => {
        btn.addEventListener('click', () => {
          if (img) { img.style.opacity = '0'; setTimeout(() => { img.src = btn.dataset.heroThumb; img.style.opacity = '1'; }, 150); }
          btns.forEach((b) => { b.classList.add('bg-brand/5', 'text-brand-ink/60'); b.classList.remove('bg-white', 'text-brand-ink', 'ring-2', 'ring-brand'); });
          btn.classList.add('bg-white', 'text-brand-ink', 'ring-2', 'ring-brand'); btn.classList.remove('bg-brand/5', 'text-brand-ink/60');
        });
      });
    })();

    (function () {
      const els = document.querySelectorAll('.fade-up');
      if (!('IntersectionObserver' in window)) { els.forEach((el) => el.classList.add('visible')); return; }
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => { if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); } });
      }, { threshold: 0.1 });
      els.forEach((el) => observer.observe(el));
    })();

    // Force autoplay: browsers kadang abaikan attribute autoplay untuk video besar.
    // Main bila masuk skrin, pause bila keluar (jimat bandwidth).
    (function () {
      const vids = document.querySelectorAll('.media-frame video');
      vids.forEach((v) => { v.muted = true; v.setAttribute('muted', ''); v.playsInline = true; });
      const tryPlay = (v) => { const p = v.play(); if (p && p.catch) p.catch(() => {}); };
      if (!('IntersectionObserver' in window)) { vids.forEach(tryPlay); return; }
      const vObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const v = entry.target;
          if (entry.isIntersecting) { if (v.preload !== 'auto') v.preload = 'auto'; tryPlay(v); }
          else { v.pause(); }
        });
      }, { threshold: 0.25 });
      vids.forEach((v) => vObserver.observe(v));
    })();
  </script>
