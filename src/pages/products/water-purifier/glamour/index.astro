    title: 'Air Panas Segera',
    copy: 'Air panas tersedia untuk kopi, teh, susu dan minuman harian keluarga.'
  },
  {
    icon: '🔒',
    title: 'Child Lock + Button Lock',
    copy: 'Ciri keselamatan untuk bantu elak tersalah tekan, terutama di rumah keluarga.'
  }
];

const smartFeatures = [
  {
    title: 'Fungsi Memori',
    copy: 'Simpan tetapan minuman kegemaran untuk penggunaan harian yang lebih mudah.',
    image: `${glamourImageBase}/Group-205.png.webp`,
    alt: 'CUCKOO Glamour memory function pada panel digital'
  },
  {
    title: 'Mod Jimat Tenaga',
    copy: 'Membantu mengurangkan penggunaan elektrik apabila tidak aktif digunakan.',
    image: `${glamourImageBase}/Glamour-Icon-B@2x.webp`,
    alt: 'CUCKOO Glamour dengan energy saving mode'
  },
  {
    title: 'Air Panas Segera',
    copy: 'Air panas tersedia dengan satu sentuhan untuk minuman harian.',
    image: `${glamourImageBase}/Glamour-Icon-c@2x.webp`,
    alt: 'CUCKOO Glamour instant hot water untuk minuman panas'
  }
];

const wellnessItems = [
  {
    title: 'Kulit Lebih Sihat',
    image: `${glamourImageBase}/Glamour-Icon-001@2x.webp`,
    alt: 'Ikon healthier skin CUCKOO Glamour'
  },
  {
    title: 'Sendi & Tisu Lebih Baik',
    image: `${glamourImageBase}/Group-152.png.webp`,
    alt: 'Ikon improved joints and tissues CUCKOO Glamour'
  },
  {
    title: 'Penghadaman Lebih Baik',
    image: `${glamourImageBase}/Glamour-Icon-003@2x.webp`,
    alt: 'Ikon better digestion CUCKOO Glamour'
  },
  {
    title: 'Sokong Kawalan Suhu Badan',
    image: `${glamourImageBase}/Glamour-Icon-004@2x.webp`,
    alt: 'Ikon body temperature regulation CUCKOO Glamour'
  }
];

const filtrationSteps = [
  {
    stage: 'Peringkat 1',
    title: 'Sediment',
    copy: 'Membantu membuang partikel besar dan bendasing terapung.'
  },
  {
    stage: 'Peringkat 2-4',
    title: 'Carbon Composite',
    copy: 'Membantu menapis partikel besar, bahan cemar organik, bau dan klorin.'
  },
  {
    stage: 'Peringkat 5-6',
    title: 'Nano Positive Filter',
    copy: 'Membantu menapis bakteria, virus dan bahan berbahaya sambil mengekalkan mineral.'
  }
];

const galleryItems = Array.from({ length: 21 }, (_, index) => {
  const number = index + 1;
  return {
    image: `${glamourImageBase}/penapis-air-cuckoo-glamour-water-purifier-${number}.webp`,
    title: `CUCKOO Glamour Gallery ${number}`,
    copy: 'Rujukan gambar produk Glamour untuk lihat rupa, warna dan kesesuaian pemasangan di rumah.',
    alt: `Gambar CUCKOO Glamour water purifier ${number} dengan rekaan matte black dan champagne pink`
  };
});

const faqItems = [
  {
    q: 'Apa kelebihan utama CUCKOO Glamour?',
    a: 'Glamour ialah penapis air digital dengan rekaan matte black dan champagne pink, tangki besar 7.6L, 6-stage filtration, instant hot water, memory function dan multiple volume dispensing.'
  },
  {
    q: 'Berapa kapasiti tangki Glamour?',
    a: 'Jumlah kapasiti Glamour ialah 7.6L: Hot Tank 2.4L, Cold Tank 2.5L dan Room Tank 2.7L.'
  },
  {
    q: 'Berapa harga bulanan Glamour?',
    a: 'Rujukan pelan 5 tahun ialah RM110/bulan untuk tahun 1-3 dan RM105/bulan untuk tahun 4-5. Pelan 7 tahun ialah RM105/bulan untuk tahun 1-5 dan RM100/bulan untuk tahun 6-7. Harga tertakluk kepada promo semasa.'
  },
  {
    q: 'Adakah Glamour ada promo RM12?',
    a: 'Promo RM12/bulan untuk 6 bulan pertama tertakluk kepada kempen, stok, kawasan servis dan kelayakan pendaftaran semasa.'
  },
  {
    q: 'Apa beza Glamour dengan Grande?',
    a: 'Glamour lebih fokus kepada rekaan stylish dua tona, penggunaan digital harian, tangki besar dan multiple dispensing. Grande lebih fokus kepada kawalan suhu lebih luas hingga 100°C dan smart premium features.'
  },
  {
    q: 'Apa sistem tapisan Glamour?',
    a: 'Glamour menggunakan 6-stage filtration system dengan Sediment, Carbon Composite dan Nano Positive Filter.'
  },
  {
    q: 'Adakah Glamour sesuai untuk keluarga?',
    a: 'Ya. Kapasiti 7.6L, instant hot water, child lock dan button lock menjadikan Glamour sesuai untuk rumah keluarga dan penggunaan harian.'
  },
  {
    q: 'Macam mana nak semak promo terkini?',
    a: 'Klik butang WhatsApp dan saya akan bantu semak promo Glamour, bayaran permulaan, dokumen, kelayakan dan slot pemasangan.'
  }
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'CUCKOO Glamour Water Purifier',
  image: [
    'https://www.cuckoonano.com/assets/images/products/water-purifier/glamour/glamour-front.webp',
    'https://www.cuckoonano.com/assets/images/products/water-purifier/glamour/glamour-left.webp'
  ],
  url: 'https://www.cuckoonano.com/products/water-purifier/glamour/',
  sku: 'CUCKOO-GLAMOUR',
  category: 'Water Purifier',
  brand: {
    '@type': 'Brand',
    name: 'CUCKOO'
  },
  description:
    'Penapis air digital matte black dan champagne pink dengan tangki besar 7.6L, 6-stage Nano Positive Filtration, instant hot water, memory function dan multiple volume dispensing.',
  color: ['Matte Black', 'Champagne Pink'],
  offers: [
    {
      '@type': 'Offer',
      url: 'https://www.cuckoonano.com/products/water-purifier/glamour/#harga',
      priceCurrency: 'MYR',
      price: '100',
      availability: 'https://schema.org/InStock',
      description: 'Pelan 7 tahun Glamour dari RM100/bulan pada tahun 6-7 tertakluk kepada promo semasa.'
    },
    {
      '@type': 'Offer',
      url: 'https://www.cuckoonano.com/products/water-purifier/glamour/#harga',
      priceCurrency: 'MYR',
      price: '3600',
      availability: 'https://schema.org/InStock',
      description: 'Outright purchase rujukan RM3,600 tertakluk kepada promosi semasa.'
    }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a
    }
  }))
};
---

<BaseLayout {...meta}>
  <style is:inline>
    html { scroll-behavior: smooth; }
    body { font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
    .glamour-blob { background: radial-gradient(circle at 18% 18%, rgba(244,206,216,.55), transparent 36%), radial-gradient(circle at 78% 65%, rgba(122,14,35,.18), transparent 42%), linear-gradient(145deg, #fff7f5, #ffffff); }
    .glamour-arc { background: radial-gradient(circle at 50% 0%, rgba(255,255,255,.12), transparent 38%), linear-gradient(135deg,#4B0715 0%,#7A0E23 50%,#B0163C 100%); }
  </style>

  <div class="bg-brand-cream text-brand-ink antialiased">
    <section id="hero" class="relative overflow-hidden px-4 py-10 sm:px-6 lg:px-8 lg:py-16">
      <div class="absolute left-1/2 top-0 -z-10 h-[620px] w-[620px] -translate-x-1/2 rounded-full bg-brand-soft blur-3xl"></div>

      <div class="mx-auto grid max-w-7xl gap-7 lg:grid-cols-[1.02fr_.98fr] lg:items-start lg:gap-10">
        <div class="order-1 lg:col-start-1 lg:row-start-1">
          <div class="mb-5 flex gap-2 overflow-x-auto pb-1 [-ms-overflow-style:none] [scrollbar-width:none] lg:flex-wrap lg:overflow-visible lg:pb-0 [&::-webkit-scrollbar]:hidden">
            <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Ejen CUCKOO sejak 2017</span>
            <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Free Installation</span>
            <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Servis Berkala</span>
          </div>

          <div class="mb-5 inline-flex max-w-full flex-wrap items-center gap-2 rounded-full bg-[linear-gradient(135deg,#4B0715_0%,#7A0E23_58%,#B0163C_100%)] px-4 py-3 text-white shadow-glow ring-1 ring-brand-gold/30 sm:gap-3 sm:px-5">
            <span class="rounded-full bg-white/15 px-3 py-1 text-[11px] font-black uppercase tracking-[.14em] text-brand-gold">Promo Terkini</span>
            <span class="text-sm font-black sm:text-base">RM12 x 6 bulan pertama</span>
          </div>

          <h1 class="max-w-3xl text-[2.35rem] font-black leading-[1.06] tracking-tight text-brand-ink sm:text-5xl lg:text-6xl">
            CUCKOO Glamour — Penapis Air Digital Cantik Dengan Tangki Besar 7.6L
          </h1>

          <p class="mt-5 max-w-2xl text-base leading-8 text-brand-muted sm:text-lg">
            Rekaan matte black dan champagne pink dengan air panas, sejuk dan suhu bilik, 6-stage Nano Positive Filtration, memory function dan dispensing mudah untuk rumah moden.
          </p>
        </div>

        <div class="order-2 rounded-[2rem] border border-white/80 bg-white/70 p-4 shadow-premium backdrop-blur-xl sm:p-6 lg:col-start-2 lg:row-span-2 lg:row-start-1">
          <div class="glamour-blob relative overflow-hidden rounded-[1.7rem] p-4 shadow-[0_30px_80px_rgba(122,14,35,.14)] sm:p-6 lg:p-8">


            <div class="relative mt-5 flex min-h-[300px] items-center justify-center overflow-hidden rounded-[1.5rem] bg-gradient-to-br from-white/80 to-white/35 p-5 sm:min-h-[390px] lg:min-h-[470px]">
              <div class="absolute bottom-12 h-16 w-[72%] rounded-full bg-brand-gold/20 blur-2xl"></div>
              <img
                src={`${glamourImageBase}/glamour-front.webp`}
                alt="CUCKOO Glamour water purifier matte black dan champagne pink"
                class="relative z-10 h-[290px] w-auto object-contain drop-shadow-2xl sm:h-[380px] lg:h-[455px]"
              />
            </div>

            <div class="mt-5 flex flex-wrap justify-center gap-2">
              <span class="rounded-full border border-blue-200 bg-blue-50 px-4 py-2 text-xs font-black text-blue-700">Cold Tank 2.5L</span>
              <span class="rounded-full border border-red-200 bg-red-50 px-4 py-2 text-xs font-black text-red-700">Hot Tank 2.4L</span>
              <span class="rounded-full border border-stone-200 bg-white px-4 py-2 text-xs font-black text-stone-700">Room Tank 2.7L</span>
            </div>
          </div>

          <div class="mt-4 grid grid-cols-2 gap-2 sm:grid-cols-4">
            <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10">
              <p class="text-xs font-black text-brand">Jumlah 7.6L</p>
            </div>
            <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10">
              <p class="text-xs font-black text-brand">Fungsi Memori</p>
            </div>
            <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10">
              <p class="text-xs font-black text-brand">Air Panas</p>
            </div>
            <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10">
              <p class="text-xs font-black text-brand">Child Lock</p>
            </div>
          </div>
        </div>

        <div class="order-3 lg:col-start-1 lg:row-start-2">
          <div class="flex flex-col gap-3 sm:flex-row">
            <a
              href={whatsappGlamourUrl}
              class="inline-flex items-center justify-center gap-2 rounded-full bg-[#25D366] px-7 py-4 text-sm font-black text-white shadow-[0_18px_40px_rgba(37,211,102,.28)] transition hover:-translate-y-0.5 hover:bg-[#1EBE5D]"
            >
              <img src="/assets/images/misc/whatsapp-png.webp" alt="" aria-hidden="true" class="h-5 w-5" />
              WhatsApp Promo Glamour
            </a>

            <a
              href="#harga"
              class="inline-flex items-center justify-center rounded-full border border-brand/15 bg-white px-7 py-4 text-sm font-black text-brand shadow-soft hover:border-brand/30"
            >
              Lihat Pelan Harga
            </a>
          </div>

          <div class="mt-7 rounded-[1.75rem] border border-brand/10 bg-white/80 p-4 shadow-soft backdrop-blur-xl sm:p-5">
            <div class="grid gap-3 sm:grid-cols-[1fr_1fr] sm:items-stretch">
              <div class="rounded-[1.35rem] bg-[linear-gradient(135deg,#B0163C_0%,#7A0E23_42%,#4B0715_100%)] px-5 py-5 text-white shadow-glow">
                <p class="text-xs font-black uppercase tracking-[.16em] text-brand-gold">Promo Terkini</p>
                <p class="mt-2 text-4xl font-black leading-none">
                  RM12<span class="text-sm font-black">/bulan</span>
                </p>
                <p class="mt-1 text-xs font-bold text-white/75">6 bulan pertama</p>
              </div>

              <a
                href="#harga"
                class="rounded-[1.35rem] border border-brand/10 bg-brand-cream px-5 py-5 shadow-soft transition hover:-translate-y-1 hover:border-brand/25"
              >
                <p class="text-xs font-black uppercase tracking-[.14em] text-brand-gold">Harga Glamour</p>
                <p class="mt-2 text-xl font-black text-brand">Dari RM100-RM110/bulan</p>
                <p class="mt-2 text-sm font-bold text-brand-muted">Pakej 5 tahun | 7 tahun | Outright →</p>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 py-10 sm:px-6 lg:px-8">
      <div class="mx-auto grid max-w-7xl gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {highlights.map((item) => (
          <article class="rounded-3xl bg-white p-6 shadow-soft">
            <div class="mb-4 text-2xl">{item.icon}</div>
            <h3 class="font-black">{item.title}</h3>
            <p class="mt-2 text-sm leading-7 text-brand-muted">{item.copy}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="ciri-ciri" class="px-4 py-10 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">Ciri-Ciri Glamour</p>
          <h2 class="mt-3 text-3xl font-black sm:text-4xl">Jangan Nilai Glamour Pada Rupa Sahaja</h2>
          <p class="mt-4 leading-8 text-brand-muted">
            Glamour nampak elegan, tetapi kekuatannya pada kapasiti 7.6L, pilihan jumlah air dan ciri keselamatan untuk kegunaan keluarga.
          </p>
        </div>

        <div class="mx-auto mt-8 hidden max-w-6xl gap-5 lg:grid lg:grid-cols-[.95fr_1.05fr]">
          <article class="overflow-hidden rounded-[2rem] bg-[#f9f3f5] px-6 pt-8 text-center shadow-premium ring-1 ring-brand/10">
            <h3 class="text-3xl font-black leading-tight text-brand">Tangki Besar 7.6L</h3>
            <p class="mt-2 text-lg text-brand">Sesuai untuk kegunaan seisi keluarga.</p>
            <img
              src={`${glamourImageBase}/Glamour-extraparge_01.png.webp`}
              alt="CUCKOO Glamour extra large 7.6L tank dengan Hot 2.4L Cold 2.5L dan Room 2.7L"
              loading="lazy"
              class="mx-auto mt-4 h-[330px] w-full object-contain object-bottom"
            />
          </article>

          <div class="grid gap-5">
            <article class="grid overflow-hidden rounded-[2rem] bg-[#f9f3f5] shadow-premium ring-1 ring-brand/10 md:grid-cols-[.85fr_1.15fr]">
              <img
                src={`${glamourImageBase}/Glamour-Multiple.webp`}
                alt="CUCKOO Glamour multiple volume dispensing options"
                loading="lazy"
                class="h-full min-h-[205px] w-full object-cover"
              />
              <div class="flex flex-col justify-center p-8 text-brand">
                <h3 class="text-2xl font-black leading-tight">Pilihan Jumlah Air</h3>
                <p class="mt-3 text-lg text-brand">Tetapan air ikut keperluan.</p>
                <p class="mt-5 text-base font-black leading-7">
                  Half Cup : hingga 350ml<br />
                  One Cup : hingga 500ml<br />
                  Non-stop : hingga 2000ml
                </p>
              </div>
            </article>

            <article class="grid overflow-hidden rounded-[2rem] bg-[#f9f3f5] shadow-premium ring-1 ring-brand/10 md:grid-cols-[.85fr_1.15fr]">
              <img
                src={`${glamourImageBase}/Glamour-safety.webp`}
                alt="CUCKOO Glamour safety features child lock and button lock"
                loading="lazy"
                class="h-full min-h-[205px] w-full object-cover"
              />
              <div class="flex flex-col justify-center p-8 text-brand">
                <h3 class="text-2xl font-black leading-tight">Ciri Keselamatan</h3>
                <p class="mt-4 text-lg leading-8">Child Lock dan Button Lock untuk bantu elak tersalah tekan.</p>
              </div>
            </article>
          </div>
        </div>

        <div class="mt-8 space-y-5 lg:hidden">
          <article class="grid grid-cols-[1.05fr_.95fr] items-center overflow-hidden rounded-[2rem] bg-[#f9f3f5] shadow-premium ring-1 ring-brand/10">
            <img
              src={`${glamourImageBase}/Glamour-extraparge_01.png.webp`}
              alt="CUCKOO Glamour extra large 7.6L tank"
              loading="lazy"
              class="h-full min-h-[240px] w-full object-cover object-left"
            />
            <div class="p-5 text-brand">
              <h3 class="text-xl font-black leading-tight sm:text-2xl">Tangki Besar 7.6L</h3>
              <p class="mt-2 text-sm font-bold leading-6 text-brand-muted sm:text-base">
                Hot 2.4L, Cold 2.5L dan Room 2.7L untuk kegunaan keluarga.
              </p>
              <span class="mt-4 inline-flex rounded-full bg-brand px-4 py-2 text-xs font-black text-white">
                Kapasiti besar
              </span>
            </div>
          </article>

          <article class="grid grid-cols-[1.05fr_.95fr] items-center overflow-hidden rounded-[2rem] bg-[#f9f3f5] shadow-premium ring-1 ring-brand/10">
            <img src={`${glamourImageBase}/Glamour-Multiple.webp`} alt="CUCKOO Glamour multiple volume dispensing" loading="lazy" class="h-full min-h-[220px] w-full object-cover object-left" />
            <div class="p-5 text-brand">
              <h3 class="text-xl font-black leading-tight sm:text-2xl">Pilihan Jumlah Air</h3>
              <p class="mt-2 text-sm font-bold leading-6 text-brand-muted sm:text-base">Tetapan air ikut keperluan.</p>
              <div class="mt-4 flex flex-wrap gap-2">
                <span class="rounded-full bg-brand px-3 py-2 text-[11px] font-black text-white">Half Cup</span>
                <span class="rounded-full bg-brand px-3 py-2 text-[11px] font-black text-white">One Cup</span>
                <span class="rounded-full bg-brand px-3 py-2 text-[11px] font-black text-white">Non-stop</span>
              </div>
            </div>
          </article>

          <article class="grid grid-cols-[1.05fr_.95fr] items-center overflow-hidden rounded-[2rem] bg-[#f9f3f5] shadow-premium ring-1 ring-brand/10">
            <img src={`${glamourImageBase}/Glamour-safety.webp`} alt="CUCKOO Glamour safety features" loading="lazy" class="h-full min-h-[220px] w-full object-cover object-left" />
            <div class="p-5 text-brand">
              <h3 class="text-xl font-black leading-tight sm:text-2xl">Ciri Keselamatan</h3>
              <p class="mt-2 text-sm font-bold leading-6 text-brand-muted sm:text-base">Child Lock dan Button Lock untuk bantu elak tersalah tekan.</p>
            </div>
          </article>
        </div>

        <p class="mt-5 text-center text-xs font-bold text-brand-muted">
          *Suhu air yang keluar mungkin berbeza mengikut keadaan persekitaran dan corak penggunaan.
        </p>

