const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a
    }
  }))
};
---

<BaseLayout {...meta}>
  <style is:inline>
    html { scroll-behavior: smooth; }
    body { font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
    .gold-line { background: linear-gradient(90deg, transparent, rgba(216,166,74,.8), transparent); }
    .product-blob { background: radial-gradient(circle at 35% 30%, rgba(216,166,74,.24), transparent 38%), radial-gradient(circle at 70% 62%, rgba(122,14,35,.14), transparent 42%), linear-gradient(145deg, #fff8f2, #ffffff); }
    .accent-ring { box-shadow: 0 30px 80px rgba(20,20,20,.14); }
  </style>

  <div class="bg-brand-cream text-brand-ink antialiased">
    <section id="hero" class="relative overflow-hidden px-4 py-10 sm:px-6 lg:px-8 lg:py-16">
      <div class="absolute left-1/2 top-0 -z-10 h-[620px] w-[620px] -translate-x-1/2 rounded-full bg-brand-soft blur-3xl"></div>

      <div class="mx-auto grid max-w-7xl gap-7 lg:grid-cols-[1.02fr_.98fr] lg:items-start lg:gap-10">
        <div class="order-1 lg:col-start-1 lg:row-start-1">
          <div class="mb-5 flex gap-2 overflow-x-auto pb-1 [-ms-overflow-style:none] [scrollbar-width:none] lg:flex-wrap lg:overflow-visible lg:pb-0 [&::-webkit-scrollbar]:hidden">
            <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Ejen CUCKOO sejak 2017</span>
            <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Free Installation</span>
            <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Servis Berkala</span>
          </div>

          <div class="mb-5 inline-flex max-w-full flex-wrap items-center gap-2 rounded-full bg-[linear-gradient(135deg,#4B0715_0%,#7A0E23_58%,#8E1830_100%)] px-4 py-3 text-white shadow-glow ring-1 ring-brand-gold/30 sm:gap-3 sm:px-5">
            <span class="rounded-full bg-white/15 px-3 py-1 text-[11px] font-black uppercase tracking-[.14em] text-brand-gold">Promo Terkini</span>
            <span class="text-sm font-black sm:text-base">Rental dari RM66/bulan</span>
          </div>

          <h1 class="max-w-3xl text-[2.35rem] font-black leading-[1.06] tracking-tight text-brand-ink sm:text-5xl lg:text-6xl">
            CUCKOO VIVID — Penapis Air Panas Tangki Besar Untuk Keluarga
          </h1>

          <p class="mt-5 max-w-2xl text-base leading-8 text-brand-muted sm:text-lg">
            Hot water tank 5.3L, warm water 1.3L, 6-stage Nano Positive Filtration dan Child Lock dalam rekaan premium untuk keluarga yang kerap guna air panas.
          </p>
        </div>

        <div class="order-2 rounded-[2rem] border border-white/80 bg-white/70 p-4 shadow-premium backdrop-blur-xl sm:p-6 lg:col-start-2 lg:row-span-2 lg:row-start-1">
          <div class="product-blob accent-ring relative overflow-hidden rounded-[1.7rem] p-4 sm:p-6 lg:p-8">
            <div class="flex flex-wrap gap-2">
              <span class="rounded-full bg-white/85 px-4 py-2 text-xs font-black text-brand shadow-soft">Large Hot Tank</span>
              <span class="rounded-full bg-white/85 px-4 py-2 text-xs font-black text-brand shadow-soft">4-8 Family Members</span>
            </div>

            <div class="relative mt-5 flex min-h-[300px] items-center justify-center overflow-hidden rounded-[1.5rem] bg-gradient-to-br from-white/80 to-white/35 p-5 sm:min-h-[390px] lg:min-h-[470px]">
              <div class="absolute bottom-12 h-16 w-[72%] rounded-full bg-brand-gold/20 blur-2xl"></div>
              <img
                src={`${vividImageBase}/cuckoo-vivid-water-purifier-hero.webp`}
                alt="CUCKOO VIVID penapis air panas tangki besar untuk keluarga"
                class="relative z-10 h-[290px] w-auto object-contain drop-shadow-2xl sm:h-[380px] lg:h-[455px]"
              />
            </div>

            <div class="mt-5 flex flex-wrap justify-center gap-2">
              <span class="rounded-full border border-red-200 bg-red-50 px-4 py-2 text-xs font-black text-red-700">Hot Tank 5.3L</span>
              <span class="rounded-full border border-amber-200 bg-amber-50 px-4 py-2 text-xs font-black text-amber-800">Warm Tank 1.3L</span>
              <span class="rounded-full border border-stone-200 bg-white px-4 py-2 text-xs font-black text-stone-700">Nano Positive</span>
            </div>
          </div>

          <div class="mt-4 grid grid-cols-2 gap-2 sm:grid-cols-4">
            <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10">
              <p class="text-xs font-black text-brand">Child Lock</p>
            </div>
            <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10">
              <p class="text-xs font-black text-brand">6-Stage Filter</p>
            </div>
            <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10">
              <p class="text-xs font-black text-brand">Stainless Tank</p>
            </div>
            <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10">
              <p class="text-xs font-black text-brand">Servis Berkala</p>
            </div>
          </div>
        </div>

        <div class="order-3 lg:col-start-1 lg:row-start-2">
          <div class="flex flex-col gap-3 sm:flex-row">
            <a
              href={whatsappVividUrl}
              class="inline-flex items-center justify-center gap-2 rounded-full bg-[#25D366] px-7 py-4 text-sm font-black text-white shadow-[0_18px_40px_rgba(37,211,102,.28)] transition hover:-translate-y-0.5 hover:bg-[#1EBE5D]"
            >
              <img src="/assets/images/misc/whatsapp-png.webp" alt="" aria-hidden="true" class="h-5 w-5" />
              WhatsApp Promo VIVID
            </a>

            <a
              href="#harga"
              class="inline-flex items-center justify-center rounded-full border border-brand/15 bg-white px-7 py-4 text-sm font-black text-brand shadow-soft hover:border-brand/30"
            >
              Lihat Pelan Harga
            </a>
          </div>

          <div class="mt-7 rounded-[1.75rem] border border-brand/10 bg-white/80 p-4 shadow-soft backdrop-blur-xl sm:p-5">
            <div class="grid gap-3 sm:grid-cols-[1fr_1fr] sm:items-stretch">
              <div class="rounded-[1.35rem] bg-brand px-5 py-5 text-white shadow-glow">
                <p class="text-xs font-black uppercase tracking-[.16em] text-brand-gold">Rental Plan</p>
                <p class="mt-2 text-4xl font-black leading-none">
                  RM66<span class="text-sm font-black">/bulan</span>
                </p>
                <p class="mt-1 text-xs font-bold text-white/75">Pelan 7 tahun</p>
              </div>

              <a
                href="#harga"
                class="rounded-[1.35rem] border border-brand/10 bg-brand-cream px-5 py-5 shadow-soft transition hover:-translate-y-1 hover:border-brand/25"
              >
                <p class="text-xs font-black uppercase tracking-[.14em] text-brand-gold">Harga VIVID</p>
                <p class="mt-2 text-xl font-black text-brand">RM77 / RM66 sebulan</p>
                <p class="mt-2 text-sm font-bold text-brand-muted">Outright RM3,360 -></p>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 pb-8 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl overflow-hidden rounded-[2rem] bg-white shadow-premium ring-1 ring-brand/10">
        <img
          src={`${vividImageBase}/cuckoo-vivid-hq-banner.png`}
          alt="CUCKOO VIVID large hot water tank purifier banner rasmi"
          loading="lazy"
          class="h-full w-full object-cover"
        />
      </div>
    </section>

    <section id="ciri-ciri" class="px-4 py-14 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="max-w-3xl">
          <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">Ciri-Ciri Utama</p>
          <h2 class="mt-3 text-3xl font-black sm:text-4xl">Apa Yang Buat VIVID Sesuai Untuk Keluarga</h2>
          <p class="mt-4 text-base leading-8 text-brand-muted">
            Feature disusun supaya customer cepat faham kenapa VIVID praktikal untuk rumah yang mahukan air panas dan suam setiap hari.
          </p>
        </div>

        <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {quickBenefits.map((item) => (
            <article class="rounded-3xl bg-white p-6 shadow-soft ring-1 ring-brand/10">
              <h3 class="text-lg font-black text-brand-ink">{item.title}</h3>
              <p class="mt-2 text-sm leading-7 text-brand-muted">{item.copy}</p>
            </article>
          ))}
        </div>

        <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:gap-7">
          {featureStories.map((item, index) => (
            <article class="group flex min-h-full flex-col overflow-hidden rounded-[1.75rem] bg-white shadow-premium ring-1 ring-brand/10 transition duration-300 hover:-translate-y-1 hover:shadow-glow">
              <div class="bg-[linear-gradient(180deg,#fff8f2_0%,#fff2ea_100%)] p-3 sm:p-4">
                <div class="relative aspect-[16/10] overflow-hidden rounded-[1.25rem] bg-white shadow-soft ring-1 ring-white/70">
                  <img
                    src={item.image}
                    alt={item.alt}
                    loading="lazy"
                    class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.025]"
                  />
                  <div class="pointer-events-none absolute inset-0 ring-1 ring-inset ring-brand/5"></div>
                </div>
              </div>
              <div class="flex flex-1 flex-col p-5 sm:p-6">
                <div class="flex items-start gap-4">
                  <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand-cream text-xs font-black text-brand-gold ring-1 ring-brand/10">
                    {String(index + 1).padStart(2, '0')}
                  </span>
                  <div>
                    <p class="text-[11px] font-black uppercase tracking-[.18em] text-brand-gold">{item.eyebrow}</p>
                    <h3 class="mt-1 text-xl font-black leading-tight text-brand-ink sm:text-2xl">
                      {item.title}
                    </h3>
                  </div>
                </div>
                <p class="mt-4 flex-1 text-sm leading-7 text-brand-muted">
                  {item.copy}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="filtration" class="px-4 py-14 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl rounded-[2rem] bg-white p-5 shadow-premium sm:p-8 lg:p-10">
        <div class="mx-auto max-w-3xl text-center">
