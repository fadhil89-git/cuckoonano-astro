  '@type': 'Product',
  name: 'CUCKOO VIVID Water Purifier',
  image: [
    'https://www.cuckoonano.com/assets/images/products/water-purifier/vivid/cuckoo-vivid-water-purifier-hero.webp',
    'https://www.cuckoonano.com/assets/images/products/water-purifier/vivid/cuckoo-vivid-hq-product.png'
  ],
  url: 'https://www.cuckoonano.com/products/water-purifier/vivid/',
  sku: 'CUCKOO-VIVID',
  category: 'Water Purifier',
  brand: {
    '@type': 'Brand',
    name: 'CUCKOO'
