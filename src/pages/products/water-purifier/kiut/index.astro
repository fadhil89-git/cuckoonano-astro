  ogImage: 'https://www.cuckoonano.com/assets/images/products/water-purifier/kiut/cuckoo-kiut-tankless-water-purifier-hero.png',
  ogType: 'website'
};

const heroChips = ['Tankless Design', '135mm Slim', '4-Stage Filtration'];

const panelOptions = [
  {
    name: 'Cool Silver',
    image: `${kiutImageBase}/cuckoo-kiut-cool-silver-panel.png`,
    alt: 'CUCKOO KIUT Cool Silver interchangeable colour panel',
    swatch: '#d5d8da'
