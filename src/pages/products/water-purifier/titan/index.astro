---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import WaterHalalSection from '../../../../components/WaterHalalSection.astro';
import FreeGiftSection from '../../../../components/FreeGiftSection.astro';
import AgentSection from '../../../../components/AgentSection.astro';
import CustomerProofSection from '../../../../components/CustomerProofSection.astro';
import PromoBannerSection from '../../../../components/PromoBannerSection.astro';
import ProductCategorySection from '../../../../components/ProductCategorySection.astro';
import WaterPurifierServiceSection from '../../../../components/WaterPurifierServiceSection.astro';
import WhyChooseCuckooWaterPurifiers from '../../../../components/water-purifier/WhyChooseCuckooWaterPurifiers.astro';

const whatsappTitanUrl =
  'https://api.whatsapp.com/send?phone=60139916967&text=Salam%20Fadhil%2C%20saya%20berminat%20dengan%20promo%20CUCKOO%20Titan.%20Boleh%20bantu%20saya%3F';

const titanProductImage = '/assets/images/Gambar%20Produk%20png/titan.webp';

const meta = {
  title: 'CUCKOO Titan Water Purifier | Tankless 100°C, Harga & Promo 2026',
  description:
    'CUCKOO Titan penapis air tankless dengan instant 100°C hot water, 5-stage filtration, sterilisation water mode, voice navigation, spec dan promo terkini.',
  canonical: 'https://www.cuckoonano.com/products/water-purifier/titan/',
  ogImage: 'https://www.cuckoonano.com/assets/images/Gambar%20Produk%20png/titan.webp',
  ogType: 'website'
};

const heroChips = ['Tankless Design', 'Instant 100°C', '5-Stage Filtration'];

const quickBenefits = [
  {
    title: 'Tankless Direct Water',
    copy: 'Tiada tangki simpanan besar. Air ditapis terus untuk dapur moden yang mahukan mesin compact dan bersih.'
  },
  {
    title: 'Instant Extra Hot 100°C',
    copy: 'Air panas tersedia cepat untuk kopi, teh, susu, herba atau keperluan harian tanpa tunggu lama.'
  },
  {
    title: 'Sterilisation Water Mode',
    copy: 'Mode air steril sesuai untuk bantu bersihkan botol, cawan, buah, sayur atau perkakas kecil.'
  },
  {
    title: 'Slim 166mm Width',
    copy: 'Rekaan slim yang mudah masuk dapur kecil, kabinet moden, pantry ringkas atau unit apartment.'
  }
];

const featureStories = [
  {
    title: 'Instant 100°C Hot Water',
    copy: 'Titan fokus kepada air panas segera. Sesuai untuk pelanggan yang kerap bancuh kopi, teh, susu atau perlukan air panas untuk kegunaan dapur.',
    mediaTitle: '100°C',
    mediaCopy: 'Extra hot water ready in seconds'
  },
  {
    title: 'Sterilisation Water Mode',
    copy: 'Gunakan air panas untuk bantu steril botol bayi, cawan, buah, sayur dan perkakas kecil. Ini menjadikan Titan lebih praktikal untuk rumah moden.',
    mediaTitle: 'Sterilise',
    mediaCopy: 'Hot water support for daily hygiene'
  },
  {
    title: 'Adjustable 4-Way Faucet',
    copy: 'Faucet boleh dilaras supaya lebih mudah isi cawan rendah, mug tinggi atau botol air tanpa rasa sempit.',
    mediaTitle: '4-Way',
    mediaCopy: 'Flexible dispensing position'
  },
  {
    title: 'Hidden Stop Touch',
    copy: 'Butang stop yang kemas membantu hentikan dispensing dengan cepat tanpa mengganggu rupa premium mesin.',
    mediaTitle: 'Stop',
    mediaCopy: 'Quick control, cleaner design'
  },
  {
    title: 'Voice Navigation',
    copy: 'Panduan suara memudahkan penggunaan harian, terutama bila mahu faham status mesin atau mode yang sedang digunakan.',
    mediaTitle: 'Voice',
    mediaCopy: 'Clear guidance for daily use'
  }
];

const filtrationSteps = [
  {
    stage: 'Stage 1 - 4',
    title: 'Carbon Composite Filter',
    schedule: 'Setiap 4 bulan',
    copy: 'Membantu mengurangkan klorin, bau, fine particles dan bahan organik untuk rasa air yang lebih bersih.'
  },
  {
    stage: 'Stage 5',
    title: 'Nano Positive Plus 3.0 Filter',
    schedule: 'Setiap 8 bulan',
    copy: 'Membantu menapis bakteria, virus, heavy metals, algae dan fungi sambil mengekalkan mineral bermanfaat.'
  }
];

const pricingPlans = [
  {
    tier: 'Tier 1',
    title: 'Rental Plan 5 Tahun',
    price: 'RM110',
    suffix: '/bulan',
    badge: 'Best Seller',
    copy: 'Pilihan popular untuk pelanggan yang mahu Titan dengan servis berkala CUCKOO dan bayaran bulanan lebih mudah.',
    details: ['Servis dan filter berkala CUCKOO', 'Sesuai untuk rumah moden dan dapur compact'],
    featured: true
  },
  {
    tier: 'Tier 2',
    title: 'Rental Plan 7 Tahun',
    price: 'Semak',
    suffix: '',
    badge: '',
    copy: 'Pakej 7 tahun tertakluk kepada kempen semasa. WhatsApp untuk semak bayaran bulanan dan kelayakan terkini.',
    details: ['Semak pakej dan promo semasa', 'Boleh bandingkan dengan model Grande atau XCEL'],
    featured: false
  },
  {
    tier: 'Tier 3',
    title: 'Outright',
    price: 'RM4,300',
    suffix: '',
    badge: '',
    copy: 'Pilihan untuk pelanggan yang mahu beli terus tanpa komitmen bulanan.',
    details: ['Bayaran sekali sahaja', 'Semak terma servis dan stok semasa'],
    featured: false
  }
];

const specRows = [
  ['Model', 'CUCKOO Titan'],
  ['Jenis', 'Tankless water purifier'],
  ['Tapisan', '5-Stage Filtration'],
  ['Filter Utama', 'Carbon Composite Filter, Nano Positive Plus 3.0 Filter'],
  ['Air Panas', 'Instant extra hot water up to 100°C'],
  ['Mode Khas', 'Sterilisation water mode'],
  ['Faucet', 'Adjustable 4-way faucet'],
  ['Lebar', '166mm'],
  ['Sesuai Untuk', 'Dapur kecil, rumah moden, apartment, pantry compact'],
  ['Servis', 'Servis berkala CUCKOO']
];

const comparisonRows = [
  ['Design', 'Tankless slim', 'Tangki besar 7.6L', 'Countertop digital premium'],
  ['Fokus utama', 'Compact + air panas 100°C', 'Kapasiti besar + suhu lengkap', 'Air panas, sejuk dan room dalam satu sentuhan'],
  ['Sesuai untuk', 'Dapur kecil / apartment', 'Keluarga besar / penggunaan kerap', 'Rumah moden yang mahu design premium'],
  ['Filtration', '5-stage, 2 filter utama', '6-stage, 3 filter utama', 'Nano Positive Filtration'],
  ['Harga rujukan', 'Dari RM110/bulan', 'Dari RM115/bulan', 'Dari RM95/bulan']
];

const faqItems = [
  {
    q: 'Apa kelebihan utama CUCKOO Titan?',
    a: 'Titan ialah penapis air tankless yang slim dengan instant 100°C hot water, 5-stage filtration, sterilisation water mode, adjustable faucet dan voice navigation.'
  },
  {
    q: 'CUCKOO Titan ada tangki tak?',
    a: 'Titan ialah model tankless, jadi ia sesuai untuk pelanggan yang mahukan rekaan compact tanpa tangki simpanan besar.'
  },
  {
    q: 'Berapa harga CUCKOO Titan?',
    a: 'Rujukan harga Titan ialah dari RM110/bulan untuk rental dan RM4,300 untuk outright. Harga tertakluk kepada promo dan kempen semasa.'
  },
  {
    q: 'Apa beza Titan dengan Grande?',
    a: 'Titan lebih fokus kepada design tankless slim dan instant 100°C hot water. Grande pula fokus kepada tangki besar 7.6L dan pilihan suhu lengkap untuk penggunaan ramai.'
  },
  {
    q: 'Apa sistem tapisan Titan?',
    a: 'Titan menggunakan 5-stage filtration dengan Carbon Composite Filter dan Nano Positive Plus 3.0 Filter.'
  },
  {
    q: 'Titan sesuai untuk siapa?',
    a: 'Titan sesuai untuk dapur kecil, apartment, rumah moden, pelanggan yang kerap guna air panas dan customer yang mahu mesin slim tanpa tangki besar.'
  },
  {
    q: 'Macam mana nak semak promo Titan?',
    a: 'Klik butang WhatsApp dan saya akan bantu semak promo Titan, bayaran permulaan, dokumen, stok dan slot pemasangan.'
  }
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'CUCKOO Titan Water Purifier',
  image: ['https://www.cuckoonano.com/assets/images/Gambar%20Produk%20png/titan.webp'],
  url: 'https://www.cuckoonano.com/products/water-purifier/titan/',
  sku: 'CUCKOO-TITAN',
  category: 'Water Purifier',
  brand: {
    '@type': 'Brand',
    name: 'CUCKOO'
  },
  description:
    'Penapis air tankless slim dengan instant 100°C hot water, 5-stage filtration, sterilisation water mode, adjustable faucet dan voice navigation.',
  offers: [
    {
      '@type': 'Offer',
      url: 'https://www.cuckoonano.com/products/water-purifier/titan/#harga',
      priceCurrency: 'MYR',
      price: '110',
      availability: 'https://schema.org/InStock',
      description: 'Rental Titan dari RM110/bulan tertakluk kepada promo semasa.'
    },
    {
      '@type': 'Offer',
      url: 'https://www.cuckoonano.com/products/water-purifier/titan/#harga',
      priceCurrency: 'MYR',
      price: '4300',
      availability: 'https://schema.org/InStock',
      description: 'Outright purchase rujukan RM4,300 tertakluk kepada promosi semasa.'
    }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a
    }
  }))
};
---

<BaseLayout {...meta}>
  <style is:inline>
    html { scroll-behavior: smooth; }
    body { font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
    .titan-hero { background: radial-gradient(circle at 26% 18%, rgba(216,166,74,.22), transparent 34%), radial-gradient(circle at 76% 56%, rgba(122,14,35,.14), transparent 36%), linear-gradient(145deg, #fff8f2, #ffffff); }
  </style>

  <div class="bg-brand-cream text-brand-ink antialiased">
    <section id="hero" class="relative overflow-hidden px-4 py-10 sm:px-6 lg:px-8 lg:py-16">
      <div class="absolute left-1/2 top-0 -z-10 h-[620px] w-[620px] -translate-x-1/2 rounded-full bg-brand-soft blur-3xl"></div>

      <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[1.02fr_.98fr] lg:items-start lg:gap-10">
        <div class="order-1 lg:col-start-1 lg:row-start-1">
          <div class="mb-5 flex gap-2 overflow-x-auto pb-1 [-ms-overflow-style:none] [scrollbar-width:none] lg:flex-wrap lg:overflow-visible lg:pb-0 [&::-webkit-scrollbar]:hidden">
            <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Ejen CUCKOO sejak 2017</span>
            <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Free Installation</span>
            <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Servis Berkala</span>
          </div>

          <div class="mb-5 inline-flex max-w-full flex-wrap items-center gap-2 rounded-full bg-[linear-gradient(135deg,#4B0715_0%,#7A0E23_58%,#8E1830_100%)] px-4 py-3 text-white shadow-glow ring-1 ring-brand-gold/30 sm:gap-3 sm:px-5">
            <span class="rounded-full bg-white/15 px-3 py-1 text-[11px] font-black uppercase tracking-[.14em] text-brand-gold">Promo Terkini</span>
            <span class="text-sm font-black sm:text-base">RM12/bulan untuk 6 bulan pertama</span>
          </div>

          <h1 class="max-w-3xl text-[2.35rem] font-black leading-[1.06] tracking-tight text-brand-ink sm:text-5xl lg:text-6xl">
            CUCKOO Titan — Penapis Air Tankless Dengan Instant 100°C Hot Water
          </h1>

          <p class="mt-5 max-w-2xl text-base leading-8 text-brand-muted sm:text-lg">
            Titan sesuai untuk dapur moden yang mahukan penapis air slim, tankless, air panas segera 100°C, mode sterilisation dan sistem tapisan khas 5 peringkat.
          </p>
        </div>

        <div class="order-2 rounded-[2rem] border border-white/80 bg-white/70 p-4 shadow-premium backdrop-blur-xl sm:p-6 lg:col-start-2 lg:row-span-2 lg:row-start-1">
          <div class="titan-hero relative overflow-hidden rounded-[1.7rem] p-4 shadow-[0_30px_80px_rgba(20,20,20,.16)] sm:p-6 lg:p-8">
            <div class="flex flex-wrap justify-center gap-2">
              {heroChips.map((chip) => (
                <span class="rounded-full bg-white/85 px-4 py-2 text-xs font-black text-brand shadow-soft">{chip}</span>
              ))}
            </div>

            <div class="relative mt-5 flex min-h-[320px] items-center justify-center overflow-hidden rounded-[1.5rem] bg-gradient-to-br from-white/90 to-white/35 p-5 sm:min-h-[430px] lg:min-h-[520px]">
              <div class="absolute bottom-14 h-16 w-[70%] rounded-full bg-brand-gold/25 blur-2xl"></div>
              <img
                src={titanProductImage}
                alt="CUCKOO Titan water purifier tankless slim dengan air panas 100 darjah"
                class="relative z-10 h-[300px] w-auto object-contain drop-shadow-2xl sm:h-[410px] lg:h-[500px]"
              />
            </div>

            <div class="mt-5 flex flex-wrap justify-center gap-2">
              <span class="rounded-full border border-red-200 bg-red-50 px-4 py-2 text-xs font-black text-red-700">Instant 100°C</span>
              <span class="rounded-full border border-blue-200 bg-blue-50 px-4 py-2 text-xs font-black text-blue-700">Tankless</span>
              <span class="rounded-full border border-stone-200 bg-white px-4 py-2 text-xs font-black text-stone-700">166mm Slim</span>
            </div>
          </div>
        </div>

        <div class="order-3 lg:col-start-1 lg:row-start-2">
          <div class="flex flex-col gap-3 sm:flex-row">
            <a
              href={whatsappTitanUrl}
              class="inline-flex items-center justify-center gap-2 rounded-full bg-[#25D366] px-7 py-4 text-sm font-black text-white shadow-[0_18px_40px_rgba(37,211,102,.28)] transition hover:-translate-y-0.5 hover:bg-[#1EBE5D]"
            >
              <img src="/assets/images/misc/whatsapp-png.webp" alt="" aria-hidden="true" class="h-5 w-5" />
              WhatsApp Promo Titan
            </a>

            <a
              href="#harga"
              class="inline-flex items-center justify-center rounded-full border border-brand/15 bg-white px-7 py-4 text-sm font-black text-brand shadow-soft hover:border-brand/30"
            >
              Lihat Harga Titan
            </a>
          </div>

          <div class="mt-7 rounded-[1.75rem] border border-brand/10 bg-white/80 p-4 shadow-soft backdrop-blur-xl sm:p-5">
            <div class="grid gap-3 sm:grid-cols-[1fr_1fr] sm:items-stretch">
              <div class="rounded-[1.35rem] bg-brand px-5 py-5 text-white shadow-glow">
                <p class="text-xs font-black uppercase tracking-[.16em] text-brand-gold">Harga Titan</p>
                <p class="mt-2 text-4xl font-black leading-none">
                  RM110<span class="text-sm font-black">/bulan</span>
                </p>
                <p class="mt-1 text-xs font-bold text-white/75">rental plan rujukan</p>
              </div>

              <a
                href="#harga"
                class="rounded-[1.35rem] border border-brand/10 bg-brand-cream px-5 py-5 shadow-soft transition hover:-translate-y-1 hover:border-brand/25"
              >
                <p class="text-xs font-black uppercase tracking-[.14em] text-brand-gold">Outright</p>
                <p class="mt-2 text-xl font-black text-brand">RM4,300</p>
                <p class="mt-2 text-sm font-bold text-brand-muted">Promo RM12 selepas table →</p>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="kenapa-titan" class="px-4 py-14 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">Kenapa Titan</p>
          <h2 class="mt-3 text-3xl font-black sm:text-4xl lg:text-5xl">Tankless, Slim Dan Fokus Air Panas Segera</h2>
          <p class="mt-5 leading-8 text-brand-muted">
            Titan bukan model tangki besar. Ia direka untuk customer yang mahu mesin compact, premium dan praktikal untuk dapur moden.
          </p>
        </div>

        <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {quickBenefits.map((item) => (
            <article class="rounded-[1.75rem] bg-white p-6 shadow-soft ring-1 ring-brand/10">
              <h3 class="text-xl font-black text-brand-ink">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-brand-muted">{item.copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="ciri-ciri" class="px-4 py-14 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">Titan Features</p>
          <h2 class="mt-3 text-3xl font-black sm:text-4xl">Ciri-Ciri Yang Buat Titan Sesuai Untuk Dapur Moden</h2>
          <p class="mt-4 text-base leading-8 text-brand-muted">
            Susunan ini fokus kepada apa yang pelanggan mahu faham cepat: air panas 100°C, sterilisation, faucet fleksibel dan kawalan yang mudah.
          </p>
        </div>

        <div class="mt-10 space-y-6">
          {featureStories.map((item, index) => {
            const imageFirst = index % 2 === 0;
            return (
              <article class="overflow-hidden rounded-[2rem] bg-white shadow-premium ring-1 ring-brand/10 lg:grid lg:grid-cols-2 lg:items-center">
                <div class={`${imageFirst ? 'lg:order-1' : 'lg:order-2'} bg-brand-cream p-4 sm:p-6`}>
                  <div class="flex aspect-[4/3] flex-col items-center justify-center overflow-hidden rounded-[1.5rem] bg-[radial-gradient(circle_at_50%_32%,rgba(255,255,255,.2),transparent_34%),linear-gradient(135deg,#4B0715_0%,#7A0E23_55%,#9A2540_100%)] p-6 text-center text-white shadow-soft">
                    <img
                      src={titanProductImage}
                      alt={`CUCKOO Titan ${item.title}`}
                      loading="lazy"
                      class="h-40 w-auto object-contain drop-shadow-2xl sm:h-52"
                    />
                    <p class="mt-4 text-5xl font-black text-brand-gold">{item.mediaTitle}</p>
                    <p class="mt-2 text-sm font-bold text-white/75">{item.mediaCopy}</p>
                  </div>
                </div>
                <div class={`${imageFirst ? 'lg:order-2' : 'lg:order-1'} p-6 sm:p-8 lg:p-12`}>
                  <p class="text-xs font-black uppercase tracking-[.2em] text-brand-gold">Ciri {index + 1}</p>
                  <h3 class="mt-3 text-2xl font-black text-brand-ink sm:text-3xl">{item.title}</h3>
                  <p class="mt-4 text-base leading-8 text-brand-muted">{item.copy}</p>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section id="filtration" class="px-4 py-14 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl overflow-hidden rounded-[2rem] bg-[radial-gradient(circle_at_20%_10%,rgba(255,255,255,.14),transparent_34%),linear-gradient(135deg,#4B0715_0%,#7A0E23_46%,#9A2540_100%)] shadow-premium">
        <div class="px-5 pt-10 text-center sm:px-8 lg:px-10">
          <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">Titan Filtration</p>
          <h2 class="mt-3 text-3xl font-black uppercase tracking-[.12em] text-white sm:text-4xl">
            Sistem Tapisan 5 Peringkat Titan
          </h2>
          <p class="mt-3 text-lg font-bold text-white/75">
            Berbeza daripada Grande dan XCEL, Titan menggunakan sistem tankless dengan 2 filter utama.
          </p>
        </div>

        <div class="mx-auto mt-8 grid max-w-5xl gap-5 px-5 pb-6 md:grid-cols-2 lg:px-10">
          {filtrationSteps.map((item) => (
            <article class="overflow-hidden rounded-[1.75rem] bg-[#f5edef] shadow-[0_24px_70px_rgba(20,0,8,.22)]">
              <p class="bg-[linear-gradient(135deg,#B0163C_0%,#7A0E23_42%,#4B0715_100%)] px-6 py-4 text-sm font-black uppercase tracking-[.12em] text-white">
                {item.stage}
              </p>
              <div class="p-6">
                <p class="text-xs font-black uppercase tracking-[.16em] text-brand-gold">{item.schedule}</p>
                <h3 class="mt-3 text-2xl font-black text-brand">{item.title}</h3>
                <p class="mt-4 text-base leading-8 text-brand-muted">{item.copy}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="px-5 pb-10 pt-2 sm:px-8 lg:px-10">
          <p class="mx-auto max-w-5xl text-center text-lg leading-8 text-white/80">
            Sistem ini membantu menghasilkan <strong class="text-white">air bersih, selamat dan mild alkaline</strong> sambil mengekalkan konsep Titan yang slim dan tankless.
          </p>
        </div>
      </div>
    </section>

    <section id="harga" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">Harga</p>
          <h2 class="mt-3 text-3xl font-black sm:text-4xl lg:text-5xl">Harga CUCKOO Titan Malaysia</h2>
          <p class="mt-5 leading-8 text-brand-muted">
            Table ini bantu prospek cepat nampak pilihan bayaran sebelum WhatsApp. Promo RM12 ditunjukkan selepas pricing table.
          </p>
        </div>

        <div class="mt-10 grid gap-5 lg:grid-cols-3">
          {pricingPlans.map((plan) => (
            <article class={`relative rounded-[2rem] p-7 shadow-soft ${plan.featured ? 'border-2 border-brand bg-brand text-white shadow-glow' : 'border border-brand/10 bg-white'}`}>
              {plan.badge && (
                <div class="absolute -top-4 left-7 rounded-full bg-white px-5 py-2 text-xs font-black uppercase tracking-[.14em] text-brand shadow-soft">
                  {plan.badge}
                </div>
              )}
              <p class="mt-3 text-sm font-black uppercase tracking-[.16em] text-brand-gold">{plan.tier}</p>
              <h3 class={`mt-4 text-2xl font-black ${plan.featured ? 'text-white' : 'text-brand-ink'}`}>{plan.title}</h3>
              <div class={`mt-7 rounded-[1.5rem] p-5 ${plan.featured ? 'bg-white/10' : 'bg-brand-cream'}`}>
                <p class={`text-5xl font-black ${plan.featured ? 'text-white' : 'text-brand'}`}>
                  {plan.price}<span class={`text-base font-black ${plan.featured ? 'text-white/70' : 'text-brand-muted'}`}>{plan.suffix}</span>
                </p>
                <p class={`mt-2 text-xs font-black uppercase tracking-[.12em] ${plan.featured ? 'text-brand-gold' : 'text-brand-muted'}`}>
                  {plan.suffix ? 'Harga bulanan' : plan.price === 'Semak' ? 'Pakej semasa' : 'Harga outright'}
                </p>
              </div>
              <p class={`mt-5 text-sm leading-7 ${plan.featured ? 'text-white/78' : 'text-brand-muted'}`}>{plan.copy}</p>
              <ul class={`mt-5 space-y-2 text-sm font-bold ${plan.featured ? 'text-white/85' : 'text-brand-ink'}`}>
                {plan.details.map((detail) => (
                  <li>✓ {detail}</li>
                ))}
              </ul>
              <a href={whatsappTitanUrl}
                class="mt-7 inline-flex w-full items-center justify-center gap-2 rounded-full bg-[#25D366] px-6 py-4 text-sm font-black text-white shadow-[0_18px_40px_rgba(37,211,102,.24)] transition hover:-translate-y-0.5 hover:bg-[#1EBE5D]">
                <img src="/assets/images/misc/whatsapp-png.webp" alt="" aria-hidden="true" class="h-5 w-5" />
                WhatsApp Semak
              </a>
            </article>
          ))}
        </div>

        <div class="mt-8 rounded-[2rem] bg-white p-5 text-center text-sm font-bold leading-7 text-brand-muted shadow-soft">
          Harga dan promosi tertakluk kepada kempen semasa. WhatsApp untuk semak bayaran permulaan, kelayakan, dokumen, stok dan kawasan servis.
        </div>
      </div>
