    title: 'Carbon Composite Filter',
    copy: 'Membantu mengurangkan klorin, bau, bahan organik dan partikel halus untuk rasa air yang lebih baik.'
  },
  {
    stage: 'Stage 5',
    title: 'Nano Positive Filter',
    copy: 'Membantu menapis bakteria, virus, heavy metals dan bahan berbahaya sambil mengekalkan mineral.'
  }
