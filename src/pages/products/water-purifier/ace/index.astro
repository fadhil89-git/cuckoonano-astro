const specHighlights = [
  ['Under Sink', 'Jenis Produk'],
  ['5-Stage', 'Filtration'],
  ['2 Filter', 'Sistem Filter'],
  ['Direct Flow', 'Kapasiti Air']
];

const specRows = [
  ['Model', 'CUCKOO ACE'],
  ['Model Code', 'CP-AAS100ULDS'],
  ['Jenis', 'Under sink water purifier'],
  ['Warna', 'Lumi Dark Silver'],
  ['Filtration', '5-Stage Filtration System'],
  ['Filter Utama', 'Sediment, Carbon Composite, Nano Positive'],
  ['Water Temperature', '5°C hingga 100°C'],
  ['Capacity', 'Direct water flow'],
  ['Body Dimension', '166(W) x 390(D) x 418(H) mm'],
  ['Faucet Dimension', '61(W) x 187(D) x 306(H) mm'],
  ['Smart Faucet', 'One-touch panel, jog dial, human detection sensor, 180° rotating faucet'],
  ['Sterilisation', '100°C Steam Sterilisation, In & Out Auto Sterilisation, Cleaning Water'],
  ['Plan', 'Outright sahaja']
];

const galleryItems = [
  {
    image: `${aceImageBase}/penapis-air-cuckoo-ace-under-sink-gallery-1.png`,
    title: 'CUCKOO ACE Gallery 1',
    copy: 'Rujukan visual ACE untuk dapur moden dengan konsep under sink.',
    alt: 'Gambar CUCKOO ACE under sink water purifier untuk dapur moden gallery 1'
  },
  {
    image: `${aceImageBase}/penapis-air-cuckoo-ace-under-sink-gallery-2.png`,
    title: 'CUCKOO ACE Gallery 2',
    copy: 'Lihat suasana pemasangan ACE dengan faucet premium di atas counter.',
    alt: 'Gambar faucet premium CUCKOO ACE under sink water purifier gallery 2'
  },
  {
    image: `${aceImageBase}/penapis-air-cuckoo-ace-under-sink-gallery-3.png`,
    title: 'CUCKOO ACE Gallery 3',
    copy: 'Rujukan konsep dapur kemas dengan body mesin tersembunyi bawah sink.',
    alt: 'Gambar body CUCKOO ACE tersembunyi bawah sink kitchen cabinet gallery 3'
  },
  {
    image: `${aceImageBase}/cuckoo-ace-under-sink-kitchen-banner-desktop.png`,
    title: 'CUCKOO ACE Kitchen Concept',
    copy: 'Visual penuh konsep under sink untuk dapur moden dan minimalist.',
    alt: 'CUCKOO ACE kitchen concept under sink water purifier'
  },
  {
    image: `${aceImageBase}/cuckoo-ace-5-stage-filtration-system.png`,
    title: 'CUCKOO ACE Filtration',
    copy: 'Sistem tapisan ACE dengan 5-stage filtration dan 2 filter.',
    alt: 'Sistem tapisan 5 peringkat CUCKOO ACE water purifier'
  }
];

const faqItems = [
