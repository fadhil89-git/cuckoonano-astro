const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'CUCKOO ACE Under Sink Water Purifier',
  brand: {
    '@type': 'Brand',
    name: 'CUCKOO'
  },
  description:
    'Penapis air under sink premium dengan 100°C Steam Sterilisation, In & Out Auto Sterilisation, Cleaning Water, smart faucet dan 5-stage filtration.',
  color: 'Lumi Dark Silver'
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a
    }
  }))
};
---

<BaseLayout {...meta}>
  <div class="bg-brand-cream text-brand-ink antialiased">
    <section id="hero" class="relative overflow-hidden px-4 py-10 sm:px-6 lg:px-8 lg:py-16">
      <div class="absolute left-1/2 top-0 -z-10 h-[620px] w-[620px] -translate-x-1/2 rounded-full bg-brand-soft blur-3xl"></div>

      <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[1.02fr_.98fr] lg:items-center">
        <div>
          <div class="mb-5 flex gap-2 overflow-x-auto pb-1 [-ms-overflow-style:none] [scrollbar-width:none] lg:flex-wrap lg:overflow-visible lg:pb-0 [&::-webkit-scrollbar]:hidden">
            {heroBadges.map((badge) => (
              <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/85 px-4 py-2 text-xs font-bold text-brand shadow-soft">
                {badge}
              </span>
            ))}
          </div>

          <div class="mb-5 inline-flex max-w-full flex-wrap items-center gap-2 rounded-full bg-[linear-gradient(135deg,#4B0715_0%,#7A0E23_58%,#8E1830_100%)] px-4 py-3 text-white shadow-glow ring-1 ring-brand-gold/30 sm:gap-3 sm:px-5">
            <span class="rounded-full bg-white/15 px-3 py-1 text-[11px] font-black uppercase tracking-[.14em] text-brand-gold">CUCKOO ACE</span>
            <span class="text-sm font-black sm:text-base">Penapis air under sink premium untuk dapur moden</span>
          </div>

          <h1 class="max-w-3xl text-[2.35rem] font-black leading-[1.06] tracking-tight text-brand-ink sm:text-5xl lg:text-6xl">
            CUCKOO ACE — Simpan Mesin Bawah Sink, Dapur Nampak Lebih Kemas
          </h1>

          <p class="mt-5 max-w-2xl text-base leading-8 text-brand-muted sm:text-lg">
            Under sink water purifier dengan faucet premium, 5-stage filtration, 100°C Steam Sterilisation, In & Out Auto Sterilisation dan air dari 5°C hingga 100°C untuk dapur moden.
          </p>

          <div class="mt-7 flex flex-col gap-3 sm:flex-row">
            <a
              href={whatsappAceUrl}
              class="inline-flex items-center justify-center rounded-full bg-brand px-7 py-4 text-center text-sm font-black text-white shadow-glow transition hover:-translate-y-0.5 hover:bg-brand-dark"
            >
              Semak Harga Outright ACE
            </a>
            <a
              href="#spesifikasi"
              class="inline-flex items-center justify-center rounded-full border border-brand/15 bg-white px-7 py-4 text-center text-sm font-black text-brand shadow-soft transition hover:-translate-y-0.5 hover:bg-brand-cream"
            >
              Lihat Spesifikasi
            </a>
          </div>

          <div class="mt-7 grid gap-3 sm:grid-cols-2">
            {quickBenefits.map(([title, copy]) => (
              <div class="rounded-[1.5rem] bg-white/85 p-4 shadow-soft ring-1 ring-brand/10">
                <p class="font-black text-brand-ink">{title}</p>
                <p class="mt-1 text-sm leading-6 text-brand-muted">{copy}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="rounded-[2rem] bg-white p-4 shadow-premium ring-1 ring-brand/10 sm:p-6">
          <div class="overflow-hidden rounded-[1.75rem] bg-[linear-gradient(145deg,#fff8f2,#ffffff)]">
            <picture>
              <source media="(max-width: 767px)" srcset={`${aceImageBase}/cuckoo-ace-under-sink-kitchen-banner-mobile.png`} />
              <img
                src={`${aceImageBase}/cuckoo-ace-under-sink-kitchen-banner-desktop.png`}
                alt="CUCKOO ACE under sink water purifier dengan faucet premium untuk dapur moden"
                class="h-auto w-full object-contain"
              />
            </picture>
          </div>
          <div class="mt-4 grid grid-cols-3 gap-2 text-center text-xs font-black text-brand">
            <span class="rounded-full bg-brand-cream px-3 py-2">Under Sink</span>
            <span class="rounded-full bg-brand-cream px-3 py-2">5°C-100°C</span>
            <span class="rounded-full bg-brand-cream px-3 py-2">5-Stage</span>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 py-14 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl overflow-hidden rounded-[2rem] bg-white shadow-premium ring-1 ring-brand/10">
        <div class="grid lg:grid-cols-[1fr_.85fr]">
          <div class="relative min-h-[360px] bg-brand-ink">
            <img
              src={`${aceImageBase}/cuckoo-ace-under-sink-kitchen-banner-desktop.png`}
              alt="Konsep pemasangan CUCKOO ACE bawah sink untuk countertop dapur yang kemas"
              loading="lazy"
              class="h-full w-full object-cover"
            />
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 to-transparent p-6 text-white">
              <p class="text-xs font-black uppercase tracking-[.18em] text-brand-gold">Under Sink Concept</p>
              <h2 class="mt-2 text-2xl font-black sm:text-3xl">Countertop Lapang, Faucet Premium Di Atas Counter</h2>
            </div>
          </div>
          <div class="p-6 sm:p-8 lg:p-10">
            <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">Kenapa ACE</p>
            <h2 class="mt-3 text-3xl font-black sm:text-4xl">Untuk Dapur Yang Mahu Nampak Clean & Minimalist</h2>
            <p class="mt-4 leading-8 text-brand-muted">
              ACE sesuai untuk customer yang tidak mahu mesin besar di atas countertop. Unit utama tersembunyi bawah sink, manakala faucet premium menjadi titik penggunaan harian.
            </p>
            <div class="mt-6 grid gap-3">
              {underSinkPoints.map((item) => (
                <div class="rounded-2xl bg-brand-cream px-5 py-4 font-bold text-brand-ink">
                  {item}
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="features" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">Ciri Utama</p>
          <h2 class="mt-3 text-3xl font-black sm:text-4xl lg:text-5xl">Apa Yang Buat ACE Berbeza</h2>
          <p class="mt-5 leading-8 text-brand-muted">
            ACE bukan sekadar penapis air. Ia ialah sistem under sink premium untuk dapur moden yang mahu ruang lebih kemas, air lebih mudah dan penjagaan lebih menyeluruh.
          </p>
        </div>

        <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {featureCards.map((item) => (
            <article class="rounded-[2rem] bg-white p-6 shadow-soft ring-1 ring-brand/10">
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-brand text-sm font-black text-white">{item.icon}</div>
              <h3 class="mt-5 text-xl font-black text-brand-ink">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-brand-muted">{item.copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="rounded-[2rem] bg-[linear-gradient(135deg,#4B0715_0%,#7A0E23_52%,#9A1B35_100%)] p-6 text-white shadow-premium sm:p-8 lg:p-10">
          <div class="grid gap-8 lg:grid-cols-[.9fr_1.1fr] lg:items-center">
            <div>
              <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">Sterilisation Care</p>
              <h2 class="mt-3 text-3xl font-black sm:text-4xl lg:text-5xl">
                Penjagaan Faucet & Laluan Air Lebih Premium
              </h2>
              <p class="mt-5 leading-8 text-white/78">
                ACE membawa selling point sterilisation yang kuat: steam sterilisation, auto sterilisation dan cleaning water. Ini sesuai untuk prospek yang pentingkan kebersihan dapur dan air minuman harian.
              </p>
            </div>
            <div class="grid gap-4">
              {sterilisationItems.map((item) => (
                <article class="grid overflow-hidden rounded-[1.5rem] bg-white/10 ring-1 ring-white/15 sm:grid-cols-[.85fr_1fr]">
                  <div class="min-h-[180px] bg-white">
                    <img
                      src={item.media}
                      alt={`CUCKOO ACE ${item.title}`}
                      loading="lazy"
                      class="h-full w-full object-cover"
                    />
                  </div>
                  <div class="p-5">
                    <h3 class="text-xl font-black text-white">{item.title}</h3>
                    <p class="mt-3 text-sm leading-7 text-white/75">{item.copy}</p>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 py-14 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-8 lg:grid-cols-[1fr_.9fr] lg:items-center">
          <div>
            <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">Smart Faucet</p>
            <h2 class="mt-3 text-3xl font-black sm:text-4xl lg:text-5xl">
              Faucet Yang Jadi Pusat Kawalan Harian
            </h2>
            <p class="mt-4 leading-8 text-brand-muted">
              Dengan ACE, pengalaman penggunaan berlaku di faucet. Kawalan suhu dan jumlah air dibuat terus dari faucet, jadi dapur nampak ringkas tetapi fungsi tetap lengkap.
            </p>
            <div class="mt-7 grid gap-3">
              {smartFaucetItems.map(([title, copy]) => (
                <div class="rounded-[1.5rem] bg-white p-5 shadow-soft ring-1 ring-brand/10">
                  <h3 class="font-black text-brand-ink">{title}</h3>
                  <p class="mt-2 text-sm leading-7 text-brand-muted">{copy}</p>
                </div>
              ))}
            </div>
          </div>
          <div class="rounded-[2rem] bg-white p-6 shadow-premium ring-1 ring-brand/10">
            <img
              src={`${aceImageBase}/cuckoo-ace-under-sink-water-purifier-product.png`}
              alt="Faucet dan produk CUCKOO ACE under sink water purifier"
              loading="lazy"
              class="mx-auto h-auto max-h-[520px] w-full object-contain"
            />
          </div>
        </div>
      </div>
    </section>

    <section id="filtration" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl overflow-hidden rounded-[2rem] bg-white shadow-premium ring-1 ring-brand/10">
        <div class="bg-[radial-gradient(circle_at_25%_30%,rgba(255,255,255,.2),transparent_28%),linear-gradient(135deg,#4B0715_0%,#7A0E23_58%,#9A1B35_100%)] px-6 py-10 text-center text-white sm:px-8">
          <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">ACE Filtration</p>
          <h2 class="mt-3 text-3xl font-black sm:text-4xl lg:text-5xl">Sistem Tapisan 5 Peringkat</h2>
          <p class="mx-auto mt-4 max-w-3xl leading-8 text-white/75">
            5-stage filtration system dengan 2 filter untuk air minuman yang bersih dan worry-free.
          </p>
          <img
            src={`${aceImageBase}/cuckoo-ace-5-stage-filtration-system.png`}
            alt="Sistem tapisan 5 peringkat CUCKOO ACE dengan 2 filter"
            loading="lazy"
            class="mx-auto mt-8 max-h-[360px] w-full object-contain"
          />
        </div>
        <div class="grid overflow-hidden bg-[#f9f3f5] lg:grid-cols-3">
          {filtrationRows.map((item, index) => (
            <article class={`p-6 text-center ${index < 2 ? 'border-b border-brand/10 lg:border-b-0 lg:border-r' : ''}`}>
              <p class="mx-auto inline-flex rounded-full bg-brand px-5 py-2 text-xs font-black uppercase tracking-[.14em] text-white">
                {item.stage}
              </p>
              <h3 class="mt-5 text-xl font-black text-brand-ink">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-brand-muted">{item.copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="harga" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-5xl">
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">Harga</p>
          <h2 class="mt-3 text-3xl font-black sm:text-4xl lg:text-5xl">
            CUCKOO ACE Outright Sahaja
          </h2>
          <p class="mt-5 leading-8 text-brand-muted">
            ACE ialah model under sink premium. Untuk page ini, pilihan pembelian ialah outright sahaja. WhatsApp untuk semak harga terkini, stok dan kesesuaian pemasangan.
          </p>
