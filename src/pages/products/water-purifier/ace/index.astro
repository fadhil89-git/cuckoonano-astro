    mediaType: 'gif'
  },
  {
    title: 'Cleaning Water In One Tap',
    copy: 'Fungsi Cleaning Water memberi pilihan air untuk bantu kerja pembersihan harian di dapur.',
    media: `${aceImageBase}/cuckoo-ace-cleaning-water-one-tap.png`,
    mediaType: 'image'
  }
