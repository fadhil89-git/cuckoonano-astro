    'https://www.cuckoonano.com/assets/images/Gambar%20Produk%20png/warrior.webp',
    'https://www.cuckoonano.com/assets/images/products/water-purifier/penapis-air-cuckoo-warrior-water-purifier-1.jpg'
  ],
  url: 'https://www.cuckoonano.com/products/water-purifier/warrior/',
  sku: 'CUCKOO-WARRIOR',
  category: 'Water Purifier',
  brand: {
    '@type': 'Brand',
    name: 'CUCKOO'
  },
  description:
    'Mild alkaline water purifier dengan Nano Positive Filtration, tangki besar 5.2L, faucet sterilisation, child safety lock dan air panas, sejuk serta suhu bilik.',
