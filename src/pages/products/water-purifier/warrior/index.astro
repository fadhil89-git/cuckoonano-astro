};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a
    }
  }))
};
---

<BaseLayout {...meta}>
  <style is:inline>
    html { scroll-behavior: smooth; }
    body { font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
    .gold-line { background: linear-gradient(90deg, transparent, rgba(216,166,74,.8), transparent); }
    .product-blob { background: radial-gradient(circle at 40% 35%, rgba(216,166,74,.28), transparent 38%), radial-gradient(circle at 65% 58%, rgba(122,14,35,.18), transparent 42%), linear-gradient(145deg, #fff8f2, #ffffff); }
    .accent-ring { box-shadow: 0 30px 80px rgba(20,20,20,.16); }
  </style>

  <div class="bg-brand-cream text-brand-ink antialiased">
    <section id="hero" class="relative overflow-hidden px-4 py-10 sm:px-6 lg:px-8 lg:py-16">
      <div class="absolute left-1/2 top-0 -z-10 h-[620px] w-[620px] -translate-x-1/2 rounded-full bg-brand-soft blur-3xl"></div>

      <div class="mx-auto grid max-w-7xl gap-7 lg:grid-cols-[1.02fr_.98fr] lg:items-start lg:gap-10">
        <div class="order-1 lg:col-start-1 lg:row-start-1">
          <div class="mb-5 flex gap-2 overflow-x-auto pb-1 [-ms-overflow-style:none] [scrollbar-width:none] lg:flex-wrap lg:overflow-visible lg:pb-0 [&::-webkit-scrollbar]:hidden">
            <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Ejen CUCKOO sejak 2017</span>
            <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Free Installation</span>
            <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Servis Berkala</span>
          </div>

          <div class="mb-5 inline-flex max-w-full flex-wrap items-center gap-2 rounded-full bg-[linear-gradient(135deg,#4B0715_0%,#7A0E23_58%,#8E1830_100%)] px-4 py-3 text-white shadow-glow ring-1 ring-brand-gold/30 sm:gap-3 sm:px-5">
            <span class="rounded-full bg-white/15 px-3 py-1 text-[11px] font-black uppercase tracking-[.14em] text-brand-gold">Promo Terkini</span>
            <span class="text-sm font-black sm:text-base">RM12 x 6 bulan pertama</span>
          </div>

          <h1 class="max-w-3xl text-[2.35rem] font-black leading-[1.06] tracking-tight text-brand-ink sm:text-5xl lg:text-6xl">
            CUCKOO Warrior — Penapis Air Tangki Besar Untuk Keluarga
          </h1>

          <p class="mt-5 max-w-2xl text-base leading-8 text-brand-muted sm:text-lg">
            Mild alkaline water purifier dengan Nano Positive Filtration, tangki stainless steel 5.2L, faucet sterilisation serta air panas, sejuk dan suhu bilik untuk kegunaan harian keluarga.
          </p>
        </div>

        <div class="order-2 rounded-[2rem] border border-white/80 bg-white/70 p-4 shadow-premium backdrop-blur-xl sm:p-6 lg:col-start-2 lg:row-span-2 lg:row-start-1">
          <div class="product-blob accent-ring relative overflow-hidden rounded-[1.7rem] p-4 sm:p-6 lg:p-8">
            <div class="flex flex-wrap gap-2">
              <span class="rounded-full bg-white/85 px-4 py-2 text-xs font-black text-brand shadow-soft">Tangki Besar</span>
              <span class="rounded-full bg-white/85 px-4 py-2 text-xs font-black text-brand shadow-soft">Family Model</span>
            </div>

            <div class="relative mt-5 flex min-h-[300px] items-center justify-center overflow-hidden rounded-[1.5rem] bg-gradient-to-br from-white/80 to-white/35 p-5 sm:min-h-[390px] lg:min-h-[470px]">
              <div class="absolute bottom-12 h-16 w-[72%] rounded-full bg-brand-gold/20 blur-2xl"></div>
              <img
                src="/assets/images/Gambar%20Produk%20png/warrior.webp"
                alt="CUCKOO Warrior water purifier dengan tangki besar untuk keluarga"
                class="relative z-10 h-[290px] w-auto object-contain drop-shadow-2xl sm:h-[380px] lg:h-[455px]"
              />
            </div>

            <div class="mt-5 flex flex-wrap justify-center gap-2">
              <span class="rounded-full border border-blue-200 bg-blue-50 px-4 py-2 text-xs font-black text-blue-700">Cold Tank 2.8L</span>
              <span class="rounded-full border border-stone-200 bg-white px-4 py-2 text-xs font-black text-stone-700">Room Tank 1.0L</span>
              <span class="rounded-full border border-red-200 bg-red-50 px-4 py-2 text-xs font-black text-red-700">Hot Tank 1.4L</span>
            </div>
          </div>

          <div class="mt-4 grid grid-cols-2 gap-2 sm:grid-cols-4">
            <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10">
              <p class="text-xs font-black text-brand">Total 5.2L</p>
            </div>
            <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10">
              <p class="text-xs font-black text-brand">Nano Positive</p>
            </div>
            <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10">
              <p class="text-xs font-black text-brand">Faucet Sterilisation</p>
            </div>
            <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10">
              <p class="text-xs font-black text-brand">Child Safety Lock</p>
            </div>
          </div>
        </div>

        <div class="order-3 lg:col-start-1 lg:row-start-2">
          <div class="flex flex-col gap-3 sm:flex-row">
            <a
              href={whatsappWarriorUrl}
              class="inline-flex items-center justify-center gap-2 rounded-full bg-[#25D366] px-7 py-4 text-sm font-black text-white shadow-[0_18px_40px_rgba(37,211,102,.28)] transition hover:-translate-y-0.5 hover:bg-[#1EBE5D]"
            >
              <img src="/assets/images/misc/whatsapp-png.webp" alt="" aria-hidden="true" class="h-5 w-5" />
              WhatsApp Promo Warrior
            </a>

            <a
              href="#harga"
              class="inline-flex items-center justify-center rounded-full border border-brand/15 bg-white px-7 py-4 text-sm font-black text-brand shadow-soft hover:border-brand/30"
            >
              Lihat Pelan Harga
            </a>
          </div>

          <div class="mt-7 rounded-[1.75rem] border border-brand/10 bg-white/80 p-4 shadow-soft backdrop-blur-xl sm:p-5">
            <div class="grid gap-3 sm:grid-cols-[1fr_1fr] sm:items-stretch">
              <div class="rounded-[1.35rem] bg-brand px-5 py-5 text-white shadow-glow">
                <p class="text-xs font-black uppercase tracking-[.16em] text-brand-gold">Promo Terkini</p>
                <p class="mt-2 text-4xl font-black leading-none">
                  RM12<span class="text-sm font-black">/bulan</span>
                </p>
                <p class="mt-1 text-xs font-bold text-white/75">6 bulan pertama</p>
              </div>

              <a
                href="#harga"
                class="rounded-[1.35rem] border border-brand/10 bg-brand-cream px-5 py-5 shadow-soft transition hover:-translate-y-1 hover:border-brand/25"
              >
                <p class="text-xs font-black uppercase tracking-[.14em] text-brand-gold">
                  Pelan Bulanan & Outright
                </p>
                <p class="mt-2 text-xl font-black text-brand">
                  5 Tahun | 7 Tahun | Outright
                </p>
                <p class="mt-2 text-sm font-bold text-brand-muted">
                  Lihat detail harga →
                </p>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 py-10 sm:px-6 lg:px-8">
      <div class="mx-auto grid max-w-7xl gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {highlights.map((item) => (
          <article class="rounded-3xl bg-white p-6 shadow-soft">
            <div class="mb-4 text-2xl">{item.icon}</div>
            <h3 class="font-black">{item.title}</h3>
            <p class="mt-2 text-sm leading-7 text-brand-muted">{item.copy}</p>
          </article>
        ))}
      </div>
    </section>



    <section id="ciri-ciri" class="px-4 py-14 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="max-w-3xl">
          <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">Family Protection</p>
          <h2 class="mt-3 text-3xl font-black sm:text-4xl">Ciri-Ciri Warrior Untuk Rumah Keluarga</h2>
          <p class="mt-4 text-base leading-8 text-brand-muted">
            Warrior sesuai untuk rumah yang mahukan penapis air lengkap, tangki besar, kawalan mekanikal mudah dan fungsi keselamatan untuk kegunaan berulang setiap hari.
          </p>
        </div>

        <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {featureCards.map((item) => (
            <article class="overflow-hidden rounded-3xl bg-white shadow-soft ring-1 ring-brand/10">
              <div class="aspect-[4/3] bg-brand-cream">
                <img
                  src={item.image}
                  alt={item.alt}
                  loading="lazy"
                  class="h-full w-full object-cover"
                />
              </div>
              <div class="p-6">
                <h3 class="font-black">{item.title}</h3>
                <p class="mt-2 text-sm leading-7 text-brand-muted">{item.copy}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="filtration" class="px-4 py-14 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl rounded-[2rem] bg-white p-5 shadow-premium sm:p-8 lg:p-10">
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">Filtration System</p>
          <h2 class="mt-3 text-3xl font-black tracking-tight sm:text-4xl">6-Stage Filtration Dengan Nano Positive</h2>
          <p class="mt-4 leading-8 text-brand-muted">
            Warrior menggunakan sistem tapisan CUCKOO yang membantu menghasilkan air minuman lebih bersih untuk seisi keluarga, sambil mengekalkan fungsi air panas, sejuk dan suhu bilik.
          </p>
        </div>

        <div class="mt-8 overflow-hidden rounded-[1.5rem] bg-brand-cream">
          <img src="/assets/images/filter/filter-cuckoo-desktop.webp" class="hidden w-full md:block" alt="Sistem tapisan Nano Positive Filtration CUCKOO Warrior versi desktop">
          <img src="/assets/images/filter/filter-cuckoo-mobile.webp" class="block w-full md:hidden" alt="Sistem tapisan Nano Positive Filtration CUCKOO Warrior versi mobile">
        </div>

        <div class="mt-6 grid gap-4 md:grid-cols-4">
          <article class="rounded-2xl border border-brand/10 bg-brand-cream p-5">
            <h3 class="font-black">Sediment Filter</h3>
            <p class="text-xs font-bold text-brand-gold">Stage 1</p>
            <p class="mt-2 text-sm leading-7 text-brand-muted">Menapis partikel besar, karat dan bendasing terapung.</p>
          </article>
          <article class="rounded-2xl border border-brand/10 bg-brand-cream p-5">
            <h3 class="font-black">Pre-Carbon Block 2.0</h3>
            <p class="text-xs font-bold text-brand-gold">Stage 2-3</p>
            <p class="mt-2 text-sm leading-7 text-brand-muted">Membantu menapis klorin dan sebatian organik.</p>
          </article>
          <article class="rounded-2xl border border-brand/10 bg-brand-cream p-5">
            <h3 class="font-black">Natural 2.0 Filter</h3>
            <p class="text-xs font-bold text-brand-gold">Stage 4-5</p>
            <p class="mt-2 text-sm leading-7 text-brand-muted">Mengandungi mineral dan membantu mengurangkan bau.</p>
          </article>
          <article class="rounded-2xl border border-brand/10 bg-brand-cream p-5">
            <h3 class="font-black">Nano Positive Filter</h3>
            <p class="text-xs font-bold text-brand-gold">Stage 6</p>
            <p class="mt-2 text-sm leading-7 text-brand-muted">Membantu menapis kuman, virus, partikel dan heavy metals.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="px-4 py-14 sm:px-6 lg:px-8">
      <div class="mx-auto grid max-w-7xl gap-8 rounded-[2rem] bg-white p-6 shadow-premium lg:grid-cols-[.9fr_1.1fr] lg:p-10">
