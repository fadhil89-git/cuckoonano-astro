  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const buttons = Array.from(document.querySelectorAll('[data-grande-view]'));
      const images = Array.from(document.querySelectorAll('[data-grande-image]'));

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const selected = button.getAttribute('data-grande-view');

          images.forEach((image) => {
            image.classList.toggle('hidden', image.getAttribute('data-grande-image') !== selected);
          });

          buttons.forEach((item) => {
            const active = item === button;
            item.classList.toggle('bg-brand', active);
            item.classList.toggle('text-white', active);
            item.classList.toggle('bg-white', !active);
            item.classList.toggle('text-brand', !active);
            item.classList.toggle('ring-1', !active);
            item.classList.toggle('ring-brand/10', !active);
          });
        });
      });
    });
  </script>

