---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import WaterHalalSection from '../../../../components/WaterHalalSection.astro';
import FreeGiftSection from '../../../../components/FreeGiftSection.astro';
import AgentSection from '../../../../components/AgentSection.astro';
import CustomerProofSection from '../../../../components/CustomerProofSection.astro';
import PromoBannerSection from '../../../../components/PromoBannerSection.astro';
import ProductCategorySection from '../../../../components/ProductCategorySection.astro';
