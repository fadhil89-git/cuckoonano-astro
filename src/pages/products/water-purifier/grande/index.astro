  {
    title: 'One-Touch Temperature Control',
    copy: 'Pilih cold, room, warm, hot atau extra hot dengan sentuhan ringkas pada panel digital.',
    image: `${grandeImageBase}/laptop_3829x1955__.gif`,
    alt: 'CUCKOO Grande one touch temperature control',
    vertical: true
  },
  {
    title: 'Extra Hot 100°C',
    copy: 'Dari 5°C hingga 100°C dengan hanya satu sentuhan. Air extra hot tersedia dalam beberapa saat untuk kopi, teh, herba dan bancuhan panas.',
