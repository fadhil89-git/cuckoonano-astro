---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import AgentSection from '../../../../components/AgentSection.astro';
import ProductGallerySlider from '../../../../components/ProductGallerySlider.astro';

const base = '/assets/images/products/mattress/flex';

// Hero product views (color/angle switcher)
const heroSofa = `${base}/cuckoo-flex-daybed-grey-sofa-product-image.webp`;
const heroBed = `${base}/cuckoo-flex-daybed-grey-bed-product-image.webp`;
const blueFront = `${base}/cuckoo-flex-daybed-blue-front-product-image.webp`;
const blueSofa = `${base}/cuckoo-flex-daybed-blue-sofa-product-image.webp`;
const blueAngle = `${base}/cuckoo-flex-daybed-blue-angle-product-image.webp`;
const blueSide = `${base}/cuckoo-flex-daybed-adjustable-side-angle-blue.webp`;

const heroViews = [
  { label: 'Sofa · Grey', img: heroSofa, alt: 'CUCKOO FLEX Daybed mod sofa warna Meta Grey' },
  { label: 'Bed · Grey', img: heroBed, alt: 'CUCKOO FLEX Daybed mod bed warna Meta Grey' },
  { label: 'Sofa · Blue', img: blueSofa, alt: 'CUCKOO FLEX Daybed mod sofa warna Yale Blue' },
  { label: 'Depan · Blue', img: blueFront, alt: 'CUCKOO FLEX Daybed pandangan hadapan warna Yale Blue' },
  { label: 'Sudut · Blue', img: blueAngle, alt: 'CUCKOO FLEX Daybed pandangan sudut warna Yale Blue' }
];

// Product / lifestyle imagery
const blueRoom = `${base}/cuckoo-flex-daybed-blue-sofa-room-product-image.webp`;
const roadshow = `${base}/cuckoo-flex-daybed-roadshow-display.webp`;

// Gallery imagery
const galFoldedGrey = `${base}/cuckoo-flex-daybed-folded-sofa-mode-grey.webp`;
const galFoldedBlue = `${base}/cuckoo-flex-daybed-folded-sofa-mode-blue.webp`;
const galUnfoldedGrey = `${base}/cuckoo-flex-daybed-unfolded-bed-mode-grey.webp`;
const galDiscover = `${base}/cuckoo-flex-daybed-discover-product-social-post.webp`;
const galYaleBlue = `${base}/cuckoo-flex-daybed-yale-blue-cover-social-post.webp`;
const gal8Angle = `${base}/cuckoo-flex-8-angle-comfort-daybed-social-post.webp`;
const galFullLatex = `${base}/cuckoo-flex-full-latex-daybed-social-post.webp`;

// HQ lifestyle banner (after pain points)
const heroBgDesktop = `${base}/cuckoo-flex-daybed-sofa-bed-malaysia-hero-desktop.webp`;
const hqHighlights = [
  { icon: `${base}/cuckoo-flex-flexible-daybed-icon.png`, label: 'Supremely Versatile 8-Angle Comfort' },
  { icon: `${base}/cuckoo-flex-laidback-daybed-icon.png`, label: '100% Full Latex On Top Layer' },
  { icon: `${base}/cuckoo-flex-enjoyable-daybed-icon.png`, label: 'Easy Switch Between Sofa & Bed' },
  { icon: `${base}/cuckoo-flex-xpressive-daybed-icon.png`, label: 'FREE Daybed Cleaning Service' },
  { icon: `${base}/cuckoo-flex-three-seater-daybed-icon.png`, label: 'FREE Delivery & Installation' }
];

// Feature GIFs (responsive desktop/mobile)
const versatileGif = `${base}/cuckoo-flex-daybed-supremely-versatile-sofa-bed.gif`;
const versatileMobileGif = `${base}/cuckoo-flex-daybed-versatile-demo-mobile.gif`;
const easySwitchGif = `${base}/cuckoo-flex-daybed-easy-switch-sofa-bed.gif`;
const makingSceneGif = `${base}/cuckoo-flex-daybed-making-scene-video.gif`;

// Section assets
const latexLayers = `${base}/cuckoo-flex-full-natural-latex-daybed-layers-desktop.webp`;
const latexLayersMb = `${base}/cuckoo-flex-full-natural-latex-daybed-layers-mobile.webp`;
const specDesktop = `${base}/cuckoo-flex-daybed-specification-dimensions-desktop.png`;
const specMobile = `${base}/cuckoo-flex-daybed-specification-dimensions-mobile.png`;
const serviceBanner = `${base}/cuckoo-flex-daybed-wonderklean-service-banner.webp`;
const cleaningServiceMobile = `${base}/cuckoo-flex-daybed-wonderklean-cleaning-service-mobile.webp`;
const cleaningIconsMobile = `${base}/cuckoo-flex-daybed-wonderklean-cleaning-icons-desktop.webp`;

const features = [
  {
    badge: 'Sofa & Bed 2-in-1',
    title: 'Sofa & Bed Dalam Satu Produk',
    copy: 'CUCKOO FLEX boleh digunakan sebagai sofa santai pada waktu siang dan bertukar menjadi tempat berbaring untuk berehat. Sesuai untuk menonton TV, membaca buku atau melepak selepas hari yang panjang.',
    tags: ['Sofa santai', 'Tempat berbaring'],
    media: heroBed,
    fit: 'cover'
  },
  {
    badge: '8-Angle Comfort',
    title: 'Laras 8 Sudut Ikut Keselesaan Anda',
    copy: 'Nikmati keselesaan mengikut gaya anda sendiri dengan pelbagai sudut boleh laras. Ubah posisi FLEX ikut aktiviti — duduk santai, bersandar atau berbaring sepenuhnya.',
    tags: ['8 sudut boleh laras', 'Posisi fleksibel'],
    media: versatileGif,
    mediaMobile: versatileMobileGif,
    fit: 'contain'
  },
  {
    badge: 'Mudah Tukar & Jimat Ruang',
    title: 'Tukar Sofa ke Bed Dengan Mudah',
    copy: 'FLEX boleh ditukar daripada sofa kepada bed, atau sebaliknya, dengan mudah. Pilihan tepat untuk rumah yang mahukan perabot lebih fleksibel sambil menjimatkan ruang.',
    tags: ['Switch mudah', 'Jimat ruang'],
    media: easySwitchGif,
    mediaMobile: makingSceneGif,
    fit: 'contain'
  },
  {
    badge: 'Reka Bentuk Stylish',
    title: 'Stylish & Mudah Padan Dengan Dekorasi Rumah',
    copy: 'Dengan warna Meta Grey sebagai pilihan default, CUCKOO FLEX tampil moden dan mudah dipadankan dengan pelbagai gaya dekorasi — dari ruang tamu keluarga hingga studio dan apartment.',
    tags: ['Meta Grey default', 'Moden & kemas'],
    media: blueRoom,
    fit: 'cover'
  }
];

const galleryItems = [
  { image: galFoldedGrey, title: 'CUCKOO FLEX mod sofa Meta Grey', copy: 'FLEX dalam mod sofa warna Meta Grey.', alt: 'CUCKOO FLEX Daybed mod sofa terlipat warna Meta Grey' },
  { image: galFoldedBlue, title: 'CUCKOO FLEX mod sofa Yale Blue', copy: 'FLEX dalam mod sofa warna Yale Blue.', alt: 'CUCKOO FLEX Daybed mod sofa terlipat warna Yale Blue' },
  { image: blueSide, title: 'CUCKOO FLEX boleh laras', copy: 'FLEX dilaras antara mod sofa dan bed.', alt: 'CUCKOO FLEX Daybed posisi boleh laras warna Yale Blue' },
  { image: galUnfoldedGrey, title: 'CUCKOO FLEX mod bed Meta Grey', copy: 'FLEX dalam mod bed warna Meta Grey.', alt: 'CUCKOO FLEX Daybed mod bed terbuka warna Meta Grey' },
  { image: roadshow, title: 'CUCKOO FLEX di roadshow', copy: 'Rupa sebenar CUCKOO FLEX Daybed di roadshow.', alt: 'Paparan sebenar CUCKOO FLEX Daybed di roadshow CUCKOO' },
  { image: galDiscover, title: 'Discover CUCKOO FLEX', copy: 'Kenali CUCKOO FLEX Daybed dengan lebih dekat.', alt: 'Poster discover produk CUCKOO FLEX Daybed' },
  { image: galYaleBlue, title: 'Yale Blue Daybed Cover', copy: 'Extra Yale Blue Daybed Cover untuk FLEX.', alt: 'Poster extra Yale Blue Daybed Cover CUCKOO FLEX' },
  { image: gal8Angle, title: '8-Angle Comfort', copy: 'Laras 8 sudut keselesaan FLEX.', alt: 'Poster 8-Angle Comfort CUCKOO FLEX Daybed' },
  { image: galFullLatex, title: '100% Full Latex', copy: '100% full latex pada lapisan atas FLEX.', alt: 'Poster 100% Full Latex CUCKOO FLEX Daybed' }
];

const PRICE_VALID_UNTIL = '2026-12-31';

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'CUCKOO FLEX Daybed',
  alternateName: ['CUCKOO FLEX Sofa Daybed', 'Daybed Sofa CUCKOO', 'CUCKOO FLEX Co-Created with Napure'],
  image: [
    `https://www.cuckoonano.com${heroSofa}`,
    `https://www.cuckoonano.com${heroBed}`,
    `https://www.cuckoonano.com${blueAngle}`
  ],
  brand: { '@type': 'Brand', name: 'CUCKOO' },
  manufacturer: { '@type': 'Organization', name: 'CUCKOO Co-Created with Napure' },
  category: 'Daybed Sofa',
  color: 'Meta Grey',
  url: 'https://www.cuckoonano.com/products/mattress/flex/',
  description:
    'CUCKOO FLEX Daybed — daybed serbaguna yang boleh digunakan sebagai sofa atau tempat berbaring. 8-Angle Comfort, 100% Full Latex pada lapisan atas, scheduled service dan pilihan rental RM140/bulan atau outright RM3,900.',
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Capacity', value: '3-Seater' },
    { '@type': 'PropertyValue', name: 'Top Layer', value: '100% Full Latex' },
    { '@type': 'PropertyValue', name: 'Adjustable', value: '8-Angle Comfort' },
    { '@type': 'PropertyValue', name: 'Weight Supported', value: 'Up to 100kg' }
  ],
  offers: [
    {
      '@type': 'Offer',
      name: 'Rental Plan 3 Tahun',
      priceCurrency: 'MYR',
      price: '140',
      itemCondition: 'https://schema.org/NewCondition',
      availability: 'https://schema.org/InStock',
      priceValidUntil: PRICE_VALID_UNTIL,
      areaServed: { '@type': 'Country', name: 'Malaysia' }
    },
    {
      '@type': 'Offer',
      name: 'Outright Purchase',
      priceCurrency: 'MYR',
      price: '3900',
      itemCondition: 'https://schema.org/NewCondition',
      availability: 'https://schema.org/InStock',
      priceValidUntil: PRICE_VALID_UNTIL,
      areaServed: { '@type': 'Country', name: 'Malaysia' }
    }
  ]
};

const faqItems = [
  { q: 'Apa itu daybed sofa?', a: 'Daybed sofa ialah perabot serbaguna yang boleh digunakan sebagai sofa dan juga sebagai tempat berbaring. Ia sesuai untuk ruang rumah yang mahukan fungsi santai, rehat dan tidur sementara dalam satu produk.' },
  { q: 'Adakah CUCKOO FLEX sesuai untuk rumah di Malaysia?', a: 'Ya. CUCKOO FLEX sesuai untuk rumah Malaysia seperti apartment, kondominium, rumah teres atau ruang keluarga yang mahukan perabot fleksibel. Ia boleh digunakan sebagai sofa harian dan juga tempat rehat tambahan apabila diperlukan.' },
  { q: 'Boleh ke tidur atas CUCKOO FLEX setiap malam?', a: 'CUCKOO FLEX boleh digunakan untuk berbaring dan berehat dengan selesa. Namun, untuk penggunaan tidur setiap malam, ia bergantung kepada keselesaan badan dan keperluan sokongan individu. Jika anda mencari tempat tidur utama jangka panjang, tilam khusus mungkin lebih sesuai.' },
  { q: 'Adakah CUCKOO FLEX datang siap pasang?', a: 'CUCKOO FLEX datang bersama penghantaran dan pemasangan percuma. Jadi pelanggan tidak perlu risau tentang proses pemasangan sendiri.' },
  { q: 'Apa kelebihan 8-Angle Comfort?', a: '8-Angle Comfort membolehkan anda melaras sudut daybed mengikut keselesaan. Anda boleh gunakan posisi berbeza untuk duduk, bersandar, membaca, menonton TV atau berbaring.' },
  { q: 'Apakah material utama CUCKOO FLEX?', a: 'CUCKOO FLEX menggunakan 100% full latex pada lapisan atas. Material ini membantu memberikan rasa selesa, sokongan yang baik dan ketahanan untuk kegunaan harian.' },
  { q: 'Adakah CUCKOO FLEX sesuai untuk ruang kecil?', a: 'Ya. Disebabkan ia boleh digunakan sebagai sofa dan bed, CUCKOO FLEX sesuai untuk ruang yang mahu dimanfaatkan dengan lebih praktikal, terutama rumah yang tidak mahu terlalu banyak perabot berasingan.' },
  { q: 'Adakah harga termasuk servis?', a: 'Ya. Untuk pembelian outright, pelanggan mendapat 1 tahun scheduled service & warranty. Untuk rental plan, pelanggan mendapat scheduled service setiap 4 bulan sepanjang tempoh pelan.' },
  { q: 'Berapa berat maksimum yang boleh ditampung?', a: 'CUCKOO FLEX menyokong berat sehingga 100kg.' },
  { q: 'Apa warna CUCKOO FLEX?', a: 'Warna default ialah Meta Grey. Pelanggan juga mendapat extra Yale Blue Daybed Cover mengikut tawaran pelan yang dipilih.' }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a }
  }))
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.cuckoonano.com/' },
    { '@type': 'ListItem', position: 2, name: 'Produk', item: 'https://www.cuckoonano.com/products/' },
    { '@type': 'ListItem', position: 3, name: 'Tilam', item: 'https://www.cuckoonano.com/products/mattress/' },
    { '@type': 'ListItem', position: 4, name: 'FLEX Daybed', item: 'https://www.cuckoonano.com/products/mattress/flex/' }
  ]
};
---

<BaseLayout
  title="CUCKOO FLEX Daybed | Sofa Bed 2-in-1 Promo RM12, Rental RM140 & Outright RM3,900"
  description="CUCKOO FLEX Daybed — sofa daybed serbaguna yang bertukar antara sofa dan bed. 8-Angle Comfort, 100% Full Latex top layer, scheduled service, free delivery. Promo RM12/bulan 6 bulan pertama, rental RM140/bulan atau outright RM3,900. WhatsApp ejen untuk semak."
  canonical="https://www.cuckoonano.com/products/mattress/flex/"
  ogImage={`https://www.cuckoonano.com${heroSofa}`}
  preloadImages={[heroSofa]}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- ============================================================ -->
  <!-- HERO (maroon) -->
  <!-- ============================================================ -->
  <section class="relative overflow-hidden px-4 py-10 text-white sm:px-6 lg:px-8 lg:py-16"
           style="background: radial-gradient(circle at 72% 20%, rgba(216,180,120,.30), transparent 38%), linear-gradient(135deg, #3a0a12 0%, #5e1019 52%, #7a1f2b 100%);">
    <div class="relative mx-auto max-w-7xl">

      <!-- MOBILE HERO -->
      <div class="lg:hidden">
        <div class="mx-auto max-w-md text-center">
          <div class="mb-3 flex flex-wrap justify-center gap-2">
            <span class="rounded-full bg-[#d8c69a] px-4 py-1.5 text-[11px] font-black uppercase tracking-[0.16em] text-[#5a0f18]">🔥 Promo RM12</span>
            <span class="rounded-full bg-white/10 px-4 py-1.5 text-[11px] font-black uppercase tracking-[0.16em] text-white ring-1 ring-white/15">Sofa & Bed 2-in-1</span>
            <span class="rounded-full bg-white/10 px-4 py-1.5 text-[11px] font-black uppercase tracking-[0.16em] text-white ring-1 ring-white/15">8-Angle Comfort</span>
          </div>
          <p class="text-[11px] font-black uppercase tracking-[0.22em] text-[#d8c69a]">CUCKOO Daybed Malaysia</p>
          <h1 class="mt-2 text-[1.85rem] font-black leading-[1.05] tracking-tight text-white">
            CUCKOO <span class="gold-text">FLEX</span> Daybed
          </h1>
          <p class="mx-auto mt-3 max-w-xs text-sm leading-6 text-[#f0e6d6]/90">
            Sofa daybed serbaguna yang bertukar antara sofa santai dan tempat berbaring — dengan 8-angle comfort dan 100% full latex pada lapisan atas.
          </p>
        </div>

        <!-- Mobile product card -->
        <div class="mx-auto mt-5 max-w-sm overflow-hidden rounded-[2rem] bg-white/10 p-3 ring-1 ring-white/15 backdrop-blur">
          <div class="overflow-hidden rounded-[1.5rem] bg-white/50 p-2">
            <img id="heroImgMobile" src={heroSofa}
                 alt="CUCKOO FLEX Daybed mod sofa warna Meta Grey"
                 class="mx-auto h-auto w-full max-w-[440px] object-contain transition duration-300" />
          </div>
          <div class="mt-3 flex flex-wrap justify-center gap-1.5">
            {heroViews.map((v, i) => (
              <button type="button" data-img-mobile={v.img} data-alt={v.alt} class={`hero-thumb-mobile shrink-0 rounded-full px-3 py-1.5 text-[10px] font-black uppercase tracking-wide ${i === 0 ? 'bg-[#F6D77B] text-[#5a0f18] shadow-sm ring-2 ring-black/10' : 'bg-[#FFF7EA] text-[#7a1f2b] ring-1 ring-black/10'}`}>{v.label}</button>
            ))}
          </div>
        </div>

        <!-- Pricing card mobile -->
        <div class="mx-auto mt-5 max-w-sm rounded-[1.75rem] bg-white/10 p-4 ring-1 ring-white/15 backdrop-blur">
          <div class="rounded-[1.4rem] p-4 text-center shadow-[inset_0_0_0_1px_rgba(255,255,255,.5)]" style="background: linear-gradient(135deg, #fff7de 0%, #ffe7a8 52%, #d8b25e 100%);">
            <p class="text-[11px] font-black uppercase tracking-[0.18em] text-[#7b4e14]">Promo · 6 Bulan Pertama</p>
            <p class="mt-1 text-4xl font-black tracking-tight text-[#5a0f18]">RM12<span class="text-base font-bold text-[#7b4e14]">/bulan</span></p>
            <p class="mt-1 text-[11px] font-bold text-[#7b4e14]/85">Lepas promo RM140/bulan · atau outright RM3,900</p>
          </div>
          <div class="mt-3 grid gap-2">
            <div class="rounded-xl bg-white/10 px-3 py-2.5 text-xs font-black text-white ring-1 ring-white/15">Scheduled service setiap 4 bulan</div>
            <div class="rounded-xl bg-white/10 px-3 py-2.5 text-xs font-black text-white ring-1 ring-white/15">Free 1 extra Yale Blue Daybed Cover</div>
            <div class="rounded-xl bg-white/10 px-3 py-2.5 text-xs font-black text-white ring-1 ring-white/15">Free delivery &amp; installation*</div>
          </div>
          <p class="mt-3 text-center text-[10px] font-semibold leading-5 text-[#d8c69a]/80">*Tertakluk kepada stok, kelayakan, kawasan pemasangan dan terma semasa.</p>
        </div>

        <div class="mx-auto mt-4 max-w-sm">
          <a href="#" onclick="this.href=rotatingWhatsapp()"
             class="flex w-full items-center justify-center rounded-2xl bg-cta-green px-6 py-4 text-base font-black text-white shadow-cta transition hover:bg-cta-dark">
            📲 Semak Harga &amp; Kelayakan
          </a>
        </div>
      </div><!-- end mobile hero -->


      <!-- DESKTOP HERO -->
      <div class="hidden lg:grid lg:grid-cols-[1fr_1fr] lg:items-center lg:gap-14">
        <div>
          <div class="mb-5 flex flex-wrap gap-2">
            <span class="rounded-full bg-[#d8c69a] px-5 py-2 text-xs font-black uppercase tracking-[0.2em] text-[#5a0f18]">🔥 Promo RM12 Sekarang</span>
            <span class="rounded-full bg-white/10 px-5 py-2 text-xs font-black uppercase tracking-[0.2em] text-white ring-1 ring-white/15">Sofa & Bed 2-in-1</span>
            <span class="rounded-full bg-white/10 px-5 py-2 text-xs font-black uppercase tracking-[0.2em] text-white ring-1 ring-white/15">100% Full Latex</span>
          </div>

          <p class="text-sm font-black uppercase tracking-[0.24em] text-[#d8c69a]">CUCKOO Daybed Malaysia</p>

          <h1 class="mt-3 max-w-2xl text-balance text-5xl font-black leading-[1.03] tracking-tight text-white xl:text-6xl">
            CUCKOO <span class="gold-text">FLEX</span> Daybed
          </h1>

          <p class="mt-5 max-w-xl text-lg leading-8 text-[#f0e6d6]/90">
            It's always a good time to FLEX. Sofa daybed serbaguna yang bertukar antara sofa santai dan tempat berbaring — dengan 8-angle comfort dan 100% full latex pada lapisan atas.
          </p>

          <!-- Pricing block -->
          <div class="mt-7 max-w-xl rounded-[2rem] bg-white/10 p-4 ring-1 ring-white/15 backdrop-blur">
            <div class="grid grid-cols-[auto_1fr] items-center gap-4">
              <div class="rounded-[1.5rem] px-6 py-5 text-center shadow-[inset_0_0_0_1px_rgba(255,255,255,.5)]" style="background: linear-gradient(135deg, #fff7de 0%, #ffe7a8 52%, #d8b25e 100%);">
                <p class="text-[11px] font-black uppercase tracking-[0.2em] text-[#7b4e14]">6 Bulan Pertama</p>
                <p class="mt-1 text-5xl font-black tracking-tight text-[#5a0f18]">RM12</p>
                <p class="text-sm font-black text-[#7b4e14]">/bulan</p>
              </div>
              <div class="space-y-2.5">
                <div class="rounded-2xl bg-white/10 px-4 py-3 text-sm font-extrabold text-white ring-1 ring-white/10">Lepas promo RM140/bulan · rental 3 tahun</div>
                <div class="rounded-2xl bg-white/10 px-4 py-3 text-sm font-extrabold text-white ring-1 ring-white/10">Atau outright — RM3,900</div>
                <div class="rounded-2xl bg-white/10 px-4 py-3 text-sm font-extrabold text-white ring-1 ring-white/10">Free 1 extra Yale Blue Daybed Cover</div>
                <p class="px-1 text-xs font-semibold leading-5 text-[#d8c69a]/80">Promo RM12 tertakluk kepada produk, stok, kelayakan dan kempen semasa.</p>
              </div>
            </div>
          </div>

          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#" onclick="this.href=rotatingWhatsapp()"
               class="inline-flex items-center justify-center rounded-2xl bg-cta-green px-8 py-4 text-base font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark">
              📲 Semak Harga &amp; Kelayakan
            </a>
            <a href="#features"
               class="inline-flex items-center justify-center rounded-2xl border border-white/25 bg-white/10 px-8 py-4 text-base font-black text-white backdrop-blur transition hover:-translate-y-0.5 hover:bg-white/20">
              Lihat Features
            </a>
          </div>
        </div>

        <!-- Right: product card -->
        <div class="relative">
          <div class="relative overflow-hidden rounded-[2.5rem] bg-white/10 p-5 shadow-[0_30px_80px_rgba(75,13,24,.45)] ring-1 ring-white/15 backdrop-blur">
            <div class="mb-4 flex flex-wrap justify-center gap-2">
              <span class="rounded-full bg-[#7a1f2b] px-4 py-1.5 text-xs font-black uppercase tracking-wide text-white">3-Seater</span>
              <span class="rounded-full bg-white/10 px-4 py-1.5 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/15">Meta Grey</span>
            </div>

            <div class="overflow-hidden rounded-[1.75rem] bg-white/50 p-4">
              <img id="heroImgDesktop" src={heroSofa}
                   alt="CUCKOO FLEX Daybed mod sofa warna Meta Grey"
                   class="mx-auto h-auto w-full max-w-[480px] object-contain transition duration-300" />
            </div>

            <div class="mt-4 flex flex-wrap justify-center gap-2">
              {heroViews.map((v, i) => (
                <button type="button" data-img-desktop={v.img} data-alt={v.alt} class={`hero-thumb-desktop shrink-0 rounded-full px-4 py-2 text-xs font-black uppercase tracking-wide ${i === 0 ? 'bg-[#F6D77B] text-[#5a0f18] shadow-sm ring-2 ring-black/10' : 'bg-[#FFF7EA] text-[#7a1f2b] ring-1 ring-black/10'}`}>{v.label}</button>
              ))}
