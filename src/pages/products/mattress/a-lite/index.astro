---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import AgentSection from '../../../../components/AgentSection.astro';
import ProductGallerySlider from '../../../../components/ProductGallerySlider.astro';

const base = '/assets/images/products/mattress/a-lite';

// Hero images (point 7: 1 dengan katil, 1 tilam sahaja)
const heroBed = `${base}/A-lite-series-With-BedFrame_Font.webp`;
const heroMattress = `${base}/tilam-cuckoo-a-lite.webp`;

// Feature images (real where available, placeholder otherwise)
const feat1 = `${base}/a-lite-feature-01@2x-2.webp`; // VitalShield (graphene, navy)
const feat2 = `${base}/a-lite-feature-02@2x-1.webp`; // Dusticbac-Free (mattress + pest icons, red)
const mattress04 = `${base}/a-lite-mattress-04@2x.webp`; // mattress + leaves (Where Nature...)
const anilineIcon = `${base}/MTLP-Aniline-icon@2x.webp`;
const anilineBadge = `${base}/Aniline-free-small-icon@2x.webp`;
const latexTopperIcon = `${base}/MTLP-Latex-topper-icon@2x.webp`;
const pressureIcon = `${base}/MTLP-icon-01@2x.webp`;
const motionIcon = `${base}/MTLP-icon-02@2x.webp`;
const spinalIcon = `${base}/MTLP-icon-03@2x.webp`;

// Layers cutaway (labels baked into image), 5-zone visuals + grey icons, dimension diagrams
const layersImg = `${base}/a-lite-mattress-updated-1002.webp`;
const fiveZoneImg = `${base}/tilam-a-lite-5-zone.webp`;
const zoneIconPressure = `${base}/a-lite-icon-02@2x.png.webp`;
const zoneIconMotion = `${base}/a-lite-icon-03@2x.png.webp`;
const zoneIconSpinal = `${base}/a-lite-icon-01@2x.png.webp`;
const specQueen = `${base}/a-lite-specification-mbqueen@2x-1536x774.png`;
const specKing = `${base}/a-lite-specification-mbking@2x-1536x788.png`;

// Warranty band (icons baked in, text overlaid) + accreditation logos
const warrantyBand = `${base}/a-lite-specification-border-dt@2x.webp`;
const accreditations = [
  { src: `${base}/malaysia-record-icon@2x.webp`, alt: 'Malaysia Book of Records' },
  { src: `${base}/rubber-icon@2x.webp`, alt: 'Lembaga Getah Malaysia' },
  { src: `${base}/FDA-icon@2x.webp`, alt: 'FDA' },
  { src: `${base}/allergy-free-pass-icon@2x.webp`, alt: 'Allergy Free — Sensitivity Test Passed' },
  { src: `${base}/aniline-free-by-eco-icon@2x.webp`, alt: 'Aniline Free certified by eco Institut' },
  { src: `${base}/eco-icon@2x.webp`, alt: 'eco Institut tested product' }
];

const natureFeatureCards = [
  {
    icon: anilineIcon,
    title: '100% Bebas Aniline',
    copy: 'Bebas daripada bahan kimia keras, direka untuk tidur malam yang lebih bersih dan selesa.',
    badge: anilineBadge,
    badgeAlt: 'Aniline Free'
  },
  {
    icon: latexTopperIcon,
    title: '100% Topper Lateks Semula Jadi',
    copy: 'Lembut dan menyokong badan, pilihan tidur yang lebih sihat untuk anda dan alam sekitar.'
  }
];

const natureMiniFeatures = [
  { icon: pressureIcon, title: 'Agihan Tekanan Sekata' },
  { icon: motionIcon, title: 'Zero Motion Transfer untuk Tidur Tanpa Gangguan' },
  { icon: spinalIcon, title: 'Membantu Penjajaran Tulang Belakang Semula Jadi' }
];

// CUCKOO+ mattress cleaning service photos (labels baked into image)
const serviceImgs = [
  { src: `${base}/a-lite_service-01@2x.png.webp`, alt: 'Lint Removal — servis pembersihan tilam CUCKOO A-LITE' },
  { src: `${base}/a-lite_service-02@2x.png`, alt: 'Bedframe Cleaning — servis pembersihan tilam CUCKOO A-LITE' },
  { src: `${base}/a-lite_service-03@2x.png.webp`, alt: 'Pillow Dry-Cleaning — servis pembersihan tilam CUCKOO A-LITE' },
  { src: `${base}/a-lite_service-04@2x.png`, alt: 'Dry Clean — servis pembersihan tilam CUCKOO A-LITE' },
  { src: `${base}/a-lite_service-05@2x.png`, alt: 'Hydro Clean — servis pembersihan tilam CUCKOO A-LITE' },
  { src: `${base}/a-lite_service-06@2x.png.webp`, alt: 'Bedbug Removal — servis pembersihan tilam CUCKOO A-LITE' }
];

const galleryItems = [
  { image: `${base}/a-lite-gallery-01@2x-1.webp`, title: 'A-LITE Campaign Visual', copy: 'Rujukan visual A-LITE Series Mattress untuk lihat gaya ruang tidur.', alt: 'CUCKOO A-LITE Series Mattress campaign visual' },
  { image: `${base}/a-lite-gallery-image_01.webp`, title: 'A-LITE Gallery 1', copy: 'Rujukan rupa dan tekstur tilam A-LITE.', alt: 'Gambar CUCKOO A-LITE Series Mattress 1' },
  { image: `${base}/a-lite-gallery-image_02.webp`, title: 'A-LITE Gallery 2', copy: 'Rujukan rupa dan tekstur tilam A-LITE.', alt: 'Gambar CUCKOO A-LITE Series Mattress 2' },
  { image: `${base}/a-lite-gallery-image_03-scaled.webp`, title: 'A-LITE Gallery 3', copy: 'Rujukan rupa dan tekstur tilam A-LITE.', alt: 'Gambar CUCKOO A-LITE Series Mattress 3' },
  { image: 'https://placehold.co/800x640/fff4ee/73101f?text=Close-up+Cover+Layer', title: 'Close-up Cover Layer', copy: 'Placeholder — close-up Graphene Infused Knit Cover.', alt: 'Placeholder close-up cover layer A-LITE' },
  { image: 'https://placehold.co/800x640/fff4ee/73101f?text=Mattress+Cleaning+Service', title: 'Mattress Cleaning Service', copy: 'Placeholder — scheduled mattress cleaning service.', alt: 'Placeholder mattress cleaning service A-LITE' }
];

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'CUCKOO A-LITE Series Mattress',
  alternateName: ['Tilam CUCKOO A-LITE', 'A-LITE Series Mattress', 'Tilam Natural Latex CUCKOO'],
  brand: { '@type': 'Brand', name: 'CUCKOO' },
  url: 'https://www.cuckoonano.com/products/mattress/a-lite/',
  description:
    'CUCKOO A-LITE Series Mattress — tilam natural latex dengan Graphene Infused Knit Cover, VitalShield Tech, Dusticbac-Free Tech, 100% Natural Latex Topper dan 5 Zone Pocket Spring. Servis tilam percuma setiap 4 bulan dan warranty 10 tahun.',
  offers: {
    '@type': 'Offer',
    priceCurrency: 'MYR',
    price: '105',
    availability: 'https://schema.org/InStock',
    areaServed: { '@type': 'Country', name: 'Malaysia' }
  }
};

const faqItems = [
  { q: 'Harga A-LITE bermula dari berapa?', a: 'Rental bermula dari RM105/bulan untuk Queen tanpa bedframe. Harga berbeza mengikut saiz dan pilihan dengan atau tanpa bedframe.' },
  { q: 'Ada pilihan King?', a: 'Ya. A-LITE tersedia dalam Queen dan King, tertakluk kepada stok semasa.' },
  { q: 'Boleh ambil tanpa bedframe?', a: 'Boleh. Customer boleh pilih tanpa bedframe atau dengan bedframe. Harga bulanan dan outright berbeza mengikut pilihan tersebut.' },
  { q: 'Servis tilam dibuat berapa bulan sekali?', a: 'Untuk pelan rental, servis pembersihan tilam berjadual dibuat setiap 4 bulan mengikut jadual dan terma semasa CUCKOO.' },
  { q: 'Waranti berapa tahun?', a: 'A-LITE disertakan dengan waranti terhad 10 tahun yang meliputi kecacatan pembuatan, tertakluk kepada terma waranti CUCKOO.' },
  { q: 'Perlu slip gaji atau kad kredit?', a: 'Biasanya proses apply CUCKOO lebih mudah dan tidak semestinya perlukan slip gaji atau kad kredit. Kelulusan tetap tertakluk kepada semakan semasa.' },
  { q: 'Sesuai untuk orang sakit belakang?', a: 'A-LITE direka untuk memberi sokongan belakang dan posisi tidur yang lebih selesa. Namun ia bukan produk rawatan perubatan; jika ada masalah kesihatan serius, dapatkan nasihat doktor.' }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a }
  }))
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.cuckoonano.com/' },
    { '@type': 'ListItem', position: 2, name: 'Produk', item: 'https://www.cuckoonano.com/products/' },
    { '@type': 'ListItem', position: 3, name: 'Tilam', item: 'https://www.cuckoonano.com/products/mattress/' },
    { '@type': 'ListItem', position: 4, name: 'A-LITE Series Mattress', item: 'https://www.cuckoonano.com/products/mattress/a-lite/' }
  ]
};
---

<BaseLayout
  title="CUCKOO A-LITE Series Mattress | Tilam Natural Latex & Back Support"
  description="CUCKOO A-LITE Series Mattress dengan Graphene Infused Knit Cover, VitalShield Tech, 100% Natural Latex Topper, 5 Zone Pocket Spring, servis tilam percuma setiap 4 bulan dan warranty 10 tahun. WhatsApp ejen untuk semak harga."
  canonical="https://www.cuckoonano.com/products/mattress/a-lite/"
  ogImage="https://www.cuckoonano.com/assets/images/products/mattress/a-lite/A-lite-series-With-BedFrame_Font.webp"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- ============================================================ -->
  <!-- HERO -->
  <!-- ============================================================ -->
  <section class="relative overflow-hidden px-4 py-10 sm:px-6 lg:px-8 lg:py-16"
           style="background: radial-gradient(circle at 15% 14%, rgba(255,255,255,.82), transparent 24%), radial-gradient(circle at 86% 25%, rgba(255,255,255,.42), transparent 30%), linear-gradient(135deg, #f9dfd2 0%, #f6d4c4 48%, #f2c5b2 100%);">
    <div class="relative mx-auto max-w-7xl">

      <!-- MOBILE HERO -->
      <div class="lg:hidden">
        <div class="mx-auto max-w-md text-center">
          <div class="mb-3 flex flex-wrap justify-center gap-2">
            <span class="rounded-full bg-[#a3172d] px-4 py-1.5 text-[11px] font-black uppercase tracking-[0.16em] text-white">🔥 Promo RM12</span>
            <span class="rounded-full bg-white/70 px-4 py-1.5 text-[11px] font-black uppercase tracking-[0.16em] text-[#73101f] ring-1 ring-[#73101f]/15">Your Bedroom Bestie</span>
            <span class="rounded-full bg-white/55 px-4 py-1.5 text-[11px] font-black uppercase tracking-[0.16em] text-[#73101f] ring-1 ring-[#73101f]/15">Warranty 10 Tahun</span>
          </div>
          <p class="text-[11px] font-black uppercase tracking-[0.22em] text-[#a3172d]">CUCKOO Mattress Malaysia</p>
          <h1 class="mt-2 text-[1.85rem] font-black leading-[1.04] tracking-tight text-[#a3172d]">
            CUCKOO A-LITE<br />Series Mattress
          </h1>
          <p class="mx-auto mt-3 max-w-xs text-sm leading-6 text-[#65443e]">
            Tilam natural latex dengan sokongan belakang, teknologi perlindungan tidur dan servis pembersihan berkala.
          </p>
        </div>

        <!-- Mobile product card -->
        <div class="mx-auto mt-5 max-w-sm overflow-hidden rounded-[2rem] bg-white p-3 shadow-[0_24px_70px_rgba(115,16,31,.16)] ring-1 ring-[#73101f]/10">
          <div class="relative flex items-center justify-center">
            <img id="heroImgMobile" src={heroBed}
                 alt="CUCKOO A-LITE Series Mattress dengan bed frame"
                 class="relative z-10 mx-auto h-auto w-full max-w-[420px] object-contain transition duration-300" />
          </div>
          <div class="mt-3 flex justify-center gap-2">
            <button type="button" data-img-mobile={heroBed} class="hero-thumb-mobile shrink-0 rounded-full bg-[#a3172d] px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white shadow-sm ring-2 ring-[#a3172d]">Dengan Katil</button>
            <button type="button" data-img-mobile={heroMattress} class="hero-thumb-mobile shrink-0 rounded-full bg-white px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-[#73101f] ring-1 ring-[#73101f]/20">Tilam Sahaja</button>
          </div>
        </div>

        <!-- Pricing card mobile -->
        <div class="mx-auto mt-5 max-w-sm rounded-[1.75rem] bg-white p-4 shadow-[0_20px_48px_rgba(115,16,31,.14)] ring-1 ring-[#73101f]/10">
          <div class="rounded-[1.4rem] p-4 text-center" style="background: linear-gradient(135deg, #fff7de, #ffe7a8, #d6b679);">
            <p class="text-[11px] font-black uppercase tracking-[0.18em] text-amber-800">6 Bulan Pertama</p>
            <p class="mt-1 text-4xl font-black tracking-tight text-slate-950">RM12<span class="text-base font-bold text-amber-900">/bulan</span></p>
            <p class="mt-1 text-[11px] font-bold text-amber-800">Lepas promo — RM105/bulan hingga 60 bulan</p>
          </div>
          <div class="mt-3 grid gap-2">
            <div class="rounded-xl bg-[#fbe7df] px-3 py-2.5 text-xs font-black text-[#73101f]">Queen &amp; King — pilihan dengan atau tanpa bedframe</div>
            <div class="rounded-xl bg-[#fbe7df] px-3 py-2.5 text-xs font-black text-[#73101f]">Servis pembersihan tilam setiap 4 bulan</div>
            <div class="rounded-xl bg-[#fbe7df] px-3 py-2.5 text-xs font-black text-[#73101f]">Penghantaran &amp; pemasangan percuma*</div>
          </div>
          <p class="mt-3 text-center text-[10px] font-semibold leading-5 text-[#745f5a]">*Tertakluk kepada stok, kelayakan, kawasan pemasangan dan terma semasa.</p>
        </div>

        <div class="mx-auto mt-4 max-w-sm">
          <a href="#" onclick="this.href=rotatingWhatsapp()"
             class="flex w-full items-center justify-center rounded-2xl bg-cta-green px-6 py-4 text-base font-black text-white shadow-cta transition hover:bg-cta-dark">
            📲 Semak Harga &amp; Kelayakan
          </a>
        </div>
      </div><!-- end mobile hero -->


      <!-- DESKTOP HERO -->
      <div class="hidden lg:grid lg:grid-cols-[0.92fr_1.08fr] lg:items-center lg:gap-14">

        <!-- Left: text -->
        <div>
          <div class="mb-5 flex flex-wrap gap-2">
            <span class="rounded-full bg-[#a3172d] px-5 py-2 text-xs font-black uppercase tracking-[0.2em] text-white">🔥 Promo RM12 Sekarang</span>
            <span class="rounded-full bg-white/70 px-5 py-2 text-xs font-black uppercase tracking-[0.2em] text-[#73101f] ring-1 ring-[#73101f]/15">Your Bedroom Bestie</span>
            <span class="rounded-full bg-white/55 px-5 py-2 text-xs font-black uppercase tracking-[0.2em] text-[#73101f] ring-1 ring-[#73101f]/15">Warranty 10 Tahun</span>
          </div>

          <p class="text-sm font-black uppercase tracking-[0.24em] text-[#a3172d]">CUCKOO Mattress Malaysia</p>

          <h1 class="mt-3 max-w-2xl text-balance text-5xl font-black leading-[1.03] tracking-tight text-[#a3172d] xl:text-6xl">
            CUCKOO A-LITE Series Mattress
          </h1>

          <p class="mt-5 max-w-xl text-lg leading-8 text-[#65443e]">
            Tilam natural latex dengan sokongan belakang, teknologi perlindungan tidur dan servis pembersihan berkala untuk rehat yang lebih selesa.
          </p>

          <!-- Pricing block -->
          <div class="mt-7 max-w-xl rounded-[2rem] bg-white p-4 shadow-[0_20px_48px_rgba(115,16,31,.14)] ring-1 ring-[#73101f]/10">
            <div class="grid grid-cols-[auto_1fr] items-center gap-4">
              <div class="rounded-[1.5rem] px-6 py-5 text-center" style="background: linear-gradient(135deg, #fff7de, #ffe7a8, #d6b679);">
                <p class="text-[11px] font-black uppercase tracking-[0.2em] text-amber-800">6 Bulan Pertama</p>
                <p class="mt-1 text-5xl font-black tracking-tight text-slate-950">RM12</p>
                <p class="text-sm font-black text-amber-900">/bulan</p>
              </div>
              <div class="space-y-2.5">
                <div class="rounded-2xl bg-[#fff4ee] px-4 py-3 text-sm font-extrabold text-[#73101f] ring-1 ring-[#73101f]/10">Lepas promo — RM105/bulan hingga 60 bulan</div>
                <div class="rounded-2xl bg-[#fff4ee] px-4 py-3 text-sm font-extrabold text-[#73101f] ring-1 ring-[#73101f]/10">Queen &amp; King — pilihan dengan atau tanpa bedframe</div>
                <p class="px-1 text-xs font-semibold leading-5 text-[#745f5a]">Servis pembersihan tilam setiap 4 bulan · Penghantaran &amp; pemasangan percuma, tertakluk kepada terma semasa.</p>
              </div>
            </div>
          </div>

          <!-- CTA buttons -->
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#" onclick="this.href=rotatingWhatsapp()"
               class="inline-flex items-center justify-center rounded-2xl bg-cta-green px-8 py-4 text-base font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark">
              📲 Semak Harga &amp; Kelayakan
            </a>
            <a href="#features"
               class="inline-flex items-center justify-center rounded-2xl border border-[#73101f]/20 bg-white px-8 py-4 text-base font-black text-[#73101f] transition hover:-translate-y-0.5 hover:bg-[#fff4ee]">
              Lihat Ciri-ciri
            </a>
          </div>
        </div>

        <!-- Right: product card -->
        <div class="relative">
          <div class="relative overflow-hidden rounded-[2.5rem] bg-white p-6 shadow-[0_34px_90px_rgba(115,16,31,.22)] ring-1 ring-[#73101f]/10">
            <div class="mb-4 flex flex-wrap justify-center gap-2">
              <span class="rounded-full bg-[#a3172d] px-4 py-1.5 text-xs font-black uppercase tracking-wide text-white">Natural Latex</span>
              <span class="rounded-full bg-[#fbe7df] px-4 py-1.5 text-xs font-black uppercase tracking-wide text-[#73101f]">5 Zone Support</span>
            </div>

            <div class="relative flex min-h-[320px] items-center justify-center">
              <img id="heroImgDesktop" src={heroBed}
                   alt="CUCKOO A-LITE Series Mattress dengan bed frame"
                   class="relative z-10 mx-auto h-auto w-full max-w-[460px] object-contain transition duration-300" />
            </div>

            <!-- Image switcher desktop -->
            <div class="mt-4 flex justify-center gap-2">
              <button type="button" data-img-desktop={heroBed} class="hero-thumb-desktop shrink-0 rounded-full bg-[#a3172d] px-4 py-2 text-xs font-black uppercase tracking-wide text-white shadow-sm ring-2 ring-[#a3172d]">Dengan Katil</button>
              <button type="button" data-img-desktop={heroMattress} class="hero-thumb-desktop shrink-0 rounded-full bg-white px-4 py-2 text-xs font-black uppercase tracking-wide text-[#73101f] ring-1 ring-[#73101f]/20">Tilam Sahaja</button>
            </div>

            <!-- Mini stats -->
            <div class="mt-5 grid grid-cols-3 gap-2">
              <div class="rounded-2xl bg-[#fff4ee] px-2 py-3 text-center"><p class="text-base font-black text-[#73101f]">10 Thn</p><p class="text-[10px] font-bold uppercase tracking-wide text-[#a3172d]">Waranti</p></div>
              <div class="rounded-2xl bg-[#fff4ee] px-2 py-3 text-center"><p class="text-base font-black text-[#73101f]">4 Bulan</p><p class="text-[10px] font-bold uppercase tracking-wide text-[#a3172d]">Servis Percuma</p></div>
              <div class="rounded-2xl bg-[#fff4ee] px-2 py-3 text-center"><p class="text-base font-black text-[#73101f]">Q / K</p><p class="text-[10px] font-bold uppercase tracking-wide text-[#a3172d]">Queen &amp; King</p></div>
            </div>
          </div>

          <!-- floating note -->
          <div class="relative mx-auto mt-4 w-10/12 rounded-3xl bg-white px-5 py-4 text-center shadow-xl ring-1 ring-[#73101f]/10">
            <p class="text-[11px] font-bold text-[#a3172d]">Supporting your back like a bestie would</p>
            <p class="text-sm font-black text-[#73101f]">Natural Latex + 5 Zone Pocket Spring</p>
          </div>
        </div>

      </div><!-- end desktop hero -->
    </div>
  </section>


  <!-- ============================================================ -->
  <!-- HIGHLIGHT STRIP -->
  <!-- ============================================================ -->
  <section class="px-4 py-8 text-white sm:px-6 lg:px-8" style="background: linear-gradient(90deg, #73101f, #a3172d, #bf2a3d);">
    <div class="mx-auto grid max-w-7xl grid-cols-2 gap-6 sm:grid-cols-4">
      <div class="text-center">
        <div class="mx-auto mb-3 flex h-14 w-14 items-center justify-center rounded-full bg-white/15 text-base font-black ring-4 ring-white/25">01</div>
        <h3 class="text-base font-black leading-tight">Graphene Knit Cover</h3>
        <p class="mt-1 text-sm leading-snug text-white/75">Lapisan cover untuk rasa tidur lebih selesa.</p>
      </div>
      <div class="text-center">
        <div class="mx-auto mb-3 flex h-14 w-14 items-center justify-center rounded-full bg-white/15 text-base font-black ring-4 ring-white/25">02</div>
        <h3 class="text-base font-black leading-tight">Natural Latex Topper</h3>
        <p class="mt-1 text-sm leading-snug text-white/75">Soft, supportive dan lebih natural untuk tidur.</p>
      </div>
      <div class="text-center">
        <div class="mx-auto mb-3 flex h-14 w-14 items-center justify-center rounded-full bg-white/15 text-base font-black ring-4 ring-white/25">03</div>
        <h3 class="text-base font-black leading-tight">5 Zone Pocket Spring</h3>
        <p class="mt-1 text-sm leading-snug text-white/75">Sokongan badan dan tulang belakang.</p>
      </div>
      <div class="text-center">
        <div class="mx-auto mb-3 flex h-14 w-14 items-center justify-center rounded-full bg-white/15 text-base font-black ring-4 ring-white/25">04</div>
        <h3 class="text-base font-black leading-tight">Service Every 4 Months</h3>
        <p class="mt-1 text-sm leading-snug text-white/75">Free scheduled mattress cleaning service.</p>
      </div>
    </div>
  </section>


  <!-- ============================================================ -->
  <!-- PAIN POINTS -->
  <!-- ============================================================ -->
  <section class="px-4 py-16 sm:px-6 lg:px-8 lg:py-24" style="background: #fff4ee;">
    <div class="mx-auto max-w-7xl">
      <div class="mx-auto max-w-3xl text-center fade-up">
        <p class="text-xs font-black uppercase tracking-[0.22em] text-[#a3172d]">Kenapa tukar tilam?</p>
        <h2 class="mt-3 text-balance text-3xl font-black tracking-tight text-[#211719] sm:text-5xl">Tidur lama, tapi badan masih rasa tidak cukup rehat?</h2>
