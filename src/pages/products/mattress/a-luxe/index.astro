<style is:global>
  .gold-text {
    background: linear-gradient(135deg, #fff3cf 0%, #e8c87e 45%, #bf9a4e 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .fade-up {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .fade-up.visible { opacity: 1; transform: translateY(0); }

  .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.3s ease, padding 0.3s ease; }
  .faq-answer.open { max-height: 400px; }
  .faq-icon { transition: transform 0.3s ease; }
  .faq-icon.open { transform: rotate(45deg); }

  .price-acc summary { list-style: none; }
  .price-acc summary::-webkit-details-marker { display: none; }
  .price-acc .acc-plus { transition: transform 0.25s ease; }
  .price-acc[open] .acc-plus { transform: rotate(45deg); }

  @media (prefers-reduced-motion: reduce) { .fade-up { transition: none; } }
</style>

<script is:inline>
  // --- Hero image switcher: mobile ---
  (function () {
    const img = document.getElementById('heroImgMobile');
    const btns = document.querySelectorAll('.hero-thumb-mobile');
    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        if (img) {
          img.style.transition = 'opacity 0.15s ease';
          img.style.opacity = '0';
          setTimeout(() => { img.src = btn.dataset.imgMobile; img.style.opacity = '1'; }, 150);
        }
        btns.forEach((b) => {
          b.className = 'hero-thumb-mobile shrink-0 rounded-full bg-[#FFF7EA] px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-[#7a1f2b] ring-1 ring-black/10';
        });
        btn.className = 'hero-thumb-mobile shrink-0 rounded-full bg-[#F6D77B] px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-[#5a0f18] shadow-sm ring-2 ring-black/10';
      });
    });
  })();

  // --- Hero image switcher: desktop ---
  (function () {
    const img = document.getElementById('heroImgDesktop');
    const btns = document.querySelectorAll('.hero-thumb-desktop');
    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        if (img) {
          img.style.transition = 'opacity 0.15s ease';
          img.style.opacity = '0';
          setTimeout(() => { img.src = btn.dataset.imgDesktop; img.style.opacity = '1'; }, 150);
        }
        btns.forEach((b) => {
          b.className = 'hero-thumb-desktop shrink-0 rounded-full bg-[#FFF7EA] px-4 py-2 text-xs font-black uppercase tracking-wide text-[#7a1f2b] ring-1 ring-black/10';
        });
        btn.className = 'hero-thumb-desktop shrink-0 rounded-full bg-[#F6D77B] px-4 py-2 text-xs font-black uppercase tracking-wide text-[#5a0f18] shadow-sm ring-2 ring-black/10';
      });
    });
  })();

  // --- Pricing accordion: update current price on option click ---
  document.querySelectorAll('[data-pricing-card]').forEach((card) => {
    const priceEl = card.querySelector('.current-price');
    const detailEl = card.querySelector('.current-detail');
    const unitClass = card.dataset.unitClass || '';
    if (!priceEl || !detailEl) return;
    card.querySelectorAll('.price-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const unit = btn.dataset.unit ? '<span class="' + unitClass + '">' + btn.dataset.unit + '</span>' : '';
        priceEl.innerHTML = btn.dataset.price + unit;
        detailEl.textContent = btn.dataset.detail;
      });
    });
  });

  // --- FAQ accordion ---
  document.querySelectorAll('.faq-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const ans = item.querySelector('.faq-answer');
      const icon = btn.querySelector('.faq-icon');
      const open = ans.classList.contains('open');
      document.querySelectorAll('.faq-answer').forEach((a) => a.classList.remove('open'));
      document.querySelectorAll('.faq-icon').forEach((i) => i.classList.remove('open'));
      if (!open) { ans.classList.add('open'); icon.classList.add('open'); }
    });
  });

  // --- Fade-up on scroll ---
  (function () {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
  })();
</script>
