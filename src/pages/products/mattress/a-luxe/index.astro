---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import AgentSection from '../../../../components/AgentSection.astro';
import ProductGallerySlider from '../../../../components/ProductGallerySlider.astro';

const base = '/assets/images/products/mattress/a-luxe';

// Hero images (point 12)
const heroBed = `${base}/A-Luxe-Mattress-1000x1000-1.png.webp`;        // dengan katil
const heroMattress = `${base}/A-Luxe-Mattress-tilam-sahaja-1000x1000.webp`; // tilam sahaja

// Section images (real where available, placeholder otherwise)
const grapheneImg = `${base}/Graphene-banner-desk.webp`;
const layerImg = `${base}/A-Luxe-LAYER-BED-with-pointer.webp`;
const layerMobile = `${base}/Layers-mobile-001.webp`;
const specQueen = `${base}/A-Luxe-Spec-Queen@2x-2048x1376.webp`;
const specKing = `${base}/A-Luxe-Spec-King@2x-2048x1376.webp`;

// "Beyond Sleep" + "Quality Sleep" sections (white line icons → dark bg)
const iconGaget = `${base}/ICON-gaget.png`;
const iconBacteria = `${base}/ICON-bacteria.png`;
const iconTemperature = `${base}/ICON-temperature.png`;
const iconEQ = `${base}/ICON-EQ_1@2x.png`;
const iconIQ = `${base}/ICON-IQ@2x.png`;
const iconEnhance = `${base}/ICON-Enhance@2x.png`;
const beyondMattressImg = `${base}/a-luxe-Mattress-img-dt@2x.webp`;

const features = [
  {
    badge: 'Graphene Conductive Fiber',
    title: 'Permukaan Tidur Lebih Selesa & Static-Free',
    copy: 'Lapisan graphene membantu mengurangkan static discomfort, sambil memberi rasa permukaan tilam yang lebih premium.',
    tags: ['Anti-static', 'Premium sleep layer'],
    media: grapheneImg,
    type: 'image'
  },
  {
    badge: 'VitalShield Tech',
    title: 'Tingkatkan Peredaran Darah & Kualiti Tidur',
    copy: 'Improves blood circulation and enhances sleep quality.',
    tags: ['Blood circulation', 'Sleep quality'],
    media: `${base}/VitalShield_Desktop_Square.mp4`,
    type: 'video',
    ratio: 'square'
  },
  {
    badge: 'Dustic Freeze Pro',
    title: 'Rasa Lebih Sejuk, Bersih & Selesa',
    copy: 'Teknologi Dustic Freeze Pro memberi cooling feel serta perlindungan permukaan daripada dust mites dan bakteria.',
    tags: ['Cooling feel', 'Anti dust mite'],
    media: `${base}/Dustic_Desktop_Square.mp4`,
    type: 'video',
    ratio: 'square'
  },
  {
    badge: '100% Natural Latex',
    title: 'Sokongan Lembut Tetapi Stabil Untuk Badan',
    copy: 'Natural latex memberi rasa breathable dan responsif, sesuai untuk anda yang mahu tilam premium tetapi masih menyokong badan.',
    tags: ['Breathable', 'Responsive support'],
    media: `${base}/Latex_Desktop_Square.mp4`,
    type: 'video',
    ratio: 'square'
  },
  {
    badge: '7-Zone Support',
    title: 'Sokongan Berbeza Untuk Bahu, Pinggang & Pinggul',
    copy: '7-Zone Skeletal Support membantu menyokong bahagian badan yang berbeza supaya tidur rasa lebih seimbang.',
    tags: ['Spine support', 'Body alignment'],
    media: `${base}/7-zone_Desktop_Horizontal.mp4`,
    type: 'video',
    ratio: 'horizontal'
  },
  {
    badge: 'Zero Motion Transfer',
    title: 'Kurang Gangguan Bila Pasangan Bergerak',
    copy: 'Gabungan pocket spring dan struktur sokongan membantu mengurangkan rasa gegaran apabila pasangan bergerak di sisi.',
    tags: ['Couple friendly', 'Pocket spring'],
    media: `${base}/Zero-Motion_Desktop_Square.mp4`,
    type: 'video',
    ratio: 'square'
  }
];

const galleryItems = [
  ...Array.from({ length: 8 }, (_, i) => {
    const n = i + 1;
    return {
      image: `${base}/tilam-cuckoo-a-luxe-napure-premium-mattress-${n}.webp`,
      title: `CUCKOO A Luxe Mattress ${n}`,
      copy: 'Rujukan rupa dan pemasangan sebenar CUCKOO A Luxe Mattress.',
      alt: `Gambar CUCKOO A Luxe Napure premium mattress ${n}`
    };
  })
];

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'CUCKOO A Luxe Mattress',
  alternateName: ['Tilam CUCKOO A Luxe', 'A Luxe Napure Mattress', 'Tilam Premium Natural Latex CUCKOO'],
  brand: { '@type': 'Brand', name: 'CUCKOO' },
  url: 'https://www.cuckoonano.com/products/mattress/a-luxe/',
  description:
    'CUCKOO A Luxe Mattress — tilam premium dengan Graphene Conductive Fiber, Dustic Freeze Pro, 100% Natural Latex, 7-Zone Support dan Zero Motion Transfer. CUCKOO+ Care Service setiap 4 bulan dan warranty 10 tahun.',
  offers: {
    '@type': 'Offer',
    priceCurrency: 'MYR',
    price: '108',
    availability: 'https://schema.org/InStock',
    areaServed: { '@type': 'Country', name: 'Malaysia' }
  }
};

const faqItems = [
  { q: 'A Luxe sesuai untuk siapa?', a: 'Sesuai untuk anda yang mahukan tilam premium dengan natural latex, sokongan badan lebih baik, rasa lebih sejuk dan kurang gangguan pergerakan pasangan.' },
  { q: 'Beza mattress sahaja dan mattress + bed frame?', a: 'Mattress sahaja ialah tilam A Luxe sahaja. Mattress + bed frame pula termasuk New CUCKOO Bed Frame mengikut pelan dan terma semasa.' },
  { q: 'Rental ada berapa tahun?', a: 'Mattress sahaja ada pilihan 3 tahun, 5 tahun dan 7 tahun. Mattress + bed frame ada pilihan 5 tahun dan 7 tahun.' },
  { q: 'Outright dapat apa?', a: 'Outright promo termasuk free 2× mattress protector dan free CCS 1 tahun, tertakluk kepada terma semasa.' },
  { q: 'Berapa kerap service tilam?', a: 'CUCKOO+ Care Service untuk tilam dibuat setiap 4 bulan mengikut pelan dan jadual servis.' },
  { q: 'Warranty cover apa?', a: 'Warranty 10 tahun adalah warranty terhad untuk manufacturing defect, tertakluk kepada terma semasa CUCKOO.' }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a }
  }))
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.cuckoonano.com/' },
    { '@type': 'ListItem', position: 2, name: 'Produk', item: 'https://www.cuckoonano.com/products/' },
    { '@type': 'ListItem', position: 3, name: 'Tilam', item: 'https://www.cuckoonano.com/products/mattress/' },
    { '@type': 'ListItem', position: 4, name: 'A Luxe Mattress', item: 'https://www.cuckoonano.com/products/mattress/a-luxe/' }
  ]
};
---

<BaseLayout
  title="CUCKOO A Luxe Mattress | Tilam Premium Natural Latex & 7-Zone Support"
  description="CUCKOO A Luxe Mattress dengan Graphene Conductive Fiber, Dustic Freeze Pro, 100% Natural Latex, 7-Zone Support, Zero Motion Transfer, CUCKOO+ Care Service setiap 4 bulan dan warranty 10 tahun. WhatsApp ejen untuk semak harga."
  canonical="https://www.cuckoonano.com/products/mattress/a-luxe/"
  ogImage="https://www.cuckoonano.com/assets/images/products/mattress/a-luxe/A-Luxe-Mattress-1000x1000-1.png.webp"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- ============================================================ -->
  <!-- HERO (navy) -->
  <!-- ============================================================ -->
  <section class="relative overflow-hidden px-4 py-10 text-white sm:px-6 lg:px-8 lg:py-16"
           style="background: radial-gradient(circle at 72% 20%, rgba(216,180,120,.30), transparent 38%), linear-gradient(135deg, #3a0a12 0%, #5e1019 52%, #7a1f2b 100%);">
    <div class="relative mx-auto max-w-7xl">

      <!-- MOBILE HERO -->
      <div class="lg:hidden">
        <div class="mx-auto max-w-md text-center">
          <div class="mb-3 flex flex-wrap justify-center gap-2">
            <span class="rounded-full bg-[#d8c69a] px-4 py-1.5 text-[11px] font-black uppercase tracking-[0.16em] text-[#5a0f18]">🔥 Promo RM12</span>
            <span class="rounded-full bg-white/10 px-4 py-1.5 text-[11px] font-black uppercase tracking-[0.16em] text-white ring-1 ring-white/15">CUCKOO × Napure Mattress</span>
            <span class="rounded-full bg-white/10 px-4 py-1.5 text-[11px] font-black uppercase tracking-[0.16em] text-white ring-1 ring-white/15">Warranty 10 Tahun</span>
          </div>
          <p class="text-[11px] font-black uppercase tracking-[0.22em] text-[#d8c69a]">CUCKOO Mattress Malaysia</p>
          <h1 class="mt-2 text-[1.85rem] font-black leading-[1.05] tracking-tight text-white">
            CUCKOO <span class="gold-text">A Luxe</span><br />Mattress
          </h1>
          <p class="mx-auto mt-3 max-w-xs text-sm leading-6 text-[#f0e6d6]/90">
            Tilam premium dengan Graphene Conductive Fiber, 100% Natural Latex dan 7-Zone Support untuk tidur yang lebih sejuk dan stabil.
          </p>
        </div>

        <!-- Mobile product card -->
        <div class="mx-auto mt-5 max-w-sm overflow-hidden rounded-[2rem] bg-white/10 p-3 ring-1 ring-white/15 backdrop-blur">
          <div class="overflow-hidden rounded-[1.5rem] bg-white/50 p-2">
            <img id="heroImgMobile" src={heroBed}
                 alt="CUCKOO A Luxe Mattress dengan bed frame"
                 class="mx-auto h-auto w-full max-w-[420px] object-contain transition duration-300" />
          </div>
          <div class="mt-3 flex justify-center gap-2">
            <button type="button" data-img-mobile={heroBed} class="hero-thumb-mobile shrink-0 rounded-full bg-[#F6D77B] px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-[#5a0f18] shadow-sm ring-2 ring-black/10">Dengan Katil</button>
            <button type="button" data-img-mobile={heroMattress} class="hero-thumb-mobile shrink-0 rounded-full bg-[#FFF7EA] px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-[#7a1f2b] ring-1 ring-black/10">Tilam Sahaja</button>
          </div>
        </div>

        <!-- Pricing card mobile -->
        <div class="mx-auto mt-5 max-w-sm rounded-[1.75rem] bg-white/10 p-4 ring-1 ring-white/15 backdrop-blur">
          <div class="rounded-[1.4rem] p-4 text-center shadow-[inset_0_0_0_1px_rgba(255,255,255,.5)]" style="background: linear-gradient(135deg, #fff7de 0%, #ffe7a8 52%, #d8b25e 100%);">
            <p class="text-[11px] font-black uppercase tracking-[0.18em] text-[#7b4e14]">6 Bulan Pertama</p>
            <p class="mt-1 text-4xl font-black tracking-tight text-[#5a0f18]">RM12<span class="text-base font-bold text-[#7b4e14]">/bulan</span></p>
            <p class="mt-1 text-[11px] font-bold text-[#7b4e14]/85">Lepas promo — dari RM108/bulan</p>
          </div>
          <div class="mt-3 grid gap-2">
            <div class="rounded-xl bg-white/10 px-3 py-2.5 text-xs font-black text-white ring-1 ring-white/15">Queen &amp; King · pilihan dengan atau tanpa bed frame</div>
            <div class="rounded-xl bg-white/10 px-3 py-2.5 text-xs font-black text-white ring-1 ring-white/15">Mattress cleaning service setiap 4 bulan</div>
            <div class="rounded-xl bg-white/10 px-3 py-2.5 text-xs font-black text-white ring-1 ring-white/15">Free delivery &amp; installation*</div>
          </div>
          <p class="mt-3 text-center text-[10px] font-semibold leading-5 text-[#d8c69a]/80">*Tertakluk kepada stok, kelayakan, kawasan pemasangan dan terma semasa.</p>
        </div>

        <div class="mx-auto mt-4 max-w-sm">
          <a href="#" onclick="this.href=rotatingWhatsapp()"
             class="flex w-full items-center justify-center rounded-2xl bg-cta-green px-6 py-4 text-base font-black text-white shadow-cta transition hover:bg-cta-dark">
            📲 Semak Harga &amp; Kelayakan
          </a>
        </div>
      </div><!-- end mobile hero -->


      <!-- DESKTOP HERO -->
      <div class="hidden lg:grid lg:grid-cols-[1fr_1fr] lg:items-center lg:gap-14">
        <div>
          <div class="mb-5 flex flex-wrap gap-2">
            <span class="rounded-full bg-[#d8c69a] px-5 py-2 text-xs font-black uppercase tracking-[0.2em] text-[#5a0f18]">🔥 Promo RM12 Sekarang</span>
            <span class="rounded-full bg-white/10 px-5 py-2 text-xs font-black uppercase tracking-[0.2em] text-white ring-1 ring-white/15">CUCKOO × Napure Mattress</span>
            <span class="rounded-full bg-white/10 px-5 py-2 text-xs font-black uppercase tracking-[0.2em] text-white ring-1 ring-white/15">Warranty 10 Tahun</span>
          </div>

          <p class="text-sm font-black uppercase tracking-[0.24em] text-[#d8c69a]">CUCKOO Mattress Malaysia</p>

          <h1 class="mt-3 max-w-2xl text-balance text-5xl font-black leading-[1.03] tracking-tight text-white xl:text-6xl">
            CUCKOO <span class="gold-text">A Luxe</span> Mattress
          </h1>

          <p class="mt-5 max-w-xl text-lg leading-8 text-[#f0e6d6]/90">
            Tilam premium dengan Graphene Conductive Fiber, 100% Natural Latex dan 7-Zone Support untuk tidur yang lebih selesa, sejuk dan kurang gangguan pergerakan.
          </p>

          <!-- Pricing block -->
          <div class="mt-7 max-w-xl rounded-[2rem] bg-white/10 p-4 ring-1 ring-white/15 backdrop-blur">
            <div class="grid grid-cols-[auto_1fr] items-center gap-4">
              <div class="rounded-[1.5rem] px-6 py-5 text-center shadow-[inset_0_0_0_1px_rgba(255,255,255,.5)]" style="background: linear-gradient(135deg, #fff7de 0%, #ffe7a8 52%, #d8b25e 100%);">
                <p class="text-[11px] font-black uppercase tracking-[0.2em] text-[#7b4e14]">6 Bulan Pertama</p>
                <p class="mt-1 text-5xl font-black tracking-tight text-[#5a0f18]">RM12</p>
                <p class="text-sm font-black text-[#7b4e14]">/bulan</p>
              </div>
              <div class="space-y-2.5">
                <div class="rounded-2xl bg-white/10 px-4 py-3 text-sm font-extrabold text-white ring-1 ring-white/10">Lepas promo — dari RM108/bulan</div>
                <div class="rounded-2xl bg-white/10 px-4 py-3 text-sm font-extrabold text-white ring-1 ring-white/10">Queen &amp; King · pilihan dengan atau tanpa bed frame</div>
                <div class="rounded-2xl bg-white/10 px-4 py-3 text-sm font-extrabold text-white ring-1 ring-white/10">Mattress cleaning service setiap 4 bulan</div>
                <p class="px-1 text-xs font-semibold leading-5 text-[#d8c69a]/80">Free delivery &amp; installation, tertakluk kepada stok, kelayakan dan terma semasa.</p>
              </div>
            </div>
          </div>

          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#" onclick="this.href=rotatingWhatsapp()"
               class="inline-flex items-center justify-center rounded-2xl bg-cta-green px-8 py-4 text-base font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark">
              📲 Semak Harga &amp; Kelayakan
            </a>
            <a href="#features"
               class="inline-flex items-center justify-center rounded-2xl border border-white/25 bg-white/10 px-8 py-4 text-base font-black text-white backdrop-blur transition hover:-translate-y-0.5 hover:bg-white/20">
              Lihat Features
            </a>
          </div>
        </div>

        <!-- Right: product card -->
        <div class="relative">
          <div class="relative overflow-hidden rounded-[2.5rem] bg-white/10 p-5 shadow-[0_30px_80px_rgba(75,13,24,.45)] ring-1 ring-white/15 backdrop-blur">
            <div class="mb-4 flex flex-wrap justify-center gap-2">
              <span class="rounded-full bg-[#7a1f2b] px-4 py-1.5 text-xs font-black uppercase tracking-wide text-white">Natural Latex</span>
              <span class="rounded-full bg-white/10 px-4 py-1.5 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/15">7-Zone Support</span>
            </div>

            <div class="overflow-hidden rounded-[1.75rem] bg-white/50 p-4">
              <img id="heroImgDesktop" src={heroBed}
                   alt="CUCKOO A Luxe Mattress dengan bed frame"
                   class="mx-auto h-auto w-full max-w-[460px] object-contain transition duration-300" />
            </div>

            <div class="mt-4 flex justify-center gap-2">
              <button type="button" data-img-desktop={heroBed} class="hero-thumb-desktop shrink-0 rounded-full bg-[#F6D77B] px-4 py-2 text-xs font-black uppercase tracking-wide text-[#5a0f18] shadow-sm ring-2 ring-black/10">Dengan Katil</button>
              <button type="button" data-img-desktop={heroMattress} class="hero-thumb-desktop shrink-0 rounded-full bg-[#FFF7EA] px-4 py-2 text-xs font-black uppercase tracking-wide text-[#7a1f2b] ring-1 ring-black/10">Tilam Sahaja</button>
            </div>

            <div class="mt-5 grid grid-cols-3 gap-2">
              <div class="rounded-2xl bg-white/10 px-2 py-3 text-center ring-1 ring-white/10"><p class="text-base font-black text-white">10 Thn</p><p class="text-[10px] font-bold uppercase tracking-wide text-[#d8c69a]">Warranty</p></div>
              <div class="rounded-2xl bg-white/10 px-2 py-3 text-center ring-1 ring-white/10"><p class="text-base font-black text-white">4 Bulan</p><p class="text-[10px] font-bold uppercase tracking-wide text-[#d8c69a]">Free Service</p></div>
              <div class="rounded-2xl bg-white/10 px-2 py-3 text-center ring-1 ring-white/10"><p class="text-base font-black text-white">Queen/King</p><p class="text-[10px] font-bold uppercase tracking-wide text-[#d8c69a]">Pilihan 2 Saiz</p></div>
            </div>
          </div>
        </div>

      </div><!-- end desktop hero -->
    </div>
  </section>


  <!-- ============================================================ -->
  <!-- TRUST STRIP -->
  <!-- ============================================================ -->
  <section class="px-4 py-8 text-white sm:px-6 lg:px-8" style="background: #7a1f2b;">
    <div class="mx-auto grid max-w-7xl grid-cols-2 gap-4 sm:grid-cols-4">
      <div class="rounded-2xl bg-white/10 p-4 ring-1 ring-white/15">
        <p class="text-base font-black">Graphene Fabric</p>
        <p class="mt-1 text-xs leading-snug text-[#f0e6d6]/80">Anti-static, antibacterial &amp; anti dust mite</p>
      </div>
      <div class="rounded-2xl bg-white/10 p-4 ring-1 ring-white/15">
        <p class="text-base font-black">Natural Latex</p>
        <p class="mt-1 text-xs leading-snug text-[#f0e6d6]/80">Breathable dan selesa untuk tidur harian</p>
      </div>
      <div class="rounded-2xl bg-white/10 p-4 ring-1 ring-white/15">
        <p class="text-base font-black">7-Zone Support</p>
        <p class="mt-1 text-xs leading-snug text-[#f0e6d6]/80">Sokongan ikut bahagian badan</p>
      </div>
      <div class="rounded-2xl bg-white/10 p-4 ring-1 ring-white/15">
        <p class="text-base font-black">Zero Motion</p>
        <p class="mt-1 text-xs leading-snug text-[#f0e6d6]/80">Kurang gangguan bila pasangan bergerak</p>
      </div>
    </div>
  </section>


  <!-- ============================================================ -->
  <!-- PAIN POINTS -->
  <!-- ============================================================ -->
  <section class="px-4 py-16 sm:px-6 lg:px-8 lg:py-24" style="background: #ededf0;">
    <div class="mx-auto max-w-7xl">
      <div class="mx-auto max-w-3xl text-center fade-up">
        <p class="text-xs font-black uppercase tracking-[0.22em] text-[#9a2a33]">Masalah Tidur Harian</p>
        <h2 class="mt-3 text-balance text-3xl font-black tracking-tight text-[#7a1322] sm:text-5xl">Tidur Lama, Tapi Bangun Masih Tak Rasa Cukup Rehat?</h2>
        <p class="mx-auto mt-4 max-w-xl text-base leading-7 text-[#5d6f80]">Tilam lama boleh nampak elok dari luar, tapi sokongan badan, haba dan kebersihan permukaan tidur mungkin sudah tidak sama.</p>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        <div class="fade-up rounded-[1.75rem] bg-white p-6 ring-1 ring-black/10 shadow-[0_12px_34px_rgba(75,13,24,.05)]">
          <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-2xl bg-[#efe9dd] text-base font-black text-[#9a2a33]">01</div>
          <h3 class="text-base font-black text-[#7a1322]">Tidur rasa panas</h3>
          <p class="mt-2 text-sm leading-6 text-[#5d6f80]">Tilam yang memerangkap haba boleh buat tidur kurang selesa sepanjang malam.</p>
        </div>
        <div class="fade-up rounded-[1.75rem] bg-white p-6 ring-1 ring-black/10 shadow-[0_12px_34px_rgba(75,13,24,.05)]">
          <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-2xl bg-[#efe9dd] text-base font-black text-[#9a2a33]">02</div>
          <h3 class="text-base font-black text-[#7a1322]">Badan rasa lenguh</h3>
          <p class="mt-2 text-sm leading-6 text-[#5d6f80]">Sokongan yang tidak sekata boleh ganggu rehat dan buat badan rasa lenguh.</p>
        </div>
        <div class="fade-up rounded-[1.75rem] bg-white p-6 ring-1 ring-black/10 shadow-[0_12px_34px_rgba(75,13,24,.05)]">
          <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-2xl bg-[#efe9dd] text-base font-black text-[#9a2a33]">03</div>
          <h3 class="text-base font-black text-[#7a1322]">Mudah terganggu</h3>
          <p class="mt-2 text-sm leading-6 text-[#5d6f80]">Pergerakan pasangan boleh terasa jika motion transfer terlalu kuat.</p>
        </div>
        <div class="fade-up rounded-[1.75rem] p-6 text-white shadow-[0_18px_44px_rgba(75,13,24,.25)]" style="background: linear-gradient(135deg, #7a1f2b, #4b0d18);">
          <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-2xl bg-white/15 text-base font-black text-white">★</div>
          <h3 class="text-base font-black">Nak bayaran lebih mudah</h3>
          <p class="mt-2 text-sm leading-6 text-[#f0e6d6]/85">A Luxe boleh dipilih secara rental bulanan dari RM108/bulan dengan servis berjadual.</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================ -->
  <!-- BEYOND SLEEP (komen 1) -->
  <!-- ============================================================ -->
  <section class="px-4 py-16 text-white sm:px-6 lg:px-8 lg:py-24"
