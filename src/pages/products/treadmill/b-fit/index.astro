---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import AgentSection from '../../../../components/AgentSection.astro';
import CustomerProofSection from '../../../../components/CustomerProofSection.astro';
import PromoBannerSection from '../../../../components/PromoBannerSection.astro';
import ProductCategorySection from '../../../../components/ProductCategorySection.astro';
import ProductGallerySlider from '../../../../components/ProductGallerySlider.astro';

const base = '/assets/images/products/treadmill';
const heroImage = `${base}/bfit-angle.png`;

const meta = {
  title: 'CUCKOO B-Fit Treadmill | Harga Rental & Promo RM12',
  description:
    'Semak CUCKOO B-Fit Treadmill untuk rumah: walking, running, foldable 20cm, 15 preset program, service berkala dan promo rental RM12/bulan.',
  canonical: 'https://www.cuckoonano.com/products/treadmill/b-fit/',
  ogImage: `https://www.cuckoonano.com${base}/treadmill-cuckoo-b-fit.webp`,
  ogType: 'website'
};

const problems = [
  {
    title: 'Tak sempat ke gym',
    copy: 'Boleh berjalan atau joging terus di rumah selepas kerja, sebelum tidur atau bila ada ruang masa pendek.'
  },
  {
    title: 'Cuaca tak menentu',
    copy: 'Tidak perlu tunggu cuaca baik. Rutin walking boleh dibuat dalam ruang rumah yang selesa.'
  },
  {
    title: 'Ruang rumah terhad',
    copy: 'Reka bentuk foldable menjadikan ia lebih sesuai untuk kondo, apartment dan rumah moden.'
  },
  {
    title: 'Nak konsisten bergerak',
    copy: 'Walking, joging dan larian ringan boleh disesuaikan mengikut tahap kecergasan seisi rumah.'
  }
];

// Hero product views — thumbnail switcher (different sides/angles)
const heroViews = [
  { label: 'Serong', image: `${base}/bfit-angle.png` },
  { label: 'Sisi', image: `${base}/bfit-side.png` },
  { label: 'Belakang', image: `${base}/bfit-back.png` },
  { label: 'Terlipat', image: `${base}/bfit-folded.png` },
  { label: 'Konsol', image: `${base}/bfit-console.png` }
];

// Features — uniform image cards (boleh tukar gambar kemudian)
const features = [
  {
    image: `${base}/bfit-walk-to-run.png`,
    title: '2-in-1 Walk-to-Run',
    copy: 'Tukar dari berjalan ke berlari dalam beberapa saat — satu mesin untuk walking santai, joging dan larian ringan.'
  },
  {
    image: `${base}/bfit-folded.png`,
    title: 'Foldable 20cm — Jimat Ruang',
    copy: 'Lipat dan simpan bawah katil atau tepi dinding. Sesuai untuk kondo, apartment dan rumah moden yang ruangnya terhad.'
  },
  {
    image: `${base}/bfit-side.png`,
    title: '8-Point Shock Absorption',
    copy: 'Kurang hentakan pada lutut dan otot — lebih selesa walaupun berjalan atau joging lama.'
  },
  {
    image: `${base}/bfit-angle.png`,
    title: '15 + 3 Program',
    copy: '15 preset program (Novice, Intermediate, Advanced) dan 3 custom profile (U1-U3) untuk pelbagai rutin.'
  },
  {
    image: `${base}/bfit-console.png`,
    title: 'LED Display',
    copy: 'Pantau speed, langkah, masa, jarak dan kalori sekali pandang. Kawalan ringkas untuk semua peringkat umur.'
  },
  {
    image: `${base}/bfit-back.png`,
    title: 'Manual Incline 2-Level',
    copy: 'Tambah cabaran dan aktifkan lebih banyak otot dengan dua aras kecondongan. Bluetooth speaker dan operasi senyap turut disertakan.'
  }
];

const rentalIncludes = [
  '3 tahun service & warranty berkala',
  'Service setiap 6 bulan',
  'Free 1-time belt change bulan ke-24',
  'Pemasangan diuruskan CUCKOO'
];

const outrightIncludes = [
  '1 tahun scheduled service & warranty',
  'Free 1-time belt change bulan ke-24',
  'Pemilikan penuh tanpa bayaran bulanan'
];

const serviceSteps = [
  {
    no: '01',
    title: 'Pemasangan di rumah',
    copy: 'Team service bantu setup dan terangkan fungsi asas penggunaan.'
  },
  {
    no: '02',
    title: 'Service berkala setiap 6 bulan',
    copy: 'Termasuk pemeriksaan asas, wet wiping, belt alignment dan penjagaan berkaitan.'
  },
  {
    no: '03',
    title: 'Free belt change bulan ke-24',
    copy: 'Salah satu nilai penting rental plan untuk pastikan belt kekal selesa digunakan.'
  }
];

const doItems = [
  'Gunakan kasut senaman yang bersih.',
  'Pastikan safety key dipasang semasa larian.',
  'Simpan di ruang indoor yang kering.',
  'Ikut jadual service berkala.'
];

const dontItems = [
  'Jangan melebihi had berat 100kg.',
  'Jangan sembur air terus ke console.',
  'Jangan biar kanak-kanak bermain tanpa pengawasan.',
  'Jangan paksa lipatan jika ada halangan.'
];

const specs = [
  ['Model', 'CUCKOO B-FIT Treadmill (CTM-YT102)'],
  ['Display', 'LED display: speed, step number, time, distance, calories'],
  ['Built-in program', '15 preset programs + 3 custom programs (U1-U3)'],
  ['Speed range', 'Walking 1-6 km/h, running 1-14 km/h'],
  ['Incline', 'Manual incline 2 level'],
  ['Motor', 'DC motor peak power 2.0 HP'],
  ['Running belt', '1050mm (L) x 420mm (W)'],
  ['Folded size', '1327mm (L) x 758mm (W) x 200mm (H)'],
  ['Unfolded size', '1255mm (L) x 758mm (W) x 1087mm (H)'],
  ['Weight supported', 'Sehingga 100kg']
];

const galleryItems = [
  {
    image: `${base}/gambar-treadmill-cuckoo-b-fit-image-photo-rm99-2-1024x768.webp`,
    title: 'B-Fit setup di rumah',
    alt: 'CUCKOO B-Fit Treadmill dipasang di rumah'
  },
  {
    image: `${base}/gambar-treadmill-cuckoo-b-fit-image-photo-rm99-1-768x1024.webp`,
    title: 'Rekaan compact B-Fit',
    alt: 'Rekaan compact CUCKOO B-Fit Treadmill'
  },
  {
    image: `${base}/gambar-treadmill-cuckoo-b-fit-image-photo-rm99-5.webp`,
    title: 'B-Fit dalam ruang moden',
    alt: 'CUCKOO B-Fit Treadmill dalam ruang rumah moden'
  },
  {
    image: `${base}/gambar-treadmill-cuckoo-b-fit-image-photo-rm99-6-768x1024.webp`,
    title: 'Walking & running setup',
    alt: 'CUCKOO B-Fit Treadmill untuk walking dan running'
  },
  {
    image: `${base}/gambar-treadmill-cuckoo-b-fit-image-photo-rm99-7-768x1024.webp`,
    title: 'Console dan handle',
    alt: 'Console dan handle CUCKOO B-Fit Treadmill'
  },
  {
    image: `${base}/gambar-treadmill-cuckoo-b-fit-image-photo-rm99-8-768x1024.webp`,
    title: 'Belt dan deck B-Fit',
    alt: 'Belt dan deck CUCKOO B-Fit Treadmill'
  },
  {
    image: `${base}/gambar-treadmill-cuckoo-b-fit-image-photo-rm99-9.webp`,
    title: 'B-Fit foldable storage',
    alt: 'CUCKOO B-Fit Treadmill foldable untuk simpanan'
  },
  {
    image: `${base}/gambar-treadmill-cuckoo-b-fit-image-photo-rm99-12-1024x710.webp`,
    title: 'B-Fit dari sudut lain',
    alt: 'CUCKOO B-Fit Treadmill dari sudut berbeza'
  }
];

const faqItems = [
  {
    q: 'Promo RM12 ini untuk berapa lama?',
    a: 'Promo RM12/bulan adalah untuk 6 bulan pertama. Selepas itu, rental kembali kepada RM102/bulan mengikut pelan standard, tertakluk kepada kempen semasa.'
  },
  {
    q: 'Apa beza rental dan outright?',
    a: 'Rental sesuai untuk bayaran bulanan dan termasuk 3 tahun service & warranty berkala. Outright pula beli terus RM3,399 dengan 1 tahun scheduled service & warranty.'
  },
  {
    q: 'Boleh guna untuk walking sahaja?',
    a: 'Boleh. Kelajuan walking 1-6 km/h sesuai untuk rutin berjalan santai, dan boleh ditingkatkan ke running 1-14 km/h bila dah selesa.'
  },
  {
    q: 'Adakah sesuai untuk apartment atau condo?',
    a: 'Ya. Design foldable dan compact (folded 20cm) menjadikan ia lebih sesuai untuk rumah dengan ruang terhad. Pastikan ruang penggunaan selamat dan lantai stabil.'
  },
  {
    q: 'Service termasuk apa?',
    a: 'Untuk rental, service berkala dibuat setiap 6 bulan termasuk pemeriksaan asas, wet wiping dan belt alignment, serta free 1-time belt change pada bulan ke-24.'
  },
  {
    q: 'Berapa had berat pengguna?',
    a: 'Had berat yang disyorkan ialah 100kg only. Ini penting untuk keselamatan serta jangka hayat motor dan belt.'
  }
];

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'CUCKOO B-Fit Treadmill',
  brand: { '@type': 'Brand', name: 'CUCKOO' },
  description:
    'Treadmill 2-in-1 untuk walking dan running di rumah. Foldable 20cm, kelajuan 1-14 km/h, 15 preset program, 8-point shock absorption, LED display dan Bluetooth speaker.',
  sku: 'CTM-YT102',
  image: `https://www.cuckoonano.com${base}/treadmill-cuckoo-b-fit.webp`,
  offers: [
    {
      '@type': 'Offer',
      priceCurrency: 'MYR',
      price: '12',
      description: 'Promo rental RM12/bulan untuk 6 bulan pertama. Selepas itu RM102/bulan, tertakluk kepada kempen semasa.'
    },
    {
      '@type': 'Offer',
      priceCurrency: 'MYR',
      price: '3399',
      description: 'Harga outright RM3,399, bayaran sekali sahaja tertakluk kepada promosi semasa.'
    }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a }
  }))
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Produk', item: 'https://www.cuckoonano.com/products/' },
    { '@type': 'ListItem', position: 2, name: 'Treadmill', item: 'https://www.cuckoonano.com/products/treadmill/' },
    { '@type': 'ListItem', position: 3, name: 'CUCKOO B-Fit Treadmill', item: 'https://www.cuckoonano.com/products/treadmill/b-fit/' }
  ]
};
---

<BaseLayout {...meta}>
  <div class="bg-brand-cream text-brand-ink antialiased">
    <!-- HERO -->
    <section id="hero" class="hero-pattern relative overflow-hidden px-4 py-10 sm:px-6 lg:px-8 lg:py-16">
      <div class="mx-auto grid max-w-7xl gap-7 lg:grid-cols-[1.02fr_.98fr] lg:items-center lg:gap-10">
        <div class="min-w-0">
          <nav aria-label="Breadcrumb" class="mb-5 flex flex-wrap items-center gap-1 text-xs font-bold text-brand-muted">
            <a href="/products/" class="hover:text-brand">Produk</a>
            <span>/</span>
            <a href="/products/treadmill/" class="hover:text-brand">Treadmill</a>
            <span>/</span>
            <span class="text-brand">B-Fit</span>
          </nav>

          <div class="mb-5 flex gap-2 overflow-x-auto pb-1 [-ms-overflow-style:none] [scrollbar-width:none] lg:flex-wrap lg:overflow-visible [&::-webkit-scrollbar]:hidden">
            <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Ejen CUCKOO sejak 2017</span>
            <span class="shrink-0 whitespace-nowrap rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-bold text-brand shadow-soft">Service Setiap 6 Bulan</span>
          </div>

          <div class="mb-5 inline-flex max-w-full flex-wrap items-center gap-2 rounded-full bg-[linear-gradient(135deg,#4B0715_0%,#7A0E23_58%,#8E1830_100%)] px-4 py-3 text-white shadow-glow ring-1 ring-brand-gold/30 sm:gap-3 sm:px-5">
            <span class="rounded-full bg-white/15 px-3 py-1 text-[11px] font-black uppercase tracking-[.14em] text-brand-gold">Promo</span>
            <span class="text-sm font-black sm:text-base">RM12/bulan untuk 6 bulan pertama</span>
          </div>

          <h1 class="max-w-3xl text-[2.35rem] font-black leading-[1.06] tracking-tight text-brand-ink sm:text-5xl lg:text-6xl">
            CUCKOO B-Fit Treadmill - Jalan, Joging Dan Lari Dari Rumah
          </h1>

          <p class="mt-5 max-w-2xl text-base leading-8 text-brand-muted sm:text-lg">
            Treadmill 2-in-1 yang compact, foldable dan sesuai untuk rumah moden. Mulakan rutin sihat tanpa perlu keluar ke gym atau bergantung pada cuaca.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a
              href="#"
              onclick="this.href=rotatingWhatsapp()"
              class="inline-flex items-center justify-center gap-2 rounded-full bg-[#25D366] px-7 py-4 text-sm font-black text-white shadow-[0_18px_40px_rgba(37,211,102,.28)] transition hover:-translate-y-0.5 hover:bg-[#1EBE5D]"
            >
              <img src="/assets/images/misc/whatsapp-png.webp" alt="" aria-hidden="true" class="h-5 w-5" />
              WhatsApp Semak Promo
            </a>
            <a
              href="#harga"
              class="inline-flex items-center justify-center rounded-full border border-brand/15 bg-white px-7 py-4 text-sm font-black text-brand shadow-soft hover:border-brand/30"
            >
              Lihat Harga
            </a>
          </div>

          <p class="mt-6 text-sm font-bold text-brand-muted">
            Kemudian RM102/bulan · Outright RM3,399 · tertakluk promo semasa
          </p>
        </div>

        <div class="rounded-[2rem] border border-white/80 bg-white/70 p-4 shadow-premium backdrop-blur-xl sm:p-6">
          <div class="relative overflow-hidden rounded-[1.7rem] bg-gradient-to-br from-white to-brand-soft p-4 sm:p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs font-black uppercase tracking-[.18em] text-brand-gold">CUCKOO Treadmill</p>
                <p class="mt-1 text-lg font-black text-brand">B-Fit (CTM-YT102)</p>
              </div>
              <span class="rounded-full bg-brand px-4 py-2 text-xs font-black text-white">Foldable</span>
            </div>

            <div class="relative mt-5 flex min-h-[300px] items-center justify-center overflow-hidden rounded-[1.5rem] bg-white/70 p-5 sm:min-h-[390px] lg:min-h-[440px]">
              <img
                id="heroProductImage"
                src={heroImage}
                alt="CUCKOO B-Fit Treadmill"
                loading="eager"
                class="relative z-10 h-[290px] w-auto object-contain drop-shadow-2xl transition duration-300 sm:h-[360px] lg:h-[420px]"
              />
            </div>

            <div class="mt-4 flex flex-wrap justify-center gap-2">
              {heroViews.map((view, index) => (
                <button
                  type="button"
                  data-hero-view={view.image}
                  class:list={[
                    'hero-view-thumb rounded-full px-4 py-2 text-xs font-black uppercase tracking-wide shadow-soft transition',
                    index === 0 ? 'bg-brand text-white ring-2 ring-brand' : 'bg-white text-brand ring-1 ring-brand/15 hover:bg-brand-cream'
                  ]}
                >
                  {view.label}
                </button>
              ))}
            </div>

            <div class="mt-5 grid grid-cols-3 gap-2">
              <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10">
                <p class="text-base font-black text-brand">1-14</p>
                <p class="text-[11px] font-bold text-brand-muted">km/h</p>
              </div>
              <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10">
                <p class="text-base font-black text-brand">20cm</p>
                <p class="text-[11px] font-bold text-brand-muted">folded</p>
              </div>
              <div class="rounded-2xl bg-white/85 px-3 py-3 text-center shadow-soft ring-1 ring-brand/10">
                <p class="text-base font-black text-brand">100kg</p>
                <p class="text-[11px] font-bold text-brand-muted">max</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PROBLEM -->
    <section id="kenapa" class="px-4 py-14 sm:px-6 lg:px-8">
      <div class="mx-auto grid max-w-7xl gap-8 rounded-[2rem] bg-white p-6 shadow-premium lg:grid-cols-[.9fr_1.1fr] lg:p-10">
        <div>
          <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">Kenapa B-Fit</p>
          <h2 class="mt-3 text-3xl font-black sm:text-4xl">Bila susah keluar bersenam, rumah jadi tempat paling mudah untuk mula.</h2>
          <p class="mt-4 leading-8 text-brand-muted">
            Ramai orang bukan tidak mahu sihat. Cuma masa, cuaca, kerja dan jarak ke gym buat rutin susah konsisten. B-Fit membantu anda bergerak walaupun hanya 15 hingga 30 minit sehari.
          </p>
          <a href="/blog/kelebihan-treadmill-cuckoo-b-fit/" class="mt-5 inline-flex items-center gap-1 text-sm font-black text-brand hover:underline">
            Baca: kelebihan treadmill CUCKOO B-Fit →
          </a>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          {problems.map((item, index) => (
            <article class="rounded-2xl bg-brand-cream p-5">
              <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-white text-sm font-black text-brand shadow-soft">0{index + 1}</span>
              <h3 class="mt-4 font-black text-brand-ink">{item.title}</h3>
              <p class="mt-2 text-sm leading-7 text-brand-muted">{item.copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section id="features" class="px-4 py-14 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">Features Utama</p>
          <h2 class="mt-3 text-3xl font-black sm:text-4xl lg:text-5xl">Ciri Utama CUCKOO B-Fit Treadmill</h2>
          <p class="mt-5 leading-8 text-brand-muted">
            Direka untuk rutin harian di rumah — mula dengan berjalan, naik ke berlari, dan simpan dengan mudah selepas guna.
          </p>
        </div>

        <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {features.map((item) => (
            <article class="overflow-hidden rounded-3xl bg-white shadow-soft ring-1 ring-brand/5">
              <img src={item.image} alt={item.title} loading="lazy" class="h-56 w-full bg-brand-cream object-contain p-4 lg:h-60" />
              <div class="p-6">
                <h3 class="font-black text-brand-ink">{item.title}</h3>
                <p class="mt-2 text-sm leading-7 text-brand-muted">{item.copy}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <CustomerProofSection />

    <!-- PRICING -->
    <section id="harga" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">Harga & Promo</p>
          <h2 class="mt-3 text-3xl font-black sm:text-4xl lg:text-5xl">Pilih Plan B-Fit Yang Sesuai</h2>
          <p class="mt-5 leading-8 text-brand-muted">
            Highlight utama ialah promo RM12 untuk 6 bulan pertama. Selepas tempoh promo, rental kembali kepada harga standard RM102/bulan.
          </p>
        </div>

        <div class="mt-10 grid gap-5 lg:grid-cols-2">
          <article class="relative rounded-[2rem] border-2 border-brand bg-white p-7 shadow-glow">
            <div class="absolute -top-4 left-7 rounded-full bg-brand px-5 py-2 text-xs font-black uppercase tracking-[.14em] text-white shadow-soft">
              Pelan Paling Popular
            </div>

            <p class="mt-3 text-sm font-black uppercase tracking-[.16em] text-brand-gold">Rental Plan</p>
            <h3 class="mt-4 text-3xl font-black text-brand-ink">RM12 Untuk 6 Bulan Pertama</h3>
            <p class="mt-3 text-sm leading-7 text-brand-muted">
              Sesuai untuk mula dengan bayaran permulaan rendah dan disertakan service berkala CUCKOO+.
            </p>

            <div class="mt-7 rounded-[1.5rem] bg-brand-cream p-5">
              <p class="text-5xl font-black text-brand">
                RM12<span class="text-base font-black text-brand-muted">/bulan</span>
              </p>
              <p class="mt-1 text-sm font-bold text-brand-muted">Bulan 1-6 — lebih kurang RM0.40 sehari</p>
              <div class="my-4 h-px bg-brand/10"></div>
              <p class="text-4xl font-black text-brand">
                RM102<span class="text-base font-black text-brand-muted">/bulan</span>
              </p>
              <p class="mt-1 text-sm font-bold text-brand-muted">Selepas promo</p>
            </div>

            <ul class="mt-6 space-y-3 text-sm font-bold text-brand-ink">
              {rentalIncludes.map((line) => (
                <li>✓ {line}</li>
              ))}
            </ul>

            <a
              href="#"
              onclick="this.href=rotatingWhatsapp()"
              class="mt-7 inline-flex w-full items-center justify-center gap-2 rounded-full bg-[#25D366] px-6 py-4 text-sm font-black text-white shadow-[0_18px_40px_rgba(37,211,102,.24)] transition hover:-translate-y-0.5 hover:bg-[#1EBE5D]"
            >
              <img src="/assets/images/misc/whatsapp-png.webp" alt="" aria-hidden="true" class="h-5 w-5" />
              Semak Kelayakan Rental
            </a>
          </article>

          <article class="rounded-[2rem] border border-brand/10 bg-white p-7 shadow-soft">
            <p class="text-sm font-black uppercase tracking-[.16em] text-brand-gold">Beli Terus</p>
            <h3 class="mt-4 text-3xl font-black text-brand-ink">Outright Purchase</h3>
            <p class="mt-3 text-sm leading-7 text-brand-muted">
              Untuk pelanggan yang mahu pemilikan terus tanpa bayaran bulanan.
            </p>

            <div class="mt-7 rounded-[1.5rem] bg-brand-cream p-5">
              <p class="text-sm font-black uppercase tracking-[.16em] text-brand-gold">Harga Outright</p>
              <p class="mt-2 text-5xl font-black text-brand">RM3,399</p>
              <p class="mt-2 text-sm font-bold text-brand-muted">Bayaran sekali sahaja</p>
            </div>

            <ul class="mt-6 space-y-3 text-sm font-bold text-brand-ink">
              {outrightIncludes.map((line) => (
                <li>✓ {line}</li>
              ))}
            </ul>

            <a
              href="#"
              onclick="this.href=rotatingWhatsapp()"
              class="mt-7 inline-flex w-full items-center justify-center gap-2 rounded-full bg-[#25D366] px-6 py-4 text-sm font-black text-white shadow-[0_18px_40px_rgba(37,211,102,.24)] transition hover:-translate-y-0.5 hover:bg-[#1EBE5D]"
            >
              <img src="/assets/images/misc/whatsapp-png.webp" alt="" aria-hidden="true" class="h-5 w-5" />
              Tanya Outright
            </a>
          </article>
        </div>

        <div class="mt-8 rounded-[2rem] bg-white p-5 text-center text-sm font-bold leading-7 text-brand-muted shadow-soft">
          Harga dan promosi tertakluk kepada kempen semasa. WhatsApp untuk semak bayaran permulaan, kelayakan, stok dan promo terkini.
        </div>
      </div>
    </section>

    <!-- SERVICE -->
    <section id="service" class="px-4 py-14 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl rounded-[2rem] bg-white p-6 shadow-premium lg:p-10">
        <div class="grid gap-8 lg:grid-cols-[.9fr_1.1fr] lg:items-center">
          <div>
            <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">CUCKOO+ Care</p>
            <h2 class="mt-3 text-3xl font-black sm:text-4xl">Pemasangan dan penjagaan berkala diuruskan.</h2>
            <p class="mt-4 leading-8 text-brand-muted">
              Untuk rental plan, pelanggan mendapat service berkala selama 3 tahun. Ini membantu treadmill kekal bersih, selamat dan lebih mudah dijaga.
            </p>
          </div>
          <div class="grid gap-4">
            {serviceSteps.map((step) => (
              <article class="rounded-3xl border border-brand/10 bg-brand-cream p-6">
                <p class="text-xs font-black uppercase tracking-[.18em] text-brand-gold">{step.no}</p>
                <h3 class="mt-2 font-black text-brand-ink">{step.title}</h3>
                <p class="mt-2 text-sm leading-7 text-brand-muted">{step.copy}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- GALLERY -->
    <ProductGallerySlider
      id="gallery"
      eyebrow="Gallery Produk"
      title="Lihat CUCKOO B-Fit Treadmill Dengan Lebih Dekat"
      description="Swipe untuk lihat rupa produk, console, reka bentuk foldable dan kegunaan B-Fit di rumah. Klik gambar untuk paparan penuh."
      items={galleryItems}
    />

    <!-- SPEC -->
    <section id="spec" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-5xl">
        <div class="mb-12 text-center">
          <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">Spesifikasi</p>
          <h2 class="mt-3 text-3xl font-black text-brand-ink sm:text-4xl lg:text-5xl">Spesifikasi CUCKOO B-Fit</h2>
          <p class="mx-auto mt-4 max-w-3xl text-base leading-8 text-brand-muted">
            Detail teknikal penting untuk bantu anda faham kelajuan, saiz dan syarat asas penggunaan.
          </p>
        </div>

        <div class="mb-8 overflow-hidden rounded-[2rem] bg-white p-4 shadow-premium sm:p-6">
          <img
            src={`${base}/bfit-dimension-desktop.webp`}
            alt="Dimensi dan saiz CUCKOO B-Fit Treadmill"
            loading="lazy"
            class="hidden h-auto w-full object-contain sm:block"
          />
          <img
            src={`${base}/b-fit-dimension-mobile.webp`}
            alt="Dimensi dan saiz CUCKOO B-Fit Treadmill"
            loading="lazy"
            class="block h-auto w-full object-contain sm:hidden"
          />
        </div>

        <div class="overflow-hidden rounded-[2rem] bg-white shadow-premium">
          {specs.map(([label, value]) => (
            <div class="grid grid-cols-1 border-b border-brand/10 last:border-b-0 sm:grid-cols-[.42fr_.58fr]">
              <div class="px-5 py-4 font-black text-brand-ink sm:py-5">{label}</div>
              <div class="px-5 pb-4 text-brand-muted sm:py-5">{value}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CARE: DO / DON'T -->
    <section class="px-4 py-14 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">Penjagaan Treadmill</p>
          <h2 class="mt-3 text-3xl font-black sm:text-4xl">Mudah dijaga bila rutin penggunaan betul.</h2>
        </div>
        <div class="mt-8 grid gap-5 md:grid-cols-2">
          <div class="rounded-[2rem] border border-cta-green/20 bg-white p-7 shadow-soft">
            <h3 class="text-2xl font-black text-cta-green">Patut Buat</h3>
            <ul class="mt-5 space-y-3 text-sm font-bold leading-7 text-brand-ink">
              {doItems.map((line) => (
                <li>✓ {line}</li>
              ))}
            </ul>
          </div>
          <div class="rounded-[2rem] border border-brand/20 bg-white p-7 shadow-soft">
            <h3 class="text-2xl font-black text-brand">Elakkan</h3>
            <ul class="mt-5 space-y-3 text-sm font-bold leading-7 text-brand-ink">
              {dontItems.map((line) => (
                <li>✕ {line}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <PromoBannerSection />

    <!-- FAQ -->
    <section id="faq" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <div class="text-center">
          <p class="text-sm font-black uppercase tracking-[.22em] text-brand-gold">FAQ</p>
          <h2 class="mt-3 text-3xl font-black text-brand-ink sm:text-4xl">Soalan Lazim CUCKOO B-Fit Treadmill</h2>
          <p class="mx-auto mt-4 max-w-2xl text-base leading-8 text-brand-muted">
            Jawapan ringkas sebelum anda pilih plan atau WhatsApp ejen.
          </p>
        </div>

        <div class="mt-8 space-y-3">
          {faqItems.map((item) => (
            <details class="group rounded-[1.35rem] bg-white shadow-soft ring-1 ring-brand/10">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-left font-black text-brand-ink">
                <span>{item.q}</span>
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-cream text-brand transition group-open:rotate-45">+</span>
              </summary>
              <div class="border-t border-brand/10 px-5 pb-5 pt-4 text-sm leading-7 text-brand-muted">
                {item.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <AgentSection />
  </div>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <script is:inline>
    (() => {
      const img = document.getElementById('heroProductImage');
      const thumbs = document.querySelectorAll('.hero-view-thumb');
      if (!img || !thumbs.length) return;
      const activeCls = ['bg-brand', 'text-white', 'ring-2', 'ring-brand'];
      const idleCls = ['bg-white', 'text-brand', 'ring-1', 'ring-brand/15'];
      thumbs.forEach((btn) => {
        btn.addEventListener('click', () => {
          const src = btn.getAttribute('data-hero-view');
          if (src) img.src = src;
          thumbs.forEach((b) => {
            b.classList.remove(...activeCls);
            b.classList.add(...idleCls);
          });
          btn.classList.remove(...idleCls);
          btn.classList.add(...activeCls);
        });
      });
    })();
  </script>
</BaseLayout>
