---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import AgentSection from '../../../../components/AgentSection.astro';
import CustomerProofSection from '../../../../components/CustomerProofSection.astro';
import PromoBannerSection from '../../../../components/PromoBannerSection.astro';
import ProductGallerySlider from '../../../../components/ProductGallerySlider.astro';

const base = '/assets/images/products/treadmill';
const heroImage = `${base}/bfit-angle.webp`;

const meta = {
  title: 'CUCKOO B-Fit Treadmill | Harga Rental & Promo RM12',
  description:
    'Semak CUCKOO B-Fit Treadmill untuk rumah: walking, running, foldable 20cm, 15 preset program, service berkala dan promo rental RM12/bulan.',
  canonical: 'https://www.cuckoonano.com/products/treadmill/b-fit/',
  ogImage: `https://www.cuckoonano.com${base}/treadmill-cuckoo-b-fit.webp`,
  ogType: 'website'
};

// Hero product views — thumbnail switcher (different sides/angles)
const heroViews = [
  { label: 'Serong', image: `${base}/bfit-angle.webp` },
  { label: 'Sisi', image: `${base}/bfit-side.webp` },
  { label: 'Belakang', image: `${base}/bfit-back.webp` },
  { label: 'Terlipat', image: `${base}/bfit-folded.webp` },
  { label: 'Konsol', image: `${base}/bfit-console.webp` }
];

// Sedentary hook stats (versi soft — tiada angka rasmi yang tak boleh disokong)
const sedentaryStats = [
  { value: '8+ jam', label: 'Masa duduk setiap hari untuk ramai orang dewasa' },
  { value: '15 min', label: 'Sudah cukup untuk mula gerakkan badan di rumah' }
];

// Barriers — "what stops you from exercising?"
const problems = [
  { no: '01', title: 'Tak sempat ke gym', copy: 'Boleh berjalan atau joging terus di rumah selepas kerja, sebelum tidur atau bila ada ruang masa pendek.' },
  { no: '02', title: 'Cuaca tak menentu', copy: 'Tidak perlu tunggu cuaca baik. Rutin walking boleh dibuat dalam ruang rumah yang selesa.' },
  { no: '03', title: 'Ruang rumah terhad', copy: 'Reka bentuk foldable menjadikan ia lebih sesuai untuk kondo, apartment dan rumah moden.' },
  { no: '04', title: 'Nak konsisten bergerak', copy: 'Walking, joging dan larian ringan boleh disesuaikan mengikut tahap kecergasan seisi rumah.' }
];

// Features utama — media cards (gaya A-Lite)
const features = [
  {
    image: `${base}/bfit-walk-to-run.png`,
    title: 'Walk-to-Run Dynamic Track',
    copy: 'Tukar dari berjalan ke berlari dalam beberapa saat — satu mesin untuk walking santai, joging dan larian ringan.'
  },
  {
    image: `${base}/bfit-folded.png`,
    title: '2-in-1 Foldable Design',
    copy: 'Lipat dan simpan bawah katil atau tepi dinding. Folded setinggi 20cm sahaja — sesuai untuk kondo dan apartment.'
  },
  {
    image: `${base}/bfit-side.png`,
    title: '8-Point Shock Absorption',
    copy: 'Kurang hentakan pada lutut dan otot — lebih selesa walaupun berjalan atau joging lama.'
  },
  {
    image: `${base}/bfit-angle.png`,
    title: '15 Personalised Programs',
    copy: '15 preset program (Novice, Intermediate, Advanced) untuk pelbagai rutin dan tahap kecergasan.'
  },
  {
    image: `${base}/bfit-console.png`,
    title: '3 Custom User Profiles',
    copy: 'Simpan rutin tersendiri dalam 3 profil custom (U1–U3) — sesuai untuk dikongsi seisi rumah.'
  },
  {
    image: `${base}/bfit-back.png`,
    title: 'LED Display + Manual Incline',
    copy: 'Pantau speed, langkah, masa, jarak dan kalori sekali pandang. Manual incline 2 aras untuk cabaran tambahan.'
  }
];

// Additional features (HQ: ciri tambahan)
const additionalFeatures = [
  { icon: '📱', title: 'Device Holder', copy: 'Letak telefon atau tablet untuk hiburan semasa bersenam.' },
  { icon: '🔑', title: 'Safety Pin', copy: 'Safety key untuk hentikan belt serta-merta jika perlu.' },
  { icon: '📟', title: 'Display Panel', copy: 'Paparan LED jelas untuk semua peringkat umur.' },
  { icon: '🏗️', title: 'Robust Support', copy: 'Rangka kukuh menampung penggunaan harian sehingga 100kg.' },
  { icon: '🔊', title: 'Bluetooth Speaker', copy: 'Sambung muzik anda dan bergerak ikut rentak kegemaran.' },
  { icon: '🤫', title: 'Operasi Senyap', copy: 'Motor DC lebih senyap — selesa digunakan dalam ruang rumah.' }
];

const rentalIncludes = [
  '3 tahun service & warranty berkala',
  'Service setiap 6 bulan',
  'Free 1-time belt change bulan ke-24',
  'Pemasangan diuruskan CUCKOO'
];

const outrightIncludes = [
  '1 tahun scheduled service & warranty',
  'Free 1-time belt change bulan ke-24',
  'Pemilikan penuh tanpa bayaran bulanan'
];

const includedStrip = [
  'FREE Delivery',
  'FREE Installation',
  'Service Berkala CUCKOO+',
  'Free Belt Change Bulan 24',
  'Worry-Free Setup'
];

// Worry-free installation (HQ: Made With You In Mind)
const installPoints = [
  { no: '01', title: 'Juruteknik terlatih', copy: 'Pemasangan dibuat oleh team service CUCKOO yang terlatih, bukan hantar kosong.' },
  { no: '02', title: 'SOP pemasangan mantap', copy: 'Setiap pemasangan ikut prosedur standard CUCKOO untuk keselamatan dan kestabilan.' },
  { no: '03', title: 'Penerangan penggunaan', copy: 'Team terangkan fungsi asas dan cara guna sebelum pergi — anda terus boleh mula.' }
];

// 8-Point Service Check (HQ) — senarai representatif, tertakluk terma semasa
const serviceCheck = [
  'Pemeriksaan console & display',
  'Penjajaran (alignment) belt',
  'Penjagaan & pelinciran belt',
  'Wet wiping & pembersihan deck',
  'Pemeriksaan skru & kekemasan rangka',
  'Pemeriksaan motor & kuasa',
  'Ujian fungsi safety key',
  'Pemeriksaan mekanisme lipatan'
];

const doItems = [
  'Gunakan kasut senaman yang bersih.',
  'Pastikan safety key dipasang semasa larian.',
  'Simpan di ruang indoor yang kering.',
  'Ikut jadual service berkala.'
];

const dontItems = [
  'Jangan melebihi had berat 100kg.',
  'Jangan sembur air terus ke console.',
  'Jangan biar kanak-kanak bermain tanpa pengawasan.',
  'Jangan paksa lipatan jika ada halangan.'
];

const specs = [
  ['Model', 'CUCKOO B-FIT Treadmill (CTM-YT102)'],
  ['Display', 'LED display: speed, step number, time, distance, calories'],
  ['Built-in program', '15 preset programs + 3 custom programs (U1-U3)'],
  ['Speed range', 'Walking 1-6 km/h, running 1-14 km/h'],
  ['Incline', 'Manual incline 2 level'],
  ['Motor', 'DC motor peak power 2.0 HP'],
  ['Running belt', '1050mm (L) x 420mm (W)'],
  ['Folded size', '1327mm (L) x 758mm (W) x 200mm (H)'],
  ['Unfolded size', '1255mm (L) x 758mm (W) x 1087mm (H)'],
  ['Weight supported', 'Sehingga 100kg']
];

const galleryItems = [
  { image: `${base}/gambar-treadmill-cuckoo-b-fit-image-photo-rm99-2-1024x768.webp`, title: 'B-Fit setup di rumah', alt: 'CUCKOO B-Fit Treadmill dipasang di rumah' },
  { image: `${base}/gambar-treadmill-cuckoo-b-fit-image-photo-rm99-1-768x1024.webp`, title: 'Rekaan compact B-Fit', alt: 'Rekaan compact CUCKOO B-Fit Treadmill' },
  { image: `${base}/gambar-treadmill-cuckoo-b-fit-image-photo-rm99-5.webp`, title: 'B-Fit dalam ruang moden', alt: 'CUCKOO B-Fit Treadmill dalam ruang rumah moden' },
  { image: `${base}/gambar-treadmill-cuckoo-b-fit-image-photo-rm99-6-768x1024.webp`, title: 'Walking & running setup', alt: 'CUCKOO B-Fit Treadmill untuk walking dan running' },
  { image: `${base}/gambar-treadmill-cuckoo-b-fit-image-photo-rm99-7-768x1024.webp`, title: 'Console dan handle', alt: 'Console dan handle CUCKOO B-Fit Treadmill' },
  { image: `${base}/gambar-treadmill-cuckoo-b-fit-image-photo-rm99-8-768x1024.webp`, title: 'Belt dan deck B-Fit', alt: 'Belt dan deck CUCKOO B-Fit Treadmill' },
  { image: `${base}/gambar-treadmill-cuckoo-b-fit-image-photo-rm99-9.webp`, title: 'B-Fit foldable storage', alt: 'CUCKOO B-Fit Treadmill foldable untuk simpanan' },
  { image: `${base}/gambar-treadmill-cuckoo-b-fit-image-photo-rm99-12-1024x710.webp`, title: 'B-Fit dari sudut lain', alt: 'CUCKOO B-Fit Treadmill dari sudut berbeza' }
];

const faqItems = [
  { q: 'Promo RM12 ini untuk berapa lama?', a: 'Promo RM12/bulan adalah untuk 6 bulan pertama. Selepas itu, rental kembali kepada RM102/bulan mengikut pelan standard, tertakluk kepada kempen semasa.' },
  { q: 'Apa beza rental dan outright?', a: 'Rental sesuai untuk bayaran bulanan dan termasuk 3 tahun service & warranty berkala. Outright pula beli terus RM3,399 dengan 1 tahun scheduled service & warranty.' },
  { q: 'Boleh guna untuk walking sahaja?', a: 'Boleh. Kelajuan walking 1-6 km/h sesuai untuk rutin berjalan santai, dan boleh ditingkatkan ke running 1-14 km/h bila dah selesa.' },
  { q: 'Adakah sesuai untuk apartment atau condo?', a: 'Ya. Design foldable dan compact (folded 20cm) menjadikan ia lebih sesuai untuk rumah dengan ruang terhad. Pastikan ruang penggunaan selamat dan lantai stabil.' },
  { q: 'Service termasuk apa?', a: 'Untuk rental, service berkala dibuat setiap 6 bulan termasuk pemeriksaan asas, wet wiping dan belt alignment, serta free 1-time belt change pada bulan ke-24.' },
  { q: 'Berapa had berat pengguna?', a: 'Had berat yang disyorkan ialah 100kg only. Ini penting untuk keselamatan serta jangka hayat motor dan belt.' }
];

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'CUCKOO B-Fit Treadmill',
  brand: { '@type': 'Brand', name: 'CUCKOO' },
  description:
    'Treadmill 2-in-1 untuk walking dan running di rumah. Foldable 20cm, kelajuan 1-14 km/h, 15 preset program, 8-point shock absorption, LED display dan Bluetooth speaker.',
  sku: 'CTM-YT102',
  image: `https://www.cuckoonano.com${base}/treadmill-cuckoo-b-fit.webp`,
  offers: [
    {
      '@type': 'Offer',
      priceCurrency: 'MYR',
      price: '12',
      description: 'Promo rental RM12/bulan untuk 6 bulan pertama. Selepas itu RM102/bulan, tertakluk kepada kempen semasa.'
    },
    {
      '@type': 'Offer',
      priceCurrency: 'MYR',
      price: '3399',
      description: 'Harga outright RM3,399, bayaran sekali sahaja tertakluk kepada promosi semasa.'
    }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a }
  }))
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Produk', item: 'https://www.cuckoonano.com/products/' },
    { '@type': 'ListItem', position: 2, name: 'Treadmill', item: 'https://www.cuckoonano.com/products/treadmill/' },
    { '@type': 'ListItem', position: 3, name: 'CUCKOO B-Fit Treadmill', item: 'https://www.cuckoonano.com/products/treadmill/b-fit/' }
  ]
};
---

<BaseLayout {...meta}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- ============================================================ -->
  <!-- HERO -->
  <!-- ============================================================ -->
  <section id="hero" class="relative overflow-hidden bg-brand-dark px-4 py-12 text-white sm:px-6 lg:px-8 lg:py-16">
    <!-- background layers -->
    <div class="absolute inset-0"
         style="background: radial-gradient(circle at 16% 10%, rgba(255,255,255,.14), transparent 26%), radial-gradient(circle at 84% 22%, rgba(216,166,74,.16), transparent 32%), linear-gradient(135deg, #8E1830 0%, #7A0E23 46%, #4B0715 100%);"></div>
    <div class="hero-grid absolute inset-0 opacity-40"></div>
    <div class="absolute -right-24 top-0 h-80 w-80 rounded-full bg-[#b5162b]/30 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 h-64 w-64 rounded-full bg-[#4B0715]/70 blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl">
      <div class="flex flex-col gap-8 lg:grid lg:grid-cols-[1.05fr_0.95fr] lg:items-start lg:gap-14">

        <!-- Head top: badges + eyebrow + headline -->
        <div class="order-1 min-w-0 text-center lg:order-none lg:col-start-1 lg:row-start-1 lg:text-left">
          <div class="mb-5 flex flex-wrap justify-center gap-2 lg:justify-start">
            <span class="rounded-full bg-white/15 px-4 py-2 text-[11px] font-black uppercase tracking-[0.18em] text-white ring-1 ring-white/20 sm:text-xs">🔥 Promo RM12</span>
            <span class="rounded-full bg-white/10 px-4 py-2 text-[11px] font-black uppercase tracking-[0.18em] text-white ring-1 ring-white/15 sm:text-xs">Your 24/7 Fitness Partner</span>
          </div>

          <p class="text-xs font-black uppercase tracking-[0.24em] text-rose-200 sm:text-sm">CUCKOO B-Fit Treadmill</p>

          <h1 class="mx-auto mt-3 max-w-2xl text-balance text-[clamp(1.5rem,7vw,2.1rem)] font-black leading-[1.08] tracking-tight text-white sm:text-5xl sm:leading-[1.03] lg:mx-0 lg:text-6xl">
            Jalan. Joging. Lari.<br />Terus Dari Rumah.<br />
            <span class="gold-text">Dari RM12/Bulan.</span>
          </h1>
        </div>

        <!-- Text bottom: penerangan + pricing + trust + CTA -->
        <div class="order-3 min-w-0 text-center lg:order-none lg:col-start-1 lg:row-start-2 lg:text-left">
          <p class="mx-auto mt-1 max-w-xl text-base leading-8 text-rose-100 sm:text-lg lg:mt-5 lg:mx-0">
            Treadmill 2-in-1 yang compact, foldable dan sesuai untuk rumah moden. Mulakan rutin sihat tanpa perlu keluar ke gym atau bergantung pada cuaca.
          </p>

          <!-- Pricing block (glass) -->
          <div class="mx-auto mt-7 max-w-md rounded-[1.75rem] bg-white/10 p-5 text-left ring-1 ring-white/15 backdrop-blur lg:mx-0">
            <div class="flex items-end justify-between gap-4">
              <div>
                <span class="inline-block rounded-full px-3 py-1 text-[10px] font-black uppercase tracking-[0.14em] text-amber-900" style="background: linear-gradient(135deg, #fff7de, #ffe7a8, #d6b679);">6 Bulan Pertama</span>
                <p class="mt-2 text-5xl font-black leading-none tracking-tight text-white">RM12<span class="text-base font-bold text-rose-200">/bln</span></p>
              </div>
              <div class="text-right">
                <p class="text-[11px] font-bold uppercase tracking-wide text-rose-200">Lepas promo</p>
                <p class="text-2xl font-black text-white">RM102<span class="text-sm font-bold text-rose-200">/bln</span></p>
              </div>
            </div>
            <div class="mt-4 flex flex-wrap items-center gap-2 border-t border-white/10 pt-4">
              <span class="rounded-lg bg-white/10 px-3 py-1.5 text-xs font-black text-white ring-1 ring-white/10">Outright RM3,399</span>
              <span class="text-xs font-semibold text-rose-200">Service CUCKOO+ · pemasangan diuruskan</span>
            </div>
            <p class="mt-3 text-[11px] font-semibold leading-5 text-rose-200/80">Tertakluk kepada stok, kelayakan & kempen semasa.</p>
          </div>

          <!-- Trust pills -->
          <div class="mt-5 flex flex-wrap justify-center gap-2 lg:justify-start">
            <span class="rounded-full bg-white/10 px-4 py-2 text-xs font-bold text-white ring-1 ring-white/15">✓ Tak perlu slip gaji</span>
            <span class="rounded-full bg-white/10 px-4 py-2 text-xs font-bold text-white ring-1 ring-white/15">🛡️ Service setiap 6 bulan</span>
            <span class="rounded-full bg-white/10 px-4 py-2 text-xs font-bold text-white ring-1 ring-white/15">📦 Free delivery & installation</span>
          </div>

          <!-- CTA buttons -->
          <div class="mt-7 flex flex-col justify-center gap-3 sm:flex-row lg:justify-start">
            <a href="#" onclick="this.href=rotatingWhatsapp()"
               class="inline-flex items-center justify-center gap-2 rounded-2xl bg-cta-green px-8 py-4 text-base font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark">
              <img src="/assets/images/misc/whatsapp-png.webp" alt="" aria-hidden="true" class="h-5 w-5" />
              Semak Promo RM12
            </a>
            <a href="#harga"
               class="inline-flex items-center justify-center rounded-2xl border border-white/25 bg-white/10 px-8 py-4 text-base font-black text-white backdrop-blur transition hover:-translate-y-0.5 hover:bg-white/20">
              Lihat Harga
            </a>
          </div>
        </div>

        <!-- Right: product card (mobile: terus selepas headline) -->
        <div class="relative order-2 lg:order-none lg:col-start-2 lg:row-start-1 lg:row-span-2 lg:self-center">
          <div class="absolute -inset-6 rounded-[3rem] blur-3xl" style="background: rgba(181,22,43,0.25);"></div>
          <div class="relative overflow-hidden rounded-[2.5rem] border border-white/15 p-5 shadow-premium"
               style="background: linear-gradient(135deg, #2d0a10, #4B0715, #1a0508);">
            <div class="absolute inset-0" style="background: radial-gradient(circle at 50% 32%, rgba(181,22,43,0.22), transparent 52%);"></div>

            <div class="relative text-center">
              <div class="mb-4 flex flex-wrap justify-center gap-2">
                <span class="rounded-full px-4 py-1.5 text-xs font-black uppercase tracking-wide text-ink" style="background: #d6b679;">2-in-1</span>
                <span class="rounded-full bg-white/10 px-4 py-1.5 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/15">Foldable</span>
              </div>

              <div class="relative flex min-h-[320px] items-center justify-center sm:min-h-[440px]">
                <div class="absolute bottom-8 h-12 w-4/5 rounded-full blur-2xl" style="background: rgba(181,22,43,0.30);"></div>
                <img id="heroProductImage" src={heroImage} alt="CUCKOO B-Fit Treadmill" loading="eager" fetchpriority="high" decoding="async" width="560" height="560"
                     class="floating relative z-10 mx-auto h-auto w-full max-w-[460px] object-contain drop-shadow-2xl transition duration-300 sm:max-w-[560px]" />
              </div>

              <!-- Image switcher -->
              <div class="thumb-scroll mt-4 justify-center">
                {heroViews.map((view, index) => (
                  <button type="button" data-hero-view={view.image}
                    class:list={[
                      'hero-view-thumb shrink-0 rounded-full px-3.5 py-1.5 text-[11px] font-bold ring-1 transition',
                      index === 0 ? 'bg-white text-brand shadow-sm ring-[#d6b679]' : 'bg-white/5 text-rose-100 ring-white/15 hover:bg-white/10'
                    ]}>
                    {view.label}
                  </button>
                ))}
              </div>

              <!-- Mini stats -->
              <div class="mt-5 grid grid-cols-3 gap-2">
                <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/10"><p class="text-base font-black text-white">1-14</p><p class="text-[10px] font-bold uppercase tracking-wide text-rose-300">km/h</p></div>
                <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/10"><p class="text-base font-black text-white">20cm</p><p class="text-[10px] font-bold uppercase tracking-wide text-rose-300">folded</p></div>
                <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/10"><p class="text-base font-black text-white">100kg</p><p class="text-[10px] font-bold uppercase tracking-wide text-rose-300">max</p></div>
              </div>
            </div>
          </div>

          <!-- Gold tag bawah card -->
          <div class="relative mx-auto mt-4 w-10/12 rounded-3xl px-5 py-4 text-center text-ink shadow-xl ring-1" style="background: #d6b679; --tw-ring-color: rgba(214,182,121,0.4);">
            <p class="text-[11px] font-bold text-amber-900">Fitness partner di rumah anda</p>
            <p class="text-sm font-black">Walking · Joging · Running</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================ -->
  <!-- SEDENTARY HOOK (light — beri rehat selepas hero gelap) -->
  <!-- ============================================================ -->
  <section class="px-4 py-14 sm:px-6 lg:px-8 lg:py-20" style="background: var(--brand-soft);">
    <div class="mx-auto max-w-5xl text-center fade-up">
      <p class="text-xs font-black uppercase tracking-[0.22em] text-brand-gold">Kenapa B-Fit</p>
      <h2 class="mx-auto mt-3 max-w-3xl text-balance text-2xl font-black tracking-tight text-brand-ink sm:text-4xl">
        Ramai dari kita habiskan terlalu banyak masa duduk — tapi belum terlambat untuk ubah.
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-sm leading-7 text-brand-muted sm:text-base">
        Kerja, perjalanan dan skrin buat badan kurang aktif. Yang anda perlukan bukan masa berjam-jam di gym — cukup beberapa minit bergerak setiap hari, di rumah sendiri.
      </p>
      <div class="mx-auto mt-8 grid max-w-xl grid-cols-2 gap-4">
        {sedentaryStats.map((s) => (
          <div class="rounded-3xl bg-white p-5 shadow-soft ring-1 ring-brand/10">
            <p class="text-3xl font-black text-brand sm:text-4xl">{s.value}</p>
            <p class="mt-2 text-xs leading-5 text-brand-muted sm:text-sm">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ============================================================ -->
  <!-- PAIN POINTS -->
  <!-- ============================================================ -->
  <section id="kenapa" class="px-4 py-16 sm:px-6 lg:px-8 lg:py-20" style="background: var(--brand-cream);">
    <div class="mx-auto max-w-7xl">
      <div class="mx-auto max-w-3xl text-center fade-up">
        <p class="text-xs font-black uppercase tracking-[0.22em] text-brand-gold">Apa Yang Menghalang Anda?</p>
        <h2 class="mt-3 text-balance text-3xl font-black tracking-tight text-brand-ink sm:text-5xl">Bila susah keluar bersenam, rumah jadi tempat paling mudah untuk mula.</h2>
        <p class="mx-auto mt-4 max-w-xl text-base leading-7 text-brand-muted">Ramai orang bukan tidak mahu sihat — cuma masa, cuaca, kerja dan jarak ke gym buat rutin susah konsisten.</p>
      </div>

