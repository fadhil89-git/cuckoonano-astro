---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import AgentSection from '../../../../components/AgentSection.astro';
import ProductGallerySlider from '../../../../components/ProductGallerySlider.astro';

const loungerBase = '/assets/images/products/massage-chair/lounger';
const pageUrl = 'https://www.cuckoonano.com/products/massage-chair/bespoke-massage-lounger/';
const heroImage = 'https://www.cuckoonano.com/assets/images/products/massage-chair/lounger/bespoke-massage-02-600x600-1.webp';

const meta = {
  title: 'CUCKOO BESPOKE Massage Lounger | Kerusi Urut 2-in-1 RM99/Bulan',
  description:
    'CUCKOO BESPOKE Massage Lounger ialah kerusi urut 2-in-1 untuk living room: lounger cantik, SL Track, 3D Shiatsu, Zero Gravity dan promo RM12/bulan.',
  canonical: pageUrl,
  ogImage: heroImage,
  ogType: 'product'
};

const galleryItems = [
  { image: `${loungerBase}/kerusi-urut-cuckoo-massage-lounger-bespoke-2.webp`, title: 'CUCKOO Massage Lounger 1', alt: 'CUCKOO BESPOKE Massage Lounger gambar 1' },
  { image: `${loungerBase}/kerusi-urut-cuckoo-massage-lounger-bespoke-3.webp`, title: 'CUCKOO Massage Lounger 2', alt: 'CUCKOO BESPOKE Massage Lounger gambar 2' },
  { image: `${loungerBase}/kerusi-urut-cuckoo-massage-lounger-bespoke-4.webp`, title: 'CUCKOO Massage Lounger 3', alt: 'CUCKOO BESPOKE Massage Lounger gambar 3' },
  { image: `${loungerBase}/kerusi-urut-cuckoo-massage-lounger-bespoke-5.webp`, title: 'CUCKOO Massage Lounger 4', alt: 'CUCKOO BESPOKE Massage Lounger gambar 4' },
  { image: `${loungerBase}/kerusi-urut-cuckoo-massage-lounger-bespoke-9.webp`, title: 'CUCKOO Massage Lounger 5', alt: 'CUCKOO BESPOKE Massage Lounger gambar 5' },
  { image: `${loungerBase}/kerusi-urut-cuckoo-massage-lounger-bespoke-10.webp`, title: 'CUCKOO Massage Lounger 6', alt: 'CUCKOO BESPOKE Massage Lounger gambar 6' },
  { image: `${loungerBase}/kerusi-urut-cuckoo-massage-lounger-bespoke-11.webp`, title: 'CUCKOO Massage Lounger 7', alt: 'CUCKOO BESPOKE Massage Lounger gambar 7' },
  { image: `${loungerBase}/kerusi-urut-cuckoo-massage-lounger-bespoke-12.webp`, title: 'CUCKOO Massage Lounger 8', alt: 'CUCKOO BESPOKE Massage Lounger gambar 8' }
];

const faqItems = [
  {
    q: 'Apa beza Massage Lounger dengan BESPOKE 2 Massage Chair?',
    a: 'Massage Lounger direka sebagai 2-in-1 — ia berfungsi sebagai lounger cantik untuk living room dan massage chair premium. Saiznya lebih compact (120×65cm) berbanding BESPOKE 2. Harga rental juga lebih rendah — RM99/bulan vs RM148/bulan untuk BESPOKE 2.'
  },
  {
    q: 'Berapa total bayaran kalau ambil pelan rental?',
    a: 'RM12 × 6 bulan = RM72, lepas tu RM99 × 54 bulan = RM5,346. Total dalam 60 bulan = RM5,418. Selepas 60 bulan, unit jadi hak milik awak. Dalam tempoh 60 bulan, awak dapat servis berkala setiap 6 bulan dan leather change bulan ke-30 secara percuma.'
  },
  {
    q: 'Perlu kad kredit untuk apply?',
    a: 'Tidak semestinya. Customer boleh guna kad bank atau debit card mengikut syarat semasa. Slip gaji dan penyata bank biasanya tidak diperlukan, tapi kelulusan tetap tertakluk kepada semakan semasa CUCKOO.'
  },
  {
    q: 'Sesuai untuk orang tua atau yang ada masalah sakit belakang?',
    a: 'Massage Lounger ada pelbagai tahap intensiti urutan yang boleh disesuaikan. Namun untuk mereka yang ada masalah kesihatan kronik, kami sarankan berunding dengan doktor terlebih dahulu.'
  },
  {
    q: 'Boleh dipindah kalau saya berpindah rumah?',
    a: 'Boleh, tapi ada caj relocation yang dikenakan oleh CUCKOO mengikut terma semasa. Maklumkan kepada ejen terlebih dahulu supaya proses pindahan dapat dirancang dengan baik.'
  },
  {
    q: 'Apa jadi kalau ada masalah teknikal dengan unit?',
    a: 'CUCKOO ada pasukan servis yang boleh dihubungi terus. Ejen juga boleh membantu follow-up kes servis dengan CUCKOO supaya urusan lebih mudah dan pantas.'
  },
  {
    q: 'Berapa lama proses kelulusan dan pemasangan?',
    a: 'Proses kelulusan biasanya mengambil masa 1-3 hari bekerja. Penghantaran dan pemasangan dijadualkan selepas kelulusan mengikut slot tersedia. Anggaran keseluruhan biasanya 1-2 minggu, tertakluk kepada stok dan kawasan.'
  },
  {
    q: 'Suri rumah atau yang tak bekerja tetap boleh apply?',
    a: 'Boleh cuba apply. Proses tetap tertakluk kepada kelulusan semasa CUCKOO. Ejen boleh bantu semak dan guide proses permohonan.'
  },
  {
    q: 'Ada caj tambahan untuk pemasangan di apartmen tanpa lift?',
    a: 'Ya. Jika tiada lift atau lift rosak, delivery melalui tangga dari tingkat 2 ke atas boleh dikenakan caj tambahan mengikut terma semasa CUCKOO.'
  },
  {
    q: 'Promo RM12 untuk berapa lama dan bila tamat?',
    a: 'Promo RM12 adalah untuk 6 bulan pertama sahaja. Selepas itu, bayaran kembali kepada RM99/bulan hingga bulan ke-60. Promo tertakluk kepada stok, kelayakan dan terma semasa.'
  }
];

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'CUCKOO BESPOKE Massage Lounger',
  alternateName: ['Kerusi Urut CUCKOO Massage Lounger', 'CUCKOO Massage Lounger', 'Massage Lounger CUCKOO'],
  image: [
    heroImage,
    'https://www.cuckoonano.com/assets/images/products/massage-chair/lounger/cuckoo-bespoke-massage-lounger-massage-lounger-mode.webp',
    'https://www.cuckoonano.com/assets/images/products/massage-chair/lounger/cuckoo-bespoke-massage-lounger-massage-chair-mode.webp'
  ],
  brand: { '@type': 'Brand', name: 'CUCKOO' },
  sku: 'cuckoo-bespoke-massage-lounger',
  model: 'BESPOKE Massage Lounger',
  category: 'Massage Chair',
  color: 'Cosy Caramel',
  material: ['Metal frame', 'Leather'],
  url: pageUrl,
  description:
    'CUCKOO BESPOKE Massage Lounger — kerusi urut 2-in-1 yang berfungsi sebagai lounger cantik dan massage chair premium. Custom-fit SL Track, 3D Shiatsu, Zero Gravity, 45°C Thermotherapy, 8 Airbags, Bluetooth Speaker.',
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Massage Track', value: 'Custom-fit SL Track' },
    { '@type': 'PropertyValue', name: 'Zero Gravity', value: '2-stage: 125° dan 136°' },
    { '@type': 'PropertyValue', name: 'Thermotherapy', value: 'Lumbar 45°C' },
    { '@type': 'PropertyValue', name: 'Airbags', value: '8 Airbags' },
    { '@type': 'PropertyValue', name: 'Product Size', value: '120cm × 65cm × 106cm' },
    { '@type': 'PropertyValue', name: 'Wall Distance', value: '6cm' }
  ],
  offers: {
    '@type': 'Offer',
    url: pageUrl,
    priceCurrency: 'MYR',
    price: '99',
    description: 'Pelan rental RM99/bulan selepas promo RM12/bulan untuk 6 bulan pertama, tertakluk kepada stok, kelayakan dan terma semasa.',
    availability: 'https://schema.org/InStock',
    itemCondition: 'https://schema.org/NewCondition',
    areaServed: { '@type': 'Country', name: 'Malaysia' },
    seller: {
      '@type': 'Organization',
      name: 'CUCKOO Nano'
    }
  }
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a
    }
  }))
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://www.cuckoonano.com/'
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Produk',
      item: 'https://www.cuckoonano.com/products/'
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'Kerusi Urut',
      item: 'https://www.cuckoonano.com/products/massage-chair/'
    },
    {
      '@type': 'ListItem',
      position: 4,
      name: 'CUCKOO BESPOKE Massage Lounger',
      item: pageUrl
    }
  ]
};
---

<BaseLayout {...meta}>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- ============================================================ -->
  <!-- HERO -->
  <!-- ============================================================ -->
  <section class="relative overflow-hidden bg-red-deep px-4 py-10 text-white sm:px-6 lg:px-8 lg:py-16">
    <div class="absolute inset-0"
         style="background: radial-gradient(circle at 18% 12%, rgba(255,255,255,0.18), transparent 28%), radial-gradient(circle at 80% 26%, rgba(255,164,176,0.18), transparent 32%), linear-gradient(135deg, #cf243d 0%, #a91429 48%, #4d0711 100%);">
    </div>
    <div class="hero-grid absolute inset-0 opacity-40"></div>
    <div class="absolute -right-20 top-0 h-80 w-80 rounded-full bg-red-brand/30 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 h-64 w-64 rounded-full bg-red-deep/60 blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl">

      <!-- MOBILE HERO -->
      <div class="lg:hidden">
        <div class="mx-auto max-w-md text-center">
          <div class="mb-3 flex flex-wrap justify-center gap-2">
            <span class="rounded-full bg-white/15 px-4 py-1.5 text-[11px] font-black uppercase tracking-[0.18em] text-white ring-1 ring-white/20">🔥 Promo RM12</span>
            <span class="rounded-full bg-white/10 px-4 py-1.5 text-[11px] font-black uppercase tracking-[0.18em] text-white ring-1 ring-white/15">2-in-1 Lounger</span>
          </div>
          <p class="text-[11px] font-black uppercase tracking-[0.22em] text-rose-200">Kerusi Urut CUCKOO Malaysia</p>
          <h1 class="mt-2 text-[1.75rem] font-black leading-[1.05] tracking-tight text-white">
            Kerusi Cantik.<br />Urutan Premium.<br />
            <span class="gold-text">Dari RM12/Bulan.</span>
          </h1>
          <p class="mx-auto mt-3 max-w-xs text-sm leading-6 text-rose-100">
            Satu kerusi. Dua fungsi. Lounger untuk living room, massage chair untuk badan yang penat.
          </p>
        </div>

        <!-- Mobile product card -->
        <div class="mx-auto mt-5 max-w-sm overflow-hidden rounded-[2rem] border border-white/15 shadow-premium"
             style="background: linear-gradient(135deg, #140a0b, #220c10, #050202);">
          <div class="relative flex min-h-[240px] items-center justify-center p-4">
            <div class="absolute bottom-6 h-10 w-4/5 rounded-full blur-2xl" style="background: rgba(181,22,43,0.35);"></div>
            <img id="heroImgMobile"
                 src="/assets/images/products/massage-chair/lounger/bespoke-massage-02-600x600-1.webp"
                 alt="CUCKOO BESPOKE Massage Lounger"
                 class="floating relative z-10 mx-auto h-auto w-full max-w-[300px] object-contain drop-shadow-2xl transition duration-300" />
          </div>
          <div class="thumb-scroll px-4 pb-4 justify-center">
            <button type="button" data-img-mobile="/assets/images/products/massage-chair/lounger/bespoke-massage-02-600x600-1.webp" class="hero-thumb-mobile shrink-0 rounded-full bg-white px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-ink shadow-sm ring-2 ring-gold">Sisi 1</button>
            <button type="button" data-img-mobile="/assets/images/products/massage-chair/lounger/cuckoo-bespoke-massage-lounger-kerusi-urut-1-copy.webp" class="hero-thumb-mobile shrink-0 rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 2</button>
            <button type="button" data-img-mobile="/assets/images/products/massage-chair/lounger/bespoke-massage-01.webp" class="hero-thumb-mobile shrink-0 rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 3</button>
            <button type="button" data-img-mobile="/assets/images/products/massage-chair/lounger/bespoke-massage-02.webp" class="hero-thumb-mobile shrink-0 rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 4</button>
            <button type="button" data-img-mobile="/assets/images/products/massage-chair/lounger/cuckoo-bespoke-massage-lounger-Photoroom.webp" class="hero-thumb-mobile shrink-0 rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 5</button>

          </div>
        </div>

        <!-- Pricing card mobile -->
        <div class="mx-auto mt-5 max-w-sm rounded-[1.75rem] bg-white/10 p-4 ring-1 ring-white/15 backdrop-blur">
          <div class="rounded-[1.4rem] p-4 text-ink" style="background: linear-gradient(135deg, #fff7de, #ffe7a8, #d6b679);">
            <p class="text-center text-[11px] font-black uppercase tracking-[0.18em] text-amber-800">6 Bulan Pertama</p>
            <p class="mt-1 text-center text-4xl font-black tracking-tight text-slate-950">RM12<span class="text-base font-bold text-slate-700">/bulan</span></p>
            <p class="mt-1 text-center text-xs font-bold text-amber-800">Lepas promo — RM99/bulan hingga 60 bulan</p>
          </div>
          <div class="mt-3 grid grid-cols-3 gap-2 text-center">
            <div class="rounded-xl bg-white/10 px-2 py-2.5 ring-1 ring-white/15">
              <p class="text-sm font-black text-white">SL Track</p>
              <p class="text-[9px] font-bold uppercase tracking-wide text-rose-200">Custom Fit</p>
            </div>
            <div class="rounded-xl bg-white/10 px-2 py-2.5 ring-1 ring-white/15">
              <p class="text-sm font-black text-white">45°C</p>
              <p class="text-[9px] font-bold uppercase tracking-wide text-rose-200">Thermotherapy</p>
            </div>
            <div class="rounded-xl bg-white/10 px-2 py-2.5 ring-1 ring-white/15">
              <p class="text-sm font-black text-white">8</p>
              <p class="text-[9px] font-bold uppercase tracking-wide text-rose-200">Airbags</p>
            </div>
          </div>
          <p class="mt-3 text-center text-[10px] font-semibold leading-5 text-rose-200">Tertakluk kepada stok, kelayakan, kawasan pemasangan dan terma semasa.</p>
        </div>

        <div class="mx-auto mt-4 max-w-sm">
          <a href="#" onclick="this.href=rotatingWhatsapp()"
             class="flex w-full items-center justify-center rounded-2xl bg-cta-green px-6 py-4 text-base font-black text-white shadow-cta transition hover:bg-cta-dark">
            📲 Semak Kelayakan RM12 Sekarang
          </a>
        </div>
      </div><!-- end mobile hero -->


      <!-- DESKTOP HERO -->
      <div class="hidden lg:grid lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-14">

        <!-- Left: text -->
        <div>
          <div class="mb-5 flex flex-wrap gap-2">
            <span class="rounded-full bg-white/15 px-5 py-2 text-xs font-black uppercase tracking-[0.22em] text-white ring-1 ring-white/20">🔥 Promo RM12 Sekarang</span>
            <span class="rounded-full bg-white/10 px-5 py-2 text-xs font-black uppercase tracking-[0.22em] text-white ring-1 ring-white/15">2-in-1 Lounger + Massage Chair</span>
          </div>

          <p class="text-sm font-black uppercase tracking-[0.24em] text-rose-200">CUCKOO BESPOKE Massage Lounger</p>

          <h1 class="mt-3 max-w-2xl text-balance text-5xl font-black leading-[1.03] tracking-tight text-white xl:text-6xl">
            Kerusi Cantik.<br />Urutan Premium.<br />
            <span class="gold-text">Dari RM12/Bulan.</span>
          </h1>

          <p class="mt-5 max-w-xl text-lg leading-8 text-rose-100">
            Satu kerusi, dua fungsi — lounger yang cantik untuk living room awak, dan massage chair premium untuk badan yang penat setiap hari.
          </p>

          <!-- Pricing block -->
          <div class="mt-7 max-w-xl rounded-[2rem] bg-white/10 p-4 ring-1 ring-white/15 backdrop-blur">
            <div class="grid grid-cols-[auto_1fr] items-center gap-4">
              <div class="rounded-[1.5rem] px-6 py-5 text-center text-ink" style="background: linear-gradient(135deg, #fff7de, #ffe7a8, #d6b679);">
                <p class="text-[11px] font-black uppercase tracking-[0.2em] text-amber-800">6 Bulan Pertama</p>
                <p class="mt-1 text-5xl font-black tracking-tight text-slate-950">RM12</p>
                <p class="text-sm font-black text-amber-900">/bulan</p>
              </div>
              <div class="space-y-2.5 text-white">
                <div class="rounded-2xl bg-white/10 px-4 py-3 text-sm font-extrabold ring-1 ring-white/10">Selepas promo — RM99/bulan hingga 60 bulan</div>
                <div class="rounded-2xl bg-white/10 px-4 py-3 text-sm font-extrabold ring-1 ring-white/10">Kad bank cukup — tak perlu kad kredit*</div>
                <p class="px-1 text-xs font-semibold leading-5 text-rose-200">Tertakluk kepada stok, kelayakan, kawasan pemasangan dan terma semasa.</p>
              </div>
            </div>
          </div>

          <!-- Trust pills -->
          <div class="mt-5 flex flex-wrap gap-2">
            <span class="rounded-full bg-white/10 px-4 py-2 text-xs font-bold text-white ring-1 ring-white/15">✓ Tak perlu slip gaji</span>
            <span class="rounded-full bg-white/10 px-4 py-2 text-xs font-bold text-white ring-1 ring-white/15">🛡️ Servis berkala setiap 6 bulan</span>
            <span class="rounded-full bg-white/10 px-4 py-2 text-xs font-bold text-white ring-1 ring-white/15">📦 Free delivery & installation</span>
          </div>

          <!-- CTA buttons -->
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#" onclick="this.href=rotatingWhatsapp()"
               class="inline-flex items-center justify-center rounded-2xl bg-cta-green px-8 py-4 text-base font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark">
              📲 Semak Kelayakan RM12
            </a>
            <a href="#features"
               class="inline-flex items-center justify-center rounded-2xl border border-white/25 bg-white/10 px-8 py-4 text-base font-black text-white backdrop-blur transition hover:-translate-y-0.5 hover:bg-white/20">
              Lihat Ciri-ciri
            </a>
          </div>
        </div>

        <!-- Right: product card -->
        <div class="relative">
          <div class="absolute -inset-6 rounded-[3rem] blur-3xl" style="background: rgba(181,22,43,0.25);"></div>
          <div class="relative overflow-hidden rounded-[2.5rem] border border-white/15 p-5 shadow-premium"
               style="background: linear-gradient(135deg, #140a0b, #220c10, #050202);">
            <div class="absolute inset-0" style="background: radial-gradient(circle at 50% 35%, rgba(181,22,43,0.22), transparent 50%);"></div>

            <div class="relative text-center">
              <div class="mb-4 flex flex-wrap justify-center gap-2">
                <span class="rounded-full px-4 py-1.5 text-xs font-black uppercase tracking-wide text-ink" style="background: #d6b679;">SL Track</span>
                <span class="rounded-full bg-white/10 px-4 py-1.5 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/15">Zero Gravity</span>
              </div>

              <div class="relative flex min-h-[320px] items-center justify-center">
                <div class="absolute bottom-8 h-12 w-4/5 rounded-full blur-2xl" style="background: rgba(181,22,43,0.30);"></div>
                <img id="heroImgDesktop"
                     src="/assets/images/products/massage-chair/lounger/bespoke-massage-02-600x600-1.webp"
                     alt="CUCKOO BESPOKE Massage Lounger"
                     class="floating relative z-10 mx-auto h-auto w-full max-w-[420px] object-contain drop-shadow-2xl transition duration-300" />
              </div>

              <!-- Image switcher desktop -->
              <div class="thumb-scroll mt-4 justify-center">
                <button type="button" data-img-desktop="/assets/images/products/massage-chair/lounger/bespoke-massage-02-600x600-1.webp" class="hero-thumb-desktop shrink-0 rounded-full bg-white px-4 py-2 text-xs font-black uppercase tracking-wide text-ink shadow-sm ring-2 ring-gold">Sisi 1</button>
                <button type="button" data-img-desktop="/assets/images/products/massage-chair/lounger/cuckoo-bespoke-massage-lounger-kerusi-urut-1-copy.webp" class="hero-thumb-desktop shrink-0 rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 2</button>
                <button type="button" data-img-desktop="/assets/images/products/massage-chair/lounger/bespoke-massage-01.webp" class="hero-thumb-desktop shrink-0 rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 3</button>
                <button type="button" data-img-desktop="/assets/images/products/massage-chair/lounger/bespoke-massage-02.webp" class="hero-thumb-desktop shrink-0 rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 4</button>
                <button type="button" data-img-desktop="/assets/images/products/massage-chair/lounger/cuckoo-bespoke-massage-lounger-Photoroom.webp" class="hero-thumb-desktop shrink-0 rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 5</button>
              </div>

              <!-- Mini stats -->
              <div class="mt-5 grid grid-cols-3 gap-2">
                <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/10"><p class="text-base font-black text-white">SL Track</p><p class="text-[10px] font-bold uppercase tracking-wide text-rose-300">Custom Fit</p></div>
                <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/10"><p class="text-base font-black text-white">45°C</p><p class="text-[10px] font-bold uppercase tracking-wide text-rose-300">Thermotherapy</p></div>
                <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/10"><p class="text-base font-black text-white">8 Bags</p><p class="text-[10px] font-bold uppercase tracking-wide text-rose-300">Airbags</p></div>
              </div>
            </div>
          </div>

          <!-- Gold tag bawah card -->
          <div class="relative mx-auto mt-4 w-10/12 rounded-3xl px-5 py-4 text-center text-ink shadow-xl ring-1" style="background: #d6b679; --tw-ring-color: rgba(214,182,121,0.4);">
            <p class="text-[11px] font-bold text-amber-900">2-in-1 Design</p>
            <p class="text-sm font-black">Lounger Cantik + Massage Chair Premium</p>
          </div>
        </div>

      </div><!-- end desktop hero -->
    </div>
