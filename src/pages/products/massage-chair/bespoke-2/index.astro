---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const meta = {
  "title": "Bespoke 2 CUCKOO | Kerusi Urut",
  "description": "Semak maklumat Bespoke 2 CUCKOO, harga cash/rental, promo terkini dan cara order melalui ejen CUCKOO.",
  "canonical": "https://www.cuckoonano.com/products/massage-chair/bespoke-2/",
  "ogImage": "https://www.cuckoonano.com/assets/images/products/massage-chair/bespoke-2/cuckoo%20bespoke%202%20massage%20chair%20kerusi%20urut%201.webp",
