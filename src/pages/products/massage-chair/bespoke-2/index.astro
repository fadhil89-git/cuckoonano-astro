---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import AgentSection from '../../../../components/AgentSection.astro';

const base = '/assets/images/products/massage-chair/bespoke-2';
const heroMain = `${base}/cuckoo%20bespoke%202%20massage%20chair%20kerusi%20urut%204.webp`;
const heroDepan = `${base}/cuckoo%20bespoke%202%20massage%20chair%20kerusi%20urut%202.webp`;
const heroAtas = `${base}/cuckoo%20bespoke%202%20massage%20chair%20kerusi%20urut%203.webp`;
const heroIncline = `${base}/cuckoo%20bespoke%202%20massage%20chair%20kerusi%20urut%205.webp`;
const heroRecline = `${base}/cuckoo%20bespoke%202%20massage%20chair%20kerusi%20urut%206.webp`;

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'CUCKOO BESPOKE 2 Massage Chair',
  alternateName: ['Kerusi Urut CUCKOO BESPOKE 2', 'CUCKOO Massage Chair', 'Kerusi Urut CUCKOO'],
  brand: { '@type': 'Brand', name: 'CUCKOO' },
  url: 'https://www.cuckoonano.com/products/massage-chair/bespoke-2/',
  description:
    'CUCKOO BESPOKE 2 Massage Chair co-created with OGAWA. Kerusi urut premium dengan Smart SL Track, 34 Airbags, 170° Natural Recline, 45°C lumbar heat, servis berkala, free leather change dan pelan bulanan CUCKOO.',
  image: [
    'https://www.cuckoonano.com/assets/images/products/massage-chair/bespoke-2/cuckoo%20bespoke%202%20massage%20chair%20kerusi%20urut%204.webp',
    'https://www.cuckoonano.com/assets/images/products/massage-chair/bespoke-2/cuckoo-ogawa-bespoke-2-massage-chair-kerusi-urut-feature-2.webp',
    'https://www.cuckoonano.com/assets/images/products/massage-chair/bespoke-2/cuckoo-ogawa-bespoke-2-massage-chair-kerusi-urut-feature-3.webp'
  ],
  offers: {
    '@type': 'Offer',
    url: 'https://www.cuckoonano.com/products/massage-chair/bespoke-2/',
    priceCurrency: 'MYR',
    price: '148',
    description:
      'Rental plan from RM148/month. Current promo may include RM12/month for first 6 months, subject to current terms, eligibility and availability.',
    availability: 'https://schema.org/InStock',
    areaServed: { '@type': 'Country', name: 'Malaysia' },
    seller: { '@type': 'Organization', name: 'CUCKOO Malaysia' }
  },
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Massage Programs', value: '6 Programs' },
    { '@type': 'PropertyValue', name: 'Massage Techniques', value: '11 Techniques' },
    { '@type': 'PropertyValue', name: 'Airbags', value: '34 Air Bags' },
    { '@type': 'PropertyValue', name: 'Recline Angle', value: '126° - 170°' },
    { '@type': 'PropertyValue', name: 'Heating', value: '45°C Lumbar Thermotherapy' }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Promo RM12 untuk berapa bulan?', acceptedAnswer: { '@type': 'Answer', text: 'Promo RM12 adalah untuk 6 bulan pertama. Selepas itu bayaran bulanan kembali kepada RM148/bulan, tertakluk kepada terma semasa.' } },
    { '@type': 'Question', name: 'Perlu kad kredit untuk apply?', acceptedAnswer: { '@type': 'Answer', text: 'Tidak semestinya. Customer boleh apply menggunakan kad bank atau debit card mengikut syarat semasa.' } },
    { '@type': 'Question', name: 'Perlu slip gaji atau penyata bank?', acceptedAnswer: { '@type': 'Answer', text: 'Untuk proses CUCKOO, biasanya tidak perlu slip gaji dan penyata bank. Kelulusan tetap tertakluk kepada semakan semasa.' } },
    { '@type': 'Question', name: 'Suri rumah boleh daftar?', acceptedAnswer: { '@type': 'Answer', text: 'Boleh cuba apply. Proses masih tertakluk kepada kelulusan semasa CUCKOO.' } },
    { '@type': 'Question', name: 'Installation free ke?', acceptedAnswer: { '@type': 'Answer', text: 'Penghantaran dan pemasangan asas adalah percuma mengikut terma semasa. Caj tambahan boleh dikenakan untuk situasi khas seperti delivery melalui tangga, dismantle, assemble, disposal atau relocation.' } },
    { '@type': 'Question', name: 'Kalau rumah apartment tiada lift?', acceptedAnswer: { '@type': 'Answer', text: 'Jika tiada lift atau lift rosak, delivery by staircase dari tingkat 2 ke atas boleh dikenakan caj RM80/floor mengikut terma semasa.' } },
    { '@type': 'Question', name: 'Bila leather change dibuat?', acceptedAnswer: { '@type': 'Answer', text: 'Leather replacement dibuat pada bulan ke-30 atau servis ke-5 dan FOC mengikut terma semasa.' } },
    { '@type': 'Question', name: 'Servis berkala dibuat setiap berapa lama?', acceptedAnswer: { '@type': 'Answer', text: 'Servis berkala dibuat setiap 6 bulan mengikut jadual CUCKOO. Item tertentu seperti motor lubrication dan air hose examination dibuat setiap 12 bulan.' } }
  ]
};
---

<BaseLayout
  title="Kerusi Urut CUCKOO BESPOKE 2 | Massage Chair RM148 Sebulan"
  description="Kerusi urut CUCKOO BESPOKE 2 dengan Smart SL Track, 34 Airbags, servis berkala, free leather change dan pelan RM148 sebulan."
  canonical="https://www.cuckoonano.com/products/massage-chair/bespoke-2/"
  ogImage="https://www.cuckoonano.com/assets/images/products/massage-chair/bespoke-2/cuckoo%20bespoke%202%20massage%20chair%20kerusi%20urut%204.webp"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />

  <!-- HERO -->
  <section class="relative overflow-hidden bg-luxe-black px-4 py-8 text-white sm:px-6 lg:px-8 lg:py-16">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_10%,rgba(214,182,121,0.26),transparent_34%),radial-gradient(circle_at_85%_20%,rgba(122,31,43,0.28),transparent_32%),linear-gradient(135deg,#09090B_0%,#151216_48%,#261815_100%)]"></div>
    <div class="hero-grid absolute inset-0 opacity-40"></div>
    <div class="absolute -right-24 top-6 h-96 w-96 rounded-full bg-luxe-gold/10 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 h-80 w-80 rounded-full bg-luxe-maroon/25 blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl">

      <!-- Mobile Hero -->
      <div class="md:hidden">
        <div class="mx-auto max-w-md text-center">
          <div class="mb-3 flex flex-wrap justify-center gap-2">
            <span class="rounded-full bg-luxe-gold/15 px-4 py-2 text-[11px] font-black uppercase tracking-[0.18em] text-luxe-champagne ring-1 ring-luxe-gold/30">🔥 Madness 12 Promo</span>
            <span class="rounded-full bg-white/10 px-4 py-2 text-[11px] font-black uppercase tracking-[0.18em] text-white ring-1 ring-white/15">Co-created with OGAWA</span>
          </div>

          <p class="text-xs font-black uppercase tracking-[0.22em] text-luxe-gold">CUCKOO Massage Chair Malaysia</p>

          <h1 class="mt-3 text-3xl font-black leading-[1.03] tracking-tight text-white">
            Kerusi Urut CUCKOO BESPOKE 2<br />
            <span class="gold-text">Dari RM12/Bulan</span>
          </h1>
        </div>

        <div class="mx-auto mt-5 max-w-md overflow-hidden rounded-[2rem] border border-white/15 bg-gradient-to-br from-[#141111] via-[#241715] to-[#050505] p-4 shadow-premium">
          <div class="relative flex min-h-[260px] items-center justify-center">
            <div class="absolute bottom-7 h-12 w-[82%] rounded-full bg-luxe-gold/25 blur-2xl"></div>
            <img id="heroProductImageMobile"
                 src={heroMain}
                 alt="Kerusi Urut CUCKOO BESPOKE 2 Massage Chair"
                 class="floating relative z-10 mx-auto h-auto w-full max-w-[330px] object-contain drop-shadow-2xl transition duration-300" />
          </div>

          <div class="mt-3 flex flex-wrap justify-center gap-2">
            <button type="button" data-hero-product={heroMain} class="hero-product-thumb-mobile rounded-full bg-white px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-luxe-black shadow-sm ring-2 ring-luxe-gold">Main</button>
            <button type="button" data-hero-product={heroDepan} class="hero-product-thumb-mobile rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20">Depan</button>
            <button type="button" data-hero-product={heroAtas} class="hero-product-thumb-mobile rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20">Atas</button>
            <button type="button" data-hero-product={heroIncline} class="hero-product-thumb-mobile rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20">Incline</button>
            <button type="button" data-hero-product={heroRecline} class="hero-product-thumb-mobile rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20">Recline</button>
          </div>
        </div>

        <div id="promo" class="mx-auto mt-5 max-w-md rounded-[1.75rem] bg-white/10 p-4 text-left shadow-premium ring-1 ring-white/15 backdrop-blur">
          <p class="text-center text-sm font-semibold leading-6 text-stone-200">Badan penat, bahu tegang atau pinggang lenguh? Nikmati urutan premium di rumah tanpa perlu bayar cash ribuan ringgit sekaligus.</p>
          <div class="mt-4 rounded-[1.45rem] bg-gradient-to-br from-[#FFF7DE] via-[#FFE7A8] to-[#D6B679] px-4 py-4 text-luxe-black shadow-soft ring-1 ring-amber-200">
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="text-[11px] font-black uppercase tracking-[0.18em] text-amber-800">6 bulan pertama</p>
                <p class="mt-1 text-4xl font-black tracking-tight text-slate-950">RM12<span class="text-base text-slate-700">/bulan</span></p>
              </div>
              <div class="text-right text-xs font-black leading-5 text-slate-700">
                <p>Lepas promo</p>
                <p>RM148/bulan</p>
              </div>
            </div>
          </div>
          <div class="mt-4 grid grid-cols-3 gap-2 text-center">
            <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/15"><p class="text-sm font-black text-white">170°</p><p class="text-[10px] font-bold uppercase tracking-wide text-luxe-cream">Recline</p></div>
            <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/15"><p class="text-sm font-black text-white">34</p><p class="text-[10px] font-bold uppercase tracking-wide text-luxe-cream">Airbags</p></div>
            <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/15"><p class="text-sm font-black text-white">45°C</p><p class="text-[10px] font-bold uppercase tracking-wide text-luxe-cream">Heat</p></div>
          </div>
          <p class="mt-3 text-center text-xs font-semibold leading-5 text-stone-300">Tertakluk kepada stok, kelayakan, kawasan pemasangan dan terma semasa.</p>
        </div>

        <div class="mx-auto mt-5 max-w-md">
          <a href="#" onclick="this.href=rotatingWhatsapp()"
             class="flex w-full items-center justify-center rounded-2xl bg-cta-green px-6 py-4 text-base font-black text-white shadow-cta">
            📲 Semak Kelayakan RM12 Sekarang
          </a>
        </div>
      </div>

      <!-- Desktop Hero -->
      <div class="hidden items-center gap-10 md:grid lg:grid-cols-[1.04fr_0.96fr] lg:gap-12">
        <div class="order-1 text-center lg:text-left">
          <div class="mb-5 flex flex-wrap justify-center gap-2 lg:justify-start">
            <span class="rounded-full bg-luxe-gold/15 px-5 py-2 text-xs font-black uppercase tracking-[0.22em] text-luxe-champagne ring-1 ring-luxe-gold/30">Madness 12 Promo</span>
            <span class="rounded-full bg-white/10 px-5 py-2 text-xs font-black uppercase tracking-[0.22em] text-white ring-1 ring-white/15">Co-created with OGAWA</span>
          </div>

          <p class="mb-3 text-sm font-black uppercase tracking-[0.24em] text-luxe-gold">CUCKOO BESPOKE 2 Massage Chair</p>

          <h1 class="mx-auto max-w-4xl text-balance text-4xl font-black leading-[1.03] tracking-tight text-white sm:text-5xl lg:mx-0 lg:text-6xl">
            Kerusi Urut CUCKOO BESPOKE 2 <span class="gold-text">Dari RM12/Bulan</span>
          </h1>

          <p class="mx-auto mt-5 max-w-2xl text-base leading-8 text-stone-200 sm:text-lg lg:mx-0">
            BESPOKE 2 memberi pengalaman urutan premium di rumah dengan 170° Natural Recline, Smart SL Track, 34 Airbags dan 45°C Lumbar Heat — sesuai untuk anda yang selalu penat bekerja, memandu atau berdiri lama.
          </p>

          <div class="mx-auto mt-6 max-w-2xl rounded-[2rem] bg-white/10 p-4 text-left shadow-premium ring-1 ring-white/15 backdrop-blur lg:mx-0">
            <div class="grid gap-3 sm:grid-cols-[0.9fr_1.1fr] sm:items-center">
              <div class="rounded-[1.5rem] bg-gradient-to-br from-[#FFF7DE] via-[#FFE7A8] to-[#D6B679] px-5 py-5 text-center text-luxe-black shadow-soft ring-1 ring-amber-200">
                <p class="text-xs font-black uppercase tracking-[0.22em] text-amber-700">6 bulan pertama</p>
                <p class="mt-2 text-5xl font-black tracking-tight text-slate-950 sm:text-6xl">RM12</p>
                <p class="text-base font-black text-luxe-black">/bulan</p>
              </div>
              <div class="space-y-3 text-white">
                <div class="rounded-2xl bg-white/10 px-4 py-3 font-extrabold ring-1 ring-white/10">Selepas promo — RM148/bulan</div>
                <div class="rounded-2xl bg-white/10 px-4 py-3 font-extrabold ring-1 ring-white/10">Tak perlu kad kredit — kad bank cukup*</div>
                <p class="text-sm font-semibold leading-6 text-stone-300">Tak perlu slip gaji dan penyata bank. Suri rumah pun boleh cuba apply, tertakluk kelayakan semasa.</p>
              </div>
            </div>
          </div>

          <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:justify-center lg:justify-start">
            <a href="#" onclick="this.href=rotatingWhatsapp()"
               class="inline-flex items-center justify-center rounded-2xl bg-cta-green px-7 py-4 text-base font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark sm:text-lg">
              📲 Semak Kelayakan RM12
            </a>
            <a href="#benefits" class="inline-flex items-center justify-center rounded-2xl border border-white/20 bg-white px-7 py-4 text-base font-black text-slate-950 shadow-sm transition hover:-translate-y-0.5 sm:text-lg">
              Lihat Kelebihan Utama
            </a>
          </div>
        </div>

        <!-- Product Visual -->
        <div class="order-2 mt-2 lg:mt-0">
          <div class="relative mx-auto max-w-[440px] sm:max-w-[520px] lg:max-w-[620px]">
            <div class="absolute -inset-8 rounded-[3rem] bg-luxe-gold/15 blur-3xl"></div>
            <div class="absolute left-1/2 top-1/2 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rounded-full bg-luxe-copper/20 blur-3xl"></div>

            <div class="relative overflow-hidden rounded-[2.5rem] border border-white/15 bg-gradient-to-br from-[#141111] via-[#241715] to-[#050505] p-5 shadow-premium sm:p-6">
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_38%,rgba(214,182,121,0.18),transparent_42%),radial-gradient(circle_at_18%_15%,rgba(255,255,255,0.10),transparent_32%)]"></div>

              <div class="relative text-center">
                <div class="mb-5 flex flex-wrap justify-center gap-2">
                  <span class="rounded-full bg-luxe-gold px-4 py-2 text-xs font-black uppercase tracking-wide text-luxe-black shadow-sm">170° Recline</span>
                  <span class="rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-luxe-cream ring-1 ring-white/15">34 Airbags</span>
                </div>

                <div class="relative mx-auto flex min-h-[260px] items-center justify-center sm:min-h-[380px]">
                  <div class="absolute bottom-8 h-12 w-[82%] rounded-full bg-luxe-gold/25 blur-2xl"></div>
                  <img id="heroProductImage"
                       src={heroMain}
                       alt="Kerusi Urut CUCKOO BESPOKE 2 Massage Chair"
                       class="floating relative z-10 mx-auto h-auto w-full max-w-[360px] object-contain drop-shadow-2xl transition duration-300 sm:max-w-[500px] lg:max-w-[560px]" />
                </div>

                <div class="mt-5 flex flex-wrap justify-center gap-2">
                  <button type="button" data-hero-product={heroMain} class="hero-product-thumb rounded-full bg-white px-4 py-2 text-xs font-black uppercase tracking-wide text-luxe-black shadow-sm ring-2 ring-luxe-gold">Main</button>
                  <button type="button" data-hero-product={heroDepan} class="hero-product-thumb rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20">Depan</button>
                  <button type="button" data-hero-product={heroAtas} class="hero-product-thumb rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20">Atas</button>
                  <button type="button" data-hero-product={heroIncline} class="hero-product-thumb rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20">Incline</button>
                  <button type="button" data-hero-product={heroRecline} class="hero-product-thumb rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20">Recline</button>
                </div>

                <div class="mt-6 grid grid-cols-3 gap-2 sm:gap-3">
                  <div class="rounded-2xl bg-white/95 px-2 py-3 shadow-sm ring-1 ring-white/20"><p class="text-base font-black text-slate-950 sm:text-lg">6</p><p class="text-[10px] font-bold uppercase tracking-wide text-stone-500">Programs</p></div>
                  <div class="rounded-2xl bg-white/95 px-2 py-3 shadow-sm ring-1 ring-white/20"><p class="text-base font-black text-slate-950 sm:text-lg">11</p><p class="text-[10px] font-bold uppercase tracking-wide text-stone-500">Techniques</p></div>
                  <div class="rounded-2xl bg-white/95 px-2 py-3 shadow-sm ring-1 ring-white/20"><p class="text-base font-black text-slate-950 sm:text-lg">5</p><p class="text-[10px] font-bold uppercase tracking-wide text-stone-500">Intensity</p></div>
                </div>
              </div>
            </div>

            <div class="relative mx-auto mt-4 w-[88%] rounded-3xl bg-luxe-gold px-5 py-4 text-center text-luxe-black shadow-xl ring-1 ring-luxe-champagne/40">
              <p class="text-[11px] font-bold text-amber-900 sm:text-xs">Highlight Utama</p>
              <p class="text-sm font-black sm:text-base">Premium Massage, Easy Monthly Payment</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Strip -->
  <section class="bg-gradient-to-r from-[#09090B] via-[#2B1A14] to-[#7A1F2B] px-4 py-6 text-white sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-3 text-sm sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-2xl bg-white/10 px-5 py-4 ring-1 ring-white/20"><p class="text-lg font-black">🔥 RM12/bulan</p><p class="mt-1 font-semibold text-luxe-cream">Untuk 6 bulan pertama*</p></div>
      <div class="rounded-2xl bg-white/10 px-5 py-4 ring-1 ring-white/20"><p class="text-lg font-black">💳 Kad bank cukup</p><p class="mt-1 font-semibold text-luxe-cream">Tak perlu kad kredit*</p></div>
      <div class="rounded-2xl bg-white/10 px-5 py-4 ring-1 ring-white/20"><p class="text-lg font-black">📄 Tak perlu slip gaji</p><p class="mt-1 font-semibold text-luxe-cream">Tak perlu penyata bank*</p></div>
      <div class="rounded-2xl bg-white/10 px-5 py-4 ring-1 ring-white/20"><p class="text-lg font-black">🛡️ 5 tahun</p><p class="mt-1 font-semibold text-luxe-cream">Servis & warranty*</p></div>
    </div>
  </section>

  <!-- Pain Points -->
  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-7xl">
      <div class="grid items-center gap-10 lg:grid-cols-[0.95fr_1.05fr]">
        <div>
          <p class="text-sm font-black uppercase tracking-[0.24em] text-luxe-goldDeep">Kenapa ramai mula cari massage chair?</p>
          <h2 class="mt-4 text-balance text-3xl font-black tracking-tight sm:text-5xl">Kerusi Urut CUCKOO Untuk Rehat Di Rumah</h2>
          <p class="mt-5 text-lg leading-8 text-stone-600">Ramai orang sebenarnya nak badan rasa lebih lega di rumah sendiri, tapi tak sempat pergi spa atau pusat urut. BESPOKE 2 beri pilihan untuk bina ruang rehat premium di rumah dengan bayaran bulanan yang lebih mudah dimiliki.</p>
          <a href="#" onclick="this.href=rotatingWhatsapp()" class="mt-7 inline-flex items-center justify-center rounded-2xl bg-cta-green px-7 py-4 text-base font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark">📲 Tanya Promo & Kelayakan</a>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-[2rem] bg-stone-50 p-6 shadow-soft ring-1 ring-stone-100"><p class="text-3xl">💼</p><h3 class="mt-4 text-xl font-black text-luxe-black">Penat selepas kerja</h3><p class="mt-3 leading-7 text-stone-600">Balik rumah badan rasa berat, bahu tegang dan susah nak relax.</p></div>
          <div class="rounded-[2rem] bg-stone-50 p-6 shadow-soft ring-1 ring-stone-100"><p class="text-3xl">🚗</p><h3 class="mt-4 text-xl font-black text-luxe-black">Banyak memandu</h3><p class="mt-3 leading-7 text-stone-600">Pinggang dan belakang mudah lenguh bila lama duduk dalam kereta.</p></div>
          <div class="rounded-[2rem] bg-amber-50 p-6 shadow-soft ring-1 ring-amber-100"><p class="text-3xl">🦵</p><h3 class="mt-4 text-xl font-black text-luxe-black">Kaki cepat letih</h3><p class="mt-3 leading-7 text-stone-600">Sesuai untuk yang banyak berjalan, berdiri lama atau aktif seharian.</p></div>
          <div class="rounded-[2rem] bg-luxe-black p-6 text-white shadow-premium"><p class="text-3xl">💸</p><h3 class="mt-4 text-xl font-black text-luxe-gold">Tak mampu bayar cash</h3><p class="mt-3 leading-7 text-luxe-muted">Dengan CUCKOO, boleh pilih bayaran bulanan RM148 selepas promo.</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Benefits Storytelling -->
