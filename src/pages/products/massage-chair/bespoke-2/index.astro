<script is:inline>
  // Hero product image switcher (desktop + mobile)
  function setupHeroProductSwitcher(imageId, buttonClass, inactiveClass, activeClass) {
    const image = document.getElementById(imageId);
    const buttons = document.querySelectorAll('.' + buttonClass);
    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        if (!image) return;
        image.src = button.dataset.heroProduct;
        buttons.forEach((thumb) => { thumb.className = buttonClass + ' ' + inactiveClass; });
        button.className = buttonClass + ' ' + activeClass;
      });
    });
  }

  setupHeroProductSwitcher('heroProductImage', 'hero-product-thumb', 'rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20', 'rounded-full bg-white px-4 py-2 text-xs font-black uppercase tracking-wide text-luxe-black shadow-sm ring-2 ring-luxe-gold');
  setupHeroProductSwitcher('heroProductImageMobile', 'hero-product-thumb-mobile', 'rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20', 'rounded-full bg-white px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-luxe-black shadow-sm ring-2 ring-luxe-gold');

  // Gallery slider
  const productSlides = [
    { image: '/assets/images/products/massage-chair/bespoke-2/cuckoo-ogawa-bespoke-2-massage-chair-kerusi-urut-gambar-image-1.webp' },
    { image: '/assets/images/products/massage-chair/bespoke-2/cuckoo-ogawa-bespoke-2-massage-chair-kerusi-urut-gambar-image-2.webp' },
    { image: '/assets/images/products/massage-chair/bespoke-2/cuckoo-ogawa-bespoke-2-massage-chair-kerusi-urut-gambar-image-3.webp' },
    { image: '/assets/images/products/massage-chair/bespoke-2/cuckoo-ogawa-bespoke-2-massage-chair-kerusi-urut-gambar-image-4.webp' },
    { image: '/assets/images/products/massage-chair/bespoke-2/cuckoo-ogawa-bespoke-2-massage-chair-kerusi-urut-gambar-image-5.webp' }
  ];

  const productImage = document.getElementById('productSliderImage');
  const productPrev = document.getElementById('productSliderPrev');
  const productNext = document.getElementById('productSliderNext');
  const productDots = document.getElementById('productSliderDots');
  let productIndex = 0;

  function renderProductSlider() {
    if (!productImage || !productDots) return;
    const slide = productSlides[productIndex];
    productImage.src = slide.image;
    productImage.alt = 'Gambar CUCKOO BESPOKE 2 Massage Chair ' + (productIndex + 1);
    productDots.innerHTML = productSlides.map((_, index) => '<button type="button" aria-label="Lihat gambar ' + (index + 1) + '" class="h-3 rounded-full transition ' + (index === productIndex ? 'w-9 bg-luxe-goldDeep' : 'w-3 bg-stone-300') + '" data-product-dot="' + index + '"></button>').join('');
    productDots.querySelectorAll('[data-product-dot]').forEach((dot) => {
      dot.addEventListener('click', () => { productIndex = Number(dot.dataset.productDot); renderProductSlider(); });
    });
  }

  if (productPrev && productNext) {
    productPrev.addEventListener('click', () => { productIndex = (productIndex - 1 + productSlides.length) % productSlides.length; renderProductSlider(); });
    productNext.addEventListener('click', () => { productIndex = (productIndex + 1) % productSlides.length; renderProductSlider(); });
  }

  renderProductSlider();
</script>
