---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const meta = {
  title: 'CUCKOO Ogawa Bespoke Massage Chair | Kerusi Urut',
  description:
    'Semak maklumat CUCKOO Ogawa Bespoke Massage Chair, harga, promo dan pilihan kerusi urut CUCKOO.',
  canonical: 'https://www.cuckoonano.com/products/massage-chair/ogawa-bespoke/',
  ogImage: 'https://www.cuckoonano.com/assets/images/products/ogawa-bespoke.webp',
  ogType: 'website'
};
---

<BaseLayout {...meta}>
  <section class="hero-pattern px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="font-bold text-brand">Kerusi Urut</p>
        <h1 class="mt-3 text-4xl font-black tracking-tight sm:text-5xl">
          CUCKOO Ogawa Bespoke Massage Chair
        </h1>
        <p class="mt-5 text-lg leading-8 text-muted">
          Page kosong/stub untuk old URL yang ada SEO value. Nanti boleh diisi dengan kandungan
          penuh Bespoke Massage Chair.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="https://wasap.my/60139916967" class="rounded-full bg-brand px-7 py-4 text-center font-bold text-white shadow-glow transition-all duration-300 hover:-translate-y-1 hover:bg-brand-dark">
            WhatsApp Ejen
          </a>
          <a href="/products/massage-chair/" class="rounded-full border border-brand/20 bg-white px-7 py-4 text-center font-bold text-brand transition-all duration-300 hover:-translate-y-1 hover:bg-brand-soft">
            Produk Kerusi Urut
          </a>
        </div>
      </div>
      <div class="rounded-[2rem] bg-white p-6 shadow-soft">
        <h2 class="text-2xl font-black">Untuk dikemaskini</h2>
        <p class="mt-3 text-muted">
          Masukkan detail model, gambar, plan bayaran, feature massage dan FAQ di sini.
        </p>
      </div>
    </div>
  </section>
  <div data-promo></div>
  <div data-product-selector data-initial="massage-chair"></div>
  <div data-agent-block></div>
</BaseLayout>
