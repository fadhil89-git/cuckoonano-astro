---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ProductGallerySlider from '../../../../components/ProductGallerySlider.astro';

// ── Single source of truth ──────────────────────────────────────────────
const pageUrl = 'https://www.cuckoonano.com/products/induction/inductrio/';
const absoluteUrl = (path) => new URL(encodeURI(path), pageUrl).toString();

const whatsappUrl =
  'https://api.whatsapp.com/send?phone=60139916967&text=Salam%20Fadhil%2C%20saya%20berminat%20dengan%20CUCKOO%20INDUCTRIO%20Hybrid%20Induction%20Hob.%20Boleh%20bantu%20saya%20semak%20harga%20%26%20promo%3F';

const priceValidUntil = '2026-12-31';

const assetBase = '/assets/images/products/induction/inductrio';
const indBase = '/assets/images/products/induction';
const serviceBase = `${indBase}/servis`;
const technicianImg = '/assets/images/service/Cuckoo-Servis copy.webp';

const img = {
  heroClean: '/assets/images/Gambar Produk png/cuckoo inductrio.webp',
  render: `${assetBase}/dapur-induksi-cuckoo-inductrio-hybrid-hob-malaysia.webp`,
  zones: `${assetBase}/cuckoo-inductrio-3-cooking-zones.webp`,
  productImage: `${assetBase}/cuckoo-inductrio-product-image.webp`,
  productAngle: `${assetBase}/cuckoo-inductrio-product-angle.webp`,
  installedKitchen: `${assetBase}/cuckoo-inductrio-installed-kitchen.webp`,
  directTouch: `${assetBase}/cuckoo-inductrio-direct-touch-sensor.webp`,
  schott: `${assetBase}/cuckoo-inductrio-schott-ceran-glass.webp`,
  smartIh: `${assetBase}/cuckoo-inductrio-smart-ih-surface.webp`,
  ihUltra: `${assetBase}/cuckoo-inductrio-ih-ultra-high-temp.webp`,
  ihBooster: `${assetBase}/cuckoo-inductrio-ih-booster-mode.webp`,
  autoCookBanner: `${assetBase}/cuckoo-inductrio-auto-cook-banner.webp`,
  controlPanel: `${assetBase}/cuckoo-inductrio-control-panel.webp`,
  dimensions: `${assetBase}/cuckoo-inductrio-dimensions-spec.webp`,
  install15a: `${assetBase}/cuckoo-inductrio-installation-15a.webp`
};

const heroThumbs = [
  { src: img.heroClean, label: 'Produk' },
  { src: img.render, label: 'Atas' },
  { src: img.productAngle, label: 'Sisi' }
];

// "Kenapa beralih ke induction?" — 6 kad (wording lembut)
const inductionCards = [
  { img: `${indBase}/kenapa-induction-cuckoo-inductrio-inductwo-card-1-tiada-api-terbuka.webp`, title: 'Tiada Api Terbuka', copy: 'Dapur gas guna flame terbuka yang boleh menyambar kain, tisu atau minyak berdekatan. Induction memanaskan cookware tanpa nyalaan api terbuka.' },
  { img: `${indBase}/kenapa-induction-cuckoo-inductrio-inductwo-card-2-risiko-kebocoran-gas.webp`, title: 'Kurang Risiko Kebocoran Gas', copy: 'Tanpa tong gas, hose atau regulator, anda boleh kurangkan kerisauan bau gas, regulator longgar atau hose merekah.' },
  { img: `${indBase}/kenapa-induction-cuckoo-inductrio-inductwo-card-3-anak-kecil-children.webp`, title: 'Lebih Sesuai Untuk Rumah Ada Anak', copy: 'Tiada flame terbuka untuk anak main api. INDUCTRIO juga ada Safety Lock untuk bantu elak tetapan berubah secara tak sengaja.' },
  { img: `${indBase}/kenapa-induction-cuckoo-inductrio-inductwo-card-4-kawalan-haba-lebih-tepat.webp`, title: 'Kawalan Haba Lebih Tepat', copy: 'Dengan heating level 1–10 dan Direct Touch Sensor, suhu lebih mudah dikawal mengikut jenis masakan.' },
  { img: `${indBase}/kenapa-induction-cuckoo-inductrio-inductwo-card-5-dapur-kurang-bahang.webp`, title: 'Dapur Kurang Bahang', copy: 'Induction lebih fokus memanaskan cookware, bukan udara sekeliling. Ruang dapur terasa lebih selesa ketika memasak.' },
  { img: `${indBase}/kenapa-induction-cuckoo-inductrio-inductwo-card-5-mudah-bersih-easy-clean.webp`, title: 'Lebih Mudah Dibersihkan', copy: 'Permukaan glass-ceramic yang rata lebih mudah dilap berbanding burner gas yang banyak celah dan perangkap minyak.' }
];

// Masalah yang produk selesaikan
const problems = [
  'Dapur gas biasa nampak besar, berminyak dan susah dibersihkan',
  'Api terbuka buat rasa kurang tenang, terutama rumah ada anak kecil',
  'Tong gas habis waktu tengah masak',
  'Bau gas dan isu regulator / hose buat rasa risau',
  'Nak masak lebih dari satu lauk dalam satu masa',
  'Nak dapur moden yang nampak premium dan built-in',
  'Nak kawalan haba lebih tepat untuk masakan harian',
  'Nak dapur yang datang dengan servis berkala — bukan beli dan tinggal'
];

// Kenapa INDUCTRIO premium (6)
const premiumPoints = [
  { n: '01', t: '3 Zon Memasak Dalam Satu Dapur', d: 'Dengan 2 induction zone + 1 highlight zone, anda boleh masak beberapa hidangan serentak — sesuai untuk keluarga yang kerap memasak.' },
  { n: '02', t: 'Firepower Lebih Kuat — IH Booster Mode', d: 'Setiap induction zone berkuasa sehingga 1800W dan boleh naik sehingga 2000W dengan Booster untuk memasak lebih pantas bila perlu.' },
  { n: '03', t: 'Direct Touch Sensor', d: 'Direct Touch Sensor bantu suhu dikawal lebih tepat supaya masakan lebih konsisten, terutama hidangan yang perlukan haba stabil.' },
  { n: '04', t: 'Surface Premium SCHOTT CERAN', d: 'Permukaan German glass-ceramic SCHOTT CERAN beri rupa moden, premium dan mudah dibersihkan — sesuai untuk kitchen cabinet & built-in.' },
  { n: '05', t: 'Hybrid Untuk Lebih Fleksibiliti', d: 'Gabungan induction zone dan highlight zone beri pilihan lebih luas untuk gaya memasak dan jenis cookware berbeza.' },
  { n: '06', t: 'Sokongan Servis Berkala CUCKOO', d: 'Pelan rental hadir dengan servis & warranty 5 tahun mengikut terma CUCKOO — bukan sekadar dapur moden, tapi datang dengan sokongan selepas jualan.' }
];

// Manfaat pelanggan
const benefits = [
  { e: '🍽️', t: '3 Zon Memasak', d: 'Lebih banyak hidangan dalam satu masa untuk keluarga.' },
  { e: '⚡', t: 'Pemanasan Pantas', d: 'Induction heating + IH Booster jimatkan masa.' },
  { e: '🧼', t: 'Kemas & Mudah Dilap', d: 'Surface premium rata, kelihatan moden.' },
  { e: '🛡️', t: 'Servis Berkala', d: 'Pelan rental termasuk service & warranty 5 tahun.' }
];

// Cooking modes (emoji + brief)
const cookingModes = [
  { e: '🍳', t: 'Pan Fry', d: 'Menggoreng harian — telur, ikan, ayam dan lauk biasa.' },
  { e: '🍤', t: 'Deep Fry', d: 'Sesuai untuk gorengan yang perlukan haba lebih tinggi.' },
  { e: '🍚', t: 'White Rice', d: 'Masak nasi dengan tetapan haba yang lebih terkawal.' },
  { e: '🥣', t: 'Porridge', d: 'Bubur lembut dengan haba rendah yang sekata.' },
  { e: '🍜', t: 'Noodles', d: 'Rebus mi & masakan berkuah dengan lebih mudah.' },
  { e: '♨️', t: 'Keep Warm', d: 'Pastikan makanan kekal panas sebelum dihidang.' }
];

// Feature list penuh (chips)
const featureChips = [
  'IH-Ultra High Temperature Mode', 'IH Booster Mode', 'Direct Touch Sensor',
  '2 Induction Zone', '1 Highlight Zone', 'SCHOTT CERAN Glass-Ceramic',
  'Heating Level 1–10', 'Voice Navigation', 'Touch Panel', 'Safety Lock',
  'Timer Function', 'Smart Error Detection', 'Auto Power Saving', 'Voice Cooking Alarm'
];

// Installation note
const installPoints = [
  'Memerlukan 15A power plug',
  'Disarankan direct wiring dari MCB',
  'Minimum MCB 20A',
  'Tidak disarankan menggunakan extension cable',
  'Pemeriksaan lokasi mungkin diperlukan sebelum pemasangan',
  'Kos tambahan untuk wiring / socket / MCB bergantung keadaan rumah'
];

// Servis
const serviceCards = [
  { icon: `${serviceBase}/kitchen-check-list-icon-natural-care-service-visit.webp`, t: 'Servis Berkala', d: 'Pasukan CUCKOO+ Care Service datang mengikut jadual untuk bantu periksa dan jaga induction hob anda.' },
  { icon: `${serviceBase}/kitchen-check-list-icon-one-to-one.webp`, t: 'Servis Profesional 1-to-1', d: 'Servis dibuat secara profesional dan lebih teliti mengikut keadaan produk pelanggan.' },
  { icon: `${serviceBase}/kitchen-check-list-icon-ncs-8.webp`, t: 'CCS 8-Point Check', d: 'Pemeriksaan pada bahagian penting seperti temperature, touch panel, touch sensor, power plug dan permukaan kaca.' },
  { icon: `${serviceBase}/kitchen-check-list-icon-additional-care-service.webp`, t: 'Additional Care Service', d: 'Boleh termasuk penjagaan tambahan seperti steam sterilisation untuk chopping board dan sink mengikut pakej.' }
];

const ccsCheck = [
  'Temperature Test', 'Tempered Glass Surface', 'Touch Sensor', 'Touch Panel',
  'Service Card Explanation', 'On/Off Button', 'Power Plug', 'Pemeriksaan kebersihan & keadaan keseluruhan hob'
];

// Turutan fail step terbalik dari turutan proses
const serviceSteps = [
  { img: `${serviceBase}/kitchen-check-list-step-06.webp`, t: 'Prepare Steamer & Hygiene Kit', d: 'Pasukan servis menyediakan steamer dan hygiene kit sebelum proses penjagaan bermula.' },
  { img: `${serviceBase}/kitchen-check-list-step-05.webp`, t: 'Remove Stubborn Stain', d: 'Kotoran atau stain pada permukaan hob dibersihkan menggunakan scraper yang sesuai.' },
  { img: `${serviceBase}/kitchen-check-list-step-04.webp`, t: 'Wipe With Induction Cleaner', d: 'Permukaan hob dilap dengan induction cleaner supaya permukaan kaca lebih bersih dan kemas.' },
  { img: `${serviceBase}/kitchen-check-list-step-03.webp`, t: 'Check Temperature', d: 'Suhu pada zon memasak diperiksa untuk memastikan fungsi pemanasan berada dalam keadaan baik.' },
  { img: `${serviceBase}/kitchen-check-list-step-02.webp`, t: 'Sterilise Cookware / Kitchen Area', d: 'Boleh termasuk sterilisation untuk cookware, chopping board atau sink mengikut pakej servis.' },
  { img: `${serviceBase}/kitchen-check-list-step-01.webp`, t: 'Update Service Card', d: 'Rekod servis dikemas kini pada service card supaya pelanggan tahu status lawatan servis.' }
];

// Siapa sesuai
const suitableFor = [
  'Keluarga yang kerap memasak di rumah',
  'Pelanggan yang mahu dapur utama lebih premium',
  'Rumah baru dengan kitchen cabinet / built-in kitchen',
  'Pengguna yang mahu 3 zon memasak',
  'Yang mahu kurangkan penggunaan gas',
  'Pelanggan yang mahu induction hob dengan servis berkala',
  'Yang sanggup buat setup elektrik 15A yang sesuai',
  'Pengguna yang mahu kawalan haba lebih tepat',
  'Yang mahu dapur nampak lebih moden, kemas dan mudah dibersihkan'
];

// Galeri gambar sebenar
const galleryItems = [
  { image: `${assetBase}/cuckoo-inductrio-installed-kitchen.webp`, title: 'Dipasang Dalam Dapur', copy: 'INDUCTRIO 3 zon dalam dapur rumah pelanggan.', alt: 'CUCKOO INDUCTRIO dipasang dalam dapur' },
  { image: `${assetBase}/cuckoo-inductrio-built-in-kitchen.webp`, title: 'Built-In Kitchen', copy: 'Rupa kemas & premium untuk dapur built-in.', alt: 'CUCKOO INDUCTRIO built-in kitchen premium' },
  { image: `${assetBase}/cuckoo-inductrio-kitchen-lifestyle.webp`, title: 'Dapur Moden', copy: 'Sesuai untuk kitchen cabinet dan dapur moden.', alt: 'CUCKOO INDUCTRIO dapur moden lifestyle' },
  { image: `${assetBase}/cuckoo-inductrio-masak-hidangan-keluarga.webp`, title: 'Hidangan Keluarga', copy: 'Masak lauk & hidangan keluarga dengan lebih mudah.', alt: 'CUCKOO INDUCTRIO masak hidangan keluarga' },
  { image: `${assetBase}/cuckoo-inductrio-masak-dua-zon.webp`, title: 'Masak Serentak', copy: 'Guna beberapa zon pada masa yang sama.', alt: 'CUCKOO INDUCTRIO masak serentak beberapa zon' },
  { image: `${assetBase}/cuckoo-inductrio-steamboat-hot-pot.webp`, title: 'Steamboat & Hot Pot', copy: 'Sesuai untuk masakan berkuah ramai-ramai.', alt: 'CUCKOO INDUCTRIO steamboat hot pot' },
  { image: `${assetBase}/cuckoo-inductrio-live-cooking-demo.webp`, title: 'Live Cooking Demo', copy: 'INDUCTRIO diuji dalam demo memasak sebenar.', alt: 'CUCKOO INDUCTRIO live cooking demo' },
  { image: `${assetBase}/cuckoo-inductrio-product-angle.webp`, title: 'Reka Bentuk Premium', copy: 'Permukaan SCHOTT CERAN dengan 3 zon memasak.', alt: 'CUCKOO INDUCTRIO reka bentuk premium 3 zon' }
];

// FAQ (14)
const faqItems = [
  { q: 'Apa itu CUCKOO INDUCTRIO?', a: 'CUCKOO INDUCTRIO ialah hybrid induction hob premium dengan 2 induction zone dan 1 highlight zone.' },
  { q: 'Berapa zon memasak INDUCTRIO?', a: 'INDUCTRIO mempunyai 3 zon memasak: 2 induction zone dan 1 highlight zone.' },
  { q: 'Apa beza induction zone dan highlight zone?', a: 'Induction zone memanaskan cookware induction dengan cepat dan responsif. Highlight zone pula memberi pilihan tambahan untuk cookware tertentu yang tidak sesuai dengan induction.' },
  { q: 'Berapa harga CUCKOO INDUCTRIO?', a: 'Harga outright ialah RM3,400. Rental tanpa casing ialah RM103/bulan, manakala rental dengan casing ialah RM113/bulan untuk kontrak 5 tahun.' },
  { q: 'Adakah rental termasuk servis dan warranty?', a: 'Ya, pelan rental termasuk free 5-year service & warranty mengikut terma CUCKOO.' },
  { q: 'Adakah INDUCTRIO perlukan plug khas?', a: 'Ya. INDUCTRIO memerlukan 15A power plug dan kesesuaian wiring/MCB. Pemeriksaan atau nasihat pemasangan mungkin diperlukan.' },
  { q: 'Adakah INDUCTRIO sesuai untuk rumah biasa?', a: 'Ya, tetapi ia lebih sesuai untuk rumah yang boleh menyediakan power plug dan wiring yang sesuai. Jika tidak pasti, pelanggan boleh semak dahulu sebelum installation.' },
  { q: 'Apa kelebihan Direct Touch Sensor?', a: 'Direct Touch Sensor membantu kawalan suhu menjadi lebih tepat dan konsisten, terutama untuk masakan yang memerlukan kawalan haba yang baik.' },
  { q: 'Apa kelebihan SCHOTT CERAN glass?', a: 'SCHOTT CERAN ialah German glass-ceramic surface yang premium, tahan haba dan memberi rupa dapur yang kemas serta moden.' },
  { q: 'Siapa paling sesuai guna CUCKOO INDUCTRIO?', a: 'Sesuai untuk keluarga yang kerap memasak, rumah baru dengan kitchen cabinet, pengguna yang mahu dapur built-in premium, dan pelanggan yang mahu 3 zon memasak dengan servis berkala CUCKOO.' },
  { q: 'Boleh guna semua jenis periuk?', a: 'Untuk induction zone, cookware perlu sesuai dengan induction. Highlight zone memberi lebih fleksibiliti untuk beberapa jenis cookware lain, tetapi pengguna tetap perlu ikut panduan cookware yang sesuai dan selamat.' },
  { q: 'Adakah induction lebih selamat daripada dapur gas?', a: 'Induction membantu mengurangkan risiko tertentu seperti api terbuka dan kebocoran gas kerana ia tidak menggunakan tong gas. Namun pengguna masih perlu berhati-hati kerana cookware dan permukaan dapur boleh menjadi panas.' },
  { q: 'Adakah INDUCTRIO sesuai untuk masak banyak?', a: 'Ya. Dengan 3 zon memasak, INDUCTRIO lebih sesuai untuk keluarga yang kerap memasak beberapa hidangan dalam satu masa.' },
  { q: 'Adakah INDUCTRIO ada servis berkala?', a: 'Ya, untuk pelanggan rental, servis berkala dan warranty disediakan mengikut terma pelan CUCKOO. CUCKOO+ Care Service Package (CCSP) untuk INDUCTRIO ialah RM556.50/tahun, tertakluk terma & harga semasa.' }
];

// ── JSON-LD ─────────────────────────────────────────────────────────────
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  '@id': `${pageUrl}#product`,
  name: 'CUCKOO INDUCTRIO Hybrid Induction Hob / Dapur Induksi Hybrid 3 Zon',
  alternateName: ['CUCKOO INDUCTRIO', 'INDUCTRIO Hybrid Hob', 'Dapur Induksi CUCKOO INDUCTRIO'],
  url: pageUrl,
  mainEntityOfPage: pageUrl,
  brand: { '@type': 'Brand', name: 'CUCKOO' },
  manufacturer: { '@type': 'Organization', name: 'CUCKOO' },
  category: 'Hybrid induction hob / cooktop',
  model: 'INDUCTRIO',
  image: [absoluteUrl(img.render), absoluteUrl(img.zones), absoluteUrl(img.productImage), absoluteUrl(img.dimensions)],
  description:
    'CUCKOO INDUCTRIO ialah dapur induksi hybrid premium dengan 2 Induction zone dan 1 Highlight zone, permukaan SCHOTT CERAN German glass-ceramic, IH-Ultra High Temperature Mode, IH Booster Mode, Direct Touch Sensor, Heating Level 1–10 dan Voice Navigation.',
  material: 'SCHOTT CERAN German Glass-Ceramic',
  weight: { '@type': 'QuantitativeValue', value: '10.3', unitCode: 'KGM' },
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Cooking zones', value: '2 Induction zone + 1 Highlight zone (hybrid)' },
    { '@type': 'PropertyValue', name: 'Surface', value: 'SCHOTT CERAN German Glass-Ceramic' },
    { '@type': 'PropertyValue', name: 'Power consumption', value: '3300W max (Induction 1800W / 2000W Booster each)' },
    { '@type': 'PropertyValue', name: 'Power supply', value: '220V / 60Hz, 15A power plug required' },
    { '@type': 'PropertyValue', name: 'Heating level', value: 'Level 1–10' },
    { '@type': 'PropertyValue', name: 'Special feature', value: 'Direct Touch Sensor' },
    { '@type': 'PropertyValue', name: 'Voice navigation', value: 'English' },
    { '@type': 'PropertyValue', name: 'Weight', value: '10.3 kg' }
  ],
  offers: [
    {
      '@type': 'Offer', '@id': `${pageUrl}#rental-offer`, url: pageUrl, name: 'CUCKOO INDUCTRIO Rental',
      priceCurrency: 'MYR', price: '103', priceValidUntil,
      availability: 'https://schema.org/InStock', itemCondition: 'https://schema.org/NewCondition',
      seller: { '@type': 'Organization', name: 'CUCKOO Nano' },
      description: 'Rental dari RM103/bulan (tanpa casing) atau RM113/bulan (dengan casing) untuk kontrak 5 tahun, termasuk free 5-year service & warranty mengikut terma. Tertakluk kelayakan & promo semasa.'
    },
    {
      '@type': 'Offer', '@id': `${pageUrl}#outright-offer`, url: pageUrl, name: 'CUCKOO INDUCTRIO Outright',
      priceCurrency: 'MYR', price: '3400', priceValidUntil,
      availability: 'https://schema.org/InStock', itemCondition: 'https://schema.org/NewCondition',
      seller: { '@type': 'Organization', name: 'CUCKOO Nano' },
      description: 'Harga outright RM3,400, bayar sekali sahaja. Tertakluk kepada stok dan promosi semasa.'
    }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({ '@type': 'Question', name: item.q, acceptedAnswer: { '@type': 'Answer', text: item.a } }))
};

const breadcrumbSchema = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.cuckoonano.com/' },
    { '@type': 'ListItem', position: 2, name: 'Produk', item: 'https://www.cuckoonano.com/products/' },
    { '@type': 'ListItem', position: 3, name: 'Induction', item: 'https://www.cuckoonano.com/products/induction/' },
    { '@type': 'ListItem', position: 4, name: 'CUCKOO INDUCTRIO', item: pageUrl }
  ]
};

const meta = {
  title: 'CUCKOO INDUCTRIO Hybrid Induction Hob | Rental & Harga',
  description:
    'CUCKOO INDUCTRIO dapur induksi hybrid premium 3 zon — SCHOTT CERAN glass, Direct Touch Sensor & IH Booster. Rental dari RM103/bulan, outright RM3,400.',
  canonical: pageUrl,
  ogImage: absoluteUrl(img.render),
  ogType: 'product',
  preloadImages: [encodeURI(img.heroClean)]
};
---

<BaseLayout {...meta}>
  <style is:inline>
    html { scroll-behavior: smooth; }
    .warm-blob { background: radial-gradient(circle at 40% 32%, rgba(122,14,35,.08), transparent 44%), radial-gradient(circle at 72% 64%, rgba(215,168,79,.16), transparent 46%), linear-gradient(145deg, #fff7f3, #ffffff); }
    .ink-panel { background: radial-gradient(circle at 78% 12%, rgba(216,166,74,.16), transparent 34%), linear-gradient(135deg, #35040f 0%, #6f0b20 48%, #8E1830 100%); }
    .floating { animation: floating 5.5s ease-in-out infinite; }
    @keyframes floating { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
    .fade-up { opacity: 0; transform: translateY(24px); transition: opacity .55s ease, transform .55s ease; }
    .fade-up.visible { opacity: 1; transform: translateY(0); }
    @media (prefers-reduced-motion: reduce) { .floating, .fade-up { animation: none; transition: none; opacity: 1; transform: none; } }
  </style>

  <div class="bg-brand-cream text-brand-ink antialiased">

    <!-- ============================ 1 · HERO ============================ -->
    <section id="hero" class="warm-blob relative overflow-hidden px-4 py-10 text-brand-ink sm:px-6 lg:px-8 lg:py-16">
      <div class="pointer-events-none absolute -right-24 top-1/2 h-[560px] w-[560px] -translate-y-1/2 rounded-full bg-brand-soft/50 blur-3xl"></div>
      <div class="pointer-events-none absolute -left-32 bottom-0 h-80 w-80 rounded-full bg-gold/10 blur-3xl"></div>

      <div class="relative mx-auto grid max-w-7xl gap-7 lg:grid-cols-[1.04fr_.96fr] lg:items-start lg:gap-10">
        <!-- A · Copy -->
        <div class="order-1 text-center lg:col-start-1 lg:row-start-1 lg:text-left">
          <div class="mb-5 flex max-w-full justify-center gap-2 overflow-x-auto px-1 whitespace-nowrap lg:justify-start">
            <span class="shrink-0 rounded-full bg-white/85 px-3 py-1.5 text-[10px] font-black uppercase tracking-[.13em] text-brand shadow-soft ring-1 ring-brand/10 sm:px-4 sm:py-2 sm:text-xs sm:tracking-[.16em]">✨ Premium 3 Zon</span>
            <span class="shrink-0 rounded-full bg-white/70 px-3 py-1.5 text-[10px] font-black uppercase tracking-[.13em] text-brand-ink shadow-soft ring-1 ring-brand/10 sm:px-4 sm:py-2 sm:text-xs sm:tracking-[.16em]">Hybrid Induction Hob</span>
          </div>

          <p class="text-xs font-black uppercase tracking-[.24em] text-brand-gold sm:text-sm">CUCKOO Induction Malaysia</p>

          <h1 class="mt-3 text-[2.1rem] font-black leading-[1.05] tracking-tight text-brand-ink sm:text-5xl lg:text-[3.4rem]">
            CUCKOO INDUCTRIO — Dapur Induksi Hybrid 3 Zon
            <span class="mt-1 block bg-gradient-to-r from-[#6f0b20] via-[#a3172d] to-[#4a0615] bg-clip-text text-transparent drop-shadow-[0_10px_22px_rgba(111,11,32,.18)]">Dari RM103/bulan</span>
