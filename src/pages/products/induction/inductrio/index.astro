  <script is:inline>
    (function () {
      const heroImg = document.getElementById('heroImg');
      const btns = document.querySelectorAll('.hero-thumb');
      btns.forEach((btn) => {
        btn.addEventListener('click', () => {
          if (heroImg) { heroImg.style.opacity = '0'; setTimeout(() => { heroImg.src = btn.dataset.heroThumb; heroImg.style.opacity = '1'; }, 150); }
          btns.forEach((b) => { b.classList.add('bg-brand/5', 'text-brand-ink/60'); b.classList.remove('bg-white', 'text-brand-ink', 'ring-2', 'ring-brand'); });
          btn.classList.add('bg-white', 'text-brand-ink', 'ring-2', 'ring-brand'); btn.classList.remove('bg-brand/5', 'text-brand-ink/60');
        });
      });
    })();

    (function () {
      const els = document.querySelectorAll('.fade-up');
      if (!('IntersectionObserver' in window)) { els.forEach((el) => el.classList.add('visible')); return; }
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => { if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); } });
      }, { threshold: 0.1 });
      els.forEach((el) => observer.observe(el));
    })();

    // Marquee auto-scroll berterusan (kad diduplikasi = separuh scrollWidth ialah 1 set)
    (function () {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const initMarquee = (slider) => {
        const track = slider.querySelector('[data-marquee-track]');
        if (!track) return;
        const speed = 0.5;
        let paused = reduce;
        const half = () => track.scrollWidth / 2;
        const wrap = () => { const h = half(); if (h > 0 && track.scrollLeft >= h) track.scrollLeft -= h; };
        const visible = () => track.offsetParent !== null && track.scrollWidth > track.clientWidth + 4;
        const tick = () => {
          if (!paused && visible()) { track.scrollLeft += speed; wrap(); }
          window.requestAnimationFrame(tick);
        };
        const pause = () => { paused = true; };
        const resume = () => { if (!reduce) paused = false; };
        ['pointerenter', 'pointerdown', 'touchstart'].forEach((ev) => slider.addEventListener(ev, pause, { passive: true }));
        ['pointerleave', 'pointercancel', 'touchend'].forEach((ev) => slider.addEventListener(ev, resume, { passive: true }));
        track.addEventListener('scroll', wrap, { passive: true });
        if (!reduce) window.requestAnimationFrame(tick);
      };
      document.querySelectorAll('[data-marquee]').forEach(initMarquee);
    })();
  </script>
