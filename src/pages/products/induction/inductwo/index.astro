// FAQ (10)
const faqItems = [
  { q: 'INDUCTWO ni induction penuh atau hybrid?', a: 'INDUCTWO ialah hybrid hob — satu zon Induction dan satu zon Highlight. Zon induction memanaskan periuk magnetik secara terus, manakala zon highlight pula boleh digunakan dengan kebanyakan jenis periuk.' },
  { q: 'Perlu wiring khas untuk pasang?', a: 'Tidak. INDUCTWO menggunakan plug 13A biasa, jadi anda boleh cucuk pada soket sedia ada tanpa pendawaian khas. Untuk pemasangan built-in, ruang potongan countertop perlu disemak dahulu.' },
  { q: 'Permukaan dapur jadi panas tak?', a: 'Ya, permukaan boleh menjadi panas — terutama zon highlight dan kawasan di bawah periuk akibat haba dari periuk itu sendiri. Berhati-hati menyentuh permukaan sebaik selepas memasak.' },
  { q: 'Boleh guna semua jenis periuk?', a: 'Zon induction memerlukan periuk yang sesuai untuk induksi (magnetik). Zon highlight lebih fleksibel dan boleh digunakan dengan kebanyakan periuk. Jika anda tak pasti, WhatsApp kami untuk semak.' },
  { q: 'Apa beza pilihan "tanpa casing" dan "dengan casing"?', a: 'Tanpa casing sesuai untuk pemasangan built-in (dipasang rata ke dalam countertop). Dengan casing pula menjadikannya free-standing — boleh diletak atas meja dan dialih bila perlu.' },
  { q: 'Promo RM12/bulan untuk berapa lama?', a: 'RM12/bulan ialah harga promosi untuk tempoh kempen semasa, tertakluk kepada terma dan kelayakan. WhatsApp kami untuk semak promo terkini dan tempohnya.' },
  { q: 'Beza rental dan outright macam mana?', a: 'Rental ialah bayaran bulanan untuk tempoh kontrak 5 tahun dan sesuai jika anda mahu bayaran permulaan rendah. Outright pula bayar sekali sahaja pada RM2,600. Pilih ikut keselesaan bajet anda.' },
  { q: 'Ada servis atau penyelenggaraan?', a: 'Ada pakej servis CUCKOO+ Care Service (CCSP) pada RM493.50/tahun untuk bantu jaga keadaan produk. Untuk pelan rental, servis berkala disediakan mengikut terma pelan. Butiran boleh disemak bersama ejen sebelum anda confirm.' },
  { q: 'Saiz INDUCTWO sesuai dengan dapur saya?', a: 'Dimensi unit ialah 588mm (lebar) x 508mm (dalam) x 67mm (tinggi) dengan berat 9kg. Ukur ruang dapur anda dahulu, dan kami boleh bantu semak kesesuaian pemasangan.' },
  { q: 'Selamat untuk rumah ada anak kecil?', a: 'Tanpa api terbuka dan tanpa tong gas, ia membantu mengurangkan beberapa risiko di dapur. Namun permukaan masih boleh menjadi panas selepas memasak, jadi anak kecil tetap perlu diawasi.' },
  { q: 'Adakah CUCKOO INDUCTWO ada servis berkala?', a: 'Ya. Untuk pelan rental, CUCKOO INDUCTWO hadir dengan servis berkala mengikut jadual, biasanya setiap 4 bulan tertakluk kepada terma CUCKOO.' },
  { q: 'Apa yang dibuat semasa servis INDUCTWO?', a: 'Pasukan servis akan membuat pemeriksaan dan penjagaan seperti membersihkan permukaan hob, memeriksa touch panel, touch sensor, on/off button, power plug, temperature test dan mengemas kini service card.' },
  { q: 'Berapa harga CUCKOO+ Care Service Package untuk INDUCTWO?', a: 'Berdasarkan maklumat servis, CUCKOO+ Care Service Package untuk INDUCTWO ialah RM493.50 setahun, tertakluk kepada terma dan harga semasa.' },
  { q: 'Adakah servis ini sama seperti warranty?', a: 'Servis dan warranty adalah berbeza. Servis berkala ialah penjagaan dan pemeriksaan mengikut jadual, manakala warranty pula tertakluk kepada terma pelan produk CUCKOO.' }
];

// ── JSON-LD ─────────────────────────────────────────────────────────────
