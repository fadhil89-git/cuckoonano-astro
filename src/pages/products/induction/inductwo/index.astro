    { '@type': 'PropertyValue', name: 'Auto-cook modes', value: 'Pan Fry, Grill, Hot Pot, Boil, Keep Warm' },
    { '@type': 'PropertyValue', name: 'Dimensions', value: '588mm (W) x 508mm (D) x 67mm (H)' },
    { '@type': 'PropertyValue', name: 'Weight', value: '9 kg' }
  ],
  offers: [
    {
      '@type': 'Offer',
      '@id': `${pageUrl}#rental-offer`,
      url: pageUrl,
      name: 'CUCKOO INDUCTWO Rental Promo',
      priceCurrency: 'MYR',
      price: '12',
      priceValidUntil,
      availability: 'https://schema.org/InStock',
      itemCondition: 'https://schema.org/NewCondition',
      seller: { '@type': 'Organization', name: 'CUCKOO Nano' },
