  { image: `${assetBase}/dapur-induksi-cuckoo-inductwo-mod-masak-kuali-stir-fry-malaysia.webp`, title: 'Masak Guna Kuali', copy: 'Sesuai untuk goreng & tumis guna kuali kegemaran.', alt: 'CUCKOO INDUCTWO masak guna kuali stir fry' }
