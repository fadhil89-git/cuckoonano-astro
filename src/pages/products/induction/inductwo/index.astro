// Galeri poster (square 1080x1080) — Komen 2
const posterImages = [
  { src: `${assetBase}/dapur-induksi-cuckoo-inductwo-induction-hob-poster-1.webp`, alt: 'CUCKOO INDUCTWO — masak lebih mudah & menyeronokkan' },
  { src: `${assetBase}/dapur-induksi-cuckoo-inductwo-induction-hob-poster-2.webp`, alt: 'CUCKOO INDUCTWO — 5 mod memasak: Pan Fry, Grill, Hot Pot, Boil, Keep Warm' },
  { src: `${assetBase}/dapur-induksi-cuckoo-inductwo-induction-hob-poster-4.webp`, alt: 'CUCKOO INDUCTWO — mod haba tinggi untuk rasa wok hei' },
  { src: `${assetBase}/dapur-induksi-cuckoo-inductwo-induction-hob-poster-5.webp`, alt: 'CUCKOO INDUCTWO — masak pelbagai hidangan serentak' },
  { src: `${assetBase}/dapur-induksi-cuckoo-inductwo-induction-hob-poster-6.webp`, alt: 'CUCKOO INDUCTWO — kembalikan keseronokan memasak' },
  { src: `${assetBase}/dapur-induksi-cuckoo-inductwo-induction-hob-poster-7.webp`, alt: 'CUCKOO INDUCTWO — multitasking di dapur' },
  { src: `${assetBase}/dapur-induksi-cuckoo-inductwo-induction-hob-poster-8.webp`, alt: 'CUCKOO INDUCTWO — jimat masa memasak' }
