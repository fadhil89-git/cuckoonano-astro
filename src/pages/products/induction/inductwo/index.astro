    <div data-promo></div>
    <div data-product-selector data-initial="induction"></div>
    <div data-agent-block></div>
  </div>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <script is:inline>
    (function () {
      const heroImg = document.getElementById('heroImg');
      const btns = document.querySelectorAll('.hero-thumb');
      btns.forEach((btn) => {
        btn.addEventListener('click', () => {
          if (heroImg) { heroImg.style.opacity = '0'; setTimeout(() => { heroImg.src = btn.dataset.heroThumb; heroImg.style.opacity = '1'; }, 150); }
          btns.forEach((b) => { b.classList.add('bg-brand/5', 'text-brand-ink/60'); b.classList.remove('bg-white', 'text-brand-ink', 'ring-2', 'ring-brand'); });
          btn.classList.add('bg-white', 'text-brand-ink', 'ring-2', 'ring-brand'); btn.classList.remove('bg-brand/5', 'text-brand-ink/60');
        });
      });
    })();

    (function () {
      const els = document.querySelectorAll('.fade-up');
      if (!('IntersectionObserver' in window)) { els.forEach((el) => el.classList.add('visible')); return; }
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => { if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); } });
      }, { threshold: 0.1 });
      els.forEach((el) => observer.observe(el));
    })();

    // Marquee auto-scroll berterusan (kad diduplikasi = separuh scrollWidth ialah 1 set)
    (function () {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const initMarquee = (slider) => {
        const track = slider.querySelector('[data-marquee-track]');
        if (!track) return;
        const speed = 0.5; // px setiap frame
        let paused = reduce;
        const half = () => track.scrollWidth / 2;
        const wrap = () => { const h = half(); if (h > 0 && track.scrollLeft >= h) track.scrollLeft -= h; };
        const visible = () => track.offsetParent !== null && track.scrollWidth > track.clientWidth + 4;
        const tick = () => {
          if (!paused && visible()) { track.scrollLeft += speed; wrap(); }
          window.requestAnimationFrame(tick);
        };
        const pause = () => { paused = true; };
        const resume = () => { if (!reduce) paused = false; };
        ['pointerenter', 'pointerdown', 'touchstart'].forEach((ev) => slider.addEventListener(ev, pause, { passive: true }));
        ['pointerleave', 'pointercancel', 'touchend'].forEach((ev) => slider.addEventListener(ev, resume, { passive: true }));
        track.addEventListener('scroll', wrap, { passive: true });
        if (!reduce) window.requestAnimationFrame(tick);
      };
      document.querySelectorAll('[data-marquee]').forEach(initMarquee);
    })();

    // Lightbox galeri poster INDUCTWO
    (function () {
      const lightbox = document.querySelector('[data-poster-lightbox]');
      if (!lightbox) return;
      const image = lightbox.querySelector('[data-poster-image]');
      const count = lightbox.querySelector('[data-poster-count]');
      const buttons = Array.from(document.querySelectorAll('[data-poster-open]'));
      if (!image || buttons.length === 0) return;
      let idx = 0;
      const show = (i) => {
        idx = (i + buttons.length) % buttons.length;
        const b = buttons[idx];
        image.src = b.getAttribute('data-poster-open') || '';
        image.alt = b.getAttribute('data-poster-alt') || 'Poster CUCKOO INDUCTWO';
        if (count) count.textContent = `${idx + 1} / ${buttons.length}`;
      };
      const open = (i) => { show(i); lightbox.classList.remove('hidden'); lightbox.classList.add('flex'); document.body.style.overflow = 'hidden'; };
      const close = () => { lightbox.classList.add('hidden'); lightbox.classList.remove('flex'); document.body.style.overflow = ''; };
      buttons.forEach((b, i) => b.addEventListener('click', () => open(i)));
      lightbox.querySelector('[data-poster-close]')?.addEventListener('click', close);
      lightbox.querySelector('[data-poster-backdrop]')?.addEventListener('click', close);
      lightbox.querySelector('[data-poster-prev]')?.addEventListener('click', () => show(idx - 1));
      lightbox.querySelector('[data-poster-next]')?.addEventListener('click', () => show(idx + 1));
      let sx = 0;
      lightbox.addEventListener('touchstart', (e) => { sx = e.touches[0]?.clientX || 0; }, { passive: true });
      lightbox.addEventListener('touchend', (e) => {
        const t = e.changedTouches[0]; if (!t) return;
        const dx = t.clientX - sx; if (Math.abs(dx) > 45) show(idx + (dx < 0 ? 1 : -1));
      }, { passive: true });
      document.addEventListener('keydown', (e) => {
        if (lightbox.classList.contains('hidden')) return;
        if (e.key === 'Escape') close();
        if (e.key === 'ArrowLeft') show(idx - 1);
        if (e.key === 'ArrowRight') show(idx + 1);
      });
    })();
  </script>
</BaseLayout>
