// "Kenapa beralih ke induction?" — 6 kad (wording lembut, jujur)
const inductionCards = [
  {
    img: `${indBase}/kenapa-induction-cuckoo-inductrio-inductwo-card-1-tiada-api-terbuka.webp`,
    title: 'Tiada Api Terbuka',
    copy: 'Masak guna haba induksi & highlight — tiada api terbuka di atas dapur semasa memasak.'
  },
  {
    img: `${indBase}/kenapa-induction-cuckoo-inductrio-inductwo-card-2-risiko-kebocoran-gas.webp`,
    title: 'Kurang Risiko Kebocoran Gas',
    copy: 'Tidak menggunakan tong gas, jadi anda boleh kurangkan risiko kebocoran gas di dapur.'
  },
  {
    img: `${indBase}/kenapa-induction-cuckoo-inductrio-inductwo-card-3-anak-kecil-children.webp`,
    title: 'Lebih Tenang Untuk Rumah Ada Anak Kecil',
    copy: 'Tanpa api terbuka, suasana memasak lebih terkawal. Permukaan masih boleh panas, jadi anak tetap perlu diawasi.'
  },
  {
    img: `${indBase}/kenapa-induction-cuckoo-inductrio-inductwo-card-4-kawalan-haba-lebih-tepat.webp`,
    title: 'Kawalan Haba Lebih Tepat',
    copy: 'Tetapan haba lebih konsisten membantu masakan lebih sekata berbanding api yang naik turun.'
  },
  {
    img: `${indBase}/kenapa-induction-cuckoo-inductrio-inductwo-card-5-dapur-kurang-bahang.webp`,
    title: 'Dapur Kurang Bahang',
    copy: 'Haba lebih tertumpu pada periuk, jadi dapur cenderung terasa kurang bahang berbanding dapur gas.'
  },
  {
    img: `${indBase}/kenapa-induction-cuckoo-inductrio-inductwo-card-5-mudah-bersih-easy-clean.webp`,
    title: 'Lebih Mudah Dibersihkan',
    copy: 'Permukaan kaca rata mudah dilap. Tiada burner atau dudukan periuk yang menyusahkan.'
  }
];

// 7 sebab pilih INDUCTWO
const whyInductwo = [
  { n: '01', t: 'Hybrid 2-in-1', d: 'Satu zon Induction + satu zon Highlight dalam satu dapur — fleksibel untuk pelbagai jenis masakan & periuk.' },
  { n: '02', t: 'France Eurokera Ceramic Glass', d: 'Permukaan kaca seramik dari France — tahan lasak, kemas dan mudah dibersihkan.' },
  { n: '03', t: 'Plug 13A — Mudah Pasang', d: 'Cucuk pada soket 13A biasa. Tak perlu wiring khas yang menyusahkan untuk mula guna.' },
  { n: '04', t: 'Quick Heating + Turbo Mode', d: 'Panas lebih pantas bila perlu — memasak boleh sampai 3 kali lebih pantas berbanding dapur gas biasa.' },
  { n: '05', t: 'Auto-Cook 5 Mod', d: 'Pan Fry, Grill, Hot Pot, Boil dan Keep Warm — pilih mod, masak lebih mudah.' },
  { n: '06', t: 'Dual Highlight Zone', d: 'Zon highlight dengan expansion function — sesuai untuk periuk pelbagai saiz.' }
];

// Mod memasak (5)
const cookingModes = [
  { icon: `${indBase}/pan-fry.webp`, t: 'Pan Fry', d: 'Menggoreng harian — telur, ikan, ayam dan lauk biasa.' },
  { icon: `${indBase}/grill.webp`, t: 'Grill', d: 'Memanggang ringkas untuk daging, sosej atau sayur.' },
  { icon: `${indBase}/hot-pot.webp`, t: 'Hot Pot', d: 'Sesuai untuk steamboat & masakan berkuah ramai-ramai.' },
  { icon: `${indBase}/boil.webp`, t: 'Boil', d: 'Merebus & mendidihkan air dengan lebih pantas.' },
  { icon: `${indBase}/keep-warm.webp`, t: 'Keep Warm', d: 'Pastikan makanan kekal panas sebelum dihidang.' }
];

// Manfaat pelanggan
const benefits = [
  { e: '⚡', t: 'Masak Lebih Pantas', d: 'Quick Heating + Turbo Mode jimatkan masa harian anda.' },
  { e: '🧼', t: 'Dapur Lebih Bersih', d: 'Permukaan kaca rata, tiada burner — lap sekali siap.' },
  { e: '🎯', t: 'Kawalan Suhu Tepat', d: 'Haba konsisten untuk hasil masakan lebih sekata.' },
  { e: '🏠', t: 'Sesuai Dapur Moden', d: 'Reka bentuk kemas, boleh built-in atau free-standing.' }
];

// CUCKOO+ Care Service (khusus page INDUCTWO)
const serviceBase = '/assets/images/products/induction/servis';
const technicianImg = '/assets/images/service/Cuckoo-Servis copy.webp';

const serviceCards = [
  { icon: `${serviceBase}/kitchen-check-list-icon-natural-care-service-visit.webp`, t: 'Servis Setiap 4 Bulan', d: 'Pasukan CUCKOO+ Care Service datang mengikut jadual untuk bantu pastikan INDUCTWO anda diperiksa dan dijaga secara berkala.' },
  { icon: `${serviceBase}/kitchen-check-list-icon-one-to-one.webp`, t: 'Servis Profesional 1-to-1', d: 'Servis dibuat secara customised dan profesional oleh pasukan servis CUCKOO untuk memastikan keadaan hob diperiksa dengan teliti.' },
  { icon: `${serviceBase}/kitchen-check-list-icon-ncs-8.webp`, t: 'CCS 8-Point Check', d: 'Pemeriksaan pada bahagian penting induction hob supaya setiap komponen utama kekal bersih, diperiksa dan well-maintained.' },
  { icon: `${serviceBase}/kitchen-check-list-icon-additional-care-service.webp`, t: 'Additional Care Service', d: 'Termasuk steam sterilisation untuk chopping board dan sink sebagai penjagaan tambahan di kawasan dapur.' }
];

const ccsCheck = [
  'Temperature Test',
  'Tempered Glass Surface',
  'Touch Sensor',
  'Touch Panel',
  'Service Card Explanation',
  'On/Off Button',
  'Power Plug',
  'Pemeriksaan kebersihan & keadaan keseluruhan hob'
];

// Nota: turutan fail step terbalik dari turutan proses
const serviceSteps = [
  { img: `${serviceBase}/kitchen-check-list-step-06.webp`, t: 'Prepare Steamer & Hygiene Kit', d: 'Pasukan servis menyediakan steamer dan hygiene kit sebelum proses penjagaan bermula.' },
  { img: `${serviceBase}/kitchen-check-list-step-05.webp`, t: 'Remove Stubborn Stain', d: 'Kotoran atau stain pada permukaan hob dibersihkan menggunakan scraper yang sesuai.' },
  { img: `${serviceBase}/kitchen-check-list-step-04.webp`, t: 'Clean With Induction Cleaner', d: 'Permukaan hob dilap dengan induction cleaner supaya permukaan kaca lebih bersih dan kemas.' },
  { img: `${serviceBase}/kitchen-check-list-step-03.webp`, t: 'Temperature Check', d: 'Suhu pada bahagian heating zone diperiksa untuk memastikan fungsi pemanasan berada dalam keadaan baik.' },
  { img: `${serviceBase}/kitchen-check-list-step-02.webp`, t: 'Sterilise Cookware / Kitchen Area', d: 'Servis boleh termasuk sterilisation untuk cookware tertentu seperti periuk stainless steel, chopping board atau sink, mengikut pakej servis.' },
  { img: `${serviceBase}/kitchen-check-list-step-01.webp`, t: 'Update Service Card', d: 'Rekod servis dikemas kini pada service card supaya pelanggan tahu status lawatan servis yang telah dibuat.' }
];

// Galeri gambar sebenar
const galleryItems = [
  { image: `${assetBase}/dapur-induksi-cuckoo-inductwo-produk-sebenar-dual-zone-malaysia.webp`, title: 'CUCKOO INDUCTWO', copy: 'Permukaan kaca seramik dengan zon Induction + Highlight.', alt: 'Dapur induksi CUCKOO INDUCTWO hybrid hob dual zone' },
  { image: `${assetBase}/dapur-induksi-cuckoo-inductwo-masak-serentak-dua-zon-malaysia.webp`, title: 'Masak Serentak Dua Zon', copy: 'Guna kedua-dua zon pada masa sama untuk masak lebih cepat.', alt: 'CUCKOO INDUCTWO masak serentak dua zon' },
  { image: `${assetBase}/dapur-induksi-cuckoo-inductwo-mod-rebus-hot-pot-malaysia.webp`, title: 'Rebus & Hot Pot', copy: 'Air mendidih pantas untuk steamboat dan masakan berkuah.', alt: 'CUCKOO INDUCTWO mod rebus hot pot' },
  { image: `${assetBase}/dapur-induksi-cuckoo-inductwo-masak-udang-kuali-malaysia.webp`, title: 'Masak Guna Kuali', copy: 'Sesuai untuk goreng & tumis guna kuali kegemaran.', alt: 'CUCKOO INDUCTWO masak udang guna kuali' },
  { image: `${assetBase}/dapur-induksi-cuckoo-inductwo-masak-ketam-seafood-malaysia.webp`, title: 'Masakan Seafood', copy: 'Haba kuat membantu masak hidangan seafood dengan pantas.', alt: 'CUCKOO INDUCTWO masak ketam seafood' },
  { image: `${assetBase}/dapur-induksi-cuckoo-inductwo-pemasangan-built-in-countertop-malaysia.webp`, title: 'Pemasangan Built-In', copy: 'Dipasang rata pada countertop untuk dapur yang kemas.', alt: 'CUCKOO INDUCTWO pemasangan built-in countertop' },
  { image: `${assetBase}/dapur-induksi-cuckoo-inductwo-free-standing-meja-malaysia.webp`, title: 'Free-Standing', copy: 'Letak atas meja dengan casing — boleh dialih bila perlu.', alt: 'CUCKOO INDUCTWO free standing atas meja dengan casing' },
  { image: `${assetBase}/dapur-induksi-cuckoo-inductwo-set-dapur-lengkap-rice-cooker-malaysia.webp`, title: 'Set Dapur Lengkap', copy: 'Padan dengan rice cooker & peralatan dapur CUCKOO.', alt: 'CUCKOO INDUCTWO bersama rice cooker set dapur' },
