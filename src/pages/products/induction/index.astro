---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const meta = {
  "title": "Induction CUCKOO | Produk CUCKOO",
  "description": "Pilihan induction cooker CUCKOO untuk dapur moden. Semak harga cash/rental, promo terkini dan pilihan produk sesuai.",
  "canonical": "https://www.cuckoonano.com/products/induction/",
  "ogImage": "https://www.cuckoonano.com/assets/images/brand/cuckoo-ebrandstore3.png",
  "ogType": "website"
};
---
<BaseLayout {...meta}>
  <section class="hero-pattern px-4 py-16 sm:px-6 lg:px-8"><div class="mx-auto max-w-7xl"><p class="font-bold text-brand">Kategori Produk</p><h1 class="mt-3 max-w-3xl text-4xl font-black tracking-tight sm:text-5xl">Induction CUCKOO</h1><p class="mt-5 max-w-2xl text-lg leading-8 text-muted">Pilihan induction cooker CUCKOO untuk dapur moden. Tanya harga cash, rental bulanan dan promo terkini melalui ejen.</p><div class="mt-8"><a href="https://wasap.my/60139916967" class="rounded-full bg-brand px-7 py-4 text-center font-bold text-white shadow-glow transition-all duration-300 hover:-translate-y-1 hover:bg-brand-dark">WhatsApp Ejen</a></div></div></section><div data-product-selector data-initial="induction"></div><div data-promo></div><div data-agent-block></div>
</BaseLayout>
