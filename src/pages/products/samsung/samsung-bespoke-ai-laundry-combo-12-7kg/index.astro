<script is:inline>
  // Hero product image switcher (desktop + mobile)
  function setupHeroProductSwitcher(imageId, buttonClass, inactiveClass, activeClass) {
    const image = document.getElementById(imageId);
    const buttons = document.querySelectorAll('.' + buttonClass);
    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        if (!image) return;
        image.src = button.dataset.heroProduct;
        buttons.forEach((thumb) => { thumb.className = buttonClass + ' ' + inactiveClass; });
        button.className = buttonClass + ' ' + activeClass;
      });
    });
  }
  setupHeroProductSwitcher('heroProductImage', 'hero-product-thumb', 'rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20', 'rounded-full bg-white px-4 py-2 text-xs font-black uppercase tracking-wide text-brand-maroon shadow-sm ring-2 ring-rose-300');
  setupHeroProductSwitcher('heroProductImageMobile', 'hero-product-thumb-mobile', 'rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20', 'rounded-full bg-white px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-brand-maroon shadow-sm ring-2 ring-rose-300');

  const productSlides = [
    { src: '/assets/images/products/samsung/washer-dryer/cuckoo-samsung-bespoke-ai-washer-dryer-12kg-wash-7kg-dry-mesin-basuh-pengering-1.webp', title: '', desc: 'Anak ramai pun tak risau, kapasiti besar 12kg.', alt: 'CUCKOO Samsung Bespoke AI Washer Dryer 12kg wash 7kg dry mesin basuh pengering gambar produk 1' },
    { src: '/assets/images/products/samsung/washer-dryer/cuckoo-samsung-bespoke-ai-washer-dryer-12kg-wash-7kg-dry-mesin-basuh-pengering-2.webp', title: '', desc: 'Balik kerja, sumbat je baju. Esok pagi kering.', alt: 'CUCKOO Samsung Bespoke AI Washer Dryer 12kg wash 7kg dry mesin basuh pengering gambar produk 2' },
    { src: '/assets/images/products/samsung/washer-dryer/cuckoo-samsung-bespoke-ai-washer-dryer-12kg-wash-7kg-dry-mesin-basuh-pengering-3.webp', title: '', desc: 'Musim hujan pun tak payah cari dobi.', alt: 'CUCKOO Samsung Bespoke AI Washer Dryer 12kg wash 7kg dry mesin basuh pengering gambar produk 3' },
    { src: '/assets/images/products/samsung/washer-dryer/cuckoo-samsung-bespoke-ai-washer-dryer-12kg-wash-7kg-dry-mesin-basuh-pengering-4.webp', title: '', desc: 'Lepas ni tak payah sidai baju lagi.', alt: 'CUCKOO Samsung Bespoke AI Washer Dryer 12kg wash 7kg dry mesin basuh pengering gambar produk 4' },
    { src: '/assets/images/products/samsung/washer-dryer/cuckoo-samsung-bespoke-ai-washer-dryer-12kg-wash-7kg-dry-mesin-basuh-pengering-5.webp', title: '', desc: 'Baju sekolah anak boleh cuci hari-hari.', alt: 'CUCKOO Samsung Bespoke AI Washer Dryer 12kg wash 7kg dry mesin basuh pengering gambar produk 5' },
    { src: '/assets/images/products/samsung/washer-dryer/cuckoo-samsung-bespoke-ai-washer-dryer-12kg-wash-7kg-dry-mesin-basuh-pengering-6.webp', title: '', desc: 'Tak sempat jemur pagi-pagi pun tak apa.', alt: 'CUCKOO Samsung Bespoke AI Washer Dryer 12kg wash 7kg dry mesin basuh pengering gambar produk 6' },
    { src: '/assets/images/products/samsung/washer-dryer/cuckoo-samsung-bespoke-ai-washer-dryer-12kg-wash-7kg-dry-mesin-basuh-pengering-7.webp', title: '', desc: 'Tak perlu tunggu baju menimbun baru nak cuci.', alt: 'CUCKOO Samsung Bespoke AI Washer Dryer 12kg wash 7kg dry mesin basuh pengering gambar produk 7' },
    { src: '/assets/images/products/samsung/washer-dryer/cuckoo-samsung-bespoke-ai-washer-dryer-12kg-wash-7kg-dry-mesin-basuh-pengering-8.webp', title: '', desc: 'Isteri makin gembira sebab kerja laundry jadi mudah.', alt: 'CUCKOO Samsung Bespoke AI Washer Dryer 12kg wash 7kg dry mesin basuh pengering gambar produk 8' }
  ];

  let currentProductSlide = 0;
  const productSliderImage = document.getElementById('productSliderImage');
  const productSliderTitle = document.getElementById('productSliderTitle');
  const productSliderDesc = document.getElementById('productSliderDesc');
  const productSliderPrev = document.getElementById('productSliderPrev');
  const productSliderNext = document.getElementById('productSliderNext');
  const productSliderDots = document.getElementById('productSliderDots');

  function renderProductSlide(index) {
    const slide = productSlides[index];
    productSliderImage.src = slide.src;
    productSliderImage.alt = slide.alt;
    if (productSliderTitle) {
      productSliderTitle.textContent = slide.title;
      productSliderTitle.style.display = slide.title ? 'block' : 'none';
    }
    if (productSliderDesc) { productSliderDesc.textContent = slide.desc; }
    productSliderDots.innerHTML = '';
    productSlides.forEach((item, dotIndex) => {
      const dot = document.createElement('button');
      dot.type = 'button';
      dot.setAttribute('aria-label', 'Lihat gambar produk ' + (dotIndex + 1));
      dot.className = dotIndex === index
        ? 'h-3 w-8 rounded-full bg-brand-maroon transition'
        : 'h-3 w-3 rounded-full bg-stone-300 transition hover:bg-brand-maroon';
      dot.addEventListener('click', () => { currentProductSlide = dotIndex; renderProductSlide(currentProductSlide); });
      productSliderDots.appendChild(dot);
    });
  }

  if (productSliderPrev && productSliderNext) {
    productSliderPrev.addEventListener('click', () => {
      currentProductSlide = currentProductSlide === 0 ? productSlides.length - 1 : currentProductSlide - 1;
      renderProductSlide(currentProductSlide);
    });
    productSliderNext.addEventListener('click', () => {
      currentProductSlide = currentProductSlide === productSlides.length - 1 ? 0 : currentProductSlide + 1;
      renderProductSlide(currentProductSlide);
    });
  }

  if (productSliderImage) { renderProductSlide(currentProductSlide); }
</script>
