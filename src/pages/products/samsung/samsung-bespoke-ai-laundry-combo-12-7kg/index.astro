---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import AgentSection from '../../../../components/AgentSection.astro';

const base = '/assets/images/products/samsung/washer-dryer';
const heroImg = `${base}/Cuckoo-Samsung-Bespoke-AI-Washer-Dryer-12kg-wash-7kg-dry-transparent.webp`;
// Hero product views (Sisi 1-6)
const sisi1 = `${base}/Samsung-bespoke-ai-img-12kg-wash-7kg-dry-01.webp`; // Depan 1
const sisi2 = `${base}/Samsung-bespoke-ai-img-12kg-wash-7kg-dry-02.webp`; // Depan 2
const sisi3 = `${base}/Samsung-bespoke-ai-img-12kg-wash-7kg-dry-03.webp`; // Buka
const sisi4 = `${base}/Samsung-bespoke-ai-img-12kg-wash-7kg-dry-04.webp`; // Sisi
const sisi5 = `${base}/Samsung-bespoke-ai-img-12kg-wash-7kg-dry-05.webp`; // Belakang
const sisi6 = `${base}/Samsung-bespoke-ai-img-12kg-wash-7kg-dry-06.webp`; // Contro
const pageUrl = 'https://www.cuckoonano.com/products/samsung/samsung-bespoke-ai-laundry-combo-12-7kg/';
const ogImg = 'https://www.cuckoonano.com/assets/images/products/samsung/washer-dryer/cuckoo-samsung-bespoke-ai-washer-dryer-12kg-wash-7kg-dry-mesin-basuh-pengering-1.webp';

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Samsung Bespoke AI Washer Dryer 12/7kg',
  brand: { '@type': 'Brand', name: 'Samsung' },
  description:
    'Samsung Bespoke AI Washer Dryer 12/7kg melalui CUCKOO. Promo RM99/bulan untuk 6 bulan pertama. Harga asal RM115/bulan, pelan rental 60 bulan, tertakluk kepada stok, kelayakan dan terma semasa.',
  url: pageUrl,
  image: ogImg,
  offers: {
    '@type': 'Offer',
    priceCurrency: 'MYR',
    price: '99',
    url: pageUrl,
    description:
      'Promo RM99/bulan untuk 6 bulan pertama. Harga asal RM115/bulan. Pelan rental 60 bulan. Tertakluk kepada stok, kelayakan dan terma semasa.',
    availability: 'https://schema.org/InStock'
  }
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Mesin ini boleh basuh dan kering terus ke?', acceptedAnswer: { '@type': 'Answer', text: 'Ya. Ini ialah washer dryer combo 2-in-1. Anda boleh basuh dan keringkan pakaian menggunakan satu mesin, jadi tak perlu beli dryer berasingan.' } },
    { '@type': 'Question', name: 'Sesuai tak untuk condo atau apartment?', acceptedAnswer: { '@type': 'Answer', text: 'Ya, sangat sesuai untuk condo, apartment dan rumah yang ruang laundry terhad. Sebab mesin ini 2-in-1, anda tak perlu sediakan ruang untuk washer dan dryer berasingan.' } },
    { '@type': 'Question', name: 'Sesuai tak untuk keluarga ramai?', acceptedAnswer: { '@type': 'Answer', text: 'Sesuai. Kapasiti basuhan 12kg membantu urus cucian harian keluarga dengan lebih mudah. Untuk pengeringan, kapasiti dryer ialah 7kg, jadi load yang terlalu banyak mungkin perlu dikeringkan secara berasingan.' } },
    { '@type': 'Question', name: 'Apa maksud promo RM99 untuk 6 bulan pertama?', acceptedAnswer: { '@type': 'Answer', text: 'Bayaran bulanan untuk 6 bulan pertama ialah RM99/bulan. Selepas tempoh promo, bayaran kembali kepada RM115/bulan. Pelan rental untuk tempoh 60 bulan dan tertakluk kepada stok, kelayakan serta terma semasa.' } },
    { '@type': 'Question', name: 'Berapa bayaran masa order?', acceptedAnswer: { '@type': 'Answer', text: 'Bayaran semasa order bergantung kepada promo semasa dan kelayakan customer. WhatsApp untuk semak jumlah bayaran terkini, dokumen diperlukan, stok dan slot pemasangan.' } },
    { '@type': 'Question', name: 'Apa syarat asas sebelum tempahan?', acceptedAnswer: { '@type': 'Answer', text: 'Customer perlu sediakan maklumat asas seperti IC, nombor telefon dan detail alamat pemasangan. Kelayakan tertakluk kepada semakan. Rumah digalakkan mempunyai WiFi yang stabil untuk fungsi pintar SmartThings.' } },
    { '@type': 'Question', name: 'Kalau rumah tiada lif, ada caj tambahan?', acceptedAnswer: { '@type': 'Answer', text: 'Jika rumah jenis flat atau apartment tiada lif dan unit di tingkat 2 atau ke atas, mungkin ada caj tambahan untuk mengangkat mesin. Anggaran caj ialah RM80 bagi setiap tingkat, tertakluk kepada keadaan lokasi dan terma semasa.' } },
    { '@type': 'Question', name: 'Berapa lama tunggu pemasangan?', acceptedAnswer: { '@type': 'Answer', text: 'Tempoh menunggu biasanya sekitar 5-7 hari selepas tempahan berjaya, bergantung kepada stok dan slot pemasangan.' } },
    { '@type': 'Question', name: 'Sabun apa yang sesuai digunakan?', acceptedAnswer: { '@type': 'Answer', text: 'Gunakan detergent jenis HE (High Efficiency) yang sesuai untuk front-load washer. Detergent jenis ini kurang menghasilkan buih berlebihan dan lebih sesuai untuk penjagaan mesin.' } },
    { '@type': 'Question', name: 'Kalau mesin rosak, hubungi siapa?', acceptedAnswer: { '@type': 'Answer', text: 'Customer boleh hubungi CUCKOO HQ di 1800-88-8181 untuk bantuan lanjut, atau maklumkan kepada ejen untuk bantuan guide proses seterusnya.' } }
  ]
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.cuckoonano.com/' },
    { '@type': 'ListItem', position: 2, name: 'Produk', item: 'https://www.cuckoonano.com/products/' },
    { '@type': 'ListItem', position: 3, name: 'Samsung', item: 'https://www.cuckoonano.com/products/samsung/' },
    { '@type': 'ListItem', position: 4, name: 'Samsung Bespoke AI Washer Dryer 12/7kg', item: pageUrl }
  ]
};
---

<BaseLayout
  title="Samsung Bespoke AI Washer Dryer 12/7kg | Promo RM99 CUCKOO"
  description="Samsung Bespoke AI Washer Dryer 12/7kg. Promo RM99/bulan untuk 6 bulan pertama, harga asal RM115/bulan, pelan rental 60 bulan. Basuh dan kering dalam satu mesin AI — sesuai untuk condo, apartment dan keluarga sibuk. Servis berkala CUCKOO. Semak promo melalui WhatsApp."
  canonical={pageUrl}
  ogImage={ogImg}
  ogType="website"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- HERO -->
  <section class="relative overflow-hidden bg-[#16080c] px-4 py-8 text-white sm:px-6 lg:px-8 lg:py-16">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_10%,rgba(122,31,43,0.42),transparent_34%),radial-gradient(circle_at_85%_20%,rgba(245,158,11,0.18),transparent_32%),linear-gradient(135deg,#16080c_0%,#2a0b12_48%,#070407_100%)]"></div>
    <div class="absolute -right-24 top-6 h-96 w-96 rounded-full bg-rose-500/10 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 h-80 w-80 rounded-full bg-amber-400/10 blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl">

      <!-- Mobile Hero -->
      <div class="md:hidden">
        <div class="mx-auto max-w-md text-center">
          <div class="mb-3 flex flex-wrap justify-center gap-2">
            <span class="rounded-full bg-amber-400/15 px-4 py-2 text-[11px] font-black uppercase tracking-[0.18em] text-amber-100 ring-1 ring-amber-300/30">Promo RM99</span>
            <span class="rounded-full bg-white/10 px-4 py-2 text-[11px] font-black uppercase tracking-[0.18em] text-white ring-1 ring-white/15">12kg Wash / 7kg Dry</span>
          </div>

          <p class="text-xs font-black uppercase tracking-[0.22em] text-rose-200">Samsung Bespoke AI Washer Dryer</p>

          <h1 class="mt-3 text-3xl font-black leading-[1.03] tracking-tight text-white">
            Tak Perlu Sidai Lagi<br />
            <span class="bg-gradient-to-r from-[#FFD46B] via-[#FFC233] to-[#F59E0B] bg-clip-text text-transparent">Walaupun Musim Hujan</span>
          </h1>
        </div>

        <div class="mx-auto mt-5 max-w-md overflow-hidden rounded-[2rem] border border-white/15 bg-gradient-to-br from-[#1a0b10] via-[#3a101b] to-[#080407] p-4 shadow-premium">
          <div class="rounded-[1.5rem] bg-white/25 p-3">
            <img id="heroProductImageMobile" src={sisi1} alt="Samsung Bespoke AI Washer Dryer 12kg wash 7kg dry" class="mx-auto h-[240px] w-full object-contain transition duration-300" />
          </div>

          <div class="mt-3 flex flex-wrap justify-center gap-2">
            <button type="button" data-hero-product={sisi1} class="hero-product-thumb-mobile rounded-full bg-white px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-brand-maroon shadow-sm ring-2 ring-rose-300">Sisi 1</button>
            <button type="button" data-hero-product={sisi2} class="hero-product-thumb-mobile rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 2</button>
            <button type="button" data-hero-product={sisi3} class="hero-product-thumb-mobile rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 3</button>
            <button type="button" data-hero-product={sisi4} class="hero-product-thumb-mobile rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 4</button>
            <button type="button" data-hero-product={sisi5} class="hero-product-thumb-mobile rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 5</button>
          </div>

          <div class="mt-3 grid grid-cols-3 gap-2 text-center">
            <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/15"><p class="text-sm font-black text-white">12kg</p><p class="text-[10px] font-bold uppercase tracking-wide text-rose-100">Wash</p></div>
            <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/15"><p class="text-sm font-black text-white">7kg</p><p class="text-[10px] font-bold uppercase tracking-wide text-rose-100">Dry</p></div>
            <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/15"><p class="text-sm font-black text-white">6 Bulan</p><p class="text-[10px] font-bold uppercase tracking-wide text-rose-100">Service</p></div>
          </div>
        </div>

        <div class="mx-auto mt-5 max-w-md rounded-[1.75rem] bg-white/10 p-4 text-left shadow-premium ring-1 ring-white/15 backdrop-blur">
          <p class="text-center text-sm font-semibold leading-6 text-rose-100">Basuh dan keringkan pakaian dalam satu mesin. Sesuai untuk condo, apartment dan keluarga sibuk yang tak mahu pening sidai baju.</p>
          <div class="mt-4 rounded-[1.45rem] bg-gradient-to-br from-[#FFF7DE] via-[#FFE7A8] to-[#FFD46B] px-4 py-4 text-brand-dark shadow-soft ring-1 ring-amber-200">
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="text-[11px] font-black uppercase tracking-[0.18em] text-amber-800">6 bulan pertama</p>
                <p class="mt-1 text-4xl font-black tracking-tight text-slate-950">RM99<span class="text-base text-slate-700">/bulan</span></p>
              </div>
              <div class="text-right text-xs font-black leading-5 text-slate-700"><p>Harga asal</p><p>RM115/bulan</p></div>
            </div>
          </div>
          <p class="mt-3 text-center text-xs font-semibold leading-5 text-rose-100">Pelan rental 60 bulan. Tertakluk kepada stok, kelayakan dan terma semasa.</p>
        </div>

        <div class="mx-auto mt-5 max-w-md">
          <a href="#" onclick="this.href=rotatingWhatsapp()" class="flex w-full items-center justify-center rounded-2xl bg-cta-green px-6 py-4 text-base font-black text-white shadow-cta">📲 Semak Promo RM99 Sekarang</a>
        </div>
      </div>

      <!-- Desktop Hero -->
      <div class="hidden items-center gap-10 md:grid lg:grid-cols-[1.04fr_0.96fr] lg:gap-12">
        <div class="order-1 text-center lg:text-left">
          <div class="mb-5 flex flex-wrap justify-center gap-2 lg:justify-start">
            <span class="rounded-full bg-amber-400/15 px-5 py-2 text-xs font-black uppercase tracking-[0.22em] text-amber-100 ring-1 ring-amber-300/30">Promo RM99</span>
            <span class="rounded-full bg-white/10 px-5 py-2 text-xs font-black uppercase tracking-[0.22em] text-white ring-1 ring-white/15">Samsung Bespoke AI</span>
          </div>

          <p class="mb-3 text-sm font-black uppercase tracking-[0.24em] text-rose-200">Smart Laundry Untuk Rumah Moden</p>

          <h1 class="mx-auto max-w-4xl text-balance text-4xl font-black leading-[1.03] tracking-tight text-white sm:text-5xl lg:mx-0 lg:text-6xl">
            Tak Perlu Sidai Lagi <span class="bg-gradient-to-r from-[#FFD46B] via-[#FFC233] to-[#F59E0B] bg-clip-text text-transparent">Walaupun Musim Hujan</span>
          </h1>

          <p class="mx-auto mt-5 max-w-2xl text-base leading-8 text-rose-100 sm:text-lg lg:mx-0">Samsung Bespoke AI Washer Dryer bantu basuh dan keringkan pakaian dalam satu mesin. Lebih mudah untuk condo, apartment dan keluarga yang banyak laundry setiap hari.</p>

          <div id="promo" class="mx-auto mt-6 max-w-2xl rounded-[2rem] bg-white/10 p-4 text-left shadow-premium ring-1 ring-white/15 backdrop-blur lg:mx-0">
            <div class="grid gap-3 sm:grid-cols-[0.9fr_1.1fr] sm:items-center">
              <div class="rounded-[1.5rem] bg-gradient-to-br from-[#FFF7DE] via-[#FFE7A8] to-[#FFD46B] px-5 py-5 text-center text-brand-dark shadow-soft ring-1 ring-amber-200">
                <p class="text-xs font-black uppercase tracking-[0.22em] text-amber-700">6 bulan pertama</p>
                <p class="mt-2 text-5xl font-black tracking-tight text-slate-950 sm:text-6xl">RM99</p>
                <p class="text-base font-black text-brand-dark">/bulan</p>
              </div>
              <div class="space-y-3 text-white">
                <div class="rounded-2xl bg-white/10 px-4 py-3 font-extrabold ring-1 ring-white/10">Harga asal RM115/bulan</div>
                <div class="rounded-2xl bg-white/10 px-4 py-3 font-extrabold ring-1 ring-white/10">Pelan rental 60 bulan</div>
                <p class="text-sm font-semibold leading-6 text-rose-100">Order di sini dan semak kelayakan untuk dapatkan free gift daripada kami.</p>
              </div>
            </div>
          </div>

          <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:justify-center lg:justify-start">
            <a href="#" onclick="this.href=rotatingWhatsapp()" class="inline-flex items-center justify-center rounded-2xl bg-cta-green px-7 py-4 text-base font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark sm:text-lg">📲 Semak Promo RM99 Sekarang</a>
            <a href="#benefits" class="inline-flex items-center justify-center rounded-2xl border border-white/20 bg-white px-7 py-4 text-base font-black text-slate-950 shadow-sm transition hover:-translate-y-0.5 sm:text-lg">Lihat Kelebihan</a>
          </div>

          <p class="mt-5 text-sm font-semibold text-rose-100">Boleh WhatsApp untuk semak stok, pemasangan, syarat rumah dan servis berkala CUCKOO.</p>
        </div>

        <!-- Product Visual -->
        <div class="order-2 mt-2 lg:mt-0">
          <div class="relative mx-auto max-w-[440px] sm:max-w-[520px] lg:max-w-[620px]">
            <div class="absolute -inset-8 rounded-[3rem] bg-amber-400/10 blur-3xl"></div>
            <div class="absolute left-1/2 top-1/2 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rounded-full bg-white/10 blur-3xl"></div>

            <div class="relative overflow-hidden rounded-[2.5rem] border border-white/15 bg-gradient-to-br from-[#1a0b10] via-[#3a101b] to-[#080407] p-5 shadow-premium sm:p-6">
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_38%,rgba(245,158,11,0.16),transparent_42%),radial-gradient(circle_at_18%_15%,rgba(255,255,255,0.10),transparent_32%)]"></div>

              <div class="relative text-center">
                <div class="mb-5 flex flex-wrap justify-center gap-2">
                  <span class="rounded-full bg-brand-maroon px-4 py-2 text-xs font-black uppercase tracking-wide text-white shadow-sm">12kg Wash</span>
                  <span class="rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-rose-100 ring-1 ring-white/15">7kg Dry</span>
                </div>

                <div class="rounded-[1.75rem] bg-white/25 p-4">
                  <img id="heroProductImage" src={sisi1} alt="Samsung Bespoke AI Washer Dryer 12kg wash 7kg dry" class="mx-auto h-[300px] w-full object-contain transition duration-300 sm:h-[360px]" />
                </div>

                <div class="mt-5 flex flex-wrap justify-center gap-2">
                  <button type="button" data-hero-product={sisi1} class="hero-product-thumb rounded-full bg-white px-4 py-2 text-xs font-black uppercase tracking-wide text-brand-maroon shadow-sm ring-2 ring-rose-300">Sisi 1</button>
                  <button type="button" data-hero-product={sisi2} class="hero-product-thumb rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 2</button>
                  <button type="button" data-hero-product={sisi3} class="hero-product-thumb rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 3</button>
                  <button type="button" data-hero-product={sisi4} class="hero-product-thumb rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 4</button>
                  <button type="button" data-hero-product={sisi5} class="hero-product-thumb rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 5</button>
                </div>

                <div class="mt-6 grid grid-cols-3 gap-2 sm:gap-3">
                  <div class="rounded-2xl bg-white/95 px-2 py-3 shadow-sm ring-1 ring-white/20"><p class="text-base font-black text-slate-950 sm:text-lg">12kg</p><p class="text-[10px] font-bold uppercase tracking-wide text-stone-500">Basuh</p></div>
                  <div class="rounded-2xl bg-white/95 px-2 py-3 shadow-sm ring-1 ring-white/20"><p class="text-base font-black text-slate-950 sm:text-lg">7kg</p><p class="text-[10px] font-bold uppercase tracking-wide text-stone-500">Kering</p></div>
                  <div class="rounded-2xl bg-white/95 px-2 py-3 shadow-sm ring-1 ring-white/20"><p class="text-base font-black text-slate-950 sm:text-lg">6 Bulan</p><p class="text-[10px] font-bold uppercase tracking-wide text-stone-500">Service</p></div>
                </div>
              </div>
            </div>

            <div class="relative mx-auto mt-4 w-[88%] rounded-3xl bg-brand-maroon px-5 py-4 text-center text-white shadow-xl ring-1 ring-rose-300/30">
              <p class="text-[11px] font-bold text-rose-200 sm:text-xs">Highlight Utama</p>
              <p class="text-sm font-black sm:text-base">Basuh, Kering & Tak Perlu Sidai</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Strip -->
  <section class="bg-gradient-to-r from-[#16080c] via-brand-maroon to-[#2f0b10] px-4 py-6 text-white sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-3 text-sm sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-2xl bg-white/10 px-5 py-4 ring-1 ring-white/15"><p class="text-lg font-black">🔥 RM99/Bulan</p><p class="mt-1 font-semibold text-rose-100">Untuk 6 bulan pertama</p></div>
      <div class="rounded-2xl bg-white/10 px-5 py-4 ring-1 ring-white/15"><p class="text-lg font-black">🧺 12kg Wash / 7kg Dry</p><p class="mt-1 font-semibold text-rose-100">Basuh & kering 2-in-1</p></div>
      <div class="rounded-2xl bg-white/10 px-5 py-4 ring-1 ring-white/15"><p class="text-lg font-black">🛠️ Servis 6 Bulan</p><p class="mt-1 font-semibold text-rose-100">Disokong team servis CUCKOO</p></div>
      <div class="rounded-2xl bg-white/10 px-5 py-4 ring-1 ring-white/15"><p class="text-lg font-black">🏠 Condo & Family</p><p class="mt-1 font-semibold text-rose-100">Sesuai rumah moden</p></div>
    </div>
  </section>

  <!-- Pain Point -->
  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-7xl">
      <div class="grid items-center gap-10 lg:grid-cols-[0.95fr_1.05fr]">
        <div>
          <p class="text-sm font-black uppercase tracking-[0.24em] text-brand-maroon">Masalah Harian</p>
          <h2 class="mt-4 text-balance text-3xl font-black tracking-tight sm:text-5xl">Laundry Tak Patut Ambil Banyak Masa Setiap Hari</h2>
          <p class="mt-5 text-lg leading-8 text-stone-600">Kalau setiap minggu masih penat basuh, sidai, tunggu kering dan angkat kain — mungkin sudah tiba masa untuk upgrade cara anda urus laundry.</p>

          <div class="mt-7 rounded-[2rem] bg-gradient-to-br from-[#4B0715] via-brand-maroon to-[#2f0b10] p-6 text-white shadow-premium">
            <p class="text-sm font-black uppercase tracking-[0.22em] text-promo-gold">Solusi Lebih Praktikal</p>
            <p class="mt-3 text-2xl font-black leading-tight">Basuh + kering dalam satu mesin, tanpa perlu tunggu cuaca panas.</p>
            <p class="mt-3 leading-7 text-rose-100">Sesuai untuk keluarga sibuk, condo, apartment dan rumah yang ruang sidai terhad.</p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
