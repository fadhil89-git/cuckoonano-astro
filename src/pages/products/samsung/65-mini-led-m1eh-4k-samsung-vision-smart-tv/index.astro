---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import AgentSection from '../../../../components/AgentSection.astro';

const base = '/assets/images/products/samsung/oled-tv';

// Gambar produk rasmi Samsung (background putih bersih, tiada sticker)
const tvAngleL = `${base}/my-mini-led-m1eh-ua65m1ehakxxm-552158898.avif`; // angle kiri
const tvAngleR = `${base}/my-mini-led-m1eh-ua65m1ehakxxm-552158900.avif`; // angle kanan
const tvFront  = `${base}/my-mini-led-m1eh-ua65m1ehakxxm-552158899.avif`; // depan + Mini LED
const tvSlim   = `${base}/my-mini-led-m1eh-ua65m1ehakxxm-552158901.avif`; // sisi nipis
const tvBezel  = `${base}/my-mini-led-m1eh-ua65m1ehakxxm-552158902.avif`; // bezel close-up
const tvPorts  = `${base}/my-mini-led-m1eh-ua65m1ehakxxm-552171410.avif`; // port belakang
const tvDimens = `${base}/my-mini-led-m1eh-ua65m1ehakxxm-552158917.avif`; // dimensi
const tvRemote = `${base}/my-mini-led-tv-ua65m1ehakxxm-----mini-led-m-eh--k-samsung-vision-ai-smart-tv------black-552158878.avif`; // remote

const heroImg = tvAngleL;                                              // default hero

// Full-bleed showcase media (Komen 2 & 3)
const showcaseVidDesktop = `${base}/my-feature--nbsp-552132597.webm`; // showcase video (desktop)
const showcaseVidMobile  = `${base}/my-feature--nbsp-552132598.webm`; // showcase video (mobile)
const privacyImgMobile   = `${base}/my-feature-your-privacy--secured--551629436.webp`; // Knox privacy (mobile)
const smartThingsVid     = `${base}/2025-smart-tv-06-smart-home-f03-1-smartthings-pc-others.mp4`; // SmartThings
const metalDesktop = `${base}/my-feature-elegant-metal-stream-design-to-upgrade-your-space-551629399.avif`; // MetalStream (desktop)
const metalMobile  = `${base}/my-feature-elegant-metal-stream-design-to-upgrade-your-space-551629400.avif`; // MetalStream (mobile)

// FEATURE MEDIA — gambar/video feature rasmi Samsung
const featMiniLedVid = `${base}/my-feature-our-advanced-mini-led-technology-551629418.webm`; // Mini LED (video)
const featMotion  = `${base}/my-feature-improved-picture-clarity-with-smooth-motion-551629433.webp`;                                            // Motion Xcelerator / gaming
const featSmart   = `${base}/my-feature-ask-your-companion-anything--samsung-vision-ai-is-here--551629406.avif`; // Vision AI
const featColour  = tvFront;                                                                 // warna pada skrin
const featConnect = tvPorts;                                                                 // connectivity
const featDesign  = tvSlim;                                                                  // design slim

// SOUND (gaya Samsung — 3 sub-feature)
const soundHero     = `${base}/my-feature--nbsp-552132612.avif`;              // Dynamic Sound Pack scene
const soundOTS      = `${base}/uk-feature-object-tracking-sound-lite-552306116.avif`;
const soundQSym     = `${base}/uk-feature-q-symphony-552306114.avif`;
const soundAdaptive = `${base}/uk-feature-adaptive-sound-552306118.avif`;

// Trust / pengalaman jangka panjang
const sevenYears = `${base}/my-feature-enjoy-7-years-of-new-tv-experiences-552365655.avif`;
const privacyImg = `${base}/my-feature-your-privacy--secured--551629435.avif`;

const pageUrl = 'https://www.cuckoonano.com/products/samsung/65-mini-led-m1eh-4k-samsung-vision-smart-tv/';
// OG image kekal webp untuk keserasian preview WhatsApp/FB (AVIF kurang disokong scraper)
const ogImg = `https://www.cuckoonano.com${base}/M1EH-4K-TV-img-01.webp`;

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Samsung 65" Mini LED M1EH 4K Vision AI Smart TV',
  alternateName: [
    'TV Samsung 65 inch Mini LED 4K',
    'Cuckoo Samsung Smart TV 65 inci',
    'Samsung Vision AI Smart TV M1EH'
  ],
  category: 'Television',
  brand: { '@type': 'Brand', name: 'Samsung' },
  sku: 'UA65M1EHAKXXM',
  description:
    'TV Samsung 65 inch Mini LED M1EH 4K Vision AI Smart TV melalui CUCKOO. Mini LED Processor 4K, Motion Xcelerator, Tizen Smart TV dan bayaran bulanan Cuckoo dari RM153/bulan di Malaysia.',
  url: pageUrl,
  image: ogImg,
  offers: {
    '@type': 'Offer',
    priceCurrency: 'MYR',
    price: '153',
    url: pageUrl,
    availability: 'https://schema.org/InStock',
    priceSpecification: {
      '@type': 'UnitPriceSpecification',
      price: '153',
      priceCurrency: 'MYR',
      unitText: 'MONTH'
    },
    seller: { '@type': 'Organization', name: 'CUCKOO' }
  }
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Berapa harga TV Samsung 65" Mini LED 4K ini?', acceptedAnswer: { '@type': 'Answer', text: 'Boleh dimiliki melalui pelan rental Cuckoo dari RM153/bulan untuk 3 tahun, atau beli terus RM4,599. Sahkan stok dan promo terkini melalui WhatsApp sebelum order.' } },
    { '@type': 'Question', name: 'Boleh ansuran bulanan untuk TV Cuckoo ni?', acceptedAnswer: { '@type': 'Answer', text: 'Boleh. TV ini ditawarkan dengan bayaran bulanan dari RM153/bulan untuk tempoh 3 tahun, tertakluk kepada kelayakan dan terma semasa.' } },
    { '@type': 'Question', name: 'TV ini saiz berapa dan resolusi apa?', acceptedAnswer: { '@type': 'Answer', text: 'TV ini bersaiz 65 inci dengan resolusi 4K (3840 x 2160) menggunakan teknologi Mini LED.' } },
    { '@type': 'Question', name: 'Sesuai untuk tengok bola dan action movie?', acceptedAnswer: { '@type': 'Answer', text: 'Ya. Motion Xcelerator dan Soccer/Football Mode membantu pergerakan pada skrin nampak lebih smooth untuk bola, action movie dan gaming.' } },
    { '@type': 'Question', name: 'Boleh connect phone ke TV?', acceptedAnswer: { '@type': 'Answer', text: 'Ya. TV ini menyokong Mobile to TV, Sound Mirroring, Apple AirPlay dan Google Cast.' } },
    { '@type': 'Question', name: 'Ada Wi-Fi dan Bluetooth?', acceptedAnswer: { '@type': 'Answer', text: 'Ya. Model ini menyokong Wi-Fi 5 dan Bluetooth 5.3, serta 3 port HDMI (eARC) dan 1 USB-A.' } },
    { '@type': 'Question', name: 'Boleh pasang pada dinding (wall mount)?', acceptedAnswer: { '@type': 'Answer', text: 'Ya. Model ini menyokong VESA 200 x 200 dan Full Motion Slim Wall Mount Support (Y22). Saiz tanpa stand: 1444 x 831 x 77 mm.' } },
    { '@type': 'Question', name: 'Apa waranti yang disediakan?', acceptedAnswer: { '@type': 'Answer', text: 'Disediakan waranti standard 2 tahun + 1 tahun lanjutan eksklusif Cuckoo. Tertakluk kepada terma semasa.' } },
    { '@type': 'Question', name: 'Apa beza rental dan outright?', acceptedAnswer: { '@type': 'Answer', text: 'Rental ialah RM153/bulan untuk 3 tahun, manakala outright ialah beli terus pada RM4,599. Kedua-duanya tertakluk kepada stok dan terma semasa.' } },
    { '@type': 'Question', name: 'Macam mana nak semak stok dan order?', acceptedAnswer: { '@type': 'Answer', text: 'Tekan WhatsApp dan saya akan bantu semak stok, promo, kawasan delivery, kesesuaian saiz ruang dan proses order.' } }
  ]
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.cuckoonano.com/' },
    { '@type': 'ListItem', position: 2, name: 'Produk', item: 'https://www.cuckoonano.com/products/' },
    { '@type': 'ListItem', position: 3, name: 'Samsung', item: 'https://www.cuckoonano.com/products/samsung/' },
    { '@type': 'ListItem', position: 4, name: '65" Mini LED M1EH 4K Samsung Vision AI Smart TV', item: pageUrl }
  ]
};
---

<BaseLayout
  title='TV Samsung 65" Mini LED 4K Vision AI | CUCKOO RM153/Bulan'
  description="TV Samsung 65 inch Mini LED M1EH 4K Vision AI Smart TV melalui CUCKOO — gambar lebih terang, motion smooth untuk bola & gaming, dari RM153/bulan ansuran di Malaysia. Semak promo melalui WhatsApp."
  canonical={pageUrl}
  ogImage={ogImg}
  ogType="website"
  preloadImages={[heroImg]}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- HERO -->
  <section class="relative overflow-hidden bg-[#16080c] px-4 py-8 text-white sm:px-6 lg:px-8 lg:py-16">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_10%,rgba(122,31,43,0.42),transparent_34%),radial-gradient(circle_at_85%_20%,rgba(245,158,11,0.18),transparent_32%),linear-gradient(135deg,#16080c_0%,#2a0b12_48%,#070407_100%)]"></div>
    <div class="absolute -right-24 top-6 h-96 w-96 rounded-full bg-rose-500/10 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 h-80 w-80 rounded-full bg-amber-400/10 blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl">
      <!-- Mobile Hero -->
      <div class="md:hidden">
        <div class="mx-auto max-w-md text-center">
          <div class="mb-3 flex flex-wrap justify-center gap-2">
            <span class="rounded-full bg-amber-400/15 px-4 py-2 text-[11px] font-black uppercase tracking-[0.18em] text-amber-100 ring-1 ring-amber-300/30">Dari RM153/Bulan</span>
            <span class="rounded-full bg-white/10 px-4 py-2 text-[11px] font-black uppercase tracking-[0.18em] text-white ring-1 ring-white/15">65" Mini LED 4K</span>
          </div>

          <p class="text-xs font-black uppercase tracking-[0.22em] text-rose-200">CUCKOO x Samsung</p>

          <p class="mt-3 text-3xl font-black leading-[1.03] tracking-tight text-white">
            TV Samsung 65" Mini LED 4K<br />
            <span class="bg-gradient-to-r from-[#FFD46B] via-[#FFC233] to-[#F59E0B] bg-clip-text text-transparent">Vision AI Smart TV</span>
          </p>
        </div>

        <div class="mx-auto mt-5 max-w-md overflow-hidden rounded-[2rem] border border-white/15 bg-gradient-to-br from-[#1a0b10] via-[#3a101b] to-[#080407] p-4 shadow-premium">
          <div class="rounded-[1.5rem] bg-white p-3">
            <img id="heroProductImageMobile" src={heroImg} alt="TV Samsung 65 inch Mini LED M1EH 4K Vision AI Smart TV melalui CUCKOO" width="1080" height="864" fetchpriority="high" decoding="async" class="mx-auto h-[230px] w-full object-contain transition duration-300" />
          </div>
          <div class="mt-3 flex flex-wrap justify-center gap-2">
            <button type="button" data-hero-product={tvAngleL} class="hero-product-thumb-mobile rounded-full bg-white px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-brand-maroon shadow-sm ring-2 ring-amber-300">Sisi 1</button>
            <button type="button" data-hero-product={tvAngleR} class="hero-product-thumb-mobile rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 2</button>
            <button type="button" data-hero-product={tvFront} class="hero-product-thumb-mobile rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20">Depan</button>
            <button type="button" data-hero-product={tvSlim} class="hero-product-thumb-mobile rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi</button>
            <button type="button" data-hero-product={tvPorts} class="hero-product-thumb-mobile rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20">Port</button>
          </div>
          <div class="mt-3 grid grid-cols-3 gap-2 text-center">
            <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/15"><p class="text-sm font-black text-white">65"</p><p class="text-[10px] font-bold uppercase tracking-wide text-rose-100">Skrin</p></div>
            <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/15"><p class="text-sm font-black text-white">4K</p><p class="text-[10px] font-bold uppercase tracking-wide text-rose-100">Mini LED</p></div>
            <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/15"><p class="text-sm font-black text-white">AI</p><p class="text-[10px] font-bold uppercase tracking-wide text-rose-100">Vision</p></div>
          </div>
        </div>

        <div class="mx-auto mt-5 max-w-md rounded-[1.75rem] bg-white/10 p-4 text-left shadow-premium ring-1 ring-white/15 backdrop-blur">
          <p class="text-center text-sm font-semibold leading-6 text-rose-100">Upgrade ruang tamu dengan TV 65" yang lebih terang, smooth &amp; pintar — tanpa modal besar.</p>
          <div class="mt-4 rounded-[1.45rem] bg-gradient-to-br from-[#FFF7DE] via-[#FFE7A8] to-[#FFD46B] px-4 py-4 text-brand-dark shadow-soft ring-1 ring-amber-200">
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="text-[11px] font-black uppercase tracking-[0.18em] text-amber-800">Rental dari</p>
                <p class="mt-1 text-4xl font-black tracking-tight text-slate-950">RM153<span class="text-base text-slate-700">/bulan</span></p>
              </div>
              <div class="text-right text-xs font-black leading-5 text-slate-700"><p>Beli terus</p><p>RM4,599</p></div>
            </div>
          </div>
          <p class="mt-3 text-center text-xs font-semibold leading-5 text-rose-100">Pelan rental 3 tahun. Tertakluk kepada stok, kelayakan dan terma semasa.</p>
        </div>

        <div class="mx-auto mt-5 max-w-md">
          <a href="#" onclick="this.href=rotatingWhatsapp()" class="flex w-full items-center justify-center rounded-2xl bg-cta-green px-6 py-4 text-base font-black text-white shadow-cta">📲 Semak Promo TV RM153</a>
        </div>
      </div>

      <!-- Desktop Hero -->
      <div class="hidden items-center gap-10 md:grid lg:grid-cols-[1.04fr_0.96fr] lg:gap-12">
        <div class="order-1 text-center lg:text-left">
          <div class="mb-5 flex flex-wrap justify-center gap-2 lg:justify-start">
            <span class="rounded-full bg-amber-400/15 px-5 py-2 text-xs font-black uppercase tracking-[0.22em] text-amber-100 ring-1 ring-amber-300/30">Dari RM153/Bulan</span>
            <span class="rounded-full bg-white/10 px-5 py-2 text-xs font-black uppercase tracking-[0.22em] text-white ring-1 ring-white/15">CUCKOO x Samsung</span>
          </div>

          <p class="mb-3 text-sm font-black uppercase tracking-[0.24em] text-rose-200">Smart Healthy Home Series</p>

          <h1 class="mx-auto max-w-4xl text-balance text-4xl font-black leading-[1.03] tracking-tight text-white sm:text-5xl lg:mx-0 lg:text-6xl">
            TV Samsung 65" Mini LED 4K Vision AI <span class="bg-gradient-to-r from-[#FFD46B] via-[#FFC233] to-[#F59E0B] bg-clip-text text-transparent">Dari RM153/Bulan</span>
          </h1>

          <p class="mx-auto mt-5 max-w-2xl text-base leading-8 text-rose-100 sm:text-lg lg:mx-0">Upgrade ruang tamu dengan TV 65 inci Mini LED 4K: gambar lebih terang, contrast lebih hidup, motion lebih smooth untuk bola &amp; gaming, dan lebih pintar dengan Samsung Vision AI — semua tanpa perlu keluar modal besar.</p>

          <div id="promo" class="mx-auto mt-6 max-w-2xl rounded-[2rem] bg-white/10 p-4 text-left shadow-premium ring-1 ring-white/15 backdrop-blur lg:mx-0">
            <div class="grid gap-3 sm:grid-cols-[0.9fr_1.1fr] sm:items-center">
              <div class="rounded-[1.5rem] bg-gradient-to-br from-[#FFF7DE] via-[#FFE7A8] to-[#FFD46B] px-5 py-5 text-center text-brand-dark shadow-soft ring-1 ring-amber-200">
                <p class="text-xs font-black uppercase tracking-[0.22em] text-amber-700">Pelan rental dari</p>
                <p class="mt-2 text-5xl font-black tracking-tight text-slate-950 sm:text-6xl">RM153</p>
                <p class="text-base font-black text-brand-dark">/bulan</p>
              </div>
              <div class="space-y-3 text-white">
                <div class="rounded-2xl bg-white/10 px-4 py-3 font-extrabold ring-1 ring-white/10">Beli terus RM4,599</div>
                <div class="rounded-2xl bg-white/10 px-4 py-3 font-extrabold ring-1 ring-white/10">Pelan rental 3 tahun</div>
                <p class="text-sm font-semibold leading-6 text-rose-100">Order di sini dan semak kelayakan untuk dapatkan free gift daripada kami.</p>
              </div>
            </div>
          </div>

          <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:justify-center lg:justify-start">
            <a href="#" onclick="this.href=rotatingWhatsapp()" class="inline-flex items-center justify-center rounded-2xl bg-cta-green px-7 py-4 text-base font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark sm:text-lg">📲 Semak Promo TV RM153</a>
            <a href="#product-features" class="inline-flex items-center justify-center rounded-2xl border border-white/20 bg-white px-7 py-4 text-base font-black text-slate-950 shadow-sm transition hover:-translate-y-0.5 sm:text-lg">Lihat Kelebihan</a>
          </div>

          <p class="mt-5 text-sm font-semibold text-rose-100">Boleh WhatsApp untuk semak stok, kawasan delivery, saiz ruang TV dan kelayakan order.</p>
        </div>

        <!-- Product Visual -->
        <div class="order-2 mt-2 lg:mt-0">
          <div class="relative mx-auto max-w-[440px] sm:max-w-[520px] lg:max-w-[640px]">
            <div class="absolute -inset-8 rounded-[3rem] bg-amber-400/10 blur-3xl"></div>
            <div class="absolute left-1/2 top-1/2 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rounded-full bg-white/10 blur-3xl"></div>

            <div class="relative overflow-hidden rounded-[2.5rem] border border-white/15 bg-gradient-to-br from-[#1a0b10] via-[#3a101b] to-[#080407] p-5 shadow-premium sm:p-6">
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_38%,rgba(245,158,11,0.16),transparent_42%),radial-gradient(circle_at_18%_15%,rgba(255,255,255,0.10),transparent_32%)]"></div>

              <div class="relative text-center">
                <div class="mb-5 flex flex-wrap justify-center gap-2">
                  <span class="rounded-full bg-brand-maroon px-4 py-2 text-xs font-black uppercase tracking-wide text-white shadow-sm">Mini LED 4K</span>
                  <span class="rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-rose-100 ring-1 ring-white/15">Vision AI</span>
                </div>

                <div class="rounded-[1.75rem] bg-white p-4">
                  <img id="heroProductImage" src={heroImg} alt="Samsung 65 inch Mini LED M1EH 4K Vision AI Smart TV — Cuckoo ansuran bulanan" width="1080" height="864" fetchpriority="high" decoding="async" class="mx-auto h-[300px] w-full object-contain transition duration-300 sm:h-[360px]" />
                </div>

                <div class="mt-5 flex flex-wrap justify-center gap-2">
                  <button type="button" data-hero-product={tvAngleL} class="hero-product-thumb rounded-full bg-white px-4 py-2 text-xs font-black uppercase tracking-wide text-brand-maroon shadow-sm ring-2 ring-amber-300">Sisi 1</button>
                  <button type="button" data-hero-product={tvAngleR} class="hero-product-thumb rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 2</button>
                  <button type="button" data-hero-product={tvFront} class="hero-product-thumb rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20">Depan</button>
                  <button type="button" data-hero-product={tvSlim} class="hero-product-thumb rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi</button>
                  <button type="button" data-hero-product={tvPorts} class="hero-product-thumb rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20">Port</button>
                </div>

                <div class="mt-6 grid grid-cols-3 gap-2 sm:gap-3">
                  <div class="rounded-2xl bg-white/95 px-2 py-3 shadow-sm ring-1 ring-white/20"><p class="text-base font-black text-slate-950 sm:text-lg">65"</p><p class="text-[10px] font-bold uppercase tracking-wide text-stone-500">Skrin</p></div>
                  <div class="rounded-2xl bg-white/95 px-2 py-3 shadow-sm ring-1 ring-white/20"><p class="text-base font-black text-slate-950 sm:text-lg">4K</p><p class="text-[10px] font-bold uppercase tracking-wide text-stone-500">Mini LED</p></div>
                  <div class="rounded-2xl bg-white/95 px-2 py-3 shadow-sm ring-1 ring-white/20"><p class="text-base font-black text-slate-950 sm:text-lg">Tizen</p><p class="text-[10px] font-bold uppercase tracking-wide text-stone-500">Smart TV</p></div>
                </div>
              </div>
            </div>

            <div class="relative mx-auto mt-4 w-[88%] rounded-3xl bg-brand-maroon px-5 py-4 text-center text-white shadow-xl ring-1 ring-rose-300/30">
              <p class="text-[11px] font-bold text-rose-200 sm:text-xs">Highlight Utama</p>
              <p class="text-sm font-black sm:text-base">Lebih Besar, Lebih Terang &amp; Lebih Smart</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Strip -->
  <section class="bg-gradient-to-r from-[#16080c] via-brand-maroon to-[#2f0b10] px-4 py-6 text-white sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-3 text-sm sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-2xl bg-white/10 px-5 py-4 ring-1 ring-white/15"><p class="text-lg font-black">📺 65" Mini LED 4K</p><p class="mt-1 font-semibold text-rose-100">Skrin besar, gambar hidup</p></div>
      <div class="rounded-2xl bg-white/10 px-5 py-4 ring-1 ring-white/15"><p class="text-lg font-black">⚽ Motion Xcelerator</p><p class="mt-1 font-semibold text-rose-100">Bola &amp; gaming smooth</p></div>
      <div class="rounded-2xl bg-white/10 px-5 py-4 ring-1 ring-white/15"><p class="text-lg font-black">🤖 Samsung Vision AI</p><p class="mt-1 font-semibold text-rose-100">Smart TV Tizen</p></div>
      <div class="rounded-2xl bg-white/10 px-5 py-4 ring-1 ring-white/15"><p class="text-lg font-black">🛡️ Waranti 2+1 Tahun</p><p class="mt-1 font-semibold text-rose-100">Eksklusif CUCKOO</p></div>
    </div>
  </section>

  <!-- Pain Point -->
  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-7xl">
      <div class="grid items-center gap-10 lg:grid-cols-[0.95fr_1.05fr]">
        <div>
