<style is:global>
  html { scroll-behavior: smooth; }
  body { font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
  .text-balance { text-wrap: balance; }
</style>

<script is:inline>
  // Hero product image switcher (butang Sisi) — sama gaya page aircond
  function setupHeroProductSwitcher(imageId, buttonClass, inactiveClass, activeClass) {
    const image = document.getElementById(imageId);
    const buttons = document.querySelectorAll('.' + buttonClass);
    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        if (!image) return;
        image.src = button.dataset.heroProduct;
        buttons.forEach((thumb) => { thumb.className = buttonClass + ' ' + inactiveClass; });
        button.className = buttonClass + ' ' + activeClass;
      });
    });
  }

  setupHeroProductSwitcher(
    'heroProductImage',
    'hero-product-thumb',
    'rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20',
    'rounded-full bg-white px-4 py-2 text-xs font-black uppercase tracking-wide text-brand-maroon shadow-sm ring-2 ring-amber-300'
  );

  setupHeroProductSwitcher(
    'heroProductImageMobile',
    'hero-product-thumb-mobile',
    'rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20',
    'rounded-full bg-white px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-brand-maroon shadow-sm ring-2 ring-amber-300'
  );

  const tvBase = '/assets/images/products/samsung/oled-tv';
  const productSlides = [
    { src: `${tvBase}/my-mini-led-m1eh-ua65m1ehakxxm-552158898.avif`, alt: 'Samsung 65 inch Mini LED 4K Vision AI Smart TV — pandangan sudut kiri' },
    { src: `${tvBase}/my-mini-led-m1eh-ua65m1ehakxxm-552158900.avif`, alt: 'Samsung 65 inch Mini LED 4K Vision AI Smart TV — pandangan sudut kanan' },
    { src: `${tvBase}/my-mini-led-m1eh-ua65m1ehakxxm-552158899.avif`, alt: 'Samsung 65 inch Mini LED 4K Vision AI Smart TV — pandangan depan' },
    { src: `${tvBase}/my-mini-led-m1eh-ua65m1ehakxxm-552158901.avif`, alt: 'Samsung 65 inch Mini LED 4K Vision AI Smart TV — profil slim dari sisi' },
    { src: `${tvBase}/my-mini-led-m1eh-ua65m1ehakxxm-552158902.avif`, alt: 'Samsung 65 inch Mini LED 4K Vision AI Smart TV — bezel close-up' },
    { src: `${tvBase}/my-mini-led-m1eh-ua65m1ehakxxm-552171410.avif`, alt: 'Samsung 65 inch Mini LED 4K Vision AI Smart TV — port belakang HDMI dan USB' },
    { src: `${tvBase}/my-mini-led-m1eh-ua65m1ehakxxm-552158917.avif`, alt: 'Samsung 65 inch Mini LED 4K Vision AI Smart TV — dimensi produk' },
    { src: `${tvBase}/my-mini-led-tv-ua65m1ehakxxm-----mini-led-m-eh--k-samsung-vision-ai-smart-tv------black-552158878.avif`, alt: 'Samsung 65 inch Mini LED 4K Vision AI Smart TV — alat kawalan jauh (remote)' }
  ];

  let currentProductSlide = 0;
  const productSliderImage = document.getElementById('productSliderImage');
  const productSliderPrev = document.getElementById('productSliderPrev');
  const productSliderNext = document.getElementById('productSliderNext');
  const productSliderDots = document.getElementById('productSliderDots');

  function renderProductSlide(index) {
    const slide = productSlides[index];
    productSliderImage.src = slide.src;
    productSliderImage.alt = slide.alt;
    productSliderDots.innerHTML = '';
    productSlides.forEach((item, dotIndex) => {
      const dot = document.createElement('button');
      dot.type = 'button';
      dot.setAttribute('aria-label', 'Lihat gambar produk ' + (dotIndex + 1));
      dot.className = dotIndex === index
        ? 'h-3 w-8 rounded-full bg-brand-maroon transition'
        : 'h-3 w-3 rounded-full bg-stone-300 transition hover:bg-brand-maroon';
      dot.addEventListener('click', () => { currentProductSlide = dotIndex; renderProductSlide(currentProductSlide); });
      productSliderDots.appendChild(dot);
    });
  }

  if (productSliderPrev && productSliderNext) {
    productSliderPrev.addEventListener('click', () => {
      currentProductSlide = currentProductSlide === 0 ? productSlides.length - 1 : currentProductSlide - 1;
      renderProductSlide(currentProductSlide);
    });
    productSliderNext.addEventListener('click', () => {
      currentProductSlide = currentProductSlide === productSlides.length - 1 ? 0 : currentProductSlide + 1;
      renderProductSlide(currentProductSlide);
    });
  }

  if (productSliderImage) { renderProductSlide(currentProductSlide); }

  // Testimoni slider — click buttons + drag to slide (Komen 4)
  const testiTrack = document.getElementById('testiTrack');
  const testiPrev = document.getElementById('testiPrev');
  const testiNext = document.getElementById('testiNext');

  if (testiTrack) {
    const stepWidth = () => {
      const slide = testiTrack.querySelector('.testi-slide');
      const gap = parseFloat(getComputedStyle(testiTrack).columnGap || '20') || 20;
      return slide ? slide.getBoundingClientRect().width + gap : testiTrack.clientWidth * 0.8;
    };

    if (testiPrev) testiPrev.addEventListener('click', () => testiTrack.scrollBy({ left: -stepWidth(), behavior: 'smooth' }));
    if (testiNext) testiNext.addEventListener('click', () => testiTrack.scrollBy({ left: stepWidth(), behavior: 'smooth' }));

    // Drag to slide (pointer)
    let isDown = false, startX = 0, startScroll = 0, moved = false;
    testiTrack.addEventListener('pointerdown', (e) => {
      isDown = true; moved = false;
      startX = e.clientX;
      startScroll = testiTrack.scrollLeft;
      testiTrack.classList.add('cursor-grabbing');
    });
    testiTrack.addEventListener('pointermove', (e) => {
      if (!isDown) return;
      const delta = e.clientX - startX;
      if (Math.abs(delta) > 4) moved = true;
      testiTrack.scrollLeft = startScroll - delta;
    });
    const endDrag = () => { isDown = false; testiTrack.classList.remove('cursor-grabbing'); };
    testiTrack.addEventListener('pointerup', endDrag);
    testiTrack.addEventListener('pointerleave', endDrag);
    testiTrack.addEventListener('click', (e) => { if (moved) { e.preventDefault(); e.stopPropagation(); } }, true);
  }
</script>
