        <p class="inline-flex rounded-full bg-white/12 px-5 py-2 text-xs font-black uppercase tracking-[0.24em] text-rose-100 ring-1 ring-white/15">Ready Untuk Upgrade?</p>
        <h2 class="mt-6 text-balance text-3xl font-black leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl">Upgrade Peti Sejuk Rumah Kepada 583L</h2>
        <p class="mx-auto mt-6 max-w-2xl text-base leading-8 text-rose-100 sm:text-lg">Lebih luas. Lebih pintar. Lebih jimat. Klik WhatsApp untuk semak promo dan dapatkan consultation percuma.</p>
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href="#" onclick="this.href=rotatingWhatsapp()" class="inline-flex items-center justify-center rounded-2xl bg-cta-green px-9 py-5 text-lg font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark">📲 WhatsApp Sekarang</a>
          <a href="#promo" class="inline-flex items-center justify-center rounded-2xl border border-white/20 bg-white/10 px-9 py-5 text-lg font-black text-white backdrop-blur transition hover:bg-white/20">Tengok Promo</a>
        </div>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3 text-sm font-bold text-rose-100">
          <span>✓ Consultation Percuma</span>
          <span class="hidden h-1 w-1 rounded-full bg-white/40 sm:inline-block"></span>
          <span>✓ Rental 5 Tahun</span>
          <span class="hidden h-1 w-1 rounded-full bg-white/40 sm:inline-block"></span>
          <span>✓ Support Installation</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Zoom lightbox -->
  <div id="zoomLightbox" class="fixed inset-0 z-[90] hidden items-center justify-center bg-black/80 p-4 backdrop-blur-sm">
    <button type="button" id="zoomClose" aria-label="Tutup gambar" class="absolute right-4 top-4 z-10 flex h-11 w-11 items-center justify-center rounded-full bg-white/95 text-2xl font-black text-brand-maroon shadow-lg">×</button>
    <img id="zoomImage" src="" alt="" class="max-h-[90vh] w-auto max-w-[94vw] rounded-2xl object-contain shadow-premium" />
  </div>
</BaseLayout>

<style is:global>
  html { scroll-behavior: smooth; }
  body { font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
  .text-balance { text-wrap: balance; }
</style>

<script is:inline>
  const productSlides = [
    { src: '/assets/images/products/samsung/refrigerator/Refrigerator-2.webp', alt: 'Samsung Side-by-Side Refrigerator 583L gambar produk 1' },
    { src: '/assets/images/products/samsung/refrigerator/Refrigerator-3.webp', alt: 'Samsung Side-by-Side Refrigerator 583L gambar produk 2' },
    { src: '/assets/images/products/samsung/refrigerator/Refrigerator-4.webp', alt: 'Samsung Side-by-Side Refrigerator 583L gambar produk 3' },
    { src: '/assets/images/products/samsung/refrigerator/Refrigerator-5.webp', alt: 'Samsung Side-by-Side Refrigerator 583L gambar produk 4' },
    { src: '/assets/images/products/samsung/refrigerator/Refrigerator-6.webp', alt: 'Samsung Side-by-Side Refrigerator 583L gambar produk 5' },
    { src: '/assets/images/products/samsung/refrigerator/Refrigerator-7.webp', alt: 'Samsung Side-by-Side Refrigerator 583L gambar produk 6' },
    { src: '/assets/images/products/samsung/refrigerator/Refrigerator-8.webp', alt: 'Samsung Side-by-Side Refrigerator 583L gambar produk 7' }
  ];

  let currentProductSlide = 0;
  const productSliderImage = document.getElementById('productSliderImage');
  const productSliderPrev = document.getElementById('productSliderPrev');
  const productSliderNext = document.getElementById('productSliderNext');
  const productSliderDots = document.getElementById('productSliderDots');

  function renderProductSlide(index) {
    const slide = productSlides[index];
    productSliderImage.src = slide.src;
    productSliderImage.alt = slide.alt;
    productSliderDots.innerHTML = '';
    productSlides.forEach((item, dotIndex) => {
      const dot = document.createElement('button');
      dot.type = 'button';
      dot.setAttribute('aria-label', 'Lihat gambar produk ' + (dotIndex + 1));
      dot.className = dotIndex === index
        ? 'h-3 w-8 rounded-full bg-brand-maroon transition'
        : 'h-3 w-3 rounded-full bg-stone-300 transition hover:bg-brand-maroon';
      dot.addEventListener('click', () => { currentProductSlide = dotIndex; renderProductSlide(currentProductSlide); });
      productSliderDots.appendChild(dot);
    });
  }

  if (productSliderPrev && productSliderNext) {
    productSliderPrev.addEventListener('click', () => {
      currentProductSlide = currentProductSlide === 0 ? productSlides.length - 1 : currentProductSlide - 1;
      renderProductSlide(currentProductSlide);
    });
    productSliderNext.addEventListener('click', () => {
      currentProductSlide = currentProductSlide === productSlides.length - 1 ? 0 : currentProductSlide + 1;
      renderProductSlide(currentProductSlide);
    });
  }

  if (productSliderImage) { renderProductSlide(currentProductSlide); }

  // Hero product slider — 5 sisi (mobile + desktop synced)
  const heroSlideSrcs = [
    '/assets/images/products/samsung/refrigerator/Refrigerator-cuckoo-samsung.webp',
    '/assets/images/products/samsung/refrigerator/Refrigerator-3-Photoroom.webp',
    '/assets/images/products/samsung/refrigerator/Refrigerator-4-Photoroom.webp',
    '/assets/images/products/samsung/refrigerator/Refrigerator-5-Photoroom.webp',
    '/assets/images/products/samsung/refrigerator/Refrigerator-6-Photoroom.webp'
  ];
  const heroImgs = Array.from(document.querySelectorAll('[data-hero-img]'));
  const heroDotWraps = Array.from(document.querySelectorAll('[data-hero-dots]'));
  let heroIndex = 0;

  function renderHero(index) {
    heroIndex = (index + heroSlideSrcs.length) % heroSlideSrcs.length;
    heroImgs.forEach((img) => { img.src = heroSlideSrcs[heroIndex]; });
    heroDotWraps.forEach((wrap) => {
      wrap.innerHTML = '';
      heroSlideSrcs.forEach((_, dotIndex) => {
        const dot = document.createElement('button');
        dot.type = 'button';
        dot.setAttribute('aria-label', 'Lihat sisi ' + (dotIndex + 1));
        dot.className = dotIndex === heroIndex
          ? 'h-2.5 w-7 rounded-full bg-white transition'
          : 'h-2.5 w-2.5 rounded-full bg-white/40 transition hover:bg-white/70';
        dot.addEventListener('click', () => { renderHero(dotIndex); });
        wrap.appendChild(dot);
      });
    });
  }

  if (heroImgs.length) {
    document.querySelectorAll('[data-hero-prev]').forEach((btn) =>
      btn.addEventListener('click', () => { renderHero(heroIndex - 1); }));
    document.querySelectorAll('[data-hero-next]').forEach((btn) =>
      btn.addEventListener('click', () => { renderHero(heroIndex + 1); }));

    // Swipe kiri/kanan + klik untuk zoom
    document.querySelectorAll('[data-hero-stage]').forEach((stage) => {
      const img = stage.querySelector('[data-hero-zoom]');
      let sx = 0, sy = 0, swiped = false;
      stage.addEventListener('touchstart', (e) => {
        sx = e.touches[0] ? e.touches[0].clientX : 0;
        sy = e.touches[0] ? e.touches[0].clientY : 0;
        swiped = false;
      }, { passive: true });
      stage.addEventListener('touchend', (e) => {
        const t = e.changedTouches[0];
        if (!t) return;
        const dx = t.clientX - sx, dy = t.clientY - sy;
        if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
          swiped = true;
          renderHero(heroIndex + (dx < 0 ? 1 : -1));
        }
      }, { passive: true });
      if (img) {
        img.addEventListener('click', () => {
          if (swiped) { swiped = false; return; }
          openZoom(img.currentSrc || img.src, img.alt);
        });
      }
    });

    renderHero(0);
  }

  // Problem -> solution slider (Masalah Harian)
  const PBASE = '/assets/images/products/samsung/refrigerator';
  const problems = [
    { img: PBASE + '/peti-sejuk-penuh.webp', eyebrow: 'Masalah 1', title: 'Stok Mingguan Cepat Penuh', desc: 'Lauk, frozen food, sayur, buah dan minuman susah nak susun dalam peti kecil.', alt: 'Peti sejuk kecil penuh sesak dengan stok dapur mingguan' },
    { img: PBASE + '/peti-sejuk-bil-letrik-mahal.webp', eyebrow: 'Masalah 2', title: 'Bil Elektrik Tinggi', desc: 'Peti lama tanpa inverter & AI Energy boleh guna lebih banyak tenaga setiap bulan.', alt: 'Bil elektrik tinggi akibat peti sejuk lama tidak jimat tenaga' },
    { img: PBASE + '/peti-sejuk-frost-beku.webp', eyebrow: 'Masalah 3', title: 'Ais Tebal & Defrost', desc: 'Peti tanpa No Frost menyusahkan dengan ais tebal dan kerja buang ais manual.', alt: 'Ais tebal beku dalam peti sejuk lama tanpa No Frost' },
    { img: PBASE + '/peti-sejuk-cuckoo-baru.webp', eyebrow: 'Penyelesaian', title: 'Upgrade Tanpa Modal Besar', desc: 'Dengan pelan rental RM85/bulan, upgrade ke peti premium 583L tanpa perlu bayar sekali gus.', alt: 'Peti sejuk Cuckoo x Samsung 583L baru sebagai penyelesaian', solution: true }
  ];

  const pStage = document.querySelector('[data-problem-stage]');
  const pImg = document.querySelector('[data-problem-img]');
  const pCard = document.querySelector('[data-problem-card]');
  const pEyebrow = document.querySelector('[data-problem-eyebrow]');
  const pTitle = document.querySelector('[data-problem-title]');
  const pDesc = document.querySelector('[data-problem-desc]');
  const pBtns = Array.from(document.querySelectorAll('[data-problem-btn]'));
  let pIndex = 0;

  const pBtnBase = 'flex flex-col gap-0.5 rounded-2xl px-3 py-3 text-left text-sm font-black shadow-sm transition';
  const pBtnIdle = 'border border-stone-200 bg-white text-stone-600 hover:border-brand-maroon/40';
  const pBtnActive = 'border border-brand-maroon bg-brand-maroon text-white shadow-md';
  const pBtnIdleSol = 'border border-emerald-200 bg-emerald-50 text-emerald-800 hover:border-emerald-400';
  const pBtnActiveSol = 'border border-emerald-600 bg-emerald-600 text-white shadow-md';

  function renderProblem(index) {
    if (!problems.length) return;
    pIndex = (index + problems.length) % problems.length;
    const p = problems[pIndex];
    if (pImg) { pImg.src = p.img; pImg.alt = p.alt; }
    if (pCard) {
      pCard.className = 'mt-4 rounded-[1.5rem] border p-5 shadow-soft sm:min-h-[150px] sm:p-6 ' + (p.solution ? 'border-emerald-200 bg-emerald-50' : 'border-stone-200 bg-stone-50');
    }
    if (pEyebrow) {
      pEyebrow.textContent = p.eyebrow;
      pEyebrow.className = 'text-xs font-black uppercase tracking-[0.2em] ' + (p.solution ? 'text-emerald-700' : 'text-brand-maroon');
    }
    if (pTitle) pTitle.className = 'mt-1.5 text-2xl font-black tracking-tight ' + (p.solution ? 'text-emerald-900' : 'text-brand-dark');
    if (pTitle) pTitle.textContent = p.title;
    if (pDesc) pDesc.textContent = p.desc;
    pBtns.forEach((btn) => {
      const bi = Number(btn.dataset.index || 0);
      const isSol = btn.dataset.solution === 'true';
      const active = bi === pIndex;
      btn.className = pBtnBase + ' ' + (active ? (isSol ? pBtnActiveSol : pBtnActive) : (isSol ? pBtnIdleSol : pBtnIdle));
    });
  }

  let pTimer = null;
  function restartPTimer() {
    if (pTimer) clearInterval(pTimer);
    pTimer = setInterval(() => renderProblem(pIndex + 1), 5000);
  }

  if (pStage) {
    pBtns.forEach((btn) => btn.addEventListener('click', () => { renderProblem(Number(btn.dataset.index || 0)); restartPTimer(); }));
    document.querySelectorAll('[data-problem-prev]').forEach((b) => b.addEventListener('click', () => { renderProblem(pIndex - 1); restartPTimer(); }));
    document.querySelectorAll('[data-problem-next]').forEach((b) => b.addEventListener('click', () => { renderProblem(pIndex + 1); restartPTimer(); }));

    // Swipe kiri/kanan (tanpa zoom)
    let psx = 0, psy = 0;
    pStage.addEventListener('touchstart', (e) => {
      psx = e.touches[0] ? e.touches[0].clientX : 0;
      psy = e.touches[0] ? e.touches[0].clientY : 0;
    }, { passive: true });
    pStage.addEventListener('touchend', (e) => {
      const t = e.changedTouches[0];
      if (!t) return;
      const dx = t.clientX - psx, dy = t.clientY - psy;
      if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) { renderProblem(pIndex + (dx < 0 ? 1 : -1)); restartPTimer(); }
    }, { passive: true });

    renderProblem(0);
    restartPTimer();
  }

  // Testimoni slider — butang + drag to slide
  const testiTrack = document.getElementById('testiTrack');
  const testiPrev = document.getElementById('testiPrev');
  const testiNext = document.getElementById('testiNext');

  if (testiTrack) {
    const stepWidth = () => {
      const slide = testiTrack.querySelector('.testi-slide');
      const gap = parseFloat(getComputedStyle(testiTrack).columnGap || '20') || 20;
      return slide ? slide.getBoundingClientRect().width + gap : testiTrack.clientWidth * 0.8;
    };

    if (testiPrev) testiPrev.addEventListener('click', () => testiTrack.scrollBy({ left: -stepWidth(), behavior: 'smooth' }));
    if (testiNext) testiNext.addEventListener('click', () => testiTrack.scrollBy({ left: stepWidth(), behavior: 'smooth' }));

    let isDown = false, startX = 0, startScroll = 0, moved = false;
    testiTrack.addEventListener('pointerdown', (e) => {
      isDown = true; moved = false;
      startX = e.clientX;
      startScroll = testiTrack.scrollLeft;
      testiTrack.classList.add('cursor-grabbing');
    });
    testiTrack.addEventListener('pointermove', (e) => {
      if (!isDown) return;
      const delta = e.clientX - startX;
      if (Math.abs(delta) > 4) moved = true;
      testiTrack.scrollLeft = startScroll - delta;
    });
    const endDrag = () => { isDown = false; testiTrack.classList.remove('cursor-grabbing'); };
    testiTrack.addEventListener('pointerup', endDrag);
    testiTrack.addEventListener('pointerleave', endDrag);
    testiTrack.addEventListener('click', (e) => { if (moved) { e.preventDefault(); e.stopPropagation(); } }, true);
  }

  // Zoom lightbox — any [data-zoom] element opens its current image
  const zoomLightbox = document.getElementById('zoomLightbox');
  const zoomImage = document.getElementById('zoomImage');

  function openZoom(src, alt) {
    if (!zoomLightbox || !zoomImage || !src) return;
    zoomImage.src = src;
    zoomImage.alt = alt || '';
    zoomLightbox.classList.remove('hidden');
    zoomLightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }
  function closeZoom() {
    if (!zoomLightbox) return;
    zoomLightbox.classList.add('hidden');
    zoomLightbox.classList.remove('flex');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('[data-zoom]').forEach((el) => {
    el.addEventListener('click', () => {
      const img = el.tagName === 'IMG' ? el : el.querySelector('img');
      const src = el.getAttribute('data-zoom-src') || (img && (img.currentSrc || img.src));
      openZoom(src, img && img.alt);
    });
  });
  if (zoomLightbox) {
    zoomLightbox.addEventListener('click', (e) => {
      if (e.target === zoomLightbox || e.target.id === 'zoomClose') closeZoom();
    });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeZoom(); });
  }
</script>
