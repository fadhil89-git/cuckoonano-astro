---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import AgentSection from '../../../../components/AgentSection.astro';

const base = '/assets/images/products/samsung/refrigerator';
const heroImg = `${base}/Refrigerator-cuckoo-samsung.webp`;
const kvImg = `${base}/RS4000DC_PC_KV-02.webp`;
const brandImg = `${base}/Refrigerator-cuckoo-samsung.webp`;
const smartImg = `${base}/RS4000DC_PC_Main08-1.webp`;
const energyGif = `${base}/REF-1_off-ezgif.com-optimize.gif`;
const spaceGif = `${base}/REF-2.gif`;
const coolingImg = `${base}/RS4000DC_PC_Main06.webp`;
const noFrostImg = `${base}/RS4000DC_PC_Main07.webp`;
const designImg = `${base}/RS4000DC_PC_Main09.webp`;
const accessImg = `${base}/RS4000DC_PC_Main05.webp`;
const compressorImg = `${base}/Fridge-Digital-Converter-Compressor_Updated-cuckoo.com_.my_.webp`;
const smartEnergyImg = `${base}/RS4000DC_PC_Main08-2.webp`;
const smartCareImg = `${base}/RS4000DC_PC_Main08-3.webp`;
const smartFoodImg = `${base}/RS4000DC_PC_Main08-4.webp`;
const freeShippingIcon = `${base}/free-shipping-icon.png`;
const warrantyIcon = `${base}/warranty-icon.png`;
const measureImgDesktop = `${base}/my-feature-how-to-measure-542859111.avif`;
const measureImgMobile = `${base}/my-feature-how-to-measure-542859112.avif`;

const heroSlides = [
  `${base}/Refrigerator-cuckoo-samsung.webp`,
  `${base}/Refrigerator-3-Photoroom.webp`,
  `${base}/Refrigerator-4-Photoroom.webp`,
  `${base}/Refrigerator-5-Photoroom.webp`,
  `${base}/Refrigerator-6-Photoroom.webp`
];
const heroPrimary = heroSlides[0];

const pageUrl = 'https://www.cuckoonano.com/products/samsung/side-by-side-refrigerator-583l/';
const site = 'https://www.cuckoonano.com';
const ogImg = `${site}${heroImg}`;
const priceValidUntil = '2026-12-31';
const productImages = [
  `${site}${base}/583L-Refrigerator.webp`,
  `${site}${base}/Refrigerator-cuckoo-samsung.webp`,
  `${site}${base}/Refrigerator-4.webp`,
  `${site}${base}/Refrigerator-5.webp`
];
const seller = { '@type': 'Organization', name: 'CUCKOO', url: site };

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Cuckoo x Samsung 583L Side By Side Refrigerator',
  alternateName: [
    'Peti Sejuk Side By Side Cuckoo x Samsung 583L',
    'Cuckoo Fridge Malaysia 583L',
    'Samsung 583L Side By Side Refrigerator'
  ],
  category: 'Refrigerator',
  brand: { '@type': 'Brand', name: 'Samsung' },
  manufacturer: { '@type': 'Organization', name: 'Samsung' },
  model: 'RS4000DC',
  sku: 'F-SBSREFSLV/2W',
  mpn: 'F-SBSREFSLV/2W',
  color: 'Gentle Silver Matt',
  description:
    'Peti sejuk side by side Cuckoo x Samsung 583L dengan SmartThings AI Energy. Ruang besar 583L (375L fridge + 208L freezer), kawalan pintar, jimat tenaga, No Frost dan bayaran bulanan Cuckoo dari RM85/bulan di Malaysia.',
  url: pageUrl,
  image: productImages,
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Kapasiti Total', value: '583L' },
    { '@type': 'PropertyValue', name: 'Kapasiti Fridge', value: '375L' },
    { '@type': 'PropertyValue', name: 'Kapasiti Freezer', value: '208L' },
    { '@type': 'PropertyValue', name: 'Penggunaan Tenaga', value: '385 kWh/tahun' },
    { '@type': 'PropertyValue', name: 'Dimensi (L x T x D)', value: '912mm x 1780mm x 654mm' },
    { '@type': 'PropertyValue', name: 'Smart Control', value: 'WiFi Embedded + SmartThings App' },
    { '@type': 'PropertyValue', name: 'Compressor', value: 'Digital Inverter (waranti 10 tahun)' }
  ],
  offers: [
    {
      '@type': 'Offer',
      name: 'Pelan rental Cuckoo (60 bulan)',
      priceCurrency: 'MYR',
      price: '85',
      url: pageUrl,
      availability: 'https://schema.org/InStock',
      itemCondition: 'https://schema.org/NewCondition',
      priceValidUntil,
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: '85',
        priceCurrency: 'MYR',
        unitText: 'MONTH',
        referenceQuantity: { '@type': 'QuantitativeValue', value: '60', unitText: 'MONTH' }
      },
      seller
    },
    {
      '@type': 'Offer',
      name: 'Beli terus (outright)',
      priceCurrency: 'MYR',
      price: '4099',
      url: pageUrl,
      availability: 'https://schema.org/InStock',
      itemCondition: 'https://schema.org/NewCondition',
      priceValidUntil,
      seller
    }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Berapa harga peti sejuk side by side Cuckoo x Samsung 583L?', acceptedAnswer: { '@type': 'Answer', text: 'Boleh dimiliki melalui pelan rental Cuckoo dari RM85/bulan untuk 5 tahun, atau beli terus pada harga RM4,099. Sahkan stok dan promo terkini melalui WhatsApp sebelum order.' } },
    { '@type': 'Question', name: 'Boleh sewa peti sejuk Cuckoo secara bulanan?', acceptedAnswer: { '@type': 'Answer', text: 'Boleh. Peti sejuk Cuckoo x Samsung 583L ditawarkan dengan bayaran bulanan dari RM85/bulan untuk tempoh 5 tahun, tertakluk kepada kelayakan dan terma semasa. WhatsApp kami untuk semak pelan rental yang sesuai.' } },
    { '@type': 'Question', name: 'Apa kelebihan SmartThings AI Energy?', acceptedAnswer: { '@type': 'Answer', text: 'SmartThings membolehkan anda pantau dan kawal suhu peti sejuk dari telefon, dan terima alert jika pintu tertinggal terbuka. AI Energy Mode pula membantu jimat tenaga sehingga 10% dengan melaras compressor mengikut corak penggunaan.' } },
    { '@type': 'Question', name: 'Peti ais side by side sesuai untuk siapa?', acceptedAnswer: { '@type': 'Answer', text: 'Sesuai untuk keluarga moden yang stok dapurnya sentiasa penuh, dan rumah yang mahukan ruang simpanan lebih luas serta dapur yang nampak lebih kemas dan premium.' } },
    { '@type': 'Question', name: 'Apa beza peti sejuk side by side dan peti sejuk biasa?', acceptedAnswer: { '@type': 'Answer', text: 'Peti sejuk side by side mempunyai bahagian fridge dan freezer bersebelahan (kiri-kanan), memberi ruang lebih lapang dan mudah disusun berbanding peti sejuk biasa dua pintu atas-bawah, sambil kekal kemas dengan reka bentuk flat door.' } },
    { '@type': 'Question', name: 'Adakah peti sejuk 583L sesuai untuk keluarga besar?', acceptedAnswer: { '@type': 'Answer', text: 'Ya. Kapasiti 583L (375L fridge + 208L freezer) memberi ruang luas untuk stok mingguan keluarga besar — lauk, sayur, buah, minuman dan makanan sejuk beku boleh disimpan sekali gus dengan lebih teratur.' } },
    { '@type': 'Question', name: 'Perlu semak ukuran dapur dulu?', acceptedAnswer: { '@type': 'Answer', text: 'Ya. Saiz unit ialah 912mm lebar x 1780mm tinggi x 654mm dalam. Semak lebar pintu, laluan masuk, lif (untuk kondo) dan ruang bukaan pintu sebelum confirm.' } },
    { '@type': 'Question', name: 'Apa waranti yang disediakan?', acceptedAnswer: { '@type': 'Answer', text: 'Untuk pelan rental, disediakan waranti eksklusif 5 tahun. Untuk beli terus, disediakan waranti standard 2 tahun + 1 tahun lanjutan Cuckoo. Compressor disokong waranti 10 tahun. Tertakluk kepada terma semasa.' } }
  ]
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.cuckoonano.com/' },
    { '@type': 'ListItem', position: 2, name: 'Produk', item: 'https://www.cuckoonano.com/products/' },
    { '@type': 'ListItem', position: 3, name: 'Samsung', item: 'https://www.cuckoonano.com/products/samsung/' },
    { '@type': 'ListItem', position: 4, name: 'Side-by-Side Refrigerator 583L', item: pageUrl }
  ]
};
---

<BaseLayout
  title="Peti Sejuk Side By Side Cuckoo x Samsung 583L | RM85/Bulan"
  description="Peti sejuk side by side Cuckoo x Samsung 583L dengan SmartThings AI Energy — ruang besar, kawalan pintar dan bayaran bulanan Cuckoo dari RM85/bulan di Malaysia."
  canonical={pageUrl}
  ogImage={ogImg}
  ogType="website"
  preloadImages={[heroPrimary]}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- HERO -->
  <section class="relative overflow-hidden bg-[#16080c] px-4 py-8 text-white sm:px-6 lg:px-8 lg:py-16">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_10%,rgba(122,31,43,0.42),transparent_34%),radial-gradient(circle_at_85%_20%,rgba(245,158,11,0.18),transparent_32%),linear-gradient(135deg,#16080c_0%,#2a0b12_48%,#070407_100%)]"></div>
    <div class="absolute -right-24 top-6 h-96 w-96 rounded-full bg-rose-500/10 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 h-80 w-80 rounded-full bg-amber-400/10 blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl">
      <!-- Mobile Hero -->
      <div class="md:hidden">
        <div class="mx-auto max-w-md text-center">
          <div class="mb-3 flex flex-wrap justify-center gap-2">
            <span class="rounded-full bg-amber-400/15 px-4 py-2 text-[11px] font-black uppercase tracking-[0.18em] text-amber-100 ring-1 ring-amber-300/30">Dari RM85/Bulan</span>
            <span class="rounded-full bg-white/10 px-4 py-2 text-[11px] font-black uppercase tracking-[0.18em] text-white ring-1 ring-white/15">583L Side-by-Side</span>
          </div>

          <p class="text-xs font-black uppercase tracking-[0.22em] text-rose-200">CUCKOO x Samsung</p>

          <p class="mt-3 text-3xl font-black leading-[1.03] tracking-tight text-white">
            Peti Sejuk Side By Side<br />
            <span class="bg-gradient-to-r from-[#FFD46B] via-[#FFC233] to-[#F59E0B] bg-clip-text text-transparent">Cuckoo x Samsung 583L</span>
          </p>
        </div>

        <div class="mx-auto mt-5 max-w-md overflow-hidden rounded-[2rem] border border-white/15 bg-gradient-to-br from-[#1a0b10] via-[#3a101b] to-[#080407] p-3 shadow-premium">
          <div data-hero-stage class="relative rounded-[1.5rem] bg-white/20 p-2">
            <img data-hero-img data-hero-zoom src={heroPrimary} alt="Peti sejuk side by side Cuckoo x Samsung 583L SmartThings AI Energy" width="1080" height="1080" fetchpriority="high" decoding="async" class="mx-auto h-[330px] w-full cursor-zoom-in object-contain transition-opacity duration-300" />
            <button type="button" data-hero-prev aria-label="Gambar sebelum" class="absolute left-2 top-1/2 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-xl font-black text-brand-maroon shadow-lg transition hover:bg-white">‹</button>
            <button type="button" data-hero-next aria-label="Gambar seterusnya" class="absolute right-2 top-1/2 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-xl font-black text-brand-maroon shadow-lg transition hover:bg-white">›</button>
            <span class="pointer-events-none absolute bottom-2 right-2 inline-flex items-center gap-1 rounded-full bg-black/45 px-2.5 py-1 text-[11px] font-bold text-white backdrop-blur">🔍 Zoom</span>
          </div>
          <div data-hero-dots class="mt-3 flex justify-center gap-2"></div>
          <div class="mt-3 grid grid-cols-3 gap-2 text-center">
            <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/15"><p class="text-sm font-black text-white">583L</p><p class="text-[10px] font-bold uppercase tracking-wide text-rose-100">Total</p></div>
            <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/15"><p class="text-sm font-black text-white">375L</p><p class="text-[10px] font-bold uppercase tracking-wide text-rose-100">Fridge</p></div>
            <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/15"><p class="text-sm font-black text-white">208L</p><p class="text-[10px] font-bold uppercase tracking-wide text-rose-100">Freezer</p></div>
          </div>
        </div>

        <div class="mx-auto mt-5 max-w-md rounded-[1.75rem] bg-white/10 p-4 text-left shadow-premium ring-1 ring-white/15 backdrop-blur">
          <p class="text-center text-sm font-semibold leading-6 text-rose-100">Peti sejuk besar yang pintar &amp; jimat tenaga — pantau dari telefon, tanpa modal besar.</p>
          <div class="mt-4 rounded-[1.45rem] bg-gradient-to-br from-[#FFF7DE] via-[#FFE7A8] to-[#FFD46B] px-4 py-4 text-brand-dark shadow-soft ring-1 ring-amber-200">
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="text-[11px] font-black uppercase tracking-[0.18em] text-amber-800">Pelan rental dari</p>
                <p class="mt-1 text-4xl font-black tracking-tight text-slate-950">RM85<span class="text-base text-slate-700">/bulan</span></p>
              </div>
              <div class="text-right text-xs font-black leading-5 text-slate-700"><p>Beli terus</p><p>RM4,099</p></div>
            </div>
          </div>
          <p class="mt-3 text-center text-xs font-semibold leading-5 text-rose-100">Pelan rental 5 tahun. Tertakluk kepada stok, kelayakan dan terma semasa.</p>
        </div>

        <div class="mx-auto mt-5 max-w-md">
          <a href="#" onclick="this.href=rotatingWhatsapp()" class="flex w-full items-center justify-center rounded-2xl bg-cta-green px-6 py-4 text-base font-black text-white shadow-cta">📲 Semak Promo Peti 583L</a>
        </div>
      </div>

      <!-- Desktop Hero -->
      <div class="hidden items-center gap-10 md:grid lg:grid-cols-[1.04fr_0.96fr] lg:gap-12">
        <div class="order-1 text-center lg:text-left">
          <div class="mb-5 flex flex-wrap justify-center gap-2 lg:justify-start">
            <span class="rounded-full bg-amber-400/15 px-5 py-2 text-xs font-black uppercase tracking-[0.22em] text-amber-100 ring-1 ring-amber-300/30">Dari RM85/Bulan</span>
            <span class="rounded-full bg-white/10 px-5 py-2 text-xs font-black uppercase tracking-[0.22em] text-white ring-1 ring-white/15">CUCKOO x Samsung</span>
          </div>

          <p class="mb-3 text-sm font-black uppercase tracking-[0.24em] text-rose-200">Smart Healthy Home Series</p>

          <h1 class="mx-auto max-w-4xl text-balance text-4xl font-black leading-[1.03] tracking-tight text-white sm:text-5xl lg:mx-0 lg:text-6xl">
            Peti Sejuk Side By Side Cuckoo x Samsung 583L <span class="bg-gradient-to-r from-[#FFD46B] via-[#FFC233] to-[#F59E0B] bg-clip-text text-transparent">Dari RM85/Bulan</span>
          </h1>

          <p class="mx-auto mt-5 max-w-2xl text-base leading-8 text-rose-100 sm:text-lg lg:mx-0">Peti ais side by side 583L untuk keluarga moden: ruang simpanan besar, kawalan pintar SmartThings dan AI Energy yang membantu jadikan peti sejuk jimat elektrik — semua tanpa perlu keluar modal besar sekali gus. Cuckoo fridge Malaysia dengan bayaran bulanan.</p>

          <div id="promo" class="mx-auto mt-6 max-w-2xl rounded-[2rem] bg-white/10 p-4 text-left shadow-premium ring-1 ring-white/15 backdrop-blur lg:mx-0">
            <div class="grid gap-3 sm:grid-cols-[0.9fr_1.1fr] sm:items-center">
              <div class="rounded-[1.5rem] bg-gradient-to-br from-[#FFF7DE] via-[#FFE7A8] to-[#FFD46B] px-5 py-5 text-center text-brand-dark shadow-soft ring-1 ring-amber-200">
                <p class="text-xs font-black uppercase tracking-[0.22em] text-amber-700">Pelan rental dari</p>
                <p class="mt-2 text-5xl font-black tracking-tight text-slate-950 sm:text-6xl">RM85</p>
                <p class="text-base font-black text-brand-dark">/bulan</p>
              </div>
              <div class="space-y-3 text-white">
                <div class="rounded-2xl bg-white/10 px-4 py-3 font-extrabold ring-1 ring-white/10">Beli terus RM4,099</div>
                <div class="rounded-2xl bg-white/10 px-4 py-3 font-extrabold ring-1 ring-white/10">Pelan rental 5 tahun</div>
                <p class="text-sm font-semibold leading-6 text-rose-100">Order di sini dan semak kelayakan untuk dapatkan free gift daripada kami.</p>
              </div>
            </div>
          </div>

          <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:justify-center lg:justify-start">
            <a href="#" onclick="this.href=rotatingWhatsapp()" class="inline-flex items-center justify-center rounded-2xl bg-cta-green px-7 py-4 text-base font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark sm:text-lg">📲 Semak Promo Peti 583L</a>
            <a href="#benefits" class="inline-flex items-center justify-center rounded-2xl border border-white/20 bg-white px-7 py-4 text-base font-black text-slate-950 shadow-sm transition hover:-translate-y-0.5 sm:text-lg">Lihat Kelebihan</a>
          </div>

          <p class="mt-5 text-sm font-semibold text-rose-100">Boleh WhatsApp untuk semak stok, kawasan delivery, ukuran dapur dan kelayakan order.</p>
        </div>

        <!-- Product Visual -->
        <div class="order-2 mt-2 lg:mt-0">
          <div class="relative mx-auto max-w-[440px] sm:max-w-[520px] lg:max-w-[620px]">
            <div class="absolute -inset-8 rounded-[3rem] bg-amber-400/10 blur-3xl"></div>
            <div class="absolute left-1/2 top-1/2 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rounded-full bg-white/10 blur-3xl"></div>

            <div class="relative overflow-hidden rounded-[2.5rem] border border-white/15 bg-gradient-to-br from-[#1a0b10] via-[#3a101b] to-[#080407] p-5 shadow-premium sm:p-6">
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_38%,rgba(245,158,11,0.16),transparent_42%),radial-gradient(circle_at_18%_15%,rgba(255,255,255,0.10),transparent_32%)]"></div>

              <div class="relative text-center">
                <div class="mb-5 flex flex-wrap justify-center gap-2">
                  <span class="rounded-full bg-brand-maroon px-4 py-2 text-xs font-black uppercase tracking-wide text-white shadow-sm">SmartThings</span>
                  <span class="rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-rose-100 ring-1 ring-white/15">AI Energy</span>
                </div>

                <div data-hero-stage class="relative rounded-[1.75rem] bg-white/20 p-3">
                  <img data-hero-img data-hero-zoom src={heroPrimary} alt="Side by side refrigerator Malaysia — peti sejuk Cuckoo x Samsung 583L Gentle Silver Matt" width="1080" height="1080" fetchpriority="high" decoding="async" class="mx-auto h-[380px] w-full cursor-zoom-in object-contain transition-opacity duration-300 sm:h-[480px]" />
                  <button type="button" data-hero-prev aria-label="Gambar sebelum" class="absolute left-2 top-1/2 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-2xl font-black text-brand-maroon shadow-lg transition hover:bg-white">‹</button>
                  <button type="button" data-hero-next aria-label="Gambar seterusnya" class="absolute right-2 top-1/2 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-2xl font-black text-brand-maroon shadow-lg transition hover:bg-white">›</button>
                  <span class="pointer-events-none absolute bottom-3 right-3 inline-flex items-center gap-1.5 rounded-full bg-black/45 px-3 py-1.5 text-xs font-bold text-white backdrop-blur">🔍 Klik untuk zoom</span>
                </div>
                <div data-hero-dots class="mt-4 flex justify-center gap-2"></div>

                <div class="mt-6 grid grid-cols-3 gap-2 sm:gap-3">
                  <div class="rounded-2xl bg-white/95 px-2 py-3 shadow-sm ring-1 ring-white/20"><p class="text-base font-black text-slate-950 sm:text-lg">583L</p><p class="text-[10px] font-bold uppercase tracking-wide text-stone-500">Total</p></div>
                  <div class="rounded-2xl bg-white/95 px-2 py-3 shadow-sm ring-1 ring-white/20"><p class="text-base font-black text-slate-950 sm:text-lg">375L</p><p class="text-[10px] font-bold uppercase tracking-wide text-stone-500">Fridge</p></div>
                  <div class="rounded-2xl bg-white/95 px-2 py-3 shadow-sm ring-1 ring-white/20"><p class="text-base font-black text-slate-950 sm:text-lg">208L</p><p class="text-[10px] font-bold uppercase tracking-wide text-stone-500">Freezer</p></div>
                </div>
              </div>
            </div>

            <div class="relative mx-auto mt-4 w-[88%] rounded-3xl bg-brand-maroon px-5 py-4 text-center text-white shadow-xl ring-1 ring-rose-300/30">
              <p class="text-[11px] font-bold text-rose-200 sm:text-xs">Highlight Utama</p>
              <p class="text-sm font-black sm:text-base">Besar, Pintar &amp; Jimat Tenaga</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Strip -->
  <section class="bg-gradient-to-r from-[#16080c] via-brand-maroon to-[#2f0b10] px-4 py-6 text-white sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-3 text-sm sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-2xl bg-white/10 px-5 py-4 ring-1 ring-white/15"><p class="text-lg font-black">🧊 583L Side-by-Side</p><p class="mt-1 font-semibold text-rose-100">Ruang luas untuk keluarga</p></div>
      <div class="rounded-2xl bg-white/10 px-5 py-4 ring-1 ring-white/15"><p class="text-lg font-black">📱 SmartThings</p><p class="mt-1 font-semibold text-rose-100">Pantau dari telefon</p></div>
      <div class="rounded-2xl bg-white/10 px-5 py-4 ring-1 ring-white/15"><p class="text-lg font-black">⚡ AI Energy</p><p class="mt-1 font-semibold text-rose-100">Bantu jimat sehingga 10%</p></div>
      <div class="rounded-2xl bg-white/10 px-5 py-4 ring-1 ring-white/15"><p class="text-lg font-black">❄️ No Frost</p><p class="mt-1 font-semibold text-rose-100">Tak payah defrost manual</p></div>
    </div>
  </section>

  <!-- Pain Point -->
  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-7xl">
      <div class="grid items-stretch gap-10 lg:grid-cols-[0.95fr_1.05fr]">
        <!-- KIRI: problem statement + solusi + 4 button -->
        <div class="flex flex-col">
