          <summary class="cursor-pointer list-none text-lg font-black text-cool-deep">Kalau nak buka aircond lama, ada caj?</summary>
          <p class="mt-3 leading-7 text-stone-600">Ya, jika perlu buka aircond lama, anggaran caj ialah RM100 untuk 1.0HP/1.5HP, RM120 untuk 2.0HP dan RM150 untuk 2.5HP. Caj sebenar tertakluk kepada keadaan lokasi pemasangan.</p>
        </details>
        <details class="group rounded-2xl bg-white p-6 shadow-sm ring-1 ring-stone-100">
          <summary class="cursor-pointer list-none text-lg font-black text-cool-deep">Kalau ada masalah, hubungi siapa?</summary>
          <p class="mt-3 leading-7 text-stone-600">Customer boleh hubungi CUCKOO Careline di 1-800-88-8181 atau hubungi ejen untuk bantuan awal.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-5xl overflow-hidden rounded-[2.5rem] bg-gradient-to-br from-cool-navy via-cool-deep to-cool-blue p-8 text-center text-white shadow-premium sm:p-10">
      <p class="text-sm font-black uppercase tracking-[0.24em] text-sky-200">Semak Sekarang</p>
      <h2 class="mt-4 text-balance text-3xl font-black tracking-tight sm:text-5xl">Nak Tahu Model Mana Sesuai Untuk Bilik Anda?</h2>
      <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-sky-100">Tekan WhatsApp sekarang. Saya bantu semak promo 12 bulan, model 1.0HP atau 1.5HP, pemasangan, stok dan kelayakan anda.</p>
      <div class="mx-auto mt-7 grid max-w-3xl gap-3 text-left sm:grid-cols-2 lg:grid-cols-5">
        <div class="rounded-2xl bg-white/10 p-4 text-sm font-bold ring-1 ring-white/10">Semak promo</div>
        <div class="rounded-2xl bg-white/10 p-4 text-sm font-bold ring-1 ring-white/10">Semak model</div>
        <div class="rounded-2xl bg-white/10 p-4 text-sm font-bold ring-1 ring-white/10">Semak pemasangan</div>
        <div class="rounded-2xl bg-white/10 p-4 text-sm font-bold ring-1 ring-white/10">Semak kelayakan</div>
        <div class="rounded-2xl bg-white/10 p-4 text-sm font-bold ring-1 ring-white/10">Semak servis</div>
      </div>
      <a href={aircondWhatsappUrl} data-aircond-whatsapp
         class="mt-8 inline-flex items-center justify-center gap-2 rounded-2xl bg-cta-green px-8 py-5 text-lg font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark">
        <img src="/assets/images/misc/whatsapp-png.webp" alt="" aria-hidden="true" class="h-6 w-6" />
        WhatsApp Saya Sekarang
      </a>
    </div>
  </section>

  <script is:inline>
    function setupHeroProductSwitcher(imageId, buttonClass, inactiveClass, activeClass) {
      const image = document.getElementById(imageId);
      const buttons = document.querySelectorAll(`.${buttonClass}`);
      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          if (!image) return;
          image.src = button.dataset.heroProduct;
          buttons.forEach((thumb) => {
            thumb.className = `${buttonClass} ${inactiveClass}`;
          });
          button.className = `${buttonClass} ${activeClass}`;
        });
      });
    }

    setupHeroProductSwitcher(
      'heroProductImage',
      'hero-product-thumb',
      'rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20',
      'rounded-full bg-white px-4 py-2 text-xs font-black uppercase tracking-wide text-cool-blue shadow-sm ring-2 ring-sky-300'
    );

    setupHeroProductSwitcher(
      'heroProductImageMobile',
      'hero-product-thumb-mobile',
      'rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20',
      'rounded-full bg-white px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-cool-blue shadow-sm ring-2 ring-sky-300'
    );

    const productSlides = [
      {
        image: '/assets/images/products/vita-5tar/Vita-gallery-01.png',
        title: 'VITA 5TAR Product View',
        desc: 'Gambar produk CUCKOO VITA 5TAR dari sudut utama.'
      },
      {
        image: '/assets/images/products/vita-5tar/Vita-gallery-02.png',
        title: 'Modern Minimal Design',
        desc: 'Reka bentuk clean dan sesuai untuk bilik tidur, master bedroom atau ruang moden.'
      },
      {
        image: '/assets/images/products/vita-5tar/Vita-gallery-03.png',
        title: 'Premium Indoor Unit',
        desc: 'Paparan produk dari sudut berbeza untuk bantu customer lebih yakin sebelum order.'
      }
    ];

    const productImage = document.getElementById('productSliderImage');
    const productTitle = document.getElementById('productSliderTitle');
    const productDesc = document.getElementById('productSliderDesc');
    const productPrev = document.getElementById('productSliderPrev');
    const productNext = document.getElementById('productSliderNext');
    const productDots = document.getElementById('productSliderDots');
    let productIndex = 0;

    function renderProductSlider() {
      if (!productImage || !productTitle || !productDesc || !productDots) return;
      const slide = productSlides[productIndex];
      productImage.src = slide.image;
      productImage.alt = slide.title;
      productTitle.textContent = slide.title;
      productDesc.textContent = slide.desc;
      productDots.innerHTML = productSlides.map((_, index) => `
        <button type="button" aria-label="Lihat gambar ${index + 1}" class="h-3 rounded-full transition ${index === productIndex ? 'w-9 bg-cool-blue' : 'w-3 bg-stone-300'}" data-product-dot="${index}"></button>
      `).join('');
      productDots.querySelectorAll('[data-product-dot]').forEach((dot) => {
        dot.addEventListener('click', () => {
          productIndex = Number(dot.dataset.productDot);
          renderProductSlider();
        });
      });
    }

    if (productPrev && productNext) {
      productPrev.addEventListener('click', () => {
        productIndex = (productIndex - 1 + productSlides.length) % productSlides.length;
        renderProductSlider();
      });
      productNext.addEventListener('click', () => {
        productIndex = (productIndex + 1) % productSlides.length;
        renderProductSlider();
      });
    }

    const aircondWhatsappLinks = [
      'https://api.whatsapp.com/send?phone=60139916967&text=Salam%20Fadhil%2C%20saya%20nak%20semak%20promo%20CUCKOO%20VITA%205TAR%20Aircond.%20Boleh%20bantu%20semak%20model%20sesuai%20untuk%20bilik%20saya%3F',
      'https://api.whatsapp.com/send?phone=60132775539&text=Salam%20Izzah%2C%20saya%20nak%20semak%20promo%20CUCKOO%20VITA%205TAR%20Aircond.%20Boleh%20bantu%20semak%20model%20sesuai%20untuk%20bilik%20saya%3F'
    ];

    try {
      const leadIndex = Number(localStorage.getItem('vitaAircondLeadIndex') || '0');
      const nextIndex = (leadIndex + 1) % aircondWhatsappLinks.length;
      localStorage.setItem('vitaAircondLeadIndex', String(nextIndex));
      document.querySelectorAll('[data-aircond-whatsapp]').forEach((link) => {
        link.href = aircondWhatsappLinks[leadIndex % aircondWhatsappLinks.length];
      });
    } catch (error) {
      document.querySelectorAll('[data-aircond-whatsapp]').forEach((link) => {
        link.href = aircondWhatsappLinks[0];
      });
    }

    renderProductSlider();
  </script>
</BaseLayout>

