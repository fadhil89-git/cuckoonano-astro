---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import FreeGiftSection from '../../../../components/FreeGiftSection.astro';
import AgentSection from '../../../../components/AgentSection.astro';

const aircondWhatsappUrl =
  'https://api.whatsapp.com/send?phone=60139916967&text=Salam%2C%20saya%20nak%20semak%20promo%20CUCKOO%20VITA%205TAR%20Aircond.%20Boleh%20bantu%20semak%20model%20sesuai%20untuk%20bilik%20saya%3F';
---
<BaseLayout
  title="CUCKOO VITA 5TAR Inverter 5-Star Aircond | Promo 12 Bulan"
  description="CUCKOO VITA 5TAR Inverter 5-Star Aircond. Promo diskaun RM12/bulan untuk 12 bulan pertama: 1.0HP RM91/bulan dan 1.5HP RM101/bulan. Harga biasa RM103 dan RM113 selepas tempoh promo. Energy 5-Star, Vitamin C Filter, Silver Ion Filter, UVC LED Sterilisation, Golden Hydrophilic Fin dan servis berkala CUCKOO."
  canonical="https://www.cuckoonano.com/products/air-conditioner/vita-5tar/"
  ogImage="https://www.cuckoonano.com/assets/images/products/vita-5tar/aircond-cuckoo-vita-5tar-3-png.webp"
>
  <script is:inline type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "CUCKOO VITA 5TAR Inverter Air Conditioner",
    "brand": { "@type": "Brand", "name": "CUCKOO" },
    "description": "CUCKOO VITA 5TAR Inverter 5-Star Air Conditioner with Smart Control, UVC LED Sterilisation, 4-way airflow and CUCKOO care service.",
    "image": "https://www.cuckoonano.com/assets/images/products/vita-5tar/aircond-cuckoo-vita-5tar-3-png.webp",
    "offers": {
      "@type": "Offer",
      "priceCurrency": "MYR",
      "description": "RM12/month discount for first 12 months. 1.0HP promo RM91/month then RM103/month. 1.5HP promo RM101/month then RM113/month, subject to current terms and availability.",
      "availability": "https://schema.org/InStock"
    }
  }
  </script>

  <!-- HERO -->
  <section class="relative overflow-hidden bg-[#07111f] px-4 py-8 text-white sm:px-6 lg:px-8 lg:py-16">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_10%,rgba(14,165,233,0.26),transparent_34%),radial-gradient(circle_at_85%_20%,rgba(122,31,43,0.28),transparent_32%),linear-gradient(135deg,#06101f_0%,#0b1930_48%,#04070d_100%)]"></div>
    <div class="absolute -right-24 top-6 h-96 w-96 rounded-full bg-sky-500/10 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 h-80 w-80 rounded-full bg-cool-blue/25 blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl">

      <!-- Mobile Hero: headline + product + offer in one first impression -->
      <div class="md:hidden">
        <div class="mx-auto max-w-md text-center">
          <div class="mb-3 flex flex-wrap justify-center gap-2">
            <span class="rounded-full bg-sky-500/15 px-4 py-2 text-[11px] font-black uppercase tracking-[0.18em] text-sky-100 ring-1 ring-sky-300/30">🔥 Madness 12 Promo</span>
            <span class="rounded-full bg-white/10 px-4 py-2 text-[11px] font-black uppercase tracking-[0.18em] text-white ring-1 ring-white/15">VITA 5TAR Inverter</span>
          </div>

          <p class="text-xs font-black uppercase tracking-[0.22em] text-sky-200">CUCKOO Air Conditioner Malaysia</p>

          <h1 class="mt-3 text-3xl font-black leading-[1.03] tracking-tight text-white">
            CUCKOO VITA 5TAR Aircond<br />
            <span class="bg-gradient-to-r from-[#FFD46B] via-[#FFC233] to-[#F59E0B] bg-clip-text text-transparent">Dari RM91/Bulan</span>
          </h1>
        </div>

        <div class="mx-auto mt-5 max-w-md overflow-hidden rounded-[2rem] border border-white/15 bg-gradient-to-br from-[#061525] via-[#0F2A4A] to-[#05070d] p-4 shadow-premium">
          <div class="relative flex min-h-[190px] items-center justify-center">
            <div class="absolute bottom-5 h-10 w-[82%] rounded-full bg-sky-300/25 blur-2xl"></div>
            <img id="heroProductImageMobile"
                 src="/assets/images/products/vita-5tar/aircond-cuckoo-vita-5tar-3-png.webp"
                 alt="CUCKOO VITA 5TAR Inverter Air Conditioner"
                 class="relative z-10 mx-auto h-auto w-full max-w-[340px] object-contain drop-shadow-2xl transition duration-300" />
          </div>

          <div class="mt-3 flex flex-wrap justify-center gap-2">
            <button type="button" data-hero-product="/assets/images/products/aircond/vita-5tar/aircond-cuckoo-vita-5tar-3-png.webp" class="hero-product-thumb-mobile rounded-full bg-white px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-cool-blue shadow-sm ring-2 ring-sky-300">Sisi 1</button>
            <button type="button" data-hero-product="/assets/images/products/aircond/vita-5tar/aircond-cuckoo-vita-5tar-1.webp" class="hero-product-thumb-mobile rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 2</button>
            <button type="button" data-hero-product="/assets/images/products/aircond/vita-5tar/aircond-cuckoo-vita-5tar-2.webp" class="hero-product-thumb-mobile rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 3</button>
            <button type="button" data-hero-product="/assets/images/products/aircond/vita-5tar/compressor-aircond-cuckoo-vita-5tar-Photoroom.webp" class="hero-product-thumb-mobile rounded-full bg-white/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-wide text-white ring-1 ring-white/20">Outdoor</button>
          </div>
        </div>

        <div class="mx-auto mt-5 max-w-md rounded-[1.75rem] bg-white/10 p-4 text-left shadow-premium ring-1 ring-white/15 backdrop-blur">
          <p class="text-center text-sm font-semibold leading-6 text-slate-200">Sejukkan bilik tanpa keluarkan ribuan ringgit sekaligus. Aircond inverter 5-star dengan teknologi udara lebih segar, servis berkala CUCKOO dan pilihan 1.0HP atau 1.5HP untuk rumah anda.</p>
          <div class="mt-4 rounded-[1.45rem] bg-gradient-to-br from-[#FFF7DE] via-[#FFE7A8] to-[#FFD46B] px-4 py-4 text-cool-deep shadow-soft ring-1 ring-amber-200">
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="text-[11px] font-black uppercase tracking-[0.18em] text-amber-800">12 bulan pertama</p>
                <p class="mt-1 text-4xl font-black tracking-tight text-slate-950">RM91<span class="text-base text-slate-700">/bulan</span></p>
              </div>
              <div class="text-right text-xs font-black leading-5 text-slate-700">
                <p>1.0HP → RM91</p>
                <p>1.5HP → RM101</p>
              </div>
            </div>
          </div>
          <div class="mt-4 grid grid-cols-3 gap-2 text-center">
            <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/15"><p class="text-sm font-black text-white">5-Star</p><p class="text-[10px] font-bold uppercase tracking-wide text-sky-100">Energy</p></div>
            <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/15"><p class="text-sm font-black text-white">38 dB</p><p class="text-[10px] font-bold uppercase tracking-wide text-sky-100">Quiet</p></div>
            <div class="rounded-2xl bg-white/10 px-2 py-3 ring-1 ring-white/15"><p class="text-sm font-black text-white">6 Bulan</p><p class="text-[10px] font-bold uppercase tracking-wide text-sky-100">Service</p></div>
          </div>
          <p class="mt-3 text-center text-xs font-semibold leading-5 text-slate-300">Pelan rental 60 bulan. Tertakluk kepada stok, kelayakan, kawasan pemasangan dan terma semasa.</p>
        </div>

        <div class="mx-auto mt-5 max-w-md">
          <a href={aircondWhatsappUrl} data-aircond-whatsapp
             class="flex w-full items-center justify-center gap-2 rounded-2xl bg-cta-green px-6 py-4 text-base font-black text-white shadow-cta">
            <img src="/assets/images/misc/whatsapp-png.webp" alt="" aria-hidden="true" class="h-5 w-5" />
            Semak Promo Aircond
          </a>
        </div>
      </div>

      <div class="hidden items-center gap-10 md:grid lg:grid-cols-[1.04fr_0.96fr] lg:gap-12">
        <div class="order-1 text-center lg:text-left">
          <div class="mb-5 flex flex-wrap justify-center gap-2 lg:justify-start">
            <span class="rounded-full bg-sky-500/15 px-5 py-2 text-xs font-black uppercase tracking-[0.22em] text-sky-100 ring-1 ring-sky-300/30">Madness 12 Promo</span>
            <span class="rounded-full bg-white/10 px-5 py-2 text-xs font-black uppercase tracking-[0.22em] text-white ring-1 ring-white/15">VITA 5TAR Inverter</span>
          </div>

          <p class="mb-3 text-sm font-black uppercase tracking-[0.24em] text-sky-200">CUCKOO Air Conditioner Malaysia</p>

          <h1 class="mx-auto max-w-4xl text-balance text-4xl font-black leading-[1.03] tracking-tight text-white sm:text-5xl lg:mx-0 lg:text-6xl">
            CUCKOO VITA 5TAR Aircond <span class="bg-gradient-to-r from-[#FFD46B] via-[#FFC233] to-[#F59E0B] bg-clip-text text-transparent">Dari RM91/Bulan</span>
          </h1>

          <p class="mx-auto mt-5 max-w-2xl text-base leading-8 text-slate-200 sm:text-lg lg:mx-0">
            Sejukkan bilik tanpa keluarkan ribuan ringgit sekaligus. Aircond inverter 5-star dengan teknologi udara lebih segar, servis berkala CUCKOO dan pilihan 1.0HP atau 1.5HP untuk rumah anda.
          </p>

          <div id="promo" class="mx-auto mt-6 max-w-2xl rounded-[2rem] bg-white/10 p-4 text-left shadow-premium ring-1 ring-white/15 backdrop-blur lg:mx-0">
            <div class="grid gap-3 sm:grid-cols-[0.9fr_1.1fr] sm:items-center">
              <div class="rounded-[1.5rem] bg-gradient-to-br from-[#FFF7DE] via-[#FFE7A8] to-[#FFD46B] px-5 py-5 text-center text-cool-deep shadow-soft ring-1 ring-amber-200">
                <p class="text-xs font-black uppercase tracking-[0.22em] text-amber-700">12 bulan pertama</p>
                <p class="mt-2 text-5xl font-black tracking-tight text-slate-950 sm:text-6xl">RM91</p>
                <p class="text-base font-black text-cool-deep">/bulan</p>
              </div>
              <div class="space-y-3 text-white">
                <div class="rounded-2xl bg-white/10 px-4 py-3 font-extrabold ring-1 ring-white/10">1.0HP — promo RM91/bulan</div>
                <div class="rounded-2xl bg-white/10 px-4 py-3 font-extrabold ring-1 ring-white/10">1.5HP — promo RM101/bulan</div>
                <p class="text-sm font-semibold leading-6 text-slate-300">Pelan rental 60 bulan. Tertakluk kepada stok, kelayakan, kawasan pemasangan dan terma semasa.</p>
              </div>
            </div>
          </div>

          <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:justify-center lg:justify-start">
            <a href={aircondWhatsappUrl} data-aircond-whatsapp
               class="inline-flex items-center justify-center gap-2 rounded-2xl bg-cta-green px-7 py-4 text-base font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark sm:text-lg">
              <img src="/assets/images/misc/whatsapp-png.webp" alt="" aria-hidden="true" class="h-5 w-5" />
              Semak Promo Aircond
            </a>
            <a href="#benefits" class="inline-flex items-center justify-center rounded-2xl border border-white/20 bg-white px-7 py-4 text-base font-black text-slate-950 shadow-sm transition hover:-translate-y-0.5 sm:text-lg">
              Lihat 5 Teknologi Utama
            </a>
          </div>

          <p class="mt-5 text-sm font-semibold text-slate-300">Boleh WhatsApp untuk semak model sesuai, pemasangan, caj tambahan dan servis berkala.</p>
        </div>

        <!-- Product Visual -->
        <div class="order-2 mt-2 lg:mt-0">
          <div class="relative mx-auto max-w-[440px] sm:max-w-[520px] lg:max-w-[620px]">
            <div class="absolute -inset-8 rounded-[3rem] bg-sky-400/20 blur-3xl"></div>
            <div class="absolute left-1/2 top-1/2 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rounded-full bg-cyan-300/20 blur-3xl"></div>

            <div class="relative overflow-hidden rounded-[2.5rem] border border-white/15 bg-gradient-to-br from-[#061525] via-[#0F2A4A] to-[#05070d] p-5 shadow-premium sm:p-6">
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_38%,rgba(14,165,233,0.24),transparent_42%),radial-gradient(circle_at_18%_15%,rgba(255,255,255,0.12),transparent_32%)]"></div>

              <div class="relative text-center">
                <div class="mb-5 flex flex-wrap justify-center gap-2">
                  <span class="rounded-full bg-cool-blue px-4 py-2 text-xs font-black uppercase tracking-wide text-white shadow-sm">Energy 5-Star</span>
                  <span class="rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-sky-100 ring-1 ring-white/15">Smart Comfort</span>
                </div>

                <div class="relative mx-auto flex min-h-[220px] items-center justify-center sm:min-h-[330px]">
                  <div class="absolute bottom-8 h-12 w-[82%] rounded-full bg-sky-300/25 blur-2xl"></div>
                  <img id="heroProductImage"
                       src="/assets/images/products/vita-5tar/aircond-cuckoo-vita-5tar-3-png.webp"
                       alt="CUCKOO VITA 5TAR Inverter Air Conditioner"
                       class="relative z-10 mx-auto h-auto w-full max-w-[340px] object-contain drop-shadow-2xl transition duration-300 sm:max-w-[500px] lg:max-w-[560px]" />
                </div>

                <div class="mt-5 flex flex-wrap justify-center gap-2">
                  <button type="button" data-hero-product="/assets/images/products/aircond/vita-5tar/aircond-cuckoo-vita-5tar-3-png.webp" class="hero-product-thumb rounded-full bg-white px-4 py-2 text-xs font-black uppercase tracking-wide text-cool-blue shadow-sm ring-2 ring-sky-300">Sisi 1</button>
                  <button type="button" data-hero-product="/assets/images/products/aircond/vita-5tar/aircond-cuckoo-vita-5tar-1.webp" class="hero-product-thumb rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 2</button>
                  <button type="button" data-hero-product="/assets/images/products/aircond/vita-5tar/aircond-cuckoo-vita-5tar-2.webp" class="hero-product-thumb rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20">Sisi 3</button>
                  <button type="button" data-hero-product="/assets/images/products/aircond/vita-5tar/compressor-aircond-cuckoo-vita-5tar-Photoroom.webp" class="hero-product-thumb rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-wide text-white ring-1 ring-white/20">Outdoor</button>
                </div>

                <div class="mt-6 grid grid-cols-3 gap-2 sm:gap-3">
                  <div class="rounded-2xl bg-white/95 px-2 py-3 shadow-sm ring-1 ring-white/20"><p class="text-base font-black text-slate-950 sm:text-lg">5-Star</p><p class="text-[10px] font-bold uppercase tracking-wide text-stone-500">Energy</p></div>
                  <div class="rounded-2xl bg-white/95 px-2 py-3 shadow-sm ring-1 ring-white/20"><p class="text-base font-black text-slate-950 sm:text-lg">38 dB</p><p class="text-[10px] font-bold uppercase tracking-wide text-stone-500">Quiet</p></div>
                  <div class="rounded-2xl bg-white/95 px-2 py-3 shadow-sm ring-1 ring-white/20"><p class="text-base font-black text-slate-950 sm:text-lg">6 Bulan</p><p class="text-[10px] font-bold uppercase tracking-wide text-stone-500">Service</p></div>
                </div>
              </div>
            </div>

            <div class="relative mx-auto mt-4 w-[88%] rounded-3xl bg-cool-blue px-5 py-4 text-center text-white shadow-xl ring-1 ring-sky-300/30">
              <p class="text-[11px] font-bold text-sky-200 sm:text-xs">Highlight Utama</p>
              <p class="text-sm font-black sm:text-base">Sejuk, Jimat, Ada Servis Berkala</p>
            </div>
          </div>
        </div>      </div>
    </div>
  </section>

  <!-- Trust Strip -->
  <section class="bg-gradient-to-r from-[#07152a] via-[#0b4d86] to-[#0477b7] px-4 py-6 text-white sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-3 text-sm sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-2xl bg-white/10 px-5 py-4 ring-1 ring-white/20">
        <p class="text-lg font-black">🔥 Diskaun RM12/bulan</p>
        <p class="mt-1 font-semibold text-sky-100">Untuk 12 bulan pertama</p>
      </div>
      <div class="rounded-2xl bg-white/10 px-5 py-4 ring-1 ring-white/20">
        <p class="text-lg font-black">⭐ 5-Star Energy Rated</p>
        <p class="mt-1 font-semibold text-sky-100">Direka untuk penggunaan lebih efisien</p>
      </div>
      <div class="rounded-2xl bg-white/10 px-5 py-4 ring-1 ring-white/20">
        <p class="text-lg font-black">🧼 Servis berkala</p>
        <p class="mt-1 font-semibold text-sky-100">CUCKOO+ Care setiap 6 bulan</p>
      </div>
      <div class="rounded-2xl bg-white/10 px-5 py-4 ring-1 ring-white/20">
        <p class="text-lg font-black">❄️ 1.0HP & 1.5HP</p>
        <p class="mt-1 font-semibold text-sky-100">Bantu pilih ikut saiz bilik</p>
      </div>
    </div>
  </section>

  <!-- Pain Points -->
  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-7xl">
      <div class="grid items-center gap-10 lg:grid-cols-[0.95fr_1.05fr]">
        <div>
          <p class="text-sm font-black uppercase tracking-[0.24em] text-cool-blue">Kenapa Ramai Mula Upgrade?</p>
          <h2 class="mt-4 text-balance text-3xl font-black tracking-tight sm:text-5xl">Aircond Lama Mungkin Masih Sejuk, Tapi Belum Tentu Jimat & Mudah Dijaga</h2>
          <p class="mt-5 text-lg leading-8 text-stone-600">Customer biasanya bukan sekadar cari aircond. Mereka nak bilik lebih selesa, bil elektrik lebih terkawal, pemasangan jelas dan tak perlu pening cari orang servis setiap kali aircond kotor.</p>
          <a href={aircondWhatsappUrl} data-aircond-whatsapp class="mt-7 inline-flex items-center justify-center rounded-2xl bg-cta-green px-7 py-4 text-base font-black text-white shadow-cta transition hover:-translate-y-0.5 hover:bg-cta-dark">📲 Tanya Model & Pemasangan</a>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-[2rem] bg-sky-50 p-6 shadow-soft ring-1 ring-sky-100">
            <p class="text-3xl">💸</p>
            <h3 class="mt-4 text-xl font-black text-cool-deep">Tak Nak Bayar Ribuan Ringgit Terus</h3>
            <p class="mt-3 leading-7 text-stone-600">Promo diskaun RM12 selama 12 bulan bantu customer mula pasang aircond tanpa keluarkan RM2k-RM3k sekaligus.</p>
          </div>
          <div class="rounded-[2rem] bg-sky-50 p-6 shadow-soft ring-1 ring-sky-100">
            <p class="text-3xl">⚡</p>
            <h3 class="mt-4 text-xl font-black text-cool-deep">Risau Bil Elektrik Naik</h3>
            <p class="mt-3 leading-7 text-stone-600">Energy 5-Star dan inverter membantu penggunaan harian jadi lebih efisien.</p>
          </div>
          <div class="rounded-[2rem] bg-amber-50 p-6 shadow-soft ring-1 ring-amber-100">
            <p class="text-3xl">🧼</p>
            <h3 class="mt-4 text-xl font-black text-cool-deep">Tak Mahu Pening Servis</h3>
            <p class="mt-3 leading-7 text-stone-600">CUCKOO+ Care bantu servis berkala setiap 6 bulan mengikut jadual servis.</p>
          </div>
          <div class="rounded-[2rem] bg-stone-50 p-6 shadow-soft ring-1 ring-stone-100">
            <p class="text-3xl">❄️</p>
            <h3 class="mt-4 text-xl font-black text-cool-deep">Nak Bilik Lebih Selesa</h3>
            <p class="mt-3 leading-7 text-stone-600">4-way airflow, operasi senyap dan smart control sesuai untuk bilik tidur dan master bedroom.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5 Main Technologies Storytelling -->
  <section id="benefits" class="overflow-hidden bg-[#050b14] px-4 py-16 text-white sm:px-6 lg:px-8 lg:py-24">
    <div class="pointer-events-none absolute inset-x-0 h-72 bg-[radial-gradient(circle_at_top,#0EA5E955_0,transparent_42%)]"></div>
    <div class="relative mx-auto max-w-7xl">
      <div class="mx-auto max-w-4xl text-center">
        <p class="inline-flex rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-[0.24em] text-promo-gold ring-1 ring-white/15">
          5 Teknologi Utama VITA 5TAR
        </p>
        <h2 class="mt-5 text-balance text-4xl font-black tracking-tight sm:text-6xl">
          Bukan Sekadar Sejuk — Ini 5 Sebab VITA 5TAR Lebih Berbaloi
        </h2>
        <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-stone-300">
          Daripada penjimatan tenaga, udara lebih segar, sistem sterilisasi dalaman hingga fin keemasan yang bantu prestasi cooling — bahagian ini perlu customer nampak sebelum buat keputusan.
        </p>
      </div>

      <!-- Feature 1 -->
      <div class="mt-14 grid items-center gap-8 rounded-[2.5rem] bg-gradient-to-br from-[#07152a] via-[#0b1930] to-[#0b4d86] p-5 shadow-premium ring-1 ring-white/10 lg:grid-cols-[1.05fr_0.95fr] lg:p-8">
        <div class="overflow-hidden rounded-[2rem] bg-[#050b14] shadow-premium ring-1 ring-white/10">
          <img src="/assets/images/products/vita-5tar/cuckoo-vita-5tar-5-star.webp" alt="CUCKOO VITA 5TAR Energy 5-Star" class="h-full w-full object-cover" />
        </div>
        <div class="p-3 sm:p-5">
          <p class="text-sm font-black uppercase tracking-[0.24em] text-promo-gold">01 / Energy 5-Star</p>
          <h3 class="mt-4 text-balance text-3xl font-black tracking-tight sm:text-5xl">Sejuk Lebih Efisien, Bil Lebih Terkawal</h3>
