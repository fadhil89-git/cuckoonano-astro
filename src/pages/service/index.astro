---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  title: 'Servis CUCKOO | Sambung Servis Penapis Air, Penapis Udara & Outdoor Filter',
  description: 'Semak maklumat sambung servis CUCKOO untuk penapis air, penapis udara, outdoor filter dan produk dapur. Website ejen CUCKOO Fadhil & Izzah.',
  canonical: 'https://www.cuckoonano.com/service/',
  ogType: 'website'
};

const serviceCategories = [
  ['Penapis Air', 'Servis berkala, tukar filter, pemeriksaan asas dan semakan pelan sambung servis.'],
  ['Penapis Udara', 'Semak servis filter, keadaan mesin dan pilihan care service mengikut model.'],
  ['Outdoor Filter', 'Semak jadual servis, filter outdoor dan pilihan sambung servis untuk rumah.'],
  ['Kitchen & Others', 'Untuk induction, pressure cooker dan produk lain yang layak disemak mengikut kategori.']
];

const checklist = [
  'Beritahu model produk CUCKOO anda.',
  'Semak status kontrak atau tarikh tamat kontrak.',
  'Semak kategori servis yang sesuai.',
  'Bandingkan pilihan sambung servis atau trade-in jika mesin sudah lama.'
];
---

<BaseLayout {...meta}>
  <section class="bg-[linear-gradient(135deg,#35040f_0%,#76091f_58%,#a3132f_100%)] px-4 py-16 text-white sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <p class="inline-flex rounded-full bg-brand-gold px-4 py-2 text-xs font-black uppercase tracking-[.18em] text-brand">CUCKOO Service</p>
      <h1 class="mt-6 max-w-4xl text-4xl font-black leading-tight tracking-tight sm:text-5xl">
        Nak Sambung Servis CUCKOO? Semak Kategori Servis & Pilihan Yang Sesuai.
      </h1>
      <p class="mt-5 max-w-3xl text-lg font-semibold leading-8 text-white/78">
        Page ringkas untuk pelanggan sedia ada yang mahu semak servis penapis air, penapis udara, outdoor filter dan produk CUCKOO lain. Pricing penuh akan dikemaskini kemudian.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href="#kategori-servis" class="inline-flex justify-center rounded-full bg-white px-7 py-4 text-sm font-black text-brand transition-all duration-300 hover:-translate-y-1 hover:bg-brand-gold">
          Lihat Kategori Servis
        </a>
        <a href="/goood-deal/" class="inline-flex justify-center rounded-full border border-white/25 px-7 py-4 text-sm font-black text-white transition-all duration-300 hover:-translate-y-1 hover:bg-white/10">
          Banding Dengan Trade-In
        </a>
      </div>
    </div>
  </section>

  <section id="kategori-servis" class="px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="max-w-3xl">
        <p class="font-bold text-brand">Kategori servis</p>
        <h2 class="mt-3 text-3xl font-black tracking-tight sm:text-4xl">Servis CUCKOO Mengikut Jenis Produk</h2>
        <p class="mt-4 leading-8 text-muted">Pilih kategori produk dahulu. Kami bantu semak sama ada lebih sesuai sambung servis, renew care service atau trade-in kepada model baru.</p>
      </div>
      <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        {serviceCategories.map(([title, copy]) => (
          <article class="rounded-[1.5rem] bg-white p-5 shadow-sm ring-1 ring-brand/10">
            <h3 class="text-lg font-black text-brand">{title}</h3>
            <p class="mt-3 text-sm font-semibold leading-6 text-muted">{copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[.9fr_1.1fr] lg:items-start">
      <div>
        <p class="font-bold text-brand">Semak dulu</p>
        <h2 class="mt-3 text-3xl font-black tracking-tight sm:text-4xl">Maklumat Yang Perlu Ada Sebelum Semak Servis</h2>
        <p class="mt-4 leading-8 text-muted">
          Untuk semakan yang lebih cepat, sediakan maklumat asas mesin lama anda. Jika kontrak sudah lama tamat, kami boleh bantu bandingkan pilihan servis dan trade-in.
        </p>
      </div>
      <div class="grid gap-3">
        {checklist.map((item) => (
          <div class="rounded-2xl bg-cream px-5 py-4 text-sm font-bold leading-6 text-muted ring-1 ring-brand/10">✓ {item}</div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
