---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  title: 'CUCKOO CH10 Pressure Multi-Cooker',
  description:
    'Page CUCKOO CH10 Pressure Multi-Cooker dikekalkan untuk URL lama. Semak maklumat awal dan pilihan pressure cooker CUCKOO.',
  canonical: 'https://www.cuckoonano.com/cuckoo-pressure-multi-cooker-ch10-induction-heating/',
  ogImage: 'https://www.cuckoonano.com/assets/images/products/ch10.webp',
  ogType: 'website'
