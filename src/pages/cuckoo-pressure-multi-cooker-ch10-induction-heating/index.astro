      <p class="font-bold text-brand">Pressure Cooker</p>
      <h1 class="mt-3 text-4xl font-black tracking-tight sm:text-5xl">CUCKOO CH10 Pressure Multi-Cooker</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-muted">
        Page ini dikekalkan supaya URL lama tidak menjadi 404. Kandungan penuh boleh ditambah
        kemudian.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href="https://wasap.my/60139916967" class="rounded-full bg-brand px-7 py-4 text-center font-bold text-white shadow-glow transition-all duration-300 hover:-translate-y-1 hover:bg-brand-dark">WhatsApp Ejen</a>
        <a href="/products/pressure-cooker/ch10/" class="rounded-full border border-brand/20 bg-white px-7 py-4 text-center font-bold text-brand transition-all duration-300 hover:-translate-y-1 hover:bg-brand-soft">Lihat CH10</a>
      </div>
    </div>
  </section>
</BaseLayout>
