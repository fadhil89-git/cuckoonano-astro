                <p class="mt-1 text-xs font-bold leading-5 text-white/75">Anda hanya perlu iklan & sharing</p>
              </div>
              <div class="border border-white/15 bg-white/10 p-4">
                <p class="text-2xl font-black text-brand-gold">Saya Guide Anda</p>
                <p class="mt-1 text-xs font-bold leading-5 text-white/75">Skrip, content dan follow-up</p>
              </div>
            </div>

            <div class="mt-8 bg-white p-5 text-brand-ink shadow-xl sm:p-6">
              <p class="text-xs font-black uppercase tracking-[.18em] text-brand-gold">Hubungi saya sahaja untuk page ini</p>
              <h3 class="mt-2 text-2xl font-black text-brand sm:text-3xl">Wan Ahmad Fadhil</h3>
              <p class="mt-2 text-sm font-semibold leading-7 text-brand-muted">
                Hantar mesej ringkas. Saya akan reply dengan langkah daftar, flow training dan cara kira komisyen 2026.
              </p>
              <a
                href={whatsappRecruitmentUrl}
                data-track="click_whatsapp_recruitment_final"
                class="mt-5 inline-flex w-full items-center justify-center gap-2 bg-[#25D366] px-6 py-4 text-xs font-black uppercase tracking-[.1em] text-white shadow-[0_18px_40px_rgba(37,211,102,.24)] transition hover:-translate-y-0.5 hover:bg-[#1EBE5D] sm:w-auto sm:px-8"
              >
                <img src="/assets/images/misc/whatsapp-png.webp" alt="" aria-hidden="true" class="h-5 w-5" />
                WhatsApp Fadhil
              </a>
              <p class="mt-4 text-sm font-black text-brand/70">013 991 6967</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="fixed inset-x-0 bottom-0 z-50 border-t border-brand/10 bg-white/95 p-3 shadow-lg backdrop-blur md:hidden">
      <a
        href={whatsappRecruitmentUrl}
        data-track="click_whatsapp_recruitment_mobile_sticky"
        class="flex w-full items-center justify-center gap-2 bg-[#25D366] px-5 py-3 text-xs font-black uppercase tracking-[.1em] text-white"
      >
        <img src="/assets/images/misc/whatsapp-png.webp" alt="" aria-hidden="true" class="h-5 w-5" />
        Saya Nak Jadi Ejen CUCKOO
      </a>
    </div>
  </div>

  <script is:inline>
    const formatRinggit = (value) =>
      new Intl.NumberFormat('ms-MY', { style: 'currency', currency: 'MYR', maximumFractionDigits: 0 }).format(value);

    const getRentalTier = (units) => {
      if (units >= 15) return { label: '15 unit ke atas', belowRate: 500, aboveRate: 500 };
      if (units >= 10) return { label: '10-14 unit', belowRate: 350, aboveRate: 500 };
      if (units >= 5) return { label: '5-9 unit', belowRate: 250, aboveRate: 400 };
      if (units >= 1) return { label: '1-4 unit', belowRate: 200, aboveRate: 350 };
      return { label: '0 unit', belowRate: 0, aboveRate: 0 };
    };

    const getOutrightTier = (units) => {
      if (units >= 10) return { label: '10 unit ke atas', rate: 250 };
      if (units >= 1) return { label: '1-9 unit', rate: 200 };
      return { label: '0 unit', rate: 0 };
    };

    const calculateCommission = () => {
      const belowInput = document.getElementById('rentalBelow100');
      const aboveInput = document.getElementById('rentalAbove100');
      const outrightInput = document.getElementById('outrightUnits');
      if (!belowInput || !aboveInput || !outrightInput) return;

      const belowUnits = Math.max(0, Number(belowInput.value || 0));
      const aboveUnits = Math.max(0, Number(aboveInput.value || 0));
      const outrightUnits = Math.max(0, Number(outrightInput.value || 0));

      const srUnits = belowUnits + aboveUnits + outrightUnits;
      const rentalTier = getRentalTier(srUnits);
      const outrightTier = getOutrightTier(outrightUnits);
      const rentalCommission = belowUnits * rentalTier.belowRate + aboveUnits * rentalTier.aboveRate;
      const outrightBaseCommission = outrightUnits * rentalTier.aboveRate;
      const outrightExtraCommission = outrightUnits * outrightTier.rate;
      const outrightCommission = outrightBaseCommission + outrightExtraCommission;
      const total = rentalCommission + outrightCommission;

      document.getElementById('rentalTierLabel').textContent = rentalTier.label;
      document.getElementById('rentalRateLabel').textContent =
        `Atas RM100: ${formatRinggit(rentalTier.aboveRate)}/unit, Bawah RM100: ${formatRinggit(rentalTier.belowRate)}/unit`;
      document.getElementById('outrightTierLabel').textContent = outrightTier.label;
      document.getElementById('outrightRateLabel').textContent =
        `Outright: SR atas RM100 ${formatRinggit(rentalTier.aboveRate)}/unit + extra ${formatRinggit(outrightTier.rate)}/unit`;
      document.getElementById('commissionTotal').textContent = formatRinggit(total);
      document.getElementById('commissionBreakdown').textContent =
        `Rental: ${formatRinggit(rentalCommission)}. Outright: ${formatRinggit(outrightBaseCommission)} + extra ${formatRinggit(outrightExtraCommission)} = ${formatRinggit(outrightCommission)}.`;

      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'calculate_commission',
        rental_below_100_units: belowUnits,
        rental_above_100_units: aboveUnits,
        outright_units: outrightUnits,
        sr_units: srUnits,
        estimated_commission: total
      });
    };

    ['rentalBelow100', 'rentalAbove100', 'outrightUnits'].forEach((id) => {
      const input = document.getElementById(id);
      if (input) input.addEventListener('input', calculateCommission);
    });

    document.querySelectorAll('.commission-preset').forEach((button) => {
      button.addEventListener('click', () => {
        document.getElementById('rentalBelow100').value = button.dataset.presetBelow || 0;
        document.getElementById('rentalAbove100').value = button.dataset.presetAbove || 0;
        document.getElementById('outrightUnits').value = button.dataset.presetOutright || 0;
        calculateCommission();
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ event: 'commission_preset_click', preset_label: button.textContent.trim() });
      });
    });

    calculateCommission();

    const proofSlider = document.getElementById('recruitmentProofSlider');
    if (proofSlider) {
      const proofSlides = Array.from(proofSlider.querySelectorAll('[data-proof-slide]'));
      const proofThumbs = Array.from(proofSlider.querySelectorAll('[data-proof-thumb]'));
      const proofTitle = document.getElementById('proofSlideTitle');
      const proofCopy = document.getElementById('proofSlideCopy');
      const proofCount = document.getElementById('proofSlideCount');
      const proofOpenButtons = Array.from(proofSlider.querySelectorAll('[data-proof-open]'));
      const proofLightbox = document.getElementById('recruitmentProofLightbox');
      const proofLightboxImage = proofLightbox?.querySelector('[data-proof-lightbox-image]');
      const proofLightboxTitle = proofLightbox?.querySelector('[data-proof-lightbox-title]');
      const proofLightboxCopy = proofLightbox?.querySelector('[data-proof-lightbox-copy]');
      const proofLightboxCount = proofLightbox?.querySelector('[data-proof-lightbox-count]');
      const proofLightboxCloseButtons = proofLightbox?.querySelectorAll('[data-proof-lightbox-close]') || [];
      let activeProofSlide = 0;
      let touchStartX = 0;
      let lightboxTouchStartX = 0;
      let lightboxTouchStartY = 0;

      const setProofSlide = (nextIndex) => {
        activeProofSlide = (nextIndex + proofSlides.length) % proofSlides.length;
        const activeSlide = proofSlides[activeProofSlide];

        proofSlides.forEach((slide, index) => {
          const isActive = index === activeProofSlide;
          slide.classList.toggle('opacity-100', isActive);
          slide.classList.toggle('opacity-0', !isActive);
          slide.classList.toggle('pointer-events-none', !isActive);
          slide.setAttribute('aria-hidden', isActive ? 'false' : 'true');
        });

        proofThumbs.forEach((thumb, index) => {
          const isActive = index === activeProofSlide;
          thumb.classList.toggle('border-brand-gold', isActive);
          thumb.classList.toggle('border-brand/10', !isActive);
          thumb.classList.toggle('opacity-100', isActive);
          thumb.classList.toggle('opacity-60', !isActive);
          thumb.setAttribute('aria-current', isActive ? 'true' : 'false');
        });

        if (proofTitle) proofTitle.textContent = activeSlide.dataset.proofTitle || '';
        if (proofCopy) proofCopy.textContent = activeSlide.dataset.proofCopy || '';
        if (proofCount) proofCount.textContent = `${activeProofSlide + 1} / ${proofSlides.length}`;
        proofThumbs[activeProofSlide]?.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      };

      const showProofLightboxImage = (index) => {
        setProofSlide(index);
        const activeSlide = proofSlides[activeProofSlide];
        const image = activeSlide?.querySelector('img');
        if (!proofLightbox || !proofLightboxImage || !image) return;

        proofLightboxImage.src = image.src;
        proofLightboxImage.alt = image.alt || activeSlide.dataset.proofTitle || 'Gambar recruitment CUCKOO';
        if (proofLightboxTitle) proofLightboxTitle.textContent = activeSlide.dataset.proofTitle || '';
        if (proofLightboxCopy) proofLightboxCopy.textContent = activeSlide.dataset.proofCopy || '';
        if (proofLightboxCount) proofLightboxCount.textContent = `${activeProofSlide + 1} / ${proofSlides.length}`;
      };

      const openProofLightbox = (index) => {
        if (!proofLightbox) return;
        showProofLightboxImage(index);
        proofLightbox.classList.remove('hidden');
        proofLightbox.classList.add('flex');
        document.body.style.overflow = 'hidden';
      };

      const closeProofLightbox = () => {
        proofLightbox?.classList.add('hidden');
        proofLightbox?.classList.remove('flex');
        document.body.style.overflow = '';
      };

      proofSlider.querySelector('.proof-prev')?.addEventListener('click', () => setProofSlide(activeProofSlide - 1));
      proofSlider.querySelector('.proof-next')?.addEventListener('click', () => setProofSlide(activeProofSlide + 1));
      proofThumbs.forEach((thumb) => {
        thumb.addEventListener('click', () => setProofSlide(Number(thumb.dataset.proofThumb || 0)));
      });
      proofOpenButtons.forEach((button) => {
        button.addEventListener('click', () => openProofLightbox(Number(button.dataset.proofOpen || 0)));
      });

      proofLightbox?.querySelector('[data-proof-lightbox-prev]')?.addEventListener('click', () => showProofLightboxImage(activeProofSlide - 1));
      proofLightbox?.querySelector('[data-proof-lightbox-next]')?.addEventListener('click', () => showProofLightboxImage(activeProofSlide + 1));
      proofLightboxCloseButtons.forEach((button) => button.addEventListener('click', closeProofLightbox));

      proofSlider.addEventListener('touchstart', (event) => {
        touchStartX = event.touches[0]?.clientX || 0;
      }, { passive: true });

      proofSlider.addEventListener('touchend', (event) => {
        const touchEndX = event.changedTouches[0]?.clientX || 0;
        const distance = touchEndX - touchStartX;
        if (Math.abs(distance) < 50) return;
        setProofSlide(activeProofSlide + (distance < 0 ? 1 : -1));
      }, { passive: true });

      proofLightbox?.addEventListener('touchstart', (event) => {
        lightboxTouchStartX = event.touches[0]?.clientX || 0;
        lightboxTouchStartY = event.touches[0]?.clientY || 0;
      }, { passive: true });

      proofLightbox?.addEventListener('touchend', (event) => {
        const touch = event.changedTouches[0];
        if (!touch) return;
        const deltaX = touch.clientX - lightboxTouchStartX;
        const deltaY = touch.clientY - lightboxTouchStartY;
        if (Math.abs(deltaX) < 45 || Math.abs(deltaX) < Math.abs(deltaY)) return;
        showProofLightboxImage(activeProofSlide + (deltaX < 0 ? 1 : -1));
      }, { passive: true });

      document.addEventListener('keydown', (event) => {
        if (proofLightbox?.classList.contains('hidden')) return;
        if (event.key === 'Escape') closeProofLightbox();
        if (event.key === 'ArrowLeft') showProofLightboxImage(activeProofSlide - 1);
        if (event.key === 'ArrowRight') showProofLightboxImage(activeProofSlide + 1);
      });
    }

    document.querySelectorAll('[data-track]').forEach((element) => {
      element.addEventListener('click', () => {
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ event: element.dataset.track });
      });
    });

    const leadForm = document.getElementById('recruitmentLeadForm');
    if (leadForm) {
      leadForm.addEventListener('submit', (event) => {
        event.preventDefault();
        const formData = new FormData(leadForm);
        const message = [
          'Salam Fadhil, saya berminat nak jadi Ejen CUCKOO 2026.',
          '',
          `Nama: ${formData.get('name') || '-'}`,
          `No WhatsApp: ${formData.get('phone') || '-'}`,
          `Negeri: ${formData.get('state') || '-'}`,
          `Status: ${formData.get('status') || '-'}`,
          `Pengalaman sales: ${formData.get('experience') || '-'}`,
          `Dah ada produk CUCKOO: ${formData.get('ownedProduct') || '-'}`,
          `Target income bulanan: ${formData.get('incomeTarget') || '-'}`,
          '',
          'Mohon info lanjut tentang cara daftar dan bimbingan team.'
        ].join('\n');

        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ event: 'lead_form_submit', lead_type: 'recruitment' });
        window.location.href = `https://api.whatsapp.com/send?phone=60139916967&text=${encodeURIComponent(message)}`;
      });
    }
  </script>
</BaseLayout>
