---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locationStates } from '../../data/locations.js';
import { stateFlagUrls } from '../../data/locationFlags.js';

const meta = {
  title: 'Lokasi CUCKOO Malaysia | Ejen CUCKOO Seluruh Malaysia',
  description: 'Senarai lokasi order dan pemasangan CUCKOO mengikut negeri, bandar, daerah utama dan kawasan sekitar.',
  canonical: 'https://www.cuckoonano.com/locations/',
  ogImage: 'https://www.cuckoonano.com/assets/images/brand/cuckoo-ebrandstore3.png',
  ogType: 'website',
};
---

<BaseLayout {...meta}>
  <section class="hero-pattern px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[1fr_auto] lg:items-end">
      <div>
        <p class="font-bold text-brand">Locations</p>
        <h1 class="mt-3 max-w-3xl text-4xl font-black tracking-tight sm:text-5xl">Lokasi Order CUCKOO Seluruh Malaysia</h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-muted">Pilih negeri, kemudian pilih bandar atau daerah utama untuk tanya produk, promo dan pemasangan CUCKOO mengikut coverage servis tersedia.</p>
      </div>
      <div class="rounded-[2rem] bg-white p-5 shadow-soft sm:min-w-[320px]">
        <div class="overflow-hidden rounded-[1.5rem] border border-brand/10 bg-cream p-4">
          <img src="https://upload.wikimedia.org/wikipedia/commons/6/66/Flag_of_Malaysia.svg" alt="Bendera Malaysia" class="mx-auto h-32 w-full object-contain" />
        </div>
        <p class="mt-4 text-center text-sm font-bold text-brand">Coverage seluruh Malaysia</p>
        <p class="mt-1 text-center text-xs text-muted">Pilih negeri dahulu untuk semak lokasi berdekatan.</p>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mb-8 max-w-3xl">
        <p class="font-bold text-brand">Senarai negeri</p>
        <h2 class="mt-3 text-3xl font-black tracking-tight sm:text-4xl">Pilih negeri atau wilayah</h2>
        <p class="mt-4 text-muted leading-7">Pilih negeri untuk lihat bandar, daerah utama dan kawasan sekitar yang boleh dijadikan rujukan awal sebelum hubungi ejen.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {locationStates.map((state) => (
          <a href={state.url} class="rounded-[1.5rem] bg-cream p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-soft">
            <div class="mb-5 flex h-16 w-24 items-center justify-center overflow-hidden rounded-xl border border-brand/10 bg-white p-2 shadow-sm">
              <img src={stateFlagUrls[state.slug]} alt={`Bendera ${state.name}`} class="h-full w-full object-contain" loading="lazy" />
            </div>
            <h2 class="mt-2 text-xl font-black text-brand">{state.name}</h2>
            <p class="mt-2 text-sm text-muted">{state.tier2Count || state.locations.length} lokasi utama</p>
            <p class="mt-1 text-sm text-muted">{state.tier3Count} kawasan sekitar</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div data-agent-block></div>
</BaseLayout>
