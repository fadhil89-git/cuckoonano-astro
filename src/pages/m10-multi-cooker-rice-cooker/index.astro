---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  title: 'CUCKOO M10 Multi-Cooker / Rice Cooker',
  description:
    'Page CUCKOO M10 Multi-Cooker dikekalkan untuk SEO lama. Semak maklumat awal multi-cooker CUCKOO dan pilihan pressure cooker.',
  canonical: 'https://www.cuckoonano.com/m10-multi-cooker-rice-cooker/',
  ogImage: 'https://www.cuckoonano.com/assets/images/products/m10-multi-cooker.webp',
  ogType: 'website'
};
---

<BaseLayout {...meta}>
  <section class="hero-pattern px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <p class="font-bold text-brand">Multi-Cooker</p>
      <h1 class="mt-3 text-4xl font-black tracking-tight sm:text-5xl">CUCKOO M10 Multi-Cooker</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-muted">
        Page ini dikekalkan di URL lama kerana masih ada SEO traffic. Kandungan detail boleh
        dikemaskini kemudian.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href="https://wasap.my/60139916967" class="rounded-full bg-brand px-7 py-4 text-center font-bold text-white shadow-glow transition-all duration-300 hover:-translate-y-1 hover:bg-brand-dark">WhatsApp Ejen</a>
        <a href="/products/pressure-cooker/" class="rounded-full border border-brand/20 bg-white px-7 py-4 text-center font-bold text-brand transition-all duration-300 hover:-translate-y-1 hover:bg-brand-soft">Lihat Pressure Cooker</a>
      </div>
    </div>
  </section>
</BaseLayout>
