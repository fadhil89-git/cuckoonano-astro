---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  title: 'CUCKOO B-Fit Treadmill | Treadmill CUCKOO',
  description:
    'Page CUCKOO B-Fit dikekalkan untuk SEO lama. Semak maklumat awal treadmill CUCKOO, promo dan cara bertanya dengan ejen.',
  canonical: 'https://www.cuckoonano.com/cuckoo-b-fit/',
  ogImage: 'https://www.cuckoonano.com/assets/images/products/cuckoo-b-fit.webp',
  ogType: 'website'
};
---

<BaseLayout {...meta}>
  <section class="hero-pattern px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <p class="font-bold text-brand">Treadmill</p>
      <h1 class="mt-3 text-4xl font-black tracking-tight sm:text-5xl">CUCKOO B-Fit Treadmill</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-muted">
        Page ini dikekalkan di URL lama untuk melindungi SEO. Kandungan penuh produk boleh
        dikemaskini kemudian.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href="https://wasap.my/60139916967" class="rounded-full bg-brand px-7 py-4 text-center font-bold text-white shadow-glow transition-all duration-300 hover:-translate-y-1 hover:bg-brand-dark">WhatsApp Ejen</a>
        <a href="/products/treadmill/" class="rounded-full border border-brand/20 bg-white px-7 py-4 text-center font-bold text-brand transition-all duration-300 hover:-translate-y-1 hover:bg-brand-soft">Lihat Treadmill</a>
      </div>
    </div>
  </section>
</BaseLayout>
