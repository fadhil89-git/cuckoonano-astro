---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const meta = {
  "title": "CUCKOO Agent Commission | Recruitment CUCKOO",
  "description": "CUCKOO Agent Commission. Info peluang menjadi ejen CUCKOO.",
  "canonical": "https://www.cuckoonano.com/recruitment/cuckoo-agent-commission/",
  "ogImage": "https://www.cuckoonano.com/assets/images/brand/cuckoo-ebrandstore3.png",
  "ogType": "website"
};
---
<BaseLayout {...meta}>
  <section class="hero-pattern px-4 py-16 sm:px-6 lg:px-8"><div class="mx-auto max-w-5xl"><p class="font-bold text-brand">Recruitment</p><h1 class="mt-3 text-4xl font-black tracking-tight sm:text-5xl">CUCKOO Agent Commission</h1><p class="mt-5 max-w-3xl text-lg leading-8 text-muted">Rangka recruitment. Masukkan content penuh tentang peluang, komisyen, training dan bimbingan team.</p><div class="mt-8"><a href="https://wasap.my/60139916967" class="rounded-full bg-brand px-7 py-4 font-bold text-white shadow-glow transition-all duration-300 hover:-translate-y-1 hover:bg-brand-dark">Tanya Peluang Ejen</a></div></div></section><section class="bg-white px-4 py-16 sm:px-6 lg:px-8"><div class="mx-auto max-w-7xl"><article class="content"><h2>Ringkasan</h2><p>Page ini ialah rangka recruitment. Masukkan kandungan penuh sebelum live.</p><h2>Apa yang boleh ditanya?</h2><ul><li>Macam mana nak mula jadi ejen CUCKOO.</li><li>Bagaimana komisyen dan proses closing.</li><li>Bagaimana team membantu content, follow-up dan sales.</li></ul></article></div></section><div data-agent-block></div>
</BaseLayout>
