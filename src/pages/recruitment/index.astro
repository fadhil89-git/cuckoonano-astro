---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  "title": "Jadi Ejen CUCKOO | Recruitment CUCKOO",
  "description": "Peluang menjadi ejen CUCKOO bersama team berpengalaman. Tanya komisyen, cara mula dan bimbingan team.",
  "canonical": "https://www.cuckoonano.com/recruitment/",
  "ogImage": "https://www.cuckoonano.com/assets/images/brand/cuckoo-ebrandstore3.png",
  "ogType": "website"
};
---
<BaseLayout {...meta}>
  <section class="hero-pattern px-4 py-16 sm:px-6 lg:px-8"><div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-2 lg:items-center"><div><p class="font-bold text-brand">Recruitment</p><h1 class="mt-3 max-w-3xl text-4xl font-black tracking-tight sm:text-5xl">Nak jadi ejen CUCKOO?</h1><p class="mt-5 max-w-2xl text-lg leading-8 text-muted">Belajar cara buat sales, follow up customer dan bina pendapatan sebagai ejen CUCKOO bersama team berpengalaman.</p><div class="mt-8"><a href="https://wasap.my/60139916967" class="rounded-full bg-brand px-7 py-4 font-bold text-white shadow-glow transition-all duration-300 hover:-translate-y-1 hover:bg-brand-dark">Tanya Peluang Ejen</a></div></div><div class="rounded-[2rem] bg-white p-6 shadow-soft"><h2 class="text-2xl font-black">Sesuai untuk siapa?</h2><div class="mt-5 grid gap-3"><div class="rounded-2xl bg-cream p-4 font-bold">Yang mahu income tambahan</div><div class="rounded-2xl bg-cream p-4 font-bold">Yang suka belajar online marketing</div><div class="rounded-2xl bg-cream p-4 font-bold">Yang mahu bimbingan team</div></div></div></div></section><section class="bg-white px-4 py-16 sm:px-6 lg:px-8"><div class="mx-auto grid max-w-7xl gap-5 sm:grid-cols-2 lg:grid-cols-3"><a href="/recruitment/komisyen-ejen-cuckoo-coway/" class="rounded-soft bg-cream p-6 shadow-sm"><h2 class="font-black text-brand">Komisyen Ejen CUCKOO</h2><p class="mt-2 text-sm text-muted">Info komisyen dan peluang menjadi ejen.</p></a><a href="/recruitment/kelebihan-jadi-ejen-cuckoo/" class="rounded-soft bg-cream p-6 shadow-sm"><h2 class="font-black text-brand">Kelebihan Jadi Ejen</h2><p class="mt-2 text-sm text-muted">Kenapa ramai berminat menjadi ejen.</p></a><a href="/recruitment/cuckoo-agent-commission/" class="rounded-soft bg-cream p-6 shadow-sm"><h2 class="font-black text-brand">Agent Commission</h2><p class="mt-2 text-sm text-muted">Versi English ringkas.</p></a></div></section><div data-agent-block></div>
</BaseLayout>
