---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  "title": "Blog CUCKOO | Panduan Produk, Harga & Servis",
  "description": "Panduan berkaitan produk CUCKOO, harga, servis, promo dan tips memilih produk yang sesuai.",
  "canonical": "https://www.cuckoonano.com/blog/",
  "ogImage": "https://www.cuckoonano.com/assets/images/brand/cuckoo-ebrandstore3.png",
  "ogType": "website"
};
---
<BaseLayout {...meta}>
  <section class="hero-pattern px-4 py-16 sm:px-6 lg:px-8"><div class="mx-auto max-w-7xl"><p class="font-bold text-brand">Blog CUCKOO</p><h1 class="mt-3 max-w-3xl text-4xl font-black tracking-tight sm:text-5xl">Panduan, Review & Info CUCKOO</h1><p class="mt-5 max-w-2xl text-lg leading-8 text-muted">Artikel berkaitan produk, harga, servis dan tips memilih produk CUCKOO.</p></div></section><section class="bg-white px-4 py-16 sm:px-6 lg:px-8"><div class="mx-auto max-w-7xl" data-blog-list></div></section>
</BaseLayout>
