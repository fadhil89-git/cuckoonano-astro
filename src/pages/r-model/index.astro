---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  title: 'CUCKOO R Model Air Purifier | Penapis Udara',
  description:
    'Page CUCKOO R Model dikekalkan untuk URL lama. Semak maklumat awal penapis udara CUCKOO R Model.',
  canonical: 'https://www.cuckoonano.com/r-model/',
  ogImage: 'https://www.cuckoonano.com/assets/images/products/r-model.webp',
  ogType: 'website'
