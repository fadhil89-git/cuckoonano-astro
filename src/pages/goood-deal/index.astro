        {waterProducts.map((product) => (
          <article class="flex w-[310px] shrink-0 snap-start flex-col rounded-[1.75rem] bg-white p-4 shadow-soft ring-1 ring-brand/10 sm:w-[350px]">
            <div class="flex h-56 items-center justify-center rounded-[1.25rem] bg-gradient-to-br from-white to-cream ring-1 ring-brand/10">
