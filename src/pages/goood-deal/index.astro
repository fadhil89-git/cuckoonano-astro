    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[1fr_.88fr] lg:items-center">
      <div class="relative z-10">
        <p class="inline-flex rounded-full bg-brand-gold px-4 py-2 text-xs font-black uppercase tracking-[.18em] text-brand">GOOOD Trade-In CUCKOO</p>
