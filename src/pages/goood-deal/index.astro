        </div>

        <div class="absolute bottom-[3%] left-[28%] z-10 w-[42%] rounded-[1.75rem] border border-white/20 bg-white p-4 text-brand shadow-glow sm:bottom-[5%] sm:left-[30%] sm:w-[40%] sm:p-5">
