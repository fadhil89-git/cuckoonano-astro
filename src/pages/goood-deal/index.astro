---

<BaseLayout {...meta}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <section class="relative overflow-hidden bg-[radial-gradient(circle_at_76%_20%,rgba(242,193,90,.18),transparent_28%),linear-gradient(135deg,#35040f_0%,#76091f_55%,#a3132f_100%)] px-4 py-16 text-white sm:px-6 lg:px-8 lg:py-20">
