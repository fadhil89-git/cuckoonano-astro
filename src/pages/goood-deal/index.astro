      </div>
      <div class="mt-9 grid gap-5 lg:grid-cols-3">
        {comparison.map((item) => (
          <article class={`rounded-[1.75rem] p-6 shadow-soft ring-1 ring-brand/10 ${item.tone}`}>
            <p class={`inline-flex rounded-full px-4 py-2 text-xs font-black uppercase tracking-[.14em] ${item.tone.includes('bg-brand') ? 'bg-white/15 text-brand-gold' : 'bg-brand-soft text-brand'}`}>{item.tag}</p>
            <h3 class="mt-5 text-2xl font-black">{item.title}</h3>
            <p class={`mt-4 text-4xl font-black ${item.tone.includes('bg-brand') ? 'text-brand-gold' : 'text-brand'}`}>{item.price}</p>
            <ul class="mt-6 grid gap-3">
              {item.points.map((point) => (
                <li class={`flex gap-3 text-sm font-bold leading-6 ${item.tone.includes('bg-brand') ? 'text-white/82' : 'text-muted'}`}>
                  <span class={`mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full text-[10px] ${item.tone.includes('bg-brand') ? 'bg-white text-brand' : 'bg-brand text-white'}`}>✓</span>
                  <span>{point}</span>
